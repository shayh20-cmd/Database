/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Tracks model (v4) Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬Ч’вҖқвӮ¬
   A "track" = one consultant/discipline's own lane within a task:
   its own ordered event-chain + its own open subtasks.
   migrateTask() is ADDITIVE and non-breaking: it derives task.tracks
   from legacy processEvents/subtasks without removing the old fields,
   so existing UI that reads task.processEvents keeps working. */
/* Hoist legacy per-event subtasks (ev.subtasks) into the canonical
   task.subtasks list, tagging each with fromEventId for provenance. */
function hoistEventSubtasks(task) {
  if (!task || !task.processEvents) return task;
  let hoisted = [];
  let changed = false;
  const events = task.processEvents.map(ev => {
    if (ev.subtasks && ev.subtasks.length) {
      changed = true;
      hoisted = hoisted.concat(ev.subtasks.map(s => ({...s, fromEventId: ev.id})));
      const {subtasks, ...rest} = ev;
      return rest;
    }
    return ev;
  });
  if (!changed) return task;
  return {...task, processEvents: events, subtasks: [...(task.subtasks||[]), ...hoisted]};
}

/* New model: event sequences live on subtasks marked isProcess, not on the
   task itself. Convert any legacy task-level processEvents into a single
   subtask-process so existing data stays visible. Idempotent (clears the
   source list). */
function processToSubtask(task) {
  if (!task || !task.processEvents || !task.processEvents.length) return task;
  const sub = {id:uid(), title: 'ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ ЧіВЁЧіВҗЧіВ©Чів„ў', done:false, isProcess:true,
               events: task.processEvents, fromEventId:null};
  return {...task, processEvents:[], subtasks:[...(task.subtasks||[]), sub]};
}

function migrateTask(task) {
  task = hoistEventSubtasks(task);
  task = processToSubtask(task);
  if (!task || task.tracks) return task;              // already migrated
  const tracks = [];
  const evs = task.processEvents || [];
  if (evs.length) {
    // group legacy events by assignee (discipline) Ч’вҖ вҖҷ one track each
    const byAssignee = {};
    const order = [];
    evs.forEach(ev => {
      const key = ev.assignee || task.discipline || '_';
      if (!byAssignee[key]) { byAssignee[key] = []; order.push(key); }
      byAssignee[key].push(ev);
    });
    order.forEach(key => {
      tracks.push({
        id: uid(),
        discipline: key === '_' ? (task.discipline||'') : key,
        responsible: task.responsible || '',
        events: byAssignee[key].map(ev => ({
          id: ev.id || uid(), status: ev.status, date: ev.date||'', note: ev.note||'',
        })),
        subtasks: [],
      });
    });
  }
  // attach legacy subtasks to the track matching task.discipline, else first track, else a new one
  const subs = (task.subtasks||[]).map(s => ({...s, fromEventId: s.fromEventId||null}));
  if (subs.length) {
    let host = tracks.find(t => t.discipline === task.discipline) || tracks[0];
    if (!host) { host = {id:uid(), discipline:task.discipline||'', responsible:task.responsible||'', events:[], subtasks:[]}; tracks.push(host); }
    host.subtasks = subs;
  }
  return {...task, tracks, assigneeId: task.assigneeId||''};
}

function migrateData(d) {
  if (!d) return d;
  // Migrate old flat structure (groups/tasks) into sheets
  if (!d.sheets) {
    const sheetId = uid();
    const oldTasks = (d.tasks||[]).map(migrateTask);
    d = {
      ...d,
      sheets:[
        { id:uid(), name:'ЧівҖңЧіВҗЧіВ©ЧівҖҳЧівҖўЧіВЁЧівҖң', type:'dashboard' },
        makeEmptySheet('ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ'),
        makeEmptySheet('ЧіГ—Чів„ўЧіВ§ ЧіВһЧів„ўЧівҖңЧіВў'),
        { id:sheetId, name:'ЧіГ—ЧіВ ЧіВҗЧів„ўЧіВқ ЧіВһЧіВ§ЧівҖңЧів„ўЧіВһЧів„ўЧіВқ', type:'list',
          groups:d.groups||[], tasks:oldTasks, fields:d.fields||[], hiddenCols:d.hiddenCols||{}, colOrder:d.colOrder||[] },
        makeEmptySheet('ЧівҖҳЧіВ§ЧіВЁЧіГ— ЧіГ—ЧівҖәЧіВҹ'),
      ],
    };
    delete d.groups; delete d.tasks; delete d.fields; delete d.hiddenCols; delete d.colOrder;
    return d;
  }
  // Already has sheets Ч’вӮ¬вҖқ migrate tasks within each sheet
  if (!d.licensingMilestones) {
    d = {...d, licensingMilestones:[
      {id:uid(),title:'ЧіВ§ЧівҖҳЧіВңЧіГ— ЧіГ—Чів„ўЧіВ§ ЧіВһЧів„ўЧівҖңЧіВў',date:'2026-02-10',done:true},
      {id:uid(),title:'ЧівҖңЧів„ўЧівҖўЧіВҹ ЧівҖҳЧівҖўЧівҖўЧіВўЧівҖңЧівҖқ',  date:'2026-08-01',done:false},
    ]};
  }
  if (!d.licensingGoals) {
    d = {...d, licensingGoals:[
      {id:uid(),title:'ЧіВ§ЧівҖҳЧіВңЧіГ— ЧіГ—Чів„ўЧіВ§ ЧіВһЧів„ўЧівҖңЧіВў',  targetDate:'2026-03-01',done:true},
      {id:uid(),title:'ЧівҖқЧівҖ”ЧіВңЧіЛңЧіГ— ЧівҖўЧіВўЧівҖңЧівҖқ',      targetDate:'2026-09-01',done:false},
      {id:uid(),title:'ЧіВ§ЧівҖҳЧіВңЧіГ— ЧівҖқЧів„ўЧіГ—ЧіВЁ ЧівҖҳЧіВ Чів„ўЧів„ўЧівҖқ',targetDate:'2026-12-01',done:false},
    ]};
  }
  if (!d.staff) { d = {...d, staff: OFFICE_STAFF}; }
  // Migrate existing team members to include staffId
  if (d.team) {
    d = {...d, team: d.team.map(m => m.staffId ? m : {
      ...m,
      staffId: OFFICE_STAFF.find(s=>s.name===m.name)?.id || m.id,
    })};
  }
  return {...d, sheets: d.sheets.map(s =>
    s.type==='list' ? {...s, tasks:(s.tasks||[]).map(migrateTask)} : s
  )};
}

function repairPrecondsSheet(data) {
  if (!data || !data.sheets) return data;
  const idx = data.sheets.findIndex(s => s.name === 'ЧіГ—ЧіВ ЧіВҗЧів„ўЧіВқ ЧіВһЧіВ§ЧівҖңЧів„ўЧіВһЧів„ўЧіВқ');
  if (idx === -1) return data;
  const sheet = data.sheets[idx];
  const groups = sheet.groups || [];
  const tasks  = sheet.tasks  || [];
  const hasG1  = groups.some(g => g.name === 'ЧіВҗЧів„ўЧіВ©ЧівҖўЧіВЁЧів„ў ЧівҖқЧів„ўЧіГ—ЧіВЁ');
  const hasG2  = groups.some(g => g.name === 'ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧівҖўЧіГ—Чів„ўЧіВҗЧівҖўЧіВқ');
  // If both groups exist and enough tasks Ч’вӮ¬вҖқ nothing to repair
  if (hasG1 && hasG2 && tasks.length >= 14) return data;
  // Restore from default Ч’вӮ¬вҖқ rebuild entire sheet preserving existing non-default tasks
  const def = makeDefaultData();
  const defSheet = def.sheets.find(s => s.name === 'ЧіГ—ЧіВ ЧіВҗЧів„ўЧіВқ ЧіВһЧіВ§ЧівҖңЧів„ўЧіВһЧів„ўЧіВқ');
  if (!defSheet) return data;
  // Merge: keep existing tasks whose title already exists in default (by title match)
  const defTitles = new Set(defSheet.tasks.map(t => t.title));
  const extraTasks = tasks.filter(t => !defTitles.has(t.title));
  const mergedSheet = {
    ...sheet,
    groups: defSheet.groups,
    tasks: [...defSheet.tasks.map(migrateTask), ...extraTasks],
  };
  const sheets = data.sheets.map((s, i) => i === idx ? mergedSheet : s);
  return {...data, sheets};
}

function loadData() {
  try {
    const r = localStorage.getItem(STORAGE_KEY);
    const d = migrateData(r ? JSON.parse(r) : makeDefaultData());
    return repairPrecondsSheet(d);
  } catch { return migrateData(makeDefaultData()); }
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Cell Components
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */

/* Status Circle Ч’вӮ¬вҖқ always filled, Hebrew first-letter */
function StatusCircle({statusId, onChange}) {
  const {statuses, onEditList} = useContext(ListsCtx);
  const [open,setOpen]=useState(false);
  const ref=useRef(null);
  const st=statuses.find(s=>s.id===statusId)||statuses[0];
  useEffect(()=>{
    if(!open)return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[open]);
  const circle=(s,size=20,fSize=10,pulse=false)=>(
    <div style={{
      width:size,height:size,borderRadius:'50%',flexShrink:0,cursor:'pointer',
      background:s.color,color:'#fff',fontSize:fSize,fontWeight:800,
      display:'flex',alignItems:'center',justifyContent:'center',
      userSelect:'none',lineHeight:1,border:'none',
      fontFamily:'Heebo,system-ui,sans-serif',
      ...(pulse?{animation:'pulse-delay 2s ease infinite'}:{}),
    }}>
      {(s.label||'?')[0]}
    </div>
  );
  return(
    <div ref={ref} style={{position:'relative',flexShrink:0}}>
      <div onClick={e=>{e.stopPropagation();setOpen(o=>!o);}} title={st.label}>
        {circle(st,20,10,statusId==='S')}
      </div>
      {open&&(
        <div className="dp" style={{minWidth:170}} onClick={e=>e.stopPropagation()}>
          <div className="dp-title">ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ</div>
          {statuses.map(s=>(
            <div key={s.id} className={`dp-opt${s.id===statusId?' sel':''}`}
              onClick={()=>{onChange(s.id);setOpen(false);}}>
              {circle(s,14,7)}
              {s.label}
            </div>
          ))}
          <div className="dp-sep"/>
          <div className="dp-opt" style={{color:'var(--text-2)',fontSize:11,gap:5}}
            onClick={()=>{setOpen(false);onEditList('status');}}>
            <span>Ч’ВңВҸЧҹВёВҸ</span>ЧіВўЧіВЁЧівҖўЧіВҡ ЧіВЁЧіВ©Чів„ўЧіВһЧівҖқ
          </div>
        </div>
      )}
    </div>
  );
}

/* Priority Cell */
function PriorityCell({priority, onChange}) {
  const {priorities, onEditList} = useContext(ListsCtx);
  const [open,setOpen]=useState(false);
  const ref=useRef(null);
  const pr=priorities.find(p=>p.id===priority);
  useEffect(()=>{
    if(!open)return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[open]);
  return(
    <td ref={ref} style={{position:'relative',cursor:'pointer',padding:'0 8px'}} onClick={()=>setOpen(o=>!o)}>
      <div style={{display:'flex',width:'100%',justifyContent:'center'}}>
      {pr?<span className="pill" style={{color:'#fff',background:pr.color,minWidth:53,justifyContent:'center'}}>{pr.label}</span>
         :<span style={{color:'var(--text-3)',fontSize:12,textAlign:'center'}}>Ч’вӮ¬вҖқ</span>}
      </div>
      {open&&(
        <div className="dp" onClick={e=>e.stopPropagation()}>
          <div className="dp-title">ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—</div>
          {priorities.map(p=>(
            <div key={p.id} className={`dp-opt${p.id===priority?' sel':''}`}
              onClick={()=>{onChange(p.id);setOpen(false);}}>
