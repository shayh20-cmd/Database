  {id:'medium', label:'ЧівҖҳЧів„ўЧіВ ЧівҖўЧіВ Чів„ўЧіГ—', color:'#F59E0B', bg:'rgba(245,158,11,.15)'},
  {id:'low',    label:'ЧіВ ЧіВһЧівҖўЧівҖәЧівҖқ',   color:'#3B82F6', bg:'rgba(59,130,246,.15)'},
