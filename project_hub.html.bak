  {id:'st05',name:'ЧіГ—ЧіВһЧіВЁ ЧівҖҳЧіВңЧів„ўЧівҖ“ЧівҖўЧівҖҳЧіВЎЧіВ§Чів„ў',   role:'ЧіВһЧіВ ЧівҖқЧіВңЧіГ— ЧіВһЧіВ©ЧіВЁЧівҖң',           email:'office@kkarc.com',   phone:'052-2416555',office:'ЧівҖ”Чів„ўЧівӮӘЧівҖқ'},
  {id:'st06',name:'ЧівҖ”ЧіВ ЧіВҹ ЧіВЁЧівҖўЧівҖңЧів„ўЧіВҡ',       role:'ЧіВҗЧівҖңЧіВЁЧів„ўЧівҖәЧіВң',               email:'chanan@kkarc.com',   phone:'054-6435390',office:'ЧіГ—ЧіВң ЧіВҗЧівҖҳЧів„ўЧівҖҳ'},
  {id:'st07',name:'ЧіВ©Чів„ў ЧівҖқЧіВЁЧіВ©ЧіВ§ЧівҖўЧівҖҳЧів„ўЧіВҘ',    role:'ЧіВҗЧівҖңЧіВЁЧів„ўЧівҖәЧіВң',               email:'shay@kkarc.com',     phone:'054-2321535',office:'ЧіГ—ЧіВң ЧіВҗЧівҖҳЧів„ўЧівҖҳ'},
  {id:'st08',name:'ЧіВҗЧіВЎЧіВЈ ЧівҖәЧівҖқЧіВ Чів„ўЧіВқ',       role:'ЧіВҗЧівҖңЧіВЁЧів„ўЧівҖәЧіВң',               email:'assaf@kkarc.com',    phone:'052-6515331',office:'ЧіГ—ЧіВң ЧіВҗЧівҖҳЧів„ўЧівҖҳ'},
