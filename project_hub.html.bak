            </div>
          ))}
          {priority&&<><div className="dp-sep"/><div className="dp-opt" style={{color:'var(--text-3)'}} onClick={()=>{onChange('');setOpen(false);}}>ЧіВңЧіВңЧіВҗ ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—</div></>}
          <div className="dp-sep"/>
          <div className="dp-opt" style={{color:'var(--text-2)',fontSize:11,gap:5}}
            onClick={()=>{setOpen(false);onEditList('priority');}}>
            <span>Ч’ВңВҸЧҹВёВҸ</span>ЧіВўЧіВЁЧівҖўЧіВҡ ЧіВЁЧіВ©Чів„ўЧіВһЧівҖқ
          </div>
        </div>
      )}
    </td>
  );
}

