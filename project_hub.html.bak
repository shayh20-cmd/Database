  {id:'R', label:'ЧівҖқЧіГ—Чів„ўЧів„ўЧівҖ”ЧіВЎЧівҖўЧіГ—',  color:'#D97706'},
  {id:'S', label:'ЧіГ—ЧіВ§ЧівҖўЧіВў',      color:'#EF4444'},
