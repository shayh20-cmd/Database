  priorities:  PRIORITIES,
  disciplines: DISCIPLINES,
  statuses:    STATUSES,
  team:        [],
  onEditList:  ()=>{},
});

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ Utils Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
const uid = () => Math.random().toString(36).slice(2,9);
const todayISO = () => new Date().toISOString().slice(0,10);
const fmtDate = iso => {
  if(!iso) return '';
  const [y,m,d] = iso.split('-');
  return `${parseInt(d)} ${HE_MONTHS[parseInt(m)-1]}`;
};
const fmtDateFull = iso => {
  if(!iso) return '';
  const [y,m,d] = iso.split('-');
  return `${d.padStart(2,'0')}.${m.padStart(2,'0')}.${y}`;
};
const fmtRange = (s, e) => {
  if(s && e) return `${fmtDate(s)} - ${fmtDate(e)}`;
  return fmtDate(s||e);
};
const daysBetween = (d1,d2) => Math.max(0, Math.round((new Date(d2)-new Date(d1))/86400000));

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ Process Event Statuses (same system as planning_dashboard) Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
