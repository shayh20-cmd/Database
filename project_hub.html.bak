<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ЧіВЎЧівӮӘЧіВЁЧів„ўЧів„ўЧіГ— ЧіВңЧівҖўЧівҖң</title>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<script src="https://unpkg.com/react@18/umd/react.production.min.js"></script>
<script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js"></script>
<script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>
<style>
:root{
  --bg:#F5F6F8;--surface:#fff;--surface-2:#FAFBFC;--border:#E8EAED;--border-strong:#D0D2D6;
  --text:#1E1F21;--text-2:#6D6E6F;--text-3:#888888;
  --accent:#2563EB;--accent-h:#1D4ED8;--blue:#6366F1;
  --row-h:36px;
  --z-sticky:10;--z-col-header:50;--z-col-name:60;--z-dropdown:200;--z-sidebar-toggle:300;--z-overlay:700;--z-panel:800;
  --shadow-sm:0 1px 3px rgba(0,0,0,.07),0 1px 2px rgba(0,0,0,.04);
  --shadow-md:0 4px 12px rgba(0,0,0,.10),0 1px 3px rgba(0,0,0,.06);
  --shadow-lg:0 8px 28px rgba(0,0,0,.13),0 2px 6px rgba(0,0,0,.06);
  --radius-sm:6px;--radius-md:8px;--radius-lg:12px;
  --transition:all .15s cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;background:var(--bg);}
body{font-family:'Heebo',system-ui,sans-serif;color:var(--text);font-size:13px;-webkit-font-smoothing:antialiased;}
::-webkit-scrollbar{width:8px;height:8px;}
::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:5px;}
@media(prefers-reduced-motion:reduce){*,*::before,*::after{transition-duration:.01ms!important;animation-duration:.01ms!important;}}
:focus-visible{outline:2px solid var(--accent);outline-offset:2px;}
button:focus:not(:focus-visible),input:focus:not(:focus-visible){outline:none;}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Shell Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.shell{display:flex;height:100vh;overflow:hidden;}
.app{display:flex;flex-direction:column;flex:1;min-width:0;overflow:hidden;}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Sidebar Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.sidebar{width:220px;flex-shrink:0;background:var(--surface-2);color:var(--text);display:flex;flex-direction:column;overflow:hidden;border-left:1px solid var(--border);transition:width .2s ease;}
.sidebar.collapsed{width:0;border-left:none;}
.sb-top{padding:12px 12px 8px;flex-shrink:0;border-bottom:1px solid var(--border);}
.sb-workspace{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:var(--radius-sm);cursor:pointer;margin-bottom:4px;transition:var(--transition);}
.sb-workspace:hover{background:var(--bg);}
.sb-ws-icon{width:26px;height:26px;border-radius:var(--radius-sm);background:var(--accent);display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 1px 4px rgba(37,99,235,.35);}
.sb-ws-name{font-size:13px;font-weight:700;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
.sb-create{display:flex;align-items:center;gap:6px;padding:6px 8px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;color:var(--text-2);background:none;border:none;font-family:inherit;width:100%;}
.sb-create:hover{background:var(--bg);color:var(--text);}
.sb-create-dot{width:18px;height:18px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:14px;color:#fff;flex-shrink:0;line-height:1;}

.sb-body{flex:1;overflow-y:auto;overflow-x:hidden;padding:8px 8px 16px;}
.sb-body::-webkit-scrollbar{width:6px;}
.sb-body::-webkit-scrollbar-thumb{background:var(--border-strong);border-radius:3px;}

.sb-section{margin-bottom:4px;}
.sb-section-label{font-size:11px;font-weight:700;color:var(--text-2);padding:10px 8px 3px;letter-spacing:.5px;text-transform:uppercase;}
.sb-item{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:var(--radius-sm);cursor:pointer;font-size:13px;font-weight:500;color:var(--text);border:none;background:none;font-family:inherit;width:100%;text-align:right;min-width:0;overflow:hidden;transition:var(--transition);}
.sb-item:hover{background:var(--bg);}
.sb-item.active{background:rgba(37,99,235,.1);color:var(--accent);font-weight:600;box-shadow:inset 3px 0 0 var(--accent);}
.sb-item.disabled{opacity:.55;cursor:default;}
.sb-item.disabled:hover{background:none;}
.sb-item-icon{width:16px;height:16px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:var(--text-2);}
.sb-item.active .sb-item-icon{color:var(--accent);}
.sb-proj-badge{height:20px;border-radius:4px;flex-shrink:0;display:flex;align-items:center;justify-content:center;padding:0 5px;font-size:9px;font-weight:800;letter-spacing:.3px;font-family:monospace;}

.sb-footer{padding:10px 12px;border-top:1px solid var(--border);flex-shrink:0;background:var(--surface-2);}
.sb-user{display:flex;align-items:center;gap:8px;}
.sb-avatar{width:26px;height:26px;border-radius:50%;background:var(--accent);display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;}
.sb-user-name{font-size:12px;font-weight:500;color:var(--text);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Sidebar toggle button Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.sb-toggle{width:24px;height:24px;border-radius:6px;border:1px solid var(--border);background:var(--surface);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-2);transition:all .15s;flex-shrink:0;}
.sb-toggle:hover{background:var(--bg);color:var(--text);border-color:var(--border-strong);}
.sb-toggle-fixed{position:fixed;top:14px;right:14px;z-index:var(--z-sidebar-toggle);width:24px;height:24px;border-radius:6px;border:1px solid var(--border);background:var(--surface);cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--text-2);box-shadow:0 1px 4px rgba(0,0,0,.08);transition:all .15s;}
.sb-toggle-fixed:hover{background:var(--bg);color:var(--text);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Sidebar project sub-items Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.sb-proj-row{display:flex;align-items:center;width:100%;gap:0;}
.sb-proj-btn{flex:1;display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px 0 0 6px;cursor:pointer;font-size:13px;font-weight:500;color:var(--text);border:none;background:none;font-family:inherit;text-align:right;min-width:0;overflow:hidden;transition:background .1s;}
.sb-proj-btn:hover{background:var(--bg);}
.sb-proj-btn.active{background:rgba(37,99,235,.09);color:var(--accent);font-weight:600;}
.sb-proj-btn.disabled{opacity:.55;cursor:default;}
.sb-proj-btn.disabled:hover{background:none;}
.sb-proj-chevron{width:22px;height:32px;flex-shrink:0;border:none;background:none;cursor:pointer;color:var(--text-3);display:flex;align-items:center;justify-content:center;border-radius:0 6px 6px 0;transition:all .15s;}
.sb-proj-chevron:hover{background:var(--bg);color:var(--text-2);}
.sb-proj-chevron.disabled{opacity:.35;cursor:default;pointer-events:none;}
.sb-sub-item{display:flex;align-items:center;gap:7px;padding:5px 8px 5px 8px;padding-right:32px;border-radius:6px;cursor:pointer;font-size:12px;font-weight:500;color:var(--text-2);border:none;background:none;font-family:inherit;width:100%;text-align:right;transition:background .1s;}
.sb-sub-item:hover{background:var(--bg);color:var(--text);}
.sb-sub-item.active{color:var(--accent);font-weight:600;}
.sb-sub-item.disabled{opacity:.4;cursor:default;}
.sb-sub-item.disabled:hover{background:none;color:var(--text-2);}
.sb-sub-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Project Header Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.proj-header{background:var(--surface);border-bottom:1px solid var(--border);flex-shrink:0;}
.proj-top{height:52px;display:flex;align-items:center;gap:8px;padding:0 20px;}
.proj-icon{width:28px;height:28px;background:#2563EB;border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;box-shadow:0 1px 4px rgba(37,99,235,.35);}
.proj-name{font-weight:700;font-size:15px;cursor:default;}
.proj-name-input{font-weight:700;font-size:15px;border:1.5px solid var(--blue);border-radius:6px;padding:2px 8px;font-family:inherit;background:var(--surface);outline:none;color:var(--text);}
.icon-btn{background:none;border:none;cursor:pointer;font-size:14px;color:var(--text-3);padding:4px;border-radius:5px;line-height:1;}
.icon-btn:hover{background:var(--bg);color:var(--text-2);}
.status-chip{font-size:11px;font-weight:500;color:var(--text-2);background:var(--surface);border:1px solid var(--border-strong);border-radius:20px;padding:3px 10px;cursor:pointer;white-space:nowrap;transition:var(--transition);}
.status-chip:hover{background:var(--bg);}
.hdr-right{margin-right:auto;display:flex;align-items:center;gap:8px;}
.avatar-stack{display:flex;padding-left:6px;}
.av{width:24px;height:24px;border-radius:50%;border:2px solid var(--surface);display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;margin-left:-6px;}
.btn-share{background:var(--blue);color:#fff;border:none;border-radius:var(--radius-sm);padding:5px 16px;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;transition:var(--transition);box-shadow:0 1px 3px rgba(99,102,241,.3);}
.btn-share:hover{filter:brightness(1.08);}
.btn-cust{background:var(--surface);border:1px solid var(--border-strong);border-radius:var(--radius-sm);padding:5px 13px;font-size:12px;cursor:pointer;font-family:inherit;color:var(--text-2);transition:var(--transition);}
.btn-cust:hover{background:var(--bg);color:var(--text);border-color:var(--border-strong);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Top-level Track Tabs Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.view-tabs{display:flex;align-items:flex-end;height:38px;padding:0 12px;gap:0;border-top:1px solid var(--border);overflow-x:auto;}
.view-tabs::-webkit-scrollbar{height:0;}
.vtab{display:flex;align-items:center;gap:5px;padding:0 16px;height:36px;font-size:13px;font-weight:500;color:var(--text-2);cursor:pointer;border:none;background:none;font-family:inherit;border-bottom:2px solid transparent;white-space:nowrap;transition:var(--transition);border-radius:var(--radius-sm) var(--radius-sm) 0 0;}
.vtab:hover{color:var(--text);background:rgba(0,0,0,.03);}
.vtab.active{color:var(--accent);border-bottom-color:var(--accent);font-weight:600;}
.vtab-add{width:28px;height:36px;display:flex;align-items:center;justify-content:center;font-size:18px;color:var(--text-3);cursor:pointer;border:none;background:none;border-radius:6px;}
.vtab-add:hover{background:var(--bg);color:var(--text-2);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Sheet Sub-tabs (row 2) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.sheet-tabs{display:flex;align-items:center;height:32px;padding:0 12px;gap:2px;border-top:1px solid var(--border);background:#F0F1F3;overflow-x:auto;}
.sheet-tabs::-webkit-scrollbar{height:0;}
.stab{display:flex;align-items:center;padding:0 12px;height:26px;font-size:12px;font-weight:500;color:var(--text-2);cursor:pointer;border:1px solid transparent;background:transparent;font-family:inherit;border-radius:5px;white-space:nowrap;transition:all .12s;}
.stab:hover{background:var(--surface);color:var(--text);}
.stab.active{background:var(--surface);color:var(--text);font-weight:700;border-color:var(--border-strong);box-shadow:0 1px 3px rgba(0,0,0,.08);}
.stab-add{width:24px;height:24px;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--text-3);cursor:pointer;border:none;background:none;border-radius:5px;margin-right:4px;}
.stab-add:hover{background:var(--surface);color:var(--text-2);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Toolbar Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.toolbar{
  padding:7px 20px;display:flex;align-items:center;gap:8px;
  border-bottom:1px solid var(--border);background:var(--surface);flex-shrink:0;
}
.btn-add-wrap{display:flex;border-radius:6px;box-shadow:0 1px 2px rgba(0,0,0,.1);}
.btn-add-main{background:var(--accent);color:#fff;padding:6px 16px;font-size:13px;font-weight:600;border:none;cursor:pointer;font-family:inherit;border-radius:var(--radius-sm) 0 0 var(--radius-sm);transition:var(--transition);letter-spacing:.01em;}
.btn-add-main:hover{background:var(--accent-h);}
.btn-add-arr{background:#1D4ED8;color:#fff;padding:6px 9px;font-size:10px;border:none;cursor:pointer;border-right:1px solid rgba(255,255,255,.25);border-radius:0 var(--radius-sm) var(--radius-sm) 0;transition:var(--transition);}
.btn-add-arr:hover{background:#1648C7;}
.tb-right{margin-right:auto;display:flex;align-items:center;gap:4px;}
.btn-tb{display:flex;align-items:center;gap:5px;padding:5px 10px;font-size:12px;font-weight:500;border:1px solid var(--border);border-radius:var(--radius-sm);cursor:pointer;background:var(--surface);color:var(--text-2);font-family:inherit;transition:var(--transition);white-space:nowrap;position:relative;box-shadow:var(--shadow-sm);}
.btn-tb:hover{background:var(--bg);border-color:var(--border-strong);color:var(--text);}
.btn-tb.on{border-color:var(--accent);color:var(--accent);background:rgba(37,99,235,.06);box-shadow:none;}
.tb-badge{display:inline-flex;align-items:center;justify-content:center;background:var(--accent);color:#fff;font-size:10px;font-weight:700;width:16px;height:16px;border-radius:50%;}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Active filter bar Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.active-bar{padding:5px 20px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;gap:6px;align-items:center;flex-wrap:wrap;flex-shrink:0;}
.f-chip{display:flex;align-items:center;gap:5px;padding:3px 10px 3px 8px;background:rgba(99,102,241,.08);border:1px solid rgba(99,102,241,.25);border-radius:20px;font-size:11px;color:var(--blue);font-weight:600;}
.f-chip button{background:none;border:none;cursor:pointer;color:inherit;font-size:13px;line-height:1;padding:0;opacity:.7;}
.f-chip button:hover{opacity:1;}
.s-chip{display:flex;align-items:center;gap:5px;padding:3px 10px 3px 8px;background:rgba(37,99,235,.08);border:1px solid rgba(37,99,235,.25);border-radius:20px;font-size:11px;color:var(--accent);font-weight:600;}
.s-chip button{background:none;border:none;cursor:pointer;color:inherit;font-size:13px;line-height:1;padding:0;opacity:.7;}
.s-chip button:hover{opacity:1;}
.clear-all{background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);font-family:inherit;}
/* Sort criterion rows inside sort panel */
.sort-crit-row{display:flex;align-items:center;gap:6px;padding:6px 12px;border-bottom:1px solid var(--border);}
.sort-crit-row:last-child{border-bottom:none;}
.sort-crit-num{width:16px;height:16px;border-radius:50%;background:var(--accent);color:#fff;font-size:9px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.sort-crit-label{flex:1;font-size:12px;font-weight:600;color:var(--text);}
.sort-crit-btn{background:none;border:1px solid var(--border-strong);border-radius:5px;cursor:pointer;font-size:10px;padding:2px 6px;color:var(--text-2);font-family:inherit;white-space:nowrap;}
.sort-crit-btn:hover{background:var(--bg);}
.sort-crit-move{background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);padding:1px 3px;line-height:1;}
.sort-crit-move:hover{color:var(--blue);}
.sort-crit-move:disabled{opacity:.2;cursor:default;}
.sort-crit-del{background:none;border:none;cursor:pointer;font-size:13px;color:var(--text-3);padding:0 2px;line-height:1;margin-right:2px;}
.sort-crit-del:hover{color:#EF4444;}
.clear-all:hover{color:var(--text-2);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Dropdown panel Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.dp{position:absolute;z-index:var(--z-dropdown);background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);padding:6px;min-width:200px;box-shadow:var(--shadow-lg);top:calc(100% + 6px);right:0;}
.dp-title{font-size:11px;font-weight:600;color:var(--text-3);text-transform:uppercase;letter-spacing:.06em;padding:4px 8px 6px;}
.dp-opt{display:flex;align-items:center;gap:8px;padding:7px 8px;border-radius:var(--radius-sm);cursor:pointer;font-size:12px;color:var(--text);transition:background .1s;}
.dp-opt:hover{background:var(--bg);}
.dp-sep{height:1px;background:var(--border);margin:4px 0;}
.dp-opt.sel{background:var(--bg);font-weight:600;}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Table Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.list-wrap{overflow:auto;flex:1;}
.list-table{border-collapse:collapse;width:100%;min-width:750px;table-layout:fixed;}
/* Delay pulse animation */
@keyframes pulse-delay{0%,100%{box-shadow:0 0 0 3px rgba(239,68,68,.18);}50%{box-shadow:0 0 0 5px rgba(239,68,68,.32);}}
/* Column resize handle */
.col-rh{position:absolute;right:0;top:0;bottom:0;width:6px;cursor:col-resize;z-index:2;opacity:0;transition:opacity .15s;}
.list-table thead th:hover .col-rh{opacity:.5;}
.col-rh:hover,.col-rh:active{opacity:1!important;background:var(--accent);}
.c-name    {width:35%;min-width:300px;}
.c-pri     {width:88px;min-width:80px;}
.c-disc    {width:88px;min-width:80px;}
.c-resp    {width:90px;min-width:82px;}
.c-date    {width:168px;min-width:150px;}
.c-days    {width:88px;min-width:76px;}
.c-comment {min-width:170px;}
.c-addcol  {width:42px;}

/* thead */
.list-table thead th{
  background:var(--surface);height:32px;padding:0 12px;
  font-size:11px;font-weight:600;color:var(--text-2);
  transition:background .12s;
}
.list-table thead th.sortable:hover{background:rgba(37,99,235,.05);}
.list-table thead th.sortable:hover .sort-arrow{opacity:.3!important;}
.list-table thead th{
  border-bottom:1px solid var(--border);white-space:nowrap;text-align:right;
  position:sticky;top:0;z-index:var(--z-col-header);
}
.list-table thead th.c-name{position:sticky;right:0;z-index:var(--z-col-name);background:var(--surface);}

/* Task row */
.t-row{background:var(--surface);}
.t-row:hover td{background:#F7F8FA;}
.t-row:hover .sticky-td{background:#F7F8FA;}
.t-row td{border-bottom:1px solid var(--border);height:var(--row-h);padding:0 12px;vertical-align:middle;}
/* Expanded parent row: subtle accent on sticky edge */
.t-row.t-expanded td{background:#F8F9FF!important;}
.t-row.t-expanded .sticky-td{box-shadow:inset -3px 0 0 var(--blue);}
.sticky-td{position:sticky;right:0;z-index:var(--z-sticky);background:var(--surface);padding:0!important;}

/* Sub row */
.sub-row td{border-bottom:1px solid var(--border);height:32px;padding:0 12px;vertical-align:middle;background:#F0F2F6;}
.sub-row:hover td{background:#E8EBF0;}
.sub-row .sticky-td{background:#F0F2F6;border-right:2px solid #C5CFDF;}
.sub-row:hover .sticky-td{background:#E8EBF0;border-right:2px solid #C5CFDF;}

/* Section header */
.sec-row td{height:38px;padding:0 12px;border-bottom:1px solid var(--border);background:var(--surface);}
.sec-row td:first-child{border-right:3px solid transparent;}

/* Completed tasks sub-header */
.done-sec-row td{height:32px;padding:0 12px;border-bottom:1px solid var(--border);background:rgba(0,0,0,.018);cursor:pointer;user-select:none;}
.done-sec-row:hover td{background:rgba(0,0,0,.032);}
/* Virtual sub-group (second grouping level) */
.sub-sec-row td{height:30px;padding:0 12px 0 32px;border-bottom:1px solid var(--border);background:#F0F1F5;}
.sub-sec-row:hover td{background:#EAEBF0;}
/* Section row Ч’вӮ¬вҖқ hover-revealed controls */
.sec-drag-handle{opacity:0;transition:opacity .12s;cursor:grab;color:var(--text-3);font-size:14px;flex-shrink:0;line-height:1;user-select:none;padding:0 2px;}
.sec-row:hover .sec-drag-handle{opacity:.4;}
.sec-drag-handle:hover{opacity:1!important;}
.sec-actions-btn{opacity:0;transition:opacity .12s;}
.sec-row:hover .sec-actions-btn{opacity:1;}
/* Task drag handle */
.task-drag-handle{opacity:0;transition:opacity .12s;cursor:grab;color:var(--text-3);font-size:14px;flex-shrink:0;line-height:1;user-select:none;padding:0 3px 0 0;}
.t-row:hover .task-drag-handle{opacity:.35;}
.task-drag-handle:hover{opacity:1!important;}
.t-row.t-drag-src{opacity:.45;}
.t-row.t-drag-over td{background:rgba(37,99,235,.07)!important;box-shadow:inset 0 -2px 0 var(--accent);}
.done-chevron{display:inline-block;font-size:10px;color:#888;transition:transform .18s;line-height:1;}
.done-chevron.open{transform:rotate(90deg);}

/* Add task */
.add-task-row td{height:34px;border-bottom:1px solid var(--border);}
.add-task-btn{background:none;border:none;cursor:pointer;font-size:12px;color:var(--text-3);font-family:inherit;display:flex;align-items:center;gap:6px;height:34px;padding:0 14px;transition:color .12s;}
.add-task-btn:hover{color:var(--accent);}

/* Name inner */
.name-inner{display:flex;align-items:center;gap:6px;height:var(--row-h);padding:0 10px;}
.sub-name-inner{display:flex;align-items:center;gap:6px;height:32px;padding:0 10px 0 48px;}

/* Status circle */
.sc{width:17px;height:17px;border-radius:50%;flex-shrink:0;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:7px;font-weight:800;border:1.5px solid currentColor;transition:transform .12s,opacity .12s;user-select:none;}
.sc:hover{transform:scale(1.18);}
.sc-done{background:currentColor!important;color:#fff!important;border-color:currentColor!important;}

/* Expand */
.expand-btn{background:none;border:none;cursor:pointer;width:13px;height:13px;flex-shrink:0;display:flex;align-items:center;justify-content:center;color:var(--text-3);font-size:7px;border-radius:3px;transition:color .12s;padding:0;margin:-6px;padding:6px;}
.expand-btn:hover,.expand-btn.has-sub{color:var(--accent);}

/* Name text */
.name-text{flex:1;font-size:13px;cursor:text;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.name-edit-input{flex:1;font-size:13px;border:none;outline:none;background:transparent;font-family:inherit;color:var(--text);}

/* Pill */
.pill{display:inline-flex;align-items:center;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:700;white-space:nowrap;cursor:pointer;transition:filter .12s;}
.pill:hover{filter:brightness(.95);}

/* Date text */
.dt{font-size:12px;color:var(--text-2);white-space:nowrap;cursor:pointer;}
.dt:hover{color:var(--text);}
.dt.late{color:#EF4444;font-weight:600;}

/* Comment */
.cmt{font-size:12px;color:var(--text-2);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;cursor:text;}
.cmt-input{width:100%;border:none;outline:none;background:transparent;font-size:12px;font-family:inherit;color:var(--text-2);}

/* Sub badge */
.sub-badge{font-size:10px;font-weight:600;color:var(--text-3);background:var(--bg);border:1px solid var(--border-strong);border-radius:8px;padding:0 6px;white-space:nowrap;cursor:pointer;flex-shrink:0;}
.sub-badge:hover{color:var(--blue);border-color:var(--blue);}

/* Done circle Ч’вӮ¬вҖқ regular task (empty) */
.done-btn{width:13px;height:13px;border-radius:50%;border:1.5px solid #8E8E8E;background:transparent;cursor:pointer;flex-shrink:0;line-height:1;transition:border-color .15s,background .15s;margin:-6px;padding:6px;}
.done-btn:hover{border-color:#059669;}
.done-btn.is-done{background:#059669;border-color:#059669;}
.t-row.task-done{opacity:.42;}
.t-row.task-done .name-text{text-decoration:line-through;color:var(--text-3);}

/* Process task circle Ч’вӮ¬вҖқ filled */
.proc-btn{width:13px;height:13px;border-radius:50%;border:1.5px solid #8E8E8E;background:#8E8E8E;cursor:pointer;flex-shrink:0;padding:0;line-height:1;transition:border-color .15s,background .15s;}
.proc-btn:hover{border-color:#059669;background:#059669;}
.proc-btn.is-done{background:#059669;border-color:#059669;}
.name-text.proc-link{cursor:pointer;}
.name-text.proc-link:hover{color:var(--blue);text-decoration:underline;}

/* Process task panel */
.tp-overlay{position:fixed;inset:0;z-index:var(--z-overlay);background:rgba(0,0,0,.18);}
.tp-panel{position:fixed;top:0;left:0;bottom:0;width:min(780px,78vw);background:var(--surface);box-shadow:-6px 0 40px rgba(0,0,0,.16),-1px 0 0 rgba(0,0,0,.06);display:flex;flex-direction:column;z-index:var(--z-panel);overflow:hidden;}
.tp-hdr{display:flex;align-items:center;gap:10px;padding:14px 20px;border-bottom:1px solid var(--border);flex-shrink:0;}
.tp-proc-icon{width:18px;height:18px;border-radius:4px;border:2px solid #059669;background:#059669;display:flex;align-items:center;justify-content:center;font-size:10px;color:#fff;flex-shrink:0;}
.tp-task-title{font-size:15px;font-weight:700;flex:1;color:var(--text);}
.tp-close{background:none;border:none;cursor:pointer;font-size:18px;color:var(--text-3);padding:3px 7px;border-radius:5px;line-height:1;}
.tp-close:hover{background:var(--bg);color:var(--text);}
.tp-split{display:flex;flex:1;overflow:hidden;}

/* Subtasks side (right in RTL) */
.tp-subs{width:260px;flex-shrink:0;border-left:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden;}
.tp-subs-hdr{padding:10px 16px;font-size:12px;font-weight:700;color:var(--text-2);border-bottom:1px solid var(--border);flex-shrink:0;}
.tp-subs-list{flex:1;overflow-y:auto;padding:6px 0;}
.tp-sub-row{display:flex;align-items:center;gap:8px;padding:5px 16px;}
.tp-sub-row:hover{background:var(--bg);}
.tp-sub-cb{width:14px;height:14px;border-radius:50%;border:1.5px solid #C0C0C0;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:800;background:transparent;color:transparent;transition:all .12s;padding:0;}
.tp-sub-cb:hover{border-color:#059669;}
.tp-sub-cb.done{background:#059669;border-color:#059669;color:#fff;}
.tp-sub-text{flex:1;font-size:12px;outline:none;border:none;background:transparent;font-family:inherit;color:var(--text);}
.tp-sub-text.done-text{text-decoration:line-through;color:var(--text-3);}
.tp-sub-del{opacity:0;background:none;border:none;cursor:pointer;font-size:12px;color:var(--text-3);padding:0 3px;}
.tp-sub-row:hover .tp-sub-del{opacity:1;}
.tp-sub-del:hover{color:#EF4444;}
.tp-add-sub{display:flex;align-items:center;gap:8px;padding:7px 16px;cursor:pointer;background:none;border:none;font-size:12px;color:var(--text-3);font-family:inherit;width:100%;}
.tp-add-sub:hover{background:var(--bg);color:var(--text-2);}

/* Event timeline side (left) */
.tp-events{flex:1;display:flex;flex-direction:column;overflow:hidden;}
.tp-ev-hdr{padding:10px 20px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);flex-shrink:0;}
.tp-ev-title{font-size:12px;font-weight:700;color:var(--text-2);flex:1;}
.tp-ev-list{flex:1;overflow-y:auto;padding:16px 20px 24px;}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Event Timeline (dashboard-style) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
/* Axis is at 13px from the right edge of the container (center of the 28px column) */
.ev-timeline{position:relative;padding-right:28px;}
.ev-timeline-line{position:absolute;right:12px;top:6px;bottom:6px;width:2px;background:var(--border);border-radius:2px;}

/* Period event Ч’вӮ¬вҖқ margin-bottom (not padding-bottom) so top:50% measures the row only */
.ev-event{position:relative;margin-bottom:10px;}
.ev-event:last-child{margin-bottom:0;}
/* Dot center at 13px from right: right edge at 4px Ч’вҖ вҖҷ right = 28-4 = -24px */
.ev-dot{position:absolute;right:-24px;top:50%;transform:translateY(-50%);width:18px;height:18px;border-radius:50%;border:3px solid var(--surface);box-shadow:0 0 0 2px var(--border-strong);cursor:pointer;transition:transform .12s;}
.ev-dot:hover{transform:translateY(-50%) scale(1.18);}
.ev-card{background:var(--surface);border:1px solid var(--border);border-right-width:3px;border-radius:10px;padding:10px 12px;box-shadow:0 1px 4px rgba(0,0,0,.04);transition:box-shadow .15s;}
.ev-card:hover{box-shadow:0 2px 10px rgba(0,0,0,.09);}

/* Milestone Ч’вӮ¬вҖқ same margin-bottom approach */
.ev-milestone{position:relative;margin-bottom:10px;}
.ev-milestone:last-child{margin-bottom:0;}

/* Shared compact row Ч’вӮ¬вҖқ used by both milestones and collapsed period events */
.ev-compact-row{display:flex;align-items:center;justify-content:space-between;padding:6px 12px;border-radius:8px;gap:8px;opacity:.92;transition:opacity .12s;}
.ev-compact-row:hover{opacity:1;}

/* Status pill */
.ev-status-pill{display:inline-flex;align-items:center;gap:5px;padding:3px 10px;border-radius:20px;font-size:12px;font-weight:600;cursor:pointer;user-select:none;transition:opacity .12s;flex-shrink:0;}
.ev-status-pill:hover{opacity:.8;}

/* Discipline chip */
.ev-disc-chip{display:inline-flex;align-items:center;padding:1px 7px;border-radius:5px;font-size:10px;font-weight:700;flex-shrink:0;}

/* Duration row (inside period card) */
.ev-duration{display:flex;align-items:center;gap:6px;margin-top:8px;padding-top:8px;border-top:1px solid var(--border);font-size:11px;color:var(--text-2);}
.ev-dur-label{color:var(--text-3);}
.ev-dur-val{font-size:12px;font-weight:700;color:var(--text-2);}

/* Edit meta row */
.ev-meta-row{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-top:6px;}
.ev-meta-input{border:none;background:transparent;font-family:inherit;font-size:11px;color:var(--text-2);outline:none;padding:0;}
.ev-meta-input::placeholder{color:var(--text-3);}
.ev-meta-sep{color:var(--border-strong);font-size:10px;}

/* Title input */
.tl-ev-title{font-size:13px;font-weight:500;color:var(--text);width:100%;border:none;background:transparent;font-family:inherit;outline:none;padding:0;display:block;}
.tl-ev-title:focus{border-bottom:1px solid var(--accent);}
.tl-ev-title::placeholder{color:var(--text-3);font-weight:400;}

/* Delete button (appears on hover) */
.ev-del{opacity:0;background:none;border:none;cursor:pointer;font-size:14px;color:var(--text-3);padding:0 2px;line-height:1;flex-shrink:0;transition:color .1s,opacity .1s;}
.ev-event:hover .ev-del,.ev-milestone:hover .ev-del{opacity:1;}
.ev-del:hover{color:#EF4444;}

/* Add event button (in section header) */
.tp-add-ev-btn{padding:4px 12px;font-size:11px;font-weight:600;background:var(--accent);color:#fff;border:none;border-radius:5px;cursor:pointer;font-family:inherit;flex-shrink:0;}
.tp-add-ev-btn:hover{background:var(--accent-h);}

/* Del btn */
.del-btn{opacity:0;background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);padding:2px 4px;border-radius:4px;flex-shrink:0;line-height:1;}
.del-btn:hover{color:#EF4444;background:rgba(239,68,68,.06);}
.t-row:hover .del-btn,.sub-row:hover .del-btn{opacity:1;}
/* Add-event button on sub-row hover */
.add-ev-inline{opacity:0;background:var(--accent);border:none;cursor:pointer;font-size:12px;font-weight:700;color:#fff;width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;line-height:1;transition:opacity .12s,transform .12s;padding:0;}
.add-ev-inline:hover{transform:scale(1.15);}
.sub-row:hover .add-ev-inline{opacity:1;}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Calendar Range Picker Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.cal-picker{padding:0!important;min-width:276px!important;}
.cal-hdr-inputs{display:flex;align-items:center;gap:8px;padding:10px 12px 8px;border-bottom:1px solid var(--border);}
.cal-chip{flex:1;display:flex;align-items:center;gap:4px;padding:4px 8px;border:1.5px solid var(--border);border-radius:7px;font-size:12px;background:var(--bg);min-height:28px;cursor:pointer;}
.cal-chip.picking{border-color:var(--accent);background:rgba(37,99,235,.05);}
.cal-chip-val{flex:1;font-weight:600;color:var(--text);}
.cal-chip-val.empty{color:var(--text-3);font-weight:400;}
.cal-chip-clr{background:none;border:none;cursor:pointer;color:var(--text-3);font-size:13px;line-height:1;padding:0;}
.cal-chip-clr:hover{color:#EF4444;}
.cal-month-nav{display:flex;align-items:center;justify-content:space-between;padding:8px 12px 2px;}
.cal-nav-btn{background:none;border:none;cursor:pointer;font-size:16px;color:var(--text-2);padding:2px 8px;border-radius:5px;line-height:1;font-family:inherit;}
.cal-nav-btn:hover{background:var(--bg);color:var(--text);}
.cal-month-lbl{font-size:13px;font-weight:700;color:var(--text);}
.cal-grid{display:grid;grid-template-columns:repeat(7,1fr);padding:0 8px;}
.cal-day-hdr{text-align:center;font-size:10px;font-weight:600;color:var(--text-3);padding:5px 0 4px;}
.cal-cell{position:relative;display:flex;align-items:center;justify-content:center;height:32px;cursor:pointer;}
.cal-cell.empty{cursor:default;pointer-events:none;}
.cal-cell.in-range{background:rgba(37,99,235,.1);}
.cal-cell.rng-first{background:linear-gradient(to right,transparent 50%,rgba(37,99,235,.1) 50%);}
.cal-cell.rng-last{background:linear-gradient(to left,transparent 50%,rgba(37,99,235,.1) 50%);}
.cal-num{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;position:relative;z-index:1;transition:background .08s;}
.cal-cell:not(.empty):not(.ep):hover .cal-num{background:rgba(37,99,235,.12);}
.cal-num.ep{background:var(--accent);color:#fff;font-weight:700;}
.cal-num.today:not(.ep){border:1.5px solid var(--accent);color:var(--accent);font-weight:600;}
.cal-num.other{color:var(--text-3);opacity:.35;}
.cal-foot{display:flex;justify-content:space-between;align-items:center;padding:8px 12px 10px;border-top:1px solid var(--border);margin-top:4px;}
.cal-foot-btn{background:none;border:none;cursor:pointer;font-size:12px;font-family:inherit;padding:4px 10px;border-radius:5px;font-weight:600;}
.cal-foot-btn:hover{background:var(--bg);}
/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Overview Page Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.ov-page{flex:1;overflow:auto;padding:24px 28px 48px;}
/* Project card */
.ov-proj-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px 24px;display:flex;gap:0;margin-bottom:16px;}
.ov-proj-meta-wrap{width:210px;flex-shrink:0;border-left:1px solid var(--border);padding-left:20px;margin-left:20px;display:flex;flex-direction:column;gap:12px;}
.ov-meta-item{display:flex;flex-direction:column;gap:1px;}
.ov-meta-label{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-3);}
.ov-meta-val{font-size:12px;font-weight:600;color:var(--text);}
.ov-proj-desc-wrap{flex:1;min-width:0;}
.ov-proj-label{font-size:9px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:var(--text-3);margin-bottom:8px;}
.ov-proj-desc-text{font-size:13px;color:var(--text-2);line-height:1.7;cursor:text;min-height:48px;}
.ov-proj-desc-text:hover{color:var(--text);}
.ov-proj-desc-input{width:100%;border:none;outline:none;border-bottom:1.5px solid var(--blue);font-size:13px;font-family:inherit;color:var(--text);line-height:1.7;background:transparent;resize:none;padding-bottom:2px;}
/* Stats */
.ov-stats-row{display:flex;gap:10px;margin-bottom:16px;}
.ov-stat-card{flex:1;background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 16px;}
.ov-stat-num{font-size:30px;font-weight:800;margin-bottom:2px;line-height:1;}
.ov-stat-label{font-size:11px;color:var(--text-2);}
/* 3-column grid */
.ov-3grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:16px;}
/* Generic section */
.ov-section{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;display:flex;flex-direction:column;}
.ov-sec-hdr{display:flex;align-items:center;gap:7px;padding:11px 16px;border-bottom:1px solid var(--border);font-size:13px;font-weight:700;flex-shrink:0;}
.ov-sec-icon{font-size:14px;line-height:1;}
.ov-sec-body{flex:1;}
/* Team */
.ov-team-row{display:flex;align-items:center;gap:10px;padding:9px 16px;border-bottom:1px solid var(--border);}
.ov-team-row:last-child{border-bottom:none;}
.ov-team-av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;flex-shrink:0;}
.ov-team-info{flex:1;min-width:0;}
.ov-team-name{font-size:12px;font-weight:600;color:var(--text);}
.ov-team-role{font-size:10px;color:var(--text-3);}
.ov-team-links{display:flex;flex-direction:column;align-items:flex-start;gap:2px;}
.ov-team-links a{font-size:10px;color:var(--text-3);text-decoration:none;}
.ov-team-links a:hover{color:var(--blue);}
/* Team section edit mode */
.ov-team-row{position:relative;}
.ov-team-remove{opacity:0;position:absolute;left:8px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-3);font-size:14px;line-height:1;padding:2px;transition:opacity .12s,color .12s;}
.ov-team-row:hover .ov-team-remove{opacity:1;}
.ov-team-remove:hover{color:#EF4444!important;}
.ov-team-add-btn{display:flex;align-items:center;gap:6px;width:100%;padding:8px 16px;background:none;border:none;cursor:pointer;font-size:12px;color:var(--text-3);font-family:inherit;border-top:1px solid var(--border);}
.ov-team-add-btn:hover{background:var(--bg);color:var(--accent);}
.ov-staff-picker{position:absolute;top:calc(100% + 4px);right:0;left:0;background:var(--surface);border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.14);z-index:500;overflow:hidden;}
.ov-staff-search{width:100%;box-sizing:border-box;padding:8px 12px;border:none;border-bottom:1px solid var(--border);font-size:12px;font-family:inherit;background:var(--bg);color:var(--text);outline:none;}
.ov-staff-list{max-height:200px;overflow-y:auto;}
.ov-staff-item{display:flex;align-items:center;gap:8px;padding:7px 12px;cursor:pointer;}
.ov-staff-item:hover{background:var(--bg);}
.ov-staff-av{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;flex-shrink:0;}
.ov-staff-name{font-size:12px;color:var(--text);font-weight:600;}
.ov-staff-role{font-size:10px;color:var(--text-3);}
/* Assignee cell in task rows */
.assignee-av{width:24px;height:24px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;cursor:pointer;transition:filter .12s;flex-shrink:0;}
.assignee-av:hover{filter:brightness(1.15);}
.assignee-dp{position:absolute;top:calc(100% + 4px);right:50%;transform:translateX(50%);min-width:180px;background:var(--surface);border:1px solid var(--border);border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,.14);z-index:500;overflow:hidden;}
/* Checklist (Goals & Milestones) */
.ov-checklist-item{display:flex;align-items:flex-start;gap:8px;padding:7px 16px;border-bottom:1px solid var(--border);}
.ov-checklist-item:last-child{border-bottom:none;}
.ov-checklist-item:hover{background:var(--bg);}
.ov-check-cb{width:14px;height:14px;border-radius:4px;border:1.5px solid #C0C0C0;display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:800;color:transparent;background:transparent;flex-shrink:0;margin-top:2px;cursor:pointer;transition:all .12s;padding:0;line-height:1;}
.ov-check-cb:hover{border-color:#059669;}
.ov-check-cb.done{background:#059669;border-color:#059669;color:#fff;}
.ov-check-text{flex:1;font-size:12px;line-height:1.4;color:var(--text);}
.ov-check-text.done-text{text-decoration:line-through;color:var(--text-3);}
.ov-del-item{opacity:0;background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);padding:0 2px;flex-shrink:0;line-height:1;margin-top:2px;}
.ov-checklist-item:hover .ov-del-item{opacity:1;}
.ov-del-item:hover{color:#EF4444;}
.ov-add-item-btn{display:flex;align-items:center;gap:5px;width:100%;padding:7px 16px;background:none;border:none;border-top:1px solid var(--border);cursor:pointer;font-size:11px;color:var(--text-3);font-family:inherit;flex-shrink:0;}
.ov-add-item-btn:hover{color:var(--accent);background:var(--bg);}
/* Consultants full-width table */
.ov-consultants{background:var(--surface);border:1px solid var(--border);border-radius:12px;margin-bottom:16px;overflow:hidden;}
.ov-con-table{width:100%;border-collapse:collapse;}
.ov-con-table th{background:var(--bg);padding:8px 14px;font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--text-3);text-align:right;border-bottom:1px solid var(--border);white-space:nowrap;}
.ov-con-table td{padding:8px 14px;font-size:12px;color:var(--text);border-bottom:1px solid var(--border);vertical-align:top;}
.ov-con-table tr:last-child td{border-bottom:none;}
.ov-con-table tr:hover td{background:var(--bg);}
.ov-con-disc-chip{display:inline-flex;align-items:center;padding:1px 7px;border-radius:4px;font-size:10px;font-weight:700;white-space:nowrap;margin-left:5px;}
.ov-con-contact-line{font-size:12px;color:var(--text);}
.ov-con-contact-line+.ov-con-contact-line{margin-top:4px;font-size:11px;color:var(--text-2);}
.ov-con-sub a{color:var(--text-3);text-decoration:none;font-size:11px;}
.ov-con-sub a:hover{color:var(--blue);}
/* External contacts grid */
.ov-ext-contacts{background:var(--surface);border:1px solid var(--border);border-radius:12px;overflow:hidden;}
.ov-ext-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));}
.ov-ext-card{padding:14px 18px;border-bottom:1px solid var(--border);border-left:1px solid var(--border);}
.ov-ext-card:hover{background:var(--bg);}
.ov-ext-name{font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px;}
.ov-ext-org{font-size:11px;color:var(--text-3);margin-bottom:6px;}
.ov-ext-contact-item{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--text-2);margin-top:2px;}
.ov-ext-contact-item a{color:var(--text-2);text-decoration:none;}
.ov-ext-contact-item a:hover{color:var(--blue);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Settings Sidebar Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.sp-panel{position:fixed;top:0;left:0;bottom:0;width:286px;background:var(--surface);border-right:1px solid var(--border);box-shadow:4px 0 28px rgba(0,0,0,.12);z-index:900;display:flex;flex-direction:column;overflow:hidden;}
.sp-hdr{display:flex;align-items:center;gap:8px;padding:14px 16px 12px;border-bottom:1px solid var(--border);flex-shrink:0;}
.sp-hdr-title{font-size:15px;font-weight:700;flex:1;color:var(--text);}
.sp-hdr-btn{background:none;border:none;cursor:pointer;font-size:15px;color:var(--text-3);padding:3px 7px;border-radius:5px;line-height:1;}
.sp-hdr-btn:hover{background:var(--bg);color:var(--text);}
.sp-proj{padding:12px 16px 10px;border-bottom:1px solid var(--border);}
.sp-proj-row{display:flex;align-items:center;gap:6px;margin-bottom:3px;}
.sp-proj-name{font-size:13px;font-weight:600;flex:1;}
.sp-btn-sm{background:none;border:1px solid var(--border-strong);border-radius:5px;padding:2px 10px;font-size:11px;cursor:pointer;font-family:inherit;color:var(--text-2);display:flex;align-items:center;gap:3px;}
.sp-btn-sm:hover{background:var(--bg);}
.sp-proj-sub{font-size:11px;color:var(--text-3);}
.sp-sec-lbl{padding:10px 16px 4px;font-size:10px;font-weight:700;color:var(--text-3);text-transform:uppercase;letter-spacing:.07em;}
.sp-nav{display:flex;flex-direction:column;}
.sp-nav-item{display:flex;align-items:center;gap:9px;padding:7px 16px;cursor:pointer;border:none;background:none;font-family:inherit;font-size:13px;color:var(--text-2);width:100%;text-align:right;}
.sp-nav-item:hover{background:var(--bg);}
.sp-nav-item.active{background:rgba(37,99,235,.07);color:var(--accent);}
.sp-nav-icon{width:22px;height:22px;border:1px solid var(--border-strong);border-radius:5px;display:flex;align-items:center;justify-content:center;font-size:11px;flex-shrink:0;background:var(--surface);}
.sp-nav-badge{margin-right:auto;font-size:10px;background:var(--bg);border:1px solid var(--border);border-radius:10px;padding:1px 7px;font-weight:600;}
.sp-content{flex:1;overflow-y:auto;padding-bottom:12px;}
.sp-back{display:flex;align-items:center;gap:6px;background:none;border:none;cursor:pointer;font-size:12px;color:var(--text-3);font-family:inherit;padding:0;}
.sp-back:hover{color:var(--text);}
.sp-field-row{display:flex;align-items:center;gap:8px;padding:6px 16px;}
.sp-field-row:hover{background:var(--bg);}
.sp-field-row:hover .sp-faction{opacity:1;}
.sp-ficon{width:22px;height:22px;border-radius:5px;background:var(--bg);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--text-2);flex-shrink:0;}
.sp-fname{flex:1;font-size:12px;font-weight:500;color:var(--text);}
.sp-ftype{font-size:10px;color:var(--text-3);white-space:nowrap;margin-left:4px;}
.sp-faction{display:flex;gap:2px;opacity:0;transition:opacity .1s;}
.sp-fbtn{background:none;border:none;cursor:pointer;font-size:11px;color:var(--text-3);padding:2px 4px;border-radius:4px;line-height:1;}
.sp-fbtn:hover{background:var(--border);color:var(--text);}
.sp-toggle{width:28px;height:16px;background:var(--border-strong);border-radius:8px;position:relative;cursor:pointer;transition:background .15s;border:none;flex-shrink:0;}
.sp-toggle.on{background:#059669;}
.sp-toggle::after{content:'';position:absolute;top:2px;right:2px;width:12px;height:12px;background:#fff;border-radius:50%;transition:right .15s;}
.sp-toggle.on::after{right:calc(100% - 14px);}
.sp-sep{height:1px;background:var(--border);margin:6px 0;}
.sp-add-btn{display:flex;align-items:center;justify-content:center;gap:6px;margin:6px 12px 0;padding:7px;border:1.5px dashed var(--border-strong);border-radius:8px;cursor:pointer;background:none;font-size:12px;color:var(--text-3);font-family:inherit;width:calc(100% - 24px);}
.sp-add-btn:hover{border-color:var(--accent);color:var(--accent);background:rgba(37,99,235,.04);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Add Field Modal Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.af-overlay{position:fixed;inset:0;background:rgba(0,0,0,.4);z-index:1100;display:flex;align-items:center;justify-content:center;}
.af-box{background:var(--surface);border-radius:12px;width:400px;box-shadow:0 20px 60px rgba(0,0,0,.25);overflow:hidden;}
.af-hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);}
.af-title{font-size:14px;font-weight:700;}
.af-close{background:none;border:none;cursor:pointer;font-size:18px;color:var(--text-3);line-height:1;padding:2px;}
.af-tabs{display:flex;border-bottom:1px solid var(--border);padding:0 18px;}
.af-tab{padding:8px 12px;font-size:12px;font-weight:500;color:var(--text-2);border:none;border-bottom:2px solid transparent;cursor:pointer;background:none;font-family:inherit;}
.af-tab.active{color:var(--text);border-bottom-color:var(--text);font-weight:600;}
.af-body{padding:16px 18px;display:flex;flex-direction:column;gap:12px;}
.af-label{font-size:11px;font-weight:700;color:var(--text-2);margin-bottom:4px;}
.af-input{width:100%;border:1px solid var(--border);border-radius:7px;padding:7px 10px;font-size:13px;font-family:inherit;outline:none;color:var(--text);}
.af-input:focus{border-color:var(--accent);box-shadow:0 0 0 2px rgba(37,99,235,.1);}
.af-type-wrap{position:relative;}
.af-type-btn{width:100%;display:flex;align-items:center;gap:8px;padding:7px 10px;border:1px solid var(--border);border-radius:7px;cursor:pointer;background:var(--surface);font-size:13px;font-family:inherit;color:var(--text);}
.af-type-btn:hover{border-color:var(--border-strong);}
.af-type-label{flex:1;text-align:right;}
.af-type-menu{position:absolute;top:calc(100%+4px);right:0;left:0;background:var(--surface);border:1px solid var(--border-strong);border-radius:8px;box-shadow:0 8px 24px rgba(0,0,0,.12);z-index:10;padding:4px;}
.af-type-opt{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:5px;cursor:pointer;font-size:12px;color:var(--text);}
.af-type-opt:hover{background:var(--bg);}
.af-type-opt.sel{font-weight:700;background:var(--bg);}
.af-type-icon{width:20px;height:20px;border:1px solid var(--border);border-radius:4px;display:flex;align-items:center;justify-content:center;font-size:10px;color:var(--text-2);flex-shrink:0;}
.af-footer{display:flex;gap:8px;padding:0 18px 16px;}
.af-save{background:var(--accent);color:#fff;border:none;border-radius:7px;padding:7px 20px;font-size:13px;font-weight:600;cursor:pointer;font-family:inherit;}
.af-save:disabled{opacity:.5;cursor:default;}
.af-cancel{background:none;border:1px solid var(--border);border-radius:7px;padding:7px 14px;font-size:13px;cursor:pointer;font-family:inherit;color:var(--text-2);}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Edit Field Modal Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
.ef-box{background:var(--surface);border-radius:12px;width:500px;max-height:82vh;box-shadow:0 20px 60px rgba(0,0,0,.25);display:flex;flex-direction:column;overflow:hidden;}
.ef-hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--border);flex-shrink:0;}
.ef-title{font-size:14px;font-weight:700;}
.ef-body{padding:16px 18px;display:flex;flex-direction:column;gap:14px;overflow-y:auto;flex:1;}
.ef-row{display:flex;gap:12px;}
.ef-footer{display:flex;align-items:center;padding:12px 18px;border-top:1px solid var(--border);flex-shrink:0;gap:8px;}
.ef-delete{background:none;border:1px solid #EF4444;color:#EF4444;border-radius:7px;border-radius:7px;padding:6px 14px;font-size:12px;cursor:pointer;font-family:inherit;}
.ef-delete:hover{background:rgba(239,68,68,.06);}
.opt-row{display:flex;align-items:center;gap:8px;padding:5px 8px;border-radius:6px;}
.opt-row:hover{background:var(--bg);}
.opt-color-btn{width:18px;height:18px;border-radius:5px;border:2px solid transparent;cursor:pointer;flex-shrink:0;position:relative;}
.opt-color-btn:hover{opacity:.85;}
.color-picker-pop{position:absolute;top:26px;right:0;background:var(--surface);border:1px solid var(--border-strong);border-radius:10px;padding:8px;z-index:30;box-shadow:0 8px 28px rgba(0,0,0,.18);display:grid;grid-template-columns:repeat(5,1fr);gap:5px;width:150px;}
.color-swatch{width:18px;height:18px;border-radius:6px;cursor:pointer;border:2px solid transparent;transition:transform .12s,box-shadow .12s;padding:0;}
.color-swatch:hover{transform:scale(1.15);box-shadow:0 2px 6px rgba(0,0,0,.18);}
.color-swatch.selected{border-color:rgba(0,0,0,.5);box-shadow:0 0 0 1px rgba(0,0,0,.15);}
.opt-input{flex:1;border:none;border-bottom:1px solid transparent;padding:3px 4px;font-size:13px;font-family:inherit;outline:none;background:transparent;color:var(--text);}
.opt-input:focus{border-bottom-color:var(--accent);}
.opt-del{background:none;border:none;cursor:pointer;font-size:14px;color:var(--text-3);padding:0 4px;line-height:1;opacity:0;}
.opt-row:hover .opt-del{opacity:1;}
.opt-del:hover{color:#EF4444;}
.opt-move{display:flex;flex-direction:column;gap:1px;opacity:0;flex-shrink:0;}
.opt-row:hover .opt-move{opacity:1;}
.opt-move-btn{background:none;border:none;cursor:pointer;font-size:9px;color:var(--text-3);padding:0 2px;line-height:1.2;display:block;}
.opt-move-btn:hover{color:var(--accent);}
.opt-move-btn:disabled{opacity:.2;cursor:default;}
.opt-add-btn{display:flex;align-items:center;gap:6px;background:none;border:none;cursor:pointer;font-size:12px;color:var(--text-3);font-family:inherit;padding:6px 8px;border-radius:5px;width:100%;}
.opt-add-btn:hover{background:var(--bg);color:var(--text-2);}
</style>
</head>
<body>
<div id="root"></div>
<script type="text/babel" data-presets="react">
const { useState, useEffect, useCallback, useRef, useMemo, useContext } = React;

const STORAGE_KEY = 'pm_asana_v9';

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ Constants Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
const STATUSES = [
  {id:'I', label:'ЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ',      color:'#2563EB'},
