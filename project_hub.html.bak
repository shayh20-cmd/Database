  ],
};

function phaseDays(phase) {
  const today = '2026-06-14';
  const msDay = 86400000;
  if(phase.status==='active' && phase.startDate && phase.endDate) {
    const elapsed = Math.round((new Date(today) - new Date(phase.startDate)) / msDay);
    const remaining = Math.round((new Date(phase.endDate) - new Date(today)) / msDay);
    const total = elapsed + Math.max(remaining, 0);
    const pct = total>0 ? Math.round(elapsed/total*100) : 100;
    return {elapsed, remaining, total, pct, overdue: remaining<0};
  }
  if(phase.status==='done' && phase.startDate && phase.endDate) {
    const dur = Math.round((new Date(phase.endDate) - new Date(phase.startDate)) / msDay);
    return {dur};
  }
  return null;
}

/* hours helpers */
const DISC_ORDER = ['ARCH','ENVI','STRC','TRAF','LAND','PM'];
const DISC_LABELS = {ARCH:'ЧіВҗЧівҖңЧіВЁЧів„ўЧівҖәЧіВңЧівҖўЧіГ—',ENVI:'ЧіВЎЧівҖҳЧів„ўЧівҖҳЧівҖқ',STRC:'ЧіВ§ЧівҖўЧіВ ЧіВЎЧіЛңЧіВЁЧівҖўЧіВ§ЧіВҰЧів„ўЧівҖқ',TRAF:'ЧіГ—ЧіВ ЧівҖўЧіВўЧівҖқ',LAND:'ЧівҖҷЧів„ўЧіВ ЧівҖўЧіВҹ',PM:'ЧіВ Чів„ўЧівҖқЧівҖўЧіВң'};
const DISC_COLORS = {ARCH:'#3B82F6',ENVI:'#10B981',STRC:'#F59E0B',TRAF:'#8B5CF6',LAND:'#EC4899',PM:'#6B7280'};

function hoursTotal(hours) {
  const b = Object.values(hours).reduce((s,h)=>s+h.budget,0);
  const a = Object.values(hours).reduce((s,h)=>s+h.actual,0);
  return {budget:b, actual:a, pct: b>0?Math.round(a/b*100):0, overrun: a>b};
}
function hoursStatus(budget, actual) {
  if(budget===0) return 'none';
  const r = actual/budget;
  if(r>1)    return 'overrun';  // ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧівҖқ
  if(r>0.85) return 'warning';  // ЧіВҗЧівҖ“ЧівҖқЧіВЁЧівҖқ
  return 'ok';
}
const HOURS_STATUS_CFG = {
  none:    {color:'#D1D5DB', bg:'#F9FAFB', label:'Ч’вӮ¬вҖқ'},
  ok:      {color:'#059669', bg:'#ECFDF5', label:'ЧіГ—ЧіВ§Чів„ўЧіВҹ'},
  warning: {color:'#D97706', bg:'#FFFBEB', label:'ЧіВ§ЧіВЁЧівҖўЧівҖҳ ЧіВңЧіГ—ЧіВ§ЧіВЁЧівҖқ'},
  overrun: {color:'#DC2626', bg:'#FEF2F2', label:'ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧівҖқ'},
};

function ExpandedDetail({p}) {
  const [tab, setTab] = React.useState('gantt');
  const [showMilestones, setShowMilestones] = React.useState(false);
  const [hoveredMilestone, setHoveredMilestone] = React.useState(null);
  const tot = hoursTotal(p.hours);
  const hasOverrun = tot.overrun;
  const projectMilestones = MILESTONES_BY_PROJECT[p.id] || [];

  // Compute phase durations in days for proportional Gantt bars
  const msDay = 86400000;
  const phaseDurs = p.phases.map(ph => {
    if((ph.status==='done'||ph.status==='active') && ph.startDate && ph.endDate) {
      return Math.max(Math.round((new Date(ph.endDate)-new Date(ph.startDate))/msDay), 1);
    }
    return (ph.plannedMonths||6)*30;
  });
  const totalDays = phaseDurs.reduce((s,d)=>s+d, 0);

  const tabStyle = (id) => ({
    padding:'8px 16px', fontSize:11, fontWeight:tab===id?700:500,
    color:tab===id?'#2563EB':'var(--text-3)',
    borderBottom:tab===id?'2px solid #2563EB':'2px solid transparent',
    background:'none', border:'none', borderBottom: tab===id?'2px solid #2563EB':'2px solid transparent',
    cursor:'pointer', transition:'color .12s',
  });

  return (
    <div style={{borderTop:'1px solid var(--border)',background:'var(--bg)'}}>
      {/* Tabs */}
      <div style={{display:'flex',borderBottom:'1px solid var(--border)',padding:'0 14px',gap:4}}>
        <button style={tabStyle('gantt')} onClick={()=>setTab('gantt')}>ЧівҖҷЧіВ ЧіЛң ЧіВ©ЧіВңЧівҖҳЧів„ўЧіВқ</button>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Gantt tab Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      {tab==='gantt'&&(
        <div style={{padding:'14px 18px 10px'}}>
          {/* Milestone toggle */}
          <div style={{display:'flex',alignItems:'center',justifyContent:'flex-end',marginBottom:12}}>
            <label style={{display:'flex',alignItems:'center',gap:6,cursor:'pointer',fontSize:11,fontWeight:600,color:showMilestones?'#6366F1':'var(--text-3)',userSelect:'none'}}>
              <input type="checkbox" checked={showMilestones} onChange={e=>setShowMilestones(e.target.checked)}
                style={{accentColor:'#6366F1',width:13,height:13,cursor:'pointer'}}/>
              ЧіВҗЧівҖҳЧіВ Чів„ў ЧівҖңЧіВЁЧіВҡ
              {showMilestones&&<span style={{display:'inline-block',width:9,height:9,background:'#6366F1',transform:'rotate(45deg)',marginRight:2,flexShrink:0}}/>}
            </label>
          </div>
          {p.phases.map((ph,idx)=>{
            const days=phaseDays(ph);
            const isDone=ph.status==='done', isActive=ph.status==='active', isPending=ph.status==='pending';
            const actualDays = phaseDurs[idx]; // actual duration (startЧ’вҖ вҖҷend for done/active)
            // Planned days: from startDate to plannedEndDate if exists, else actualDays
            const plannedDays = (ph.plannedEndDate && ph.startDate)
              ? Math.max(Math.round((new Date(ph.plannedEndDate)-new Date(ph.startDate))/86400000), 1)
              : actualDays;
            const doneOverrunDays = isDone && ph.plannedEndDate ? Math.max(actualDays - plannedDays, 0) : 0;
            const hasDoneOverrun = doneOverrunDays > 0;
            const doneSavingDays = isDone && ph.plannedEndDate ? Math.max(plannedDays - actualDays, 0) : 0;
            const hasDoneSaving = doneSavingDays > 0;
            // For active: elapsed may exceed planned (overdue)
            const elapsedDays = isActive&&days ? days.elapsed : isDone ? actualDays : 0;
            const isOverdue = isActive && days?.overdue;
            const elapsedPct = isActive&&days ? Math.min(days.pct, 100) : isDone ? 100 : 0;

            return (
              <div key={ph.id} style={{marginBottom:16}}>
                {/* Row header */}
                <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:6,flexWrap:'wrap'}}>
                  <div style={{display:'flex',alignItems:'center',gap:5,minWidth:110}}>
                    <div style={{width:14,height:14,borderRadius:'50%',flexShrink:0,
                      border:`2px solid ${isDone?'#059669':isActive?'#2563EB':'#D1D5DB'}`,
                      background:isDone?'#059669':'transparent',
                      display:'flex',alignItems:'center',justifyContent:'center'}}>
                      {isDone&&<span style={{fontSize:7,color:'#fff',fontWeight:900}}>Ч’ВңвҖң</span>}
                      {isActive&&<div style={{width:5,height:5,borderRadius:'50%',background:'#2563EB'}}/>}
                    </div>
                    <span style={{fontSize:11,fontWeight:700,color:isDone?'#059669':isActive?'#2563EB':'#9CA3AF'}}>{ph.id}</span>
                  </div>
                  {isDone&&days&&(
                    <span style={{fontSize:10,color:hasDoneOverrun?'#DC2626':hasDoneSaving?'#059669':'var(--text-3)'}}>
                      {ph.startDate.split('-').reverse().join('.')} Ч’вӮ¬вҖқ {ph.endDate.split('-').reverse().join('.')} ЦІВ· <strong>{actualDays} Чів„ўЧіВһЧів„ўЧіВқ</strong>
                      {hasDoneOverrun&&<span style={{fontWeight:700,color:'#DC2626'}}> ЦІВ· ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧівҖқ ЧіВ©ЧіВң {doneOverrunDays} Чів„ўЧіВһЧів„ўЧіВқ Ч’ВҡВ </span>}
                      {hasDoneSaving&&<span style={{fontWeight:700,color:'#059669'}}> ЦІВ· ЧівҖ”ЧіВЎЧівҖәЧівҖўЧіВҹ ЧіВ©ЧіВң {doneSavingDays} Чів„ўЧіВһЧів„ўЧіВқ Ч’ВңвҖң</span>}
                    </span>
                  )}
                  {isActive&&days&&(
                    <span style={{fontSize:10,fontWeight:600,color:isOverdue?'#DC2626':'var(--text-3)'}}>
                      {isOverdue
                        ?`Ч’ВҡВ  ЧівҖҳЧіВҗЧів„ўЧівҖ”ЧівҖўЧіВЁ ${Math.abs(days.remaining)} Чів„ўЧівҖўЧіВқ (${days.elapsed} Чів„ўЧіВһЧів„ўЧіВқ ЧіВўЧівҖҳЧіВЁЧівҖў, Чів„ўЧіВўЧівҖң ${plannedDays} Чів„ўЧіВһЧів„ўЧіВқ)`
                        :`${days.elapsed} Чів„ўЧіВһЧів„ўЧіВқ ЧіВўЧівҖҳЧіВЁЧівҖў ЦІВ· ${days.remaining} ЧіВ ЧівҖўЧіГ—ЧіВЁЧівҖў ЦІВ· Чів„ўЧіВўЧівҖң ${ph.endDate.split('-').reverse().join('.')}`}
                    </span>
                  )}
                  {isPending&&<span style={{fontSize:10,color:'#9CA3AF'}}>{ph.plannedMonths?`~${ph.plannedMonths} ЧівҖ”ЧівҖўЧівҖңЧіВ©Чів„ўЧіВқ ЧіВһЧіГ—ЧівҖўЧівҖәЧіВ ЧіВҹ`:'ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ'}</span>}
                  {isActive&&hasOverrun&&(
                    <span style={{fontSize:10,fontWeight:700,color:'#DC2626',background:'#FEF2F2',padding:'1px 7px',borderRadius:4,marginRight:'auto'}}>Ч’ВҡВ  ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧіГ— ЧіВ©ЧіВўЧівҖўЧіГ—</span>
                  )}
                </div>

                {/* Gantt bar: planned track + elapsed fill + overrun/saving extension + milestones */}
                {!isPending&&(
                  <div style={{position:'relative',height:24,marginBottom:4}}>
                    {(()=>{
                      const totalBarDays = hasDoneOverrun ? elapsedDays
                                         : hasDoneSaving  ? plannedDays
                                         : isOverdue      ? elapsedDays
                                         : actualDays;
                      const actualWidthPct  = Math.round(actualDays / totalBarDays * 100);
                      const plannedWidthPct = Math.round(plannedDays / totalBarDays * 100);
                      const overrunWidthPct = 100 - plannedWidthPct;
                      const savingWidthPct  = 100 - actualWidthPct;
                      return (<>
                        {/* Actual done zone (rightmost, full width or actual portion) */}
                        <div style={{
                          position:'absolute', right:0, top:0,
                          width:`${hasDoneSaving ? actualWidthPct : (isOverdue||hasDoneOverrun) ? plannedWidthPct : 100}%`,
                          height:'100%',
                          background: isDone ? '#D1FAE5' : isActive ? '#DBEAFE' : '#F3F4F6',
                          borderRadius: (hasDoneSaving||isOverdue||hasDoneOverrun) ? '5px 0 0 5px' : 5,
                          border:`1.5px solid ${isDone?'#A7F3D0':isActive?'#93C5FD':'#E5E7EB'}`,
                          borderLeft:'none',
                          overflow:'hidden',
                        }}>
                          {/* Elapsed fill */}
                          <div style={{
                            height:'100%', width:`${elapsedPct}%`,
                            background: isDone?'#059669': isActive&&isOverdue?'#EF4444':'#2563EB',
                            opacity: isDone?0.4:0.35,
                          }}/>
                          {/* Actual day label */}
                          <span style={{position:'absolute',right:6,top:'50%',transform:'translateY(-50%)',
                            fontSize:9,fontWeight:700,color:isDone?'#059669':'#2563EB',opacity:.9}}>
                            {actualDays}Чів„ўЧіВі
                          </span>
                        </div>
                        {/* Saving zone (left of actual, lighter green) */}
                        {hasDoneSaving&&(
                          <div style={{
                            position:'absolute', left:0, top:0,
                            width:`${savingWidthPct}%`, height:'100%',
                            background:'rgba(16,185,129,0.12)',
                            border:'1.5px solid rgba(16,185,129,0.35)',
                            borderRight:'none',
                            borderRadius:'0 5px 5px 0',
                            display:'flex', alignItems:'center', justifyContent:'center',
                          }}>
                            <span style={{fontSize:9,fontWeight:800,color:'#059669'}}>
                              -{doneSavingDays}Чів„ўЧіВі
                            </span>
                          </div>
                        )}
                        {/* Overrun zone (solid red, semi-transparent) */}
                        {(isOverdue||hasDoneOverrun)&&(
                          <div style={{
                            position:'absolute', left:0, top:0,
                            width:`${overrunWidthPct}%`, height:'100%',
                            background:'rgba(220,38,38,0.18)',
                            border:'1.5px solid rgba(220,38,38,0.4)',
                            borderRight:'none',
                            borderRadius:'0 5px 5px 0',
                          }}>
                            <span style={{position:'absolute',left:4,top:'50%',transform:'translateY(-50%)',
                              fontSize:9,fontWeight:700,color:'#DC2626'}}>
                              +{isDone?doneOverrunDays:elapsedDays-plannedDays}Чів„ўЧіВі
                            </span>
                          </div>
                        )}
                        {/* Today marker (active, not overdue) */}
                        {isActive&&!isOverdue&&days&&(
                          <div style={{
                            position:'absolute',
                            right:`${100-elapsedPct}%`, top:-3,
                            width:2, height:30, background:'#F97316', borderRadius:1, zIndex:2,
                          }}>
                            <span style={{position:'absolute',top:-14,right:-14,fontSize:8,fontWeight:700,color:'#F97316',whiteSpace:'nowrap'}}>ЧівҖқЧів„ўЧівҖўЧіВқ</span>
                          </div>
                        )}
                        {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Milestone icons Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
                        {showMilestones && ph.startDate && ph.endDate && (()=>{
                          const msBarWidthPct = hasDoneSaving
                            ? Math.round(actualDays / totalBarDays * 100)
                            : 100;
                          const phStart = new Date(ph.startDate).getTime();
                          const phEnd   = new Date(ph.endDate).getTime();
                          const phRange = phEnd - phStart;
                          const phaseMilestones = projectMilestones.filter(m => m.date >= ph.startDate && m.date <= ph.endDate);
                          return phaseMilestones.map(m => {
                            const f = phRange > 0 ? Math.max(0.01, Math.min(0.97, (new Date(m.date).getTime() - phStart) / phRange)) : 0;
                            const rightPct = f * msBarWidthPct;
                            const isHov = hoveredMilestone === m.id;
                            return (
                              <div key={m.id}
                                style={{position:'absolute', right:`calc(${rightPct}% - 5px)`, top:'50%', transform:'translateY(-50%)', zIndex:30, cursor:'default'}}
                                onMouseEnter={()=>setHoveredMilestone(m.id)}
                                onMouseLeave={()=>setHoveredMilestone(null)}
                              >
                                {/* Diamond */}
                                <div style={{
                                  width:10, height:10,
                                  background: isHov ? '#4338CA' : '#6366F1',
                                  transform:'rotate(45deg)',
                                  border:'1.5px solid #fff',
                                  boxShadow:'0 1px 4px rgba(0,0,0,.28)',
                                  flexShrink:0,
                                }}/>
                                {/* Tooltip */}
                                {isHov&&(
                                  <div style={{
                                    position:'absolute', bottom:'calc(100% + 10px)',
                                    right:'-70px',
                                    background:'#1E1F21', color:'#fff',
                                    padding:'6px 10px', borderRadius:7,
                                    fontSize:11, fontWeight:600,
                                    whiteSpace:'nowrap',
                                    boxShadow:'0 4px 16px rgba(0,0,0,.3)',
                                    pointerEvents:'none', zIndex:200,
                                    lineHeight:1.4,
                                  }}>
                                    {m.title}
                                    <div style={{color:'#9CA3AF',fontSize:10,marginTop:2,fontWeight:400}}>
                                      {m.date.split('-').reverse().join('.')}
                                    </div>
                                    <div style={{
                                      position:'absolute', bottom:-4, right:73,
                                      width:8, height:8, background:'#1E1F21',
                                      transform:'rotate(45deg)',
                                    }}/>
                                  </div>
                                )}
                              </div>
                            );
                          });
                        })()}
                      </>);
                    })()}
                  </div>
                )}
                {isPending&&(
                  <div style={{height:24,background:'repeating-linear-gradient(90deg,#F3F4F6 0,#F3F4F6 8px,#E5E7EB 8px,#E5E7EB 16px)',
                    borderRadius:5,border:'1.5px dashed #D1D5DB'}}/>
                )}

                {/* Dates row */}
                {(isDone||isActive)&&ph.startDate&&ph.endDate&&(
                  <div style={{display:'flex',justifyContent:'space-between',marginTop:3}}>
                    <span style={{fontSize:9,color:'var(--text-3)'}}>{ph.startDate.split('-').reverse().join('.')}</span>
                    <span style={{fontSize:9,color:isOverdue?'#DC2626':'var(--text-3)',fontWeight:isOverdue?700:400}}>{ph.endDate.split('-').reverse().join('.')}</span>
                  </div>
                )}
                {ph.note&&<div style={{marginTop:4,fontSize:10,color:'var(--text-3)'}}>{ph.note}</div>}
                {ph.blocker&&(
                  <div style={{marginTop:4,fontSize:10,color:'#DC2626',background:'#FEF2F2',padding:'3px 8px',borderRadius:4}}>Ч’ВҡВ  {ph.blocker}</div>
                )}
              </div>
            );
          })}
          <div style={{display:'flex',gap:16,marginTop:6,paddingTop:10,borderTop:'1px solid var(--border)',flexWrap:'wrap'}}>
            <span style={{fontSize:11,color:'var(--text-3)'}}>ЧіВһЧіВ ЧівҖқЧіВң: <strong style={{color:'var(--text)'}}>{p.pm}</strong></span>
            <span style={{fontSize:11,color:'var(--text-3)'}}>ЧіГ—ЧіВ§ЧіВҰЧів„ўЧівҖҳ: <strong style={{color:'var(--text)'}}>{p.budget}</strong></span>
          </div>
        </div>
      )}

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Hours balance tab Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      {tab==='hours'&&(
        <div style={{padding:'14px 18px 10px'}}>
          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:10}}>
            <span style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.4}}>ЧіВ©ЧіВўЧівҖўЧіГ— ЧіВўЧівҖўЧівҖҳЧівҖңЧів„ў ЧіВһЧіВ©ЧіВЁЧівҖң</span>
            <span style={{fontSize:10,color:'var(--text-3)'}}>* ЧіВ ЧіГ—ЧівҖўЧіВ Чів„ў ЧівҖқЧівҖңЧівҖҷЧіВһЧівҖқ Ч’вӮ¬вҖқ Чів„ўЧіВўЧівҖўЧівҖңЧівҖәЧіВҹ ЧіВһЧівҖңЧів„ўЧівҖўЧівҖўЧівҖ” ЧіВ©ЧіВўЧівҖўЧіГ—</span>
          </div>
          <table style={{width:'100%',borderCollapse:'collapse',fontSize:11}}>
            <thead>
              <tr style={{borderBottom:'1px solid var(--border)'}}>
                {['ЧіВһЧіВЎЧіВңЧівҖўЧіВң','ЧіГ—ЧівҖўЧіВ§ЧіВҰЧівҖҳ','ЧівҖҳЧівҖўЧіВҰЧіВў','ЧіВ ЧівҖўЧіГ—ЧіВЁ','%'].map(h=>(
                  <th key={h} style={{padding:'4px 8px',textAlign:'right',fontWeight:700,color:'var(--text-3)',fontSize:10}}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {DISC_ORDER.filter(d=>p.hours[d]?.budget>0||p.hours[d]?.actual>0).map(d=>{
                const h=p.hours[d]; const st=hoursStatus(h.budget,h.actual);
                const cfg=HOURS_STATUS_CFG[st];
                const pct=h.budget>0?Math.round(h.actual/h.budget*100):0;
                const rem=Math.max(h.budget-h.actual,0);
                return (
                  <tr key={d} style={{borderBottom:'1px solid var(--border)',background:st==='overrun'?'#FFF5F5':st==='warning'?'#FFFDF0':''}}>
                    <td style={{padding:'6px 8px'}}>
                      <div style={{display:'flex',alignItems:'center',gap:6}}>
                        <span style={{width:8,height:8,borderRadius:2,background:DISC_COLORS[d],display:'inline-block',flexShrink:0}}/>
                        <span style={{fontWeight:600,color:'var(--text)'}}>{DISC_LABELS[d]}</span>
                      </div>
                    </td>
                    <td style={{padding:'6px 8px',color:'var(--text-2)'}}>{h.budget.toLocaleString()}</td>
                    <td style={{padding:'6px 8px',fontWeight:600,color:cfg.color}}>{h.actual.toLocaleString()}</td>
                    <td style={{padding:'6px 8px'}}>
                      {st==='overrun'
                        ?<span style={{color:'#DC2626',fontWeight:700}}>+{(h.actual-h.budget).toLocaleString()} Ч’ВҡВ </span>
                        :<span style={{color:'var(--text-3)'}}>{rem.toLocaleString()}</span>}
                    </td>
                    <td style={{padding:'6px 8px'}}>
                      <div style={{display:'flex',alignItems:'center',gap:5}}>
                        <div style={{width:44,height:4,borderRadius:2,background:'var(--border)',overflow:'hidden'}}>
                          <div style={{height:'100%',width:`${Math.min(pct,100)}%`,background:cfg.color}}/>
                        </div>
                        <span style={{fontSize:10,fontWeight:600,color:cfg.color}}>{pct}%</span>
                      </div>
                    </td>
                  </tr>
                );
              })}
              <tr style={{borderTop:'2px solid var(--border)',background:'var(--bg)'}}>
                <td style={{padding:'6px 8px',fontWeight:700,color:'var(--text)'}}>ЧіВЎЧівҖқЧіВҙЧівҖә</td>
                <td style={{padding:'6px 8px',fontWeight:700}}>{tot.budget.toLocaleString()}</td>
                <td style={{padding:'6px 8px',fontWeight:700,color:tot.overrun?'#DC2626':'var(--text)'}}>{tot.actual.toLocaleString()}</td>
                <td style={{padding:'6px 8px',fontWeight:700}}>
                  {tot.overrun
                    ?<span style={{color:'#DC2626'}}>+{(tot.actual-tot.budget).toLocaleString()} Ч’ВҡВ </span>
                    :<span style={{color:'var(--text-3)'}}>{(tot.budget-tot.actual).toLocaleString()}</span>}
                </td>
                <td style={{padding:'6px 8px',fontWeight:700,color:tot.overrun?'#DC2626':tot.pct>85?'#D97706':'#059669'}}>{tot.pct}%</td>
              </tr>
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}

function PortfolioView() {
  const [view, setView] = React.useState('cards');
  const [expandedId, setExpandedId] = React.useState(null);
  const [showFilter, setShowFilter] = React.useState(false);
  const filterRef = React.useRef(null);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ filter state Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [fTypes,     setFTypes]     = React.useState([]);
  const [fStages,    setFStages]    = React.useState([]);
  const [fPMs,       setFPMs]       = React.useState([]);
  const [fPrios,     setFPrios]     = React.useState([]);
  const [fTrackSt,   setFTrackSt]   = React.useState(''); // 'blocked' only for now
  const [fBlocked,   setFBlocked]   = React.useState(false);

  React.useEffect(()=>{
    if(!showFilter) return;
    const h=e=>{if(filterRef.current&&!filterRef.current.contains(e.target))setShowFilter(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showFilter]);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ derived options Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const ALL_TYPES  = [...new Set(PORTFOLIO_DATA.map(p=>p.type))];
  const ALL_STAGES = [...new Set(PORTFOLIO_DATA.map(p=>p.stage))];
  const ALL_PMS    = [...new Set(PORTFOLIO_DATA.map(p=>p.pm))];
  const ALL_PRIOS  = [{id:'high',label:'ЧівҖҷЧівҖҳЧівҖўЧівҖқЧівҖқ',color:'#EF4444'},{id:'medium',label:'ЧівҖҳЧів„ўЧіВ ЧівҖўЧіВ Чів„ўЧіГ—',color:'#F59E0B'},{id:'low',label:'ЧіВ ЧіВһЧівҖўЧівҖәЧівҖқ',color:'#9CA3AF'}];

  const activePhase = p => p.phases.find(ph=>ph.status==='active') || p.phases[p.phases.length-1];

  const toggleArr=(arr,setArr,v)=>setArr(arr.includes(v)?arr.filter(x=>x!==v):[...arr,v]);
  const clearAll=()=>{setFTypes([]);setFStages([]);setFPMs([]);setFPrios([]);setFBlocked(false);};
  const hasFilters = fTypes.length||fStages.length||fPMs.length||fPrios.length||fBlocked;

  const filtered = PORTFOLIO_DATA.filter(p=>{
    if(fTypes.length   && !fTypes.includes(p.type))                 return false;
    if(fStages.length  && !fStages.includes(activePhase(p).id))     return false;
    if(fPMs.length     && !fPMs.includes(p.pm))                     return false;
    if(fPrios.length   && !fPrios.includes(p.priority))             return false;
    if(fBlocked        && p.blockers.length===0)                    return false;
    return true;
  });

  const totalBlockers = PORTFOLIO_DATA.reduce((s,p)=>s+p.blockers.length,0);
  const totalPeople = new Set(PORTFOLIO_DATA.flatMap(p=>[p.pm,...p.team])).size;

  const PriorityDot = ({priority}) => {
    const c = priority==='high'?'#EF4444':priority==='medium'?'#F59E0B':'#9CA3AF';
    return <span style={{display:'inline-block',width:8,height:8,borderRadius:'50%',background:c,flexShrink:0}}/>;
  };

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Phase stepper (card header) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const PhaseStepper = ({phases}) => (
    <div style={{display:'flex',alignItems:'center',gap:0,marginTop:10}}>
      {phases.map((ph,i)=>{
        const days = phaseDays(ph);
        const isDone    = ph.status==='done';
        const isActive  = ph.status==='active';
        const isPending = ph.status==='pending';
        const dotColor  = isDone?'#059669':isActive?'#2563EB':'#D1D5DB';
        const labelColor= isDone?'#059669':isActive?'#2563EB':'#9CA3AF';
        return (
          <React.Fragment key={ph.id}>
            {i>0&&<div style={{flex:1,height:2,background:isDone||isActive?'#D1FAE5':'var(--border)',marginBottom:14}}/>}
            <div style={{display:'flex',flexDirection:'column',alignItems:'center',gap:3,minWidth:0}}>
              <div style={{width:20,height:20,borderRadius:'50%',border:`2px solid ${dotColor}`,
                background:isDone?dotColor:isActive?'#EFF6FF':'var(--bg)',
                display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0}}>
                {isDone&&<span style={{fontSize:9,color:'#fff',fontWeight:900}}>Ч’ВңвҖң</span>}
                {isActive&&<div style={{width:7,height:7,borderRadius:'50%',background:'#2563EB'}}/>}
              </div>
              <span style={{fontSize:9,fontWeight:isActive?700:500,color:labelColor,whiteSpace:'nowrap',maxWidth:60,textOverflow:'ellipsis',overflow:'hidden',textAlign:'center'}}>{ph.id}</span>
              {isActive&&days&&(
                <span style={{fontSize:9,color:days.overdue?'#DC2626':'#2563EB',fontWeight:600,whiteSpace:'nowrap'}}>
                  {days.overdue?`${Math.abs(days.remaining)}Чів„ўЧіВі ЧівҖҳЧіВҗЧів„ўЧівҖ”ЧівҖўЧіВЁ`:`${days.remaining}Чів„ўЧіВі ЧіВ ЧівҖўЧіГ—ЧіВЁЧівҖў`}
                </span>
              )}
            </div>
          </React.Fragment>
        );
      })}
    </div>
  );

  return (
    <div style={{flex:1,overflow:'auto',background:'var(--bg)',padding:'24px 28px',display:'flex',flexDirection:'column',gap:20}}>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Header Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div style={{display:'flex',alignItems:'flex-start',justifyContent:'space-between',gap:16,flexWrap:'wrap'}}>
        <div>
          <h1 style={{fontSize:22,fontWeight:800,color:'var(--text)',margin:0}}>ЧівӮӘЧівҖўЧіВЁЧіЛңЧівӮӘЧівҖўЧіВңЧів„ўЧівҖў ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ</h1>
          <p style={{fontSize:12,color:'var(--text-3)',margin:'3px 0 0'}}>Knafo Klimor Architects ЦІВ· ЧіГ—ЧіВҰЧівҖўЧівҖҷЧіГ— ЧіВ Чів„ўЧівҖқЧівҖўЧіВң</p>
        </div>
        <div style={{display:'flex',gap:8,alignItems:'center',flexWrap:'wrap'}}>

          {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Filter button + panel Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
          <div ref={filterRef} style={{position:'relative'}}>
            <button onClick={()=>setShowFilter(o=>!o)}
              style={{display:'flex',alignItems:'center',gap:6,padding:'6px 12px',borderRadius:8,
                border:`1px solid ${hasFilters?'var(--accent)':'var(--border)'}`,fontSize:12,fontWeight:600,
                cursor:'pointer',fontFamily:'inherit',
                background:hasFilters?'rgba(37,99,235,.07)':'var(--surface)',
                color:hasFilters?'var(--accent)':'var(--text-2)'}}>
              <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round"><path d="M2 4h12M5 8h6M7 12h2"/></svg>
              ЧіВЎЧів„ўЧіВ ЧівҖўЧіВҹ
              {!!hasFilters&&<span style={{background:'var(--accent)',color:'#fff',borderRadius:'50%',width:16,height:16,fontSize:10,display:'flex',alignItems:'center',justifyContent:'center',fontWeight:700}}>
                {[fTypes,fStages,fPMs,fPrios].reduce((s,a)=>s+a.length,0)+(fBlocked?1:0)}
              </span>}
            </button>

            {showFilter&&(
              <div onClick={e=>e.stopPropagation()}
                style={{position:'absolute',top:'calc(100% + 6px)',left:0,width:280,
                  background:'var(--surface)',border:'1px solid var(--border)',borderRadius:12,
                  boxShadow:'0 8px 28px rgba(0,0,0,.14)',zIndex:700,padding:'14px 16px',
                  display:'flex',flexDirection:'column',gap:14}}>

                {/* Type */}
                <div>
                  <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5,marginBottom:6}}>ЧіВЎЧівҖўЧівҖҷ ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң</div>
                  <div style={{display:'flex',gap:6,flexWrap:'wrap'}}>
                    {ALL_TYPES.map(t=>(
                      <button key={t} onClick={()=>toggleArr(fTypes,setFTypes,t)}
                        style={{padding:'3px 10px',borderRadius:6,border:'1px solid',fontSize:11,fontWeight:600,cursor:'pointer',fontFamily:'inherit',
                          background:fTypes.includes(t)?'var(--accent)':'var(--bg)',
                          color:fTypes.includes(t)?'#fff':'var(--text-2)',
                          borderColor:fTypes.includes(t)?'var(--accent)':'var(--border)'}}>
                        {t}
                      </button>
                    ))}
                  </div>
                </div>

                {/* Stage (active phase) */}
                <div>
                  <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5,marginBottom:6}}>ЧіВ©ЧіВңЧівҖҳ ЧіВ ЧівҖўЧівҖәЧівҖ”Чів„ў</div>
                  <div style={{display:'flex',gap:6,flexWrap:'wrap'}}>
                    {PORTFOLIO_PHASES.map(s=>(
                      <button key={s} onClick={()=>toggleArr(fStages,setFStages,s)}
                        style={{padding:'3px 10px',borderRadius:6,border:'1px solid',fontSize:11,fontWeight:600,cursor:'pointer',fontFamily:'inherit',
                          background:fStages.includes(s)?'var(--accent)':'var(--bg)',
                          color:fStages.includes(s)?'#fff':'var(--text-2)',
                          borderColor:fStages.includes(s)?'var(--accent)':'var(--border)'}}>
                        {s}
                      </button>
                    ))}
                  </div>
                </div>

                {/* Priority */}
                <div>
                  <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5,marginBottom:6}}>ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—</div>
                  <div style={{display:'flex',gap:6}}>
                    {ALL_PRIOS.map(p=>(
                      <button key={p.id} onClick={()=>toggleArr(fPrios,setFPrios,p.id)}
                        style={{display:'flex',alignItems:'center',gap:5,padding:'3px 10px',borderRadius:6,border:'1px solid',fontSize:11,fontWeight:600,cursor:'pointer',fontFamily:'inherit',
                          background:fPrios.includes(p.id)?p.color+'22':'var(--bg)',
                          color:fPrios.includes(p.id)?p.color:'var(--text-2)',
                          borderColor:fPrios.includes(p.id)?p.color:'var(--border)'}}>
                        <span style={{width:7,height:7,borderRadius:'50%',background:p.color,display:'inline-block'}}/>
                        {p.label}
                      </button>
                    ))}
                  </div>
                </div>

                {/* PM */}
                <div>
                  <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5,marginBottom:6}}>ЧіВһЧіВ ЧівҖқЧіВң ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң</div>
                  <div style={{display:'flex',flexDirection:'column',gap:4}}>
                    {ALL_PMS.map(pm=>{
                      const st=OFFICE_STAFF.find(s=>s.name===pm);
                      const color=st?staffColor(st.id):'#6B7280';
                      const sel=fPMs.includes(pm);
                      return (
                        <div key={pm} onClick={()=>toggleArr(fPMs,setFPMs,pm)}
                          style={{display:'flex',alignItems:'center',gap:8,padding:'5px 8px',borderRadius:7,cursor:'pointer',
                            background:sel?'rgba(37,99,235,.07)':'',border:`1px solid ${sel?'var(--accent)':'transparent'}`}}
                          onMouseEnter={e=>e.currentTarget.style.background=sel?'rgba(37,99,235,.07)':'var(--bg)'}
                          onMouseLeave={e=>e.currentTarget.style.background=sel?'rgba(37,99,235,.07)':''}>
                          <div style={{width:22,height:22,borderRadius:'50%',background:color,display:'flex',alignItems:'center',justifyContent:'center',fontSize:9,fontWeight:700,color:'#fff',flexShrink:0}}>{staffInitials(pm)}</div>
                          <span style={{fontSize:12,color:sel?'var(--accent)':'var(--text)',fontWeight:sel?600:400}}>{pm}</span>
                          {sel&&<span style={{marginRight:'auto',fontSize:11,color:'var(--accent)'}}>Ч’ВңвҖң</span>}
                        </div>
                      );
                    })}
                  </div>
                </div>

                {/* Blocked toggle */}
                <div style={{borderTop:'1px solid var(--border)',paddingTop:10,display:'flex',alignItems:'center',justifyContent:'space-between'}}>
                  <span style={{fontSize:12,color:'var(--text)',fontWeight:600}}>ЧівҖ”ЧіВЎЧівҖўЧіВһЧів„ўЧіВқ ЧівҖҳЧіВңЧівҖҳЧівҖң</span>
                  <div onClick={()=>setFBlocked(b=>!b)} style={{width:34,height:19,borderRadius:10,background:fBlocked?'var(--accent)':'var(--border)',cursor:'pointer',position:'relative',transition:'background .15s'}}>
                    <div style={{position:'absolute',top:2,right:fBlocked?2:15,width:15,height:15,borderRadius:'50%',background:'#fff',transition:'right .15s',boxShadow:'0 1px 3px rgba(0,0,0,.2)'}}/>
                  </div>
                </div>

                {/* Clear */}
                {!!hasFilters&&(
                  <button onClick={clearAll}
                    style={{padding:'6px',borderRadius:7,border:'1px solid var(--border)',fontSize:12,color:'var(--text-2)',cursor:'pointer',fontFamily:'inherit',background:'var(--bg)',fontWeight:500}}>
                    ЧіВ ЧіВ§ЧівҖқ ЧіВЎЧів„ўЧіВ ЧівҖўЧіВҹ
                  </button>
                )}
              </div>
            )}
          </div>

          {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Active filter chips Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
          {[
            ...fTypes.map(v=>({label:`ЧіВЎЧівҖўЧівҖҷ: ${v}`,rm:()=>toggleArr(fTypes,setFTypes,v)})),
            ...fStages.map(v=>({label:`ЧіВ©ЧіВңЧівҖҳ: ${v}`,rm:()=>toggleArr(fStages,setFStages,v)})),
            ...fPrios.map(v=>({label:`ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—: ${ALL_PRIOS.find(p=>p.id===v)?.label||v}`,rm:()=>toggleArr(fPrios,setFPrios,v)})),
            ...fPMs.map(v=>({label:v,rm:()=>toggleArr(fPMs,setFPMs,v)})),
            ...(fBlocked?[{label:'ЧівҖ”ЧіВЎЧівҖўЧіВһЧів„ўЧіВқ',rm:()=>setFBlocked(false)}]:[]),
          ].map((c,i)=>(
            <span key={i} style={{display:'inline-flex',alignItems:'center',gap:4,padding:'3px 8px',borderRadius:6,
              background:'rgba(37,99,235,.08)',color:'var(--accent)',fontSize:11,fontWeight:600,border:'1px solid rgba(37,99,235,.2)'}}>
              {c.label}
              <span onClick={c.rm} style={{cursor:'pointer',opacity:.7,fontSize:13,lineHeight:1}}>&times;</span>
            </span>
          ))}

          {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ View toggle Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
          <div style={{display:'flex',border:'1px solid var(--border)',borderRadius:8,overflow:'hidden',background:'var(--surface)',marginRight:'auto'}}>
            {[{id:'cards',icon:'Ч’ВҠВһ'},{id:'table',icon:'Ч’вҖ°ВЎ'}].map(v=>(
              <button key={v.id} onClick={()=>setView(v.id)}
                style={{padding:'5px 10px',border:'none',cursor:'pointer',fontSize:14,fontFamily:'inherit',
                  background:view===v.id?'var(--accent)':'transparent',color:view===v.id?'#fff':'var(--text-3)'}}>
                {v.icon}
              </button>
            ))}
          </div>
        </div>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ KPI strip + Phase tabs Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div style={{display:'flex',gap:12,flexWrap:'wrap',alignItems:'stretch'}}>
        {/* Summary KPIs */}
        {[
          {label:'ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ ЧівӮӘЧіВўЧів„ўЧіВңЧів„ўЧіВқ', value:PORTFOLIO_DATA.length, color:'#2563EB'},
          {label:'ЧіВҗЧіВ ЧіВ©Чів„ў ЧіВҰЧівҖўЧівҖўЧіГ—',        value:totalPeople,            color:'#059669'},
          {label:'ЧівҖ”ЧіВЎЧівҖўЧіВһЧів„ўЧіВқ ЧівҖәЧіВЁЧівҖҷЧіВў',      value:totalBlockers,          color:totalBlockers>0?'#DC2626':'#059669'},
        ].map(k=>(
          <div key={k.label} style={{background:'var(--surface)',borderRadius:12,border:'1px solid var(--border)',padding:'14px 20px',flex:'1 1 120px',minWidth:110}}>
            <div style={{fontSize:24,fontWeight:800,color:k.color}}>{k.value}</div>
            <div style={{fontSize:11,color:'var(--text-3)',marginTop:2}}>{k.label}</div>
          </div>
        ))}

        {/* Phase tabs strip */}
        <div style={{background:'var(--surface)',borderRadius:12,border:'1px solid var(--border)',padding:'14px 20px',flex:'3 1 400px',minWidth:320}}>
          <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5,marginBottom:10}}>ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ ЧіВңЧівӮӘЧів„ў ЧіВ©ЧіВңЧівҖҳ</div>
          <div style={{display:'flex',gap:0,borderRadius:8,overflow:'hidden',border:'1px solid var(--border)'}}>
            {PORTFOLIO_PHASES.map((phase,i)=>{
              const count = PORTFOLIO_DATA.filter(p=>activePhase(p).id===phase).length;
              const colors = {
                'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВ Чів„ў': {active:'#6366F1', bg:'rgba(99,102,241,.12)', border:'#6366F1'},
                'ЧівҖқЧів„ўЧіГ—ЧіВЁ':          {active:'#F59E0B', bg:'rgba(245,158,11,.12)', border:'#F59E0B'},
                'ЧіВһЧівҖәЧіВЁЧівҖ“':          {active:'#059669', bg:'rgba(5,150,105,.12)',  border:'#059669'},
                'ЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў':         {active:'#2563EB', bg:'rgba(37,99,235,.12)', border:'#2563EB'},
              };
              const c = colors[phase] || {active:'#6B7280',bg:'var(--bg)',border:'#9CA3AF'};
              const isActive = fStages.includes(phase);
              return (
                <button key={phase} onClick={()=>toggleArr(fStages,setFStages,phase)}
                  style={{
                    flex:1, border:'none', cursor:'pointer', fontFamily:'inherit',
                    borderLeft: i>0?'1px solid var(--border)':'none',
                    padding:'8px 6px',
                    background: isActive ? c.bg : 'var(--bg)',
                    transition:'background .12s',
                    display:'flex', flexDirection:'column', alignItems:'center', gap:3,
                  }}>
                  <span style={{fontSize:20,fontWeight:800,color:count>0?c.active:'var(--text-3)'}}>{count}</span>
                  <span style={{fontSize:10,fontWeight:isActive?700:500,color:isActive?c.active:'var(--text-3)',whiteSpace:'nowrap'}}>{phase}</span>
                  {isActive&&<span style={{width:16,height:2,borderRadius:1,background:c.active}}/>}
                </button>
              );
            })}
          </div>
        </div>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Cards view Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      {view==='cards' && (
        <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(360px,1fr))',gap:16}}>
          {filtered.map(p=>{
            const expanded = expandedId===p.id;
            const hasBlockers = p.blockers.length>0;
            const ap = activePhase(p);
            const apDays = phaseDays(ap);
            return (
              <div key={p.id} style={{background:'var(--surface)',borderRadius:14,border:`1.5px solid ${hasBlockers?'#FCA5A5':'var(--border)'}`,
                boxShadow:'0 1px 4px rgba(0,0,0,.06)',overflow:'hidden'}}>
                {/* Card header */}
                <div style={{padding:'16px 18px 14px',cursor:'pointer'}} onClick={()=>setExpandedId(expanded?null:p.id)}>
                  <div style={{display:'flex',alignItems:'flex-start',justifyContent:'space-between',gap:8,marginBottom:12}}>
                    <div style={{flex:1}}>
                      <div style={{display:'flex',alignItems:'center',gap:6,marginBottom:3}}>
                        <PriorityDot priority={p.priority}/>
                        <span style={{fontSize:15,fontWeight:700,color:'var(--text)'}}>{p.name}</span>
                        {p.code&&<span style={{fontSize:10,fontWeight:800,color:'var(--text-3)',background:'var(--bg)',border:'1px solid var(--border)',borderRadius:4,padding:'1px 6px',letterSpacing:.5,flexShrink:0}}>{p.code}</span>}
                      </div>
                      <div style={{display:'flex',gap:8,alignItems:'center'}}>
                        <span style={{fontSize:11,color:'var(--text-3)'}}>{p.type}</span>
                        <span style={{fontSize:11,color:'var(--text-3)'}}>ЦІВ·</span>
                        <span style={{fontSize:11,color:'var(--text-3)'}}>{p.area.toLocaleString()} ЧіВһ"ЧіВЁ</span>
                        <span style={{fontSize:11,color:'var(--text-3)'}}>ЦІВ·</span>
                        <span style={{fontSize:11,fontWeight:700,color:'#2563EB',background:'rgba(37,99,235,.08)',borderRadius:4,padding:'1px 7px'}}>{ap.id}</span>
                      </div>
                    </div>
                    <span style={{fontSize:16,color:'var(--text-3)',flexShrink:0,transform:expanded?'rotate(90deg)':'rotate(0deg)',transition:'transform .15s'}}>Ч’вӮ¬Г·</span>
                  </div>
                  {/* Phase stepper */}
                  <PhaseStepper phases={p.phases}/>
                  {/* Active phase progress bar */}
                  {apDays&&ap.status==='active'&&(()=>{
                    const plannedD = ap.plannedEndDate
                      ? Math.round((new Date(ap.plannedEndDate)-new Date(ap.startDate))/86400000)
                      : null;
                    const scheduleOverrun = plannedD ? apDays.total - plannedD : 0; // extra days deadline was pushed
                    const isOverPlan = plannedD && apDays.elapsed >= plannedD; // elapsed past original planned end
                    const plannedBarPct = plannedD ? Math.min(plannedD/apDays.total*100, 100) : 100;
                    // Bar fill: relative to planned if exists (so 100% when elapsed=planned), else relative to total
                    const elapsedBarPct = plannedD
                      ? Math.min(apDays.elapsed/plannedD*100, 100)
                      : Math.min(apDays.pct, 100);
                    const barColor = apDays.overdue||isOverPlan?'#EF4444':elapsedBarPct>75?'#F59E0B':'#2563EB';
                    return (
                      <div style={{marginTop:12}}>
                        {/* Dates + days count row */}
                        <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:4,gap:4}}>
                          <span style={{fontSize:10,fontWeight:600,color:'var(--text-3)',flexShrink:0}}>
                            {ap.startDate.split('-').reverse().join('.')}
                          </span>
                          <span style={{fontSize:10,fontWeight:700,textAlign:'center',flex:1,color:(apDays.overdue||isOverPlan)?'#DC2626':'var(--text-2)'}}>
                            {apDays.overdue || isOverPlan
                              ? <span style={{color:'#DC2626'}}>{apDays.elapsed} / {apDays.total} Чів„ўЧіВһЧів„ўЧіВқ Ч’ВҡВ </span>
                              : scheduleOverrun>0
                                ? <span>{apDays.elapsed} / {apDays.total} Чів„ўЧіВһЧів„ўЧіВқ ЦІВ· <span style={{color:'#DC2626',fontWeight:700}}>+{scheduleOverrun} Ч’ВҡВ </span></span>
                                : `${apDays.elapsed} / ${apDays.total} Чів„ўЧіВһЧів„ўЧіВқ`
                            }
                          </span>
                          <span style={{fontSize:10,fontWeight:600,color:apDays.overdue?'#DC2626':'var(--text-3)',flexShrink:0}}>
                            {ap.endDate.split('-').reverse().join('.')}
                          </span>
                        </div>
                        {/* Two-zone progress bar: planned zone + overrun zone */}
                        <div style={{position:'relative',height:5,borderRadius:3,background:'var(--border)',overflow:'hidden'}}>
                          {/* Planned zone background (lighter red tint if there's overrun) */}
                          {scheduleOverrun>0&&(
                            <div style={{position:'absolute',right:0,top:0,
                              width:`${plannedBarPct}%`,height:'100%',
                              background:'var(--border)'}}/>
                          )}
                          {/* Overrun zone background (red tint) */}
                          {scheduleOverrun>0&&(
                            <div style={{position:'absolute',left:0,top:0,
                              width:`${100-plannedBarPct}%`,height:'100%',
                              background:'#FEE2E2'}}/>
                          )}
                          {/* Progress fill */}
                          <div style={{position:'absolute',right:0,top:0,
                            height:'100%',width:`${elapsedBarPct}%`,
                            borderRadius:3,background:barColor,
                            transition:'width .3s'}}/>
                          {/* Planned-end divider line */}
                          {scheduleOverrun>0&&(
                            <div style={{position:'absolute',right:`${100-plannedBarPct}%`,top:0,
                              width:2,height:'100%',background:'#DC2626',opacity:.7,zIndex:2}}/>
                          )}
                        </div>
                        {/* Planned end label */}
                        {scheduleOverrun>0&&ap.plannedEndDate&&(
                          <div style={{display:'flex',justifyContent:'flex-end',marginTop:2,paddingLeft:`${100-plannedBarPct}%`}}>
                            <span style={{fontSize:8,color:'#DC2626',fontWeight:700}}>
                              Чів„ўЧіВўЧівҖң ЧіВһЧіВ§ЧівҖўЧіВЁЧів„ў {ap.plannedEndDate.split('-').reverse().join('.')} (+{scheduleOverrun} Чів„ўЧіВһЧів„ўЧіВқ)
                            </span>
                          </div>
                        )}
                      </div>
                    );
                  })()}
                </div>
                {/* Phase timeline compact bar */}
                {(()=>{
                  const msDay=86400000;
                  const today='2026-06-14';
                  // Compute duration for each phase (days)
                  const segs=p.phases.map(ph=>{
                    if((ph.status==='done'||ph.status==='active')&&ph.startDate&&ph.endDate){
                      return {ph,days:Math.max(Math.round((new Date(ph.endDate)-new Date(ph.startDate))/msDay),1),start:ph.startDate,end:ph.endDate};
                    }
                    return {ph,days:(ph.plannedMonths||6)*30,start:null,end:null};
                  });
                  const totalDays=segs.reduce((s,sg)=>s+sg.days,0);
                  // Find today's position: days from project start
                  const projStart=segs.find(sg=>sg.start)?.start;
                  const todayPct=projStart
                    ?Math.min(Math.max(Math.round((new Date(today)-new Date(projStart))/msDay/totalDays*100),0),100)
                    :null;
                  const hasHoursOverrun=p.hours&&hoursTotal(p.hours).overrun;
                  return (
                    <div style={{padding:'8px 18px 10px',borderTop:'1px solid var(--border)'}}>
                      {/* Segmented bar */}
                      <div style={{position:'relative',height:10,display:'flex',gap:1,borderRadius:5,overflow:'hidden',marginBottom:4}}>
                        {segs.map(({ph,days},i)=>{
                          const w=days/totalDays*100;
                          const isDone=ph.status==='done', isActive=ph.status==='active';
                          const baseColor=isDone?'#059669':isActive?'#2563EB':'#D1D5DB';
                          return (
                            <div key={ph.id}
                              title={`${ph.id}: ${days} Чів„ўЧіВһЧів„ўЧіВқ${ph.startDate?' ЦІВ· '+ph.startDate.split('-').reverse().join('.'):''}${ph.endDate?' Ч’вӮ¬вҖқ '+ph.endDate.split('-').reverse().join('.'):''}${ph.plannedMonths?' (~'+ph.plannedMonths+' ЧівҖ”ЧівҖўЧівҖңЧіВ©Чів„ўЧіВқ)':''}`}
                              style={{flex:w,minWidth:2,position:'relative',overflow:'hidden',background:'#E5E7EB'}}>
                              {/* Solid fill */}
                              <div style={{
                                position:'absolute',top:0,right:0,
                                width:'100%',height:'100%',
                                background:baseColor,
                                opacity:isDone?0.75:isActive?0.88:0.35,
                              }}/>
                              {/* Pending: dashed */}
                              {!isDone&&!isActive&&(
                                <div style={{position:'absolute',inset:0,background:'repeating-linear-gradient(90deg,#D1D5DB 0,#D1D5DB 4px,transparent 4px,transparent 8px)'}}/>
                              )}
                            </div>
                          );
                        })}
                        {/* Today red marker Ч’вӮ¬вҖқ in RTL, right:todayPct% places line at todayPct from project start */}
                        {todayPct!==null&&(
                          <div style={{position:'absolute',right:`${todayPct}%`,top:-1,width:2,height:12,
                            background:'#EF4444',zIndex:3,borderRadius:1,boxShadow:'0 0 0 1px rgba(255,255,255,.8)'}}/>
                        )}
                      </div>
                      {/* Phase labels row */}
                      <div style={{display:'flex',gap:1}}>
                        {segs.map(({ph,days},i)=>{
                          const w=days/totalDays*100;
                          const isDone=ph.status==='done', isActive=ph.status==='active';
                          const labelColor=isDone?'#059669':isActive?'#2563EB':'#9CA3AF';
                          return (
                            <div key={ph.id} style={{flex:w,minWidth:0,overflow:'hidden'}}>
                              <div style={{fontSize:8,fontWeight:isDone||isActive?600:400,
                                color:labelColor,whiteSpace:'nowrap',overflow:'hidden',textOverflow:'ellipsis',textAlign:'center'}}>
                                {ph.id}
                              </div>
                              <div style={{fontSize:7,color:'var(--text-3)',textAlign:'center',whiteSpace:'nowrap'}}>
                                {(isDone||isActive)?`${days}Чів„ўЧіВі`:ph.plannedMonths?`~${ph.plannedMonths}ЧівҖ”ЧіВі`:''}
                              </div>
                            </div>
                          );
                        })}
                      </div>
                      {/* Today + hours overrun note */}
                      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginTop:3}}>
                        {projStart&&<span style={{fontSize:8,color:'#EF4444',fontWeight:600}}>Ч’вҖ”ВҸ ЧівҖқЧів„ўЧівҖўЧіВқ {today.split('-').reverse().join('.')}</span>}
                        {hasHoursOverrun&&<span style={{fontSize:8,fontWeight:700,color:'#DC2626'}}>Ч’ВҡВ  ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧіГ— ЧіВ©ЧіВўЧівҖўЧіГ—</span>}
                      </div>
                    </div>
                  );
                })()}
                {/* Card footer */}
                <div style={{padding:'8px 18px 12px',borderTop:'1px solid var(--border)',display:'flex',alignItems:'center',justifyContent:'space-between',gap:8}}>
                  <div style={{display:'flex',gap:3,alignItems:'center'}}>
                    {[p.pm,...p.team].slice(0,5).map((name,i)=>{
                      const st=OFFICE_STAFF.find(s=>s.name===name);
                      const color=st?staffColor(st.id):STAFF_COLORS[i%STAFF_COLORS.length];
                      return (
                        <div key={name} title={name} style={{width:26,height:26,borderRadius:'50%',background:color,
                          display:'flex',alignItems:'center',justifyContent:'center',
                          fontSize:10,fontWeight:700,color:'#fff',border:'2px solid var(--surface)',marginLeft:-4,zIndex:5-i}}>
                          {staffInitials(name)}
                        </div>
                      );
                    })}
                  </div>
                  <div style={{display:'flex',gap:8,alignItems:'center'}}>
                    {hasBlockers&&<span style={{fontSize:11,fontWeight:700,color:'#DC2626',background:'#FEF2F2',padding:'2px 8px',borderRadius:6}}>Ч’ВҡВ  {p.blockers.length} ЧівҖ”ЧіВЎЧіВқ</span>}
                    <span style={{fontSize:11,color:'var(--text-3)'}}>ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ {p.lastUpdate.split('-').reverse().join('.')}</span>
                  </div>
                </div>
                {/* Expanded phase detail */}
                {expanded&&<ExpandedDetail p={p}/>}
                {false&&expanded&&(
                  <div style={{display:'none'}}>
                    <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5,marginBottom:12}}>ЧівӮӘЧів„ўЧіВЁЧівҖўЧіЛң ЧіВ©ЧіВңЧівҖҳЧів„ўЧіВқ</div>
                    {p.phases.map((ph,idx)=>{
                      const days=phaseDays(ph);
                      const isDone=ph.status==='done';
                      const isActive=ph.status==='active';
                      const isPending=ph.status==='pending';
                      const dotC=isDone?'#059669':isActive?'#2563EB':'#D1D5DB';
                      return (
                        <div key={ph.id} style={{display:'flex',gap:12,paddingBottom:idx<p.phases.length-1?16:0}}>
                          {/* Timeline line */}
                          <div style={{display:'flex',flexDirection:'column',alignItems:'center',flexShrink:0,width:20}}>
                            <div style={{width:18,height:18,borderRadius:'50%',border:`2px solid ${dotC}`,
                              background:isDone?dotC:isActive?'#EFF6FF':'var(--bg)',flexShrink:0,
                              display:'flex',alignItems:'center',justifyContent:'center'}}>
                              {isDone&&<span style={{fontSize:8,color:'#fff',fontWeight:900}}>Ч’ВңвҖң</span>}
                              {isActive&&<div style={{width:6,height:6,borderRadius:'50%',background:'#2563EB'}}/>}
                            </div>
                            {idx<p.phases.length-1&&<div style={{flex:1,width:2,background:isDone?'#D1FAE5':'var(--border)',marginTop:2,minHeight:12}}/>}
                          </div>
                          {/* Content */}
                          <div style={{flex:1,paddingBottom:2}}>
                            <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:3}}>
                              <span style={{fontSize:12,fontWeight:700,color:isDone?'#059669':isActive?'#2563EB':'#9CA3AF'}}>{ph.id}</span>
                              {isDone&&<span style={{fontSize:10,color:'#059669',fontWeight:600}}>ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ</span>}
                              {isActive&&<span style={{fontSize:10,color:'#2563EB',fontWeight:700,background:'rgba(37,99,235,.09)',borderRadius:4,padding:'1px 6px'}}>ЧівӮӘЧіВўЧів„ўЧіВң</span>}
                              {isPending&&<span style={{fontSize:10,color:'#9CA3AF'}}>
                                {ph.plannedMonths?`~${ph.plannedMonths} ЧівҖ”ЧівҖўЧівҖңЧіВ©Чів„ўЧіВқ`:'ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ'}
                              </span>}
                            </div>
                            {ph.note&&<div style={{fontSize:11,color:'var(--text-2)',marginBottom:4}}>{ph.note}</div>}
                            {/* Days info for active */}
                            {isActive&&days&&(
                              <div style={{marginTop:4}}>
                                <div style={{display:'flex',gap:16,marginBottom:5,flexWrap:'wrap'}}>
                                  <span style={{fontSize:11,color:'var(--text-3)'}}>
                                    ЧівҖқЧівҖ”ЧіВң: <strong style={{color:'var(--text-2)'}}>{ph.startDate.split('-').reverse().join('.')}</strong>
                                  </span>
                                  <span style={{fontSize:11,color:'var(--text-3)'}}>
                                    Чів„ўЧіВўЧівҖң: <strong style={{color:days.overdue?'#DC2626':'var(--text-2)'}}>{ph.endDate.split('-').reverse().join('.')}</strong>
                                  </span>
                                  <span style={{fontSize:11,fontWeight:700,color:days.overdue?'#DC2626':'var(--text-3)'}}>
                                    {days.overdue
                                      ?`Ч’ВҡВ  ЧівҖҳЧіВҗЧів„ўЧівҖ”ЧівҖўЧіВЁ ЧіВ©ЧіВң ${Math.abs(days.remaining)} Чів„ўЧівҖўЧіВқ`
                                      :`${days.elapsed} Чів„ўЧіВһЧів„ўЧіВқ ЧіВўЧівҖҳЧіВЁЧівҖў ЦІВ· ${days.remaining} ЧіВ ЧівҖўЧіГ—ЧіВЁЧівҖў`
                                    }
                                  </span>
                                </div>
                                <div style={{height:4,borderRadius:2,background:'var(--border)',overflow:'hidden'}}>
                                  <div style={{height:'100%',width:`${Math.min(days.pct,100)}%`,
                                    background:days.overdue?'#EF4444':days.pct>75?'#F59E0B':'#2563EB',borderRadius:2}}/>
                                </div>
                              </div>
                            )}
                            {/* Days info for done */}
                            {isDone&&days&&ph.startDate&&ph.endDate&&(
                              <div style={{fontSize:10,color:'#9CA3AF'}}>
                                {ph.startDate.split('-').reverse().join('.')} Ч’вӮ¬вҖқ {ph.endDate.split('-').reverse().join('.')}
                                {' ЦІВ· '}{days.dur} Чів„ўЧіВһЧів„ўЧіВқ
                              </div>
                            )}
                            {/* Blocker */}
                            {ph.blocker&&(
                              <div style={{display:'flex',gap:5,alignItems:'flex-start',marginTop:5,padding:'5px 8px',background:'#FEF2F2',borderRadius:5,fontSize:11,color:'#DC2626'}}>
                                <span>Ч’ВҡВ </span><span>{ph.blocker}</span>
                              </div>
                            )}
                          </div>
                        </div>
                      );
                    })}
                    {/* General blockers */}
                    {p.blockers.filter(b=>!p.phases.some(ph=>ph.blocker===b)).length>0&&(
                      <div style={{marginTop:10,padding:'8px 12px',background:'#FEF2F2',borderRadius:8}}>
                        <div style={{fontSize:11,fontWeight:700,color:'#DC2626',marginBottom:4}}>ЧівҖ”ЧіВЎЧіВһЧів„ўЧіВқ ЧіВ ЧівҖўЧіВЎЧівӮӘЧів„ўЧіВқ</div>
                        {p.blockers.filter(b=>!p.phases.some(ph=>ph.blocker===b)).map((b,i)=>(
                          <div key={i} style={{fontSize:11,color:'#DC2626'}}>Ч’ВҡВ  {b}</div>
                        ))}
                      </div>
                    )}
                    {/* Hours breakdown table */}
                    {p.hours&&(()=>{
                      const tot=hoursTotal(p.hours);
                      const discs=DISC_ORDER.filter(d=>p.hours[d]?.budget>0||p.hours[d]?.actual>0);
                      return (
                        <div style={{marginTop:14,paddingTop:12,borderTop:'1px solid var(--border)'}}>
                          <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:8}}>
                            <span style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.4}}>ЧіГ—ЧіВ§ЧіВҰЧів„ўЧівҖҳ ЧіВ©ЧіВўЧівҖўЧіГ— ЧіВһЧівҖўЧіВң ЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў</span>
                            <span style={{fontSize:10,color:'var(--text-3)'}}>* ЧіВ ЧіГ—ЧівҖўЧіВ Чів„ў ЧівҖқЧівҖңЧівҖҷЧіВһЧівҖқ Ч’вӮ¬вҖқ Чів„ўЧіВўЧівҖўЧівҖңЧівҖәЧіВҹ ЧіВһЧівҖңЧів„ўЧівҖўЧівҖўЧівҖ” ЧіВ©ЧіВўЧівҖўЧіГ—</span>
                          </div>
                          <table style={{width:'100%',borderCollapse:'collapse',fontSize:11}}>
                            <thead>
                              <tr style={{borderBottom:'1px solid var(--border)'}}>
                                {['ЧіВһЧіВЎЧіВңЧівҖўЧіВң','ЧіГ—ЧівҖўЧіВ§ЧіВҰЧівҖҳ','ЧівҖҳЧівҖўЧіВҰЧіВў','ЧіВ ЧівҖўЧіГ—ЧіВЁ','%','ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ'].map(h=>(
                                  <th key={h} style={{padding:'4px 6px',textAlign:'right',fontWeight:700,color:'var(--text-3)',fontSize:10}}>{h}</th>
                                ))}
                              </tr>
                            </thead>
                            <tbody>
                              {discs.map(d=>{
                                const h=p.hours[d]; const st=hoursStatus(h.budget,h.actual);
                                const cfg=HOURS_STATUS_CFG[st];
                                const pct=h.budget>0?Math.round(h.actual/h.budget*100):0;
                                const rem=Math.max(h.budget-h.actual,0);
                                return (
                                  <tr key={d} style={{borderBottom:'1px solid var(--border)',background:st==='overrun'?'#FFF5F5':st==='warning'?'#FFFDF0':''}}>
                                    <td style={{padding:'5px 6px'}}>
                                      <div style={{display:'flex',alignItems:'center',gap:5}}>
                                        <span style={{width:8,height:8,borderRadius:2,background:DISC_COLORS[d],display:'inline-block',flexShrink:0}}/>
                                        <span style={{fontWeight:600,color:'var(--text)'}}>{d}</span>
                                        <span style={{color:'var(--text-3)',fontSize:10}}>{DISC_LABELS[d]}</span>
                                      </div>
                                    </td>
                                    <td style={{padding:'5px 6px',color:'var(--text-2)'}}>{h.budget.toLocaleString()}</td>
                                    <td style={{padding:'5px 6px',fontWeight:600,color:st==='overrun'?'#DC2626':st==='warning'?'#D97706':'var(--text)'}}>{h.actual.toLocaleString()}</td>
                                    <td style={{padding:'5px 6px',color:'var(--text-3)'}}>{st==='overrun'?<span style={{color:'#DC2626',fontWeight:700}}>+{(h.actual-h.budget).toLocaleString()} Ч’ВҡВ </span>:rem.toLocaleString()}</td>
                                    <td style={{padding:'5px 6px'}}>
                                      <div style={{display:'flex',alignItems:'center',gap:5}}>
                                        <div style={{width:40,height:4,borderRadius:2,background:'var(--border)',overflow:'hidden'}}>
                                          <div style={{height:'100%',width:`${Math.min(pct,100)}%`,background:cfg.color}}/>
                                        </div>
                                        <span style={{color:cfg.color,fontWeight:600}}>{pct}%</span>
                                      </div>
                                    </td>
                                    <td style={{padding:'5px 6px'}}>
                                      <span style={{fontSize:10,fontWeight:600,color:cfg.color,background:cfg.bg,padding:'1px 6px',borderRadius:4}}>{cfg.label}</span>
                                    </td>
                                  </tr>
                                );
                              })}
                              <tr style={{borderTop:'2px solid var(--border)',background:'var(--bg)'}}>
                                <td style={{padding:'5px 6px',fontWeight:700,color:'var(--text)',fontSize:11}}>ЧіВЎЧівҖқЧіВҙЧівҖә</td>
                                <td style={{padding:'5px 6px',fontWeight:700}}>{tot.budget.toLocaleString()}</td>
                                <td style={{padding:'5px 6px',fontWeight:700,color:tot.overrun?'#DC2626':'var(--text)'}}>{tot.actual.toLocaleString()}</td>
                                <td style={{padding:'5px 6px',fontWeight:700,color:tot.overrun?'#DC2626':'var(--text-3)'}}>
                                  {tot.overrun?<span>+{(tot.actual-tot.budget).toLocaleString()} Ч’ВҡВ </span>:(tot.budget-tot.actual).toLocaleString()}
                                </td>
                                <td style={{padding:'5px 6px',fontWeight:700,color:tot.overrun?'#DC2626':tot.pct>85?'#D97706':'#059669'}}>{tot.pct}%</td>
                                <td style={{padding:'5px 6px'}}>
                                  <span style={{fontSize:10,fontWeight:700,
                                    color:tot.overrun?'#DC2626':tot.pct>85?'#D97706':'#059669',
                                    background:tot.overrun?'#FEF2F2':tot.pct>85?'#FFFBEB':'#ECFDF5',
                                    padding:'1px 6px',borderRadius:4}}>
                                    {tot.overrun?'ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧівҖқ':tot.pct>85?'ЧіВҗЧівҖ“ЧівҖқЧіВЁЧівҖқ':'ЧіГ—ЧіВ§Чів„ўЧіВҹ'}
                                  </span>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </div>
                      );
                    })()}
                    <div style={{display:'flex',gap:16,marginTop:12,paddingTop:10,borderTop:'1px solid var(--border)',flexWrap:'wrap'}}>
                      <div style={{fontSize:11,color:'var(--text-3)'}}>ЧіВһЧіВ ЧівҖқЧіВң: <strong style={{color:'var(--text)'}}>{p.pm}</strong></div>
                      <div style={{fontSize:11,color:'var(--text-3)'}}>ЧіГ—ЧіВ§ЧіВҰЧів„ўЧівҖҳ: <strong style={{color:'var(--text)'}}>{p.budget}</strong></div>
                    </div>
                  </div>
                )}
              </div>
            );
          })}
        </div>
      )}

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Table view Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      {view==='table' && (
        <div style={{background:'var(--surface)',borderRadius:14,border:'1px solid var(--border)',overflow:'auto'}}>
          <table style={{width:'100%',borderCollapse:'collapse',fontSize:12}}>
            <thead>
              <tr style={{borderBottom:'2px solid var(--border)'}}>
                {['ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң','ЧіВһЧіВ ЧівҖқЧіВң','ЧіВҰЧівҖўЧівҖўЧіГ—','ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВ Чів„ў','ЧівҖқЧів„ўЧіГ—ЧіВЁ','ЧіВһЧівҖәЧіВЁЧівҖ“','ЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў','ЧіВ©ЧіВўЧівҖўЧіГ—','ЧівҖ”ЧіВЎЧіВһЧів„ўЧіВқ','ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ'].map(h=>(
                  <th key={h} style={{padding:'10px 14px',textAlign:'right',fontWeight:700,color:'var(--text-3)',fontSize:10,textTransform:'uppercase',letterSpacing:.4,whiteSpace:'nowrap'}}>{h}</th>
                ))}
              </tr>
            </thead>
            <tbody>
              {filtered.map((p,i)=>{
                const hasBlockers=p.blockers.length>0;
                const doneCount=p.phases.filter(ph=>ph.status==='done').length;
                return (
                  <React.Fragment key={p.id}>
                    <tr style={{borderBottom:'1px solid var(--border)',background:i%2===0?'':'rgba(0,0,0,.013)',cursor:'pointer'}}
                      onClick={()=>setExpandedId(expandedId===p.id?null:p.id)}>
                      <td style={{padding:'10px 14px',whiteSpace:'nowrap'}}>
                        <div style={{display:'flex',alignItems:'center',gap:6}}>
                          <PriorityDot priority={p.priority}/>
                          <span style={{fontWeight:600,color:'var(--text)'}}>{p.name}</span>
                        </div>
                        <div style={{fontSize:10,color:'var(--text-3)'}}>{p.type} ЦІВ· {p.area.toLocaleString()} ЧіВһ"ЧіВЁ</div>
                      </td>
                      <td style={{padding:'10px 14px',color:'var(--text)',whiteSpace:'nowrap',fontSize:11}}>{p.pm}</td>
                      <td style={{padding:'10px 8px'}}>
                        <div style={{display:'flex',gap:2}}>
                          {[p.pm,...p.team].slice(0,4).map((name,ti)=>{
                            const st=OFFICE_STAFF.find(s=>s.name===name);
                            const color=st?staffColor(st.id):STAFF_COLORS[ti%STAFF_COLORS.length];
                            return <div key={name} title={name} style={{width:22,height:22,borderRadius:'50%',background:color,display:'flex',alignItems:'center',justifyContent:'center',fontSize:9,fontWeight:700,color:'#fff',flexShrink:0}}>{staffInitials(name)}</div>;
                          })}
                        </div>
                      </td>
                      {PORTFOLIO_PHASES.map(phId=>{
                        const ph=p.phases.find(x=>x.id===phId);
                        if(!ph) return <td key={phId} style={{padding:'10px 14px'}}><span style={{color:'var(--border)'}}>Ч’вӮ¬вҖқ</span></td>;
                        const days=phaseDays(ph);
                        const isDone=ph.status==='done';
                        const isActive=ph.status==='active';
                        const dotC=isDone?'#059669':isActive?'#2563EB':'#D1D5DB';
                        return (
                          <td key={phId} style={{padding:'8px 14px',minWidth:110}}>
                            <div style={{display:'flex',alignItems:'center',gap:5}}>
                              <div style={{width:14,height:14,borderRadius:'50%',border:`2px solid ${dotC}`,background:isDone?dotC:isActive?'#EFF6FF':'var(--bg)',
                                display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0}}>
                                {isDone&&<span style={{fontSize:7,color:'#fff',fontWeight:900}}>Ч’ВңвҖң</span>}
                                {isActive&&<div style={{width:5,height:5,borderRadius:'50%',background:'#2563EB'}}/>}
                              </div>
                              <div>
                                <div style={{fontSize:10,fontWeight:600,color:isDone?'#059669':isActive?'#2563EB':'#9CA3AF'}}>
                                  {isDone?'ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ':isActive?'ЧівӮӘЧіВўЧів„ўЧіВң':ph.plannedMonths?`~${ph.plannedMonths}m`:'ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ'}
                                </div>
                                {isActive&&days&&(
                                  <div style={{fontSize:9,color:days.overdue?'#DC2626':'#6B7280'}}>
                                    {days.overdue?`Ч’ВҡВ  ${Math.abs(days.remaining)}Чів„ўЧіВі ЧіВҗЧів„ўЧівҖ”ЧівҖўЧіВЁ`:`${days.remaining}Чів„ўЧіВі ЧіВ ЧівҖўЧіГ—ЧіВЁЧівҖў`}
                                  </div>
                                )}
                              </div>
                            </div>
                            {isActive&&days&&(
                              <div style={{marginTop:4,height:3,borderRadius:2,background:'var(--border)',overflow:'hidden'}}>
                                <div style={{height:'100%',width:`${Math.min(days.pct,100)}%`,background:days.overdue?'#EF4444':days.pct>75?'#F59E0B':'#2563EB'}}/>
                              </div>
                            )}
                          </td>
                        );
                      })}
                      {/* Hours summary cell */}
                      {(()=>{
                        const tot=hoursTotal(p.hours||{});
                        const overrunDiscs=DISC_ORDER.filter(d=>p.hours?.[d]&&hoursStatus(p.hours[d].budget,p.hours[d].actual)==='overrun');
                        return (
                          <td style={{padding:'8px 14px',minWidth:120}}>
                            {tot.budget>0?(
                              <>
                                <div style={{display:'flex',justifyContent:'space-between',marginBottom:3}}>
                                  <span style={{fontSize:10,color:'var(--text-3)'}}>{tot.actual.toLocaleString()} / {tot.budget.toLocaleString()}</span>
                                  <span style={{fontSize:10,fontWeight:700,color:tot.overrun?'#DC2626':tot.pct>85?'#D97706':'#059669'}}>{tot.pct}%</span>
                                </div>
                                <div style={{height:4,borderRadius:2,background:'var(--border)',overflow:'hidden',marginBottom:2}}>
                                  <div style={{height:'100%',width:`${Math.min(tot.pct,100)}%`,background:tot.overrun?'#EF4444':tot.pct>85?'#F59E0B':'#059669'}}/>
                                </div>
                                {overrunDiscs.length>0&&<div style={{fontSize:9,color:'#DC2626',fontWeight:700}}>Ч’ВҡВ  {overrunDiscs.join(' ')}</div>}
                              </>
                            ):<span style={{color:'var(--text-3)',fontSize:11}}>Ч’вӮ¬вҖқ</span>}
                          </td>
                        );
                      })()}
                      <td style={{padding:'10px 14px'}}>
                        {hasBlockers
                          ? <span style={{fontSize:11,fontWeight:700,color:'#DC2626',background:'#FEF2F2',padding:'2px 8px',borderRadius:5,whiteSpace:'nowrap'}}>Ч’ВҡВ  {p.blockers.length}</span>
                          : <span style={{fontSize:11,color:'#059669'}}>Ч’ВңвҖң</span>}
                      </td>
                      <td style={{padding:'10px 14px',color:'var(--text-3)',whiteSpace:'nowrap',fontSize:11}}>{p.lastUpdate.split('-').reverse().join('.')}</td>
                    </tr>
                    {expandedId===p.id&&(
                      <tr style={{background:'#F8FAFF'}}>
                        <td colSpan={10} style={{padding:0}}>
                          <ExpandedDetail p={p}/>
                        </td>
                      </tr>
                    )}
                  </React.Fragment>
                );
              })}
            </tbody>
          </table>
        </div>
      )}
    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   My Tasks View
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function MyTasksView({data, save}) {
  const today = todayISO();

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ collect all tasks from all sheets Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const allTasks = React.useMemo(()=>{
    const sheets = (data.sheets||[]).filter(s=>s.type==='list');
    const tasks = [];
    sheets.forEach(s=>{
      (s.tasks||[]).forEach(t=>{
        if(t.statusId==='C'||t.done) return; /* skip completed */
        tasks.push({...t, _sheet:s.name, _proj:'LDLI', _projColor:'#2563EB'});
      });
    });
    /* simulated tasks from other projects */
    const sim = [
      {id:'s1',title:'ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ ЧіГ—ЧівҖәЧіВ Чів„ўЧіГ— ЧіВ§ЧівҖўЧіВһЧівҖқ ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВ ЧівҖқ',statusId:'S',priority:'high',discipline:'ARCH',dueDate:'2026-06-20',_sheet:'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ',_proj:'YN22',_projColor:'#7C3AED'},
      {id:'s2',title:'Чів„ўЧіВ©Чів„ўЧівҖҳЧіГ— ЧівҖўЧіВўЧівҖңЧівҖқ',statusId:'N',priority:'medium',discipline:'PM',dueDate:'2026-06-15',_sheet:'ЧіВ Чів„ўЧівҖқЧівҖўЧіВң',_proj:'YN22',_projColor:'#7C3AED'},
      {id:'s3',title:'ЧівҖқЧівҖҷЧіВ©ЧіГ— ЧіГ—ЧівҖўЧівҖәЧіВ Чів„ўЧівҖўЧіГ— ЧіВңЧіВЁЧіВ©ЧівҖўЧіГ—',statusId:'P',priority:'high',discipline:'ARCH',dueDate:'2026-07-01',_sheet:'ЧіВЁЧів„ўЧіВ©ЧівҖўЧів„ў',_proj:'RGCC',_projColor:'#059669'},
      {id:'s4',title:'ЧіГ—Чів„ўЧіВҗЧівҖўЧіВқ Чів„ўЧівҖўЧіВўЧіВҘ ЧіВ§ЧівҖўЧіВ ЧіВЎЧіЛңЧіВЁЧівҖўЧіВ§ЧіВҰЧів„ўЧівҖқ',statusId:'N',priority:'low',discipline:'STRC',dueDate:'2026-06-30',_sheet:'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ',_proj:'RGCC',_projColor:'#059669'},
      {id:'s5',title:'ЧівҖҳЧівҖңЧів„ўЧіВ§ЧіГ— ЧіГ—ЧівҖҳ"ЧіВў',statusId:'S',priority:'high',discipline:'PM',dueDate:'2026-06-10',_sheet:'ЧіВЁЧів„ўЧіВ©ЧівҖўЧів„ў',_proj:'NPTN',_projColor:'#F97316'},
      {id:'s6',title:'ЧівҖқЧівҖәЧіВ ЧіГ— ЧівҖ”ЧівҖўЧівҖўЧіГ— ЧівҖңЧіВўЧіГ— ЧіГ—ЧіВ ЧівҖўЧіВўЧівҖқ',statusId:'N',priority:'medium',discipline:'TRAF',dueDate:'2026-07-15',_sheet:'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ',_proj:'NPTN',_projColor:'#F97316'},
      {id:'s7',title:'ЧіВҗЧів„ўЧіВ©ЧівҖўЧіВЁ ЧівҖқЧів„ўЧіГ—ЧіВЁ ЧівҖҳЧіВ Чів„ўЧів„ўЧівҖқ',statusId:'P',priority:'high',discipline:'PM',dueDate:'2026-06-25',_sheet:'ЧіВЁЧів„ўЧіВ©ЧівҖўЧів„ў',_proj:'FLDM',_projColor:'#EC4899'},
    ];
    return [...tasks, ...sim];
  }, [data]);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ filter state Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [fProjects,  setFProjects]  = useState([]);
  const [fStatuses,  setFStatuses]  = useState([]);
  const [fPriorities,setFPriorities]= useState([]);
  const [fDiscips,   setFDiscips]   = useState([]);
  const [fDateRange, setFDateRange] = useState('');
  const [fEventDays, setFEventDays] = useState('');
  const [filterOpen, setFilterOpen] = useState(false);
  const [sortOpen,   setSortOpen]   = useState(false);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ sort state: [{field, dir}] Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [sorts, setSorts] = useState([{field:'dueDate',dir:'asc'}]);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ group-by state Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [groupBy, setGroupBy] = useState('');
  const [showGroupMenu, setShowGroupMenu] = useState(false);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ views state Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const myViews = data.myTasksViews || [];
  const [activeViewId, setActiveViewId] = useState(null);
  const [showViewsPanel, setShowViewsPanel] = useState(false);
  const [savingView, setSavingView] = useState(false);
  const [viewNameDraft, setViewNameDraft] = useState('');
  const [renamingId, setRenamingId] = useState(null);
  const [renameDraft, setRenameDraft] = useState('');
  const viewsRef = useRef(null);

  useEffect(()=>{
    if(!showViewsPanel) return;
    const h=e=>{if(viewsRef.current&&!viewsRef.current.contains(e.target))setShowViewsPanel(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showViewsPanel]);

  const saveView = name => {
    const nv={id:uid(),name,sorts,groupBy,
      fProjects,fStatuses,fPriorities,fDiscips,fDateRange,fEventDays};
    if(save) save({...data, myTasksViews:[...myViews, nv]});
    setActiveViewId(nv.id); setSavingView(false); setViewNameDraft('');
  };
  const loadView = viewId => {
    setActiveViewId(viewId);
    if(!viewId) return;
    const v=myViews.find(x=>x.id===viewId);
    if(!v) return;
    if(v.sorts)      setSorts(v.sorts);
    if(v.groupBy!==undefined) setGroupBy(v.groupBy);
    setFProjects(v.fProjects||[]);setFStatuses(v.fStatuses||[]);
    setFPriorities(v.fPriorities||[]);setFDiscips(v.fDiscips||[]);
    setFDateRange(v.fDateRange||'');setFEventDays(v.fEventDays||'');
  };
  const deleteView = viewId => {
    if(save) save({...data, myTasksViews:myViews.filter(v=>v.id!==viewId)});
    if(activeViewId===viewId) setActiveViewId(null);
  };
  const renameView = (viewId, name) => {
    if(save) save({...data, myTasksViews:myViews.map(v=>v.id===viewId?{...v,name}:v)});
  };

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ filter logic Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const filtered = React.useMemo(()=>{
    let t = [...allTasks];
    if(fProjects.length)   t=t.filter(x=>fProjects.includes(x._proj));
    if(fStatuses.length)   t=t.filter(x=>fStatuses.includes(x.statusId));
    if(fPriorities.length) t=t.filter(x=>fPriorities.includes(x.priority));
    if(fDiscips.length)    t=t.filter(x=>fDiscips.includes(x.discipline));
    if(fDateRange) {
      const nextWeek = addDays(today,7), nextMonth=addDays(today,30);
      t=t.filter(x=>{
        if(!x.dueDate) return false;
        if(fDateRange==='overdue')     return x.dueDate < today;
        if(fDateRange==='this_week')   return x.dueDate>=today && x.dueDate<=nextWeek;
        if(fDateRange==='this_month')  return x.dueDate>=today && x.dueDate<=nextMonth;
        if(fDateRange==='next_month')  return x.dueDate>nextMonth && x.dueDate<=addDays(today,60);
        return true;
      });
    }
    if(fEventDays) {
      const minDays = parseInt(fEventDays)||0;
      t=t.filter(x=>{
        const evts = x.processEvents||[];
        if(!evts.length) return false;
        return evts.some(e=>e.date && daysBetween(e.date,today)>=minDays);
      });
    }
    return t;
  }, [allTasks, fProjects, fStatuses, fPriorities, fDiscips, fDateRange, fEventDays]);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ sort logic Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const sorted = React.useMemo(()=>{
    const t = [...filtered];
    t.sort((a,b)=>{
      for(const {field,dir} of sorts) {
        const m = dir==='asc'?1:-1;
        const av = a[field]||'', bv = b[field]||'';
        if(av<bv) return -1*m;
        if(av>bv) return 1*m;
      }
      return 0;
    });
    return t;
  }, [filtered, sorts]);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ group-by config (defined after PROJS/STATUSES/PRIOS below) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const GROUP_BY_OPTS = [
    {field:'',       label:'ЧіВңЧіВңЧіВҗ ЧіВ§Чів„ўЧівҖҳЧівҖўЧіВҘ'},
    {field:'_proj',  label:'ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң'},
    {field:'statusId',label:'ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ'},
    {field:'priority',label:'ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—'},
    {field:'discipline',label:'ЧіГ—ЧівҖ”ЧівҖўЧіВқ'},
  ];

  /* grouped tasks Ч’вӮ¬вҖқ built after PROJS/STATUSES/PRIOS are defined below */
  const groupedRows_raw = React.useMemo(()=>{
    if(!groupBy) return null; // sentinel: group after helpers
    const map = new Map();
    sorted.forEach(t=>{
      const k = t[groupBy]||'';
      if(!map.has(k)) map.set(k,[]);
      map.get(k).push(t);
    });
    return [...map.entries()];
  }, [sorted, groupBy]);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ helpers Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  function addDays(iso,n){const d=new Date(iso);d.setDate(d.getDate()+n);return d.toISOString().slice(0,10);}
  const toggleArr=(arr,setArr,v)=>setArr(arr.includes(v)?arr.filter(x=>x!==v):[...arr,v]);
  const toggleSort=(field)=>{
    setSorts(prev=>{
      const ex=prev.find(s=>s.field===field);
      if(ex) return prev.map(s=>s.field===field?{...s,dir:s.dir==='asc'?'desc':'asc'}:s);
      return [{field,dir:'asc'},...prev.slice(0,2)];
    });
  };
  const sortDir=(field)=>sorts.find(s=>s.field===field)?.dir;
  const sortRank=(field)=>{const i=sorts.findIndex(s=>s.field===field);return i>=0?i+1:null;};

  const PROJS     = MY_PROJECTS;
  const STATUSES  = [{id:'N',label:'ЧіВңЧіВҗ ЧівҖқЧіГ—ЧівҖ”Чів„ўЧіВң',color:'#8B949E'},{id:'P',label:'ЧівҖҳЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ',color:'#2563EB'},{id:'S',label:'ЧіГ—ЧіВ§ЧівҖўЧіВў',color:'#EF4444'}];
  const PRIOS     = [{id:'high',label:'ЧівҖҷЧівҖҳЧівҖўЧівҖқЧівҖқ',color:'#EF4444'},{id:'medium',label:'ЧівҖҳЧів„ўЧіВ ЧівҖўЧіВ Чів„ўЧіГ—',color:'#F59E0B'},{id:'low',label:'ЧіВ ЧіВһЧівҖўЧівҖәЧівҖқ',color:'#3B82F6'}];

  const getGroupLabel = (field, val) => {
    if(field==='_proj')   return PROJS.find(p=>p.code===val)?.name || val || 'ЧіВңЧіВңЧіВҗ ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң';
    if(field==='statusId')return STATUSES.find(s=>s.id===val)?.label || val || 'ЧіВңЧіВңЧіВҗ ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ';
    if(field==='priority')return PRIOS.find(p=>p.id===val)?.label || val || 'ЧіВңЧіВңЧіВҗ ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—';
    return val || 'ЧіВңЧіВңЧіВҗ';
  };
  const getGroupColor = (field, val) => {
    if(field==='_proj')   return PROJS.find(p=>p.code===val)?.color || '#6B7280';
    if(field==='statusId')return STATUSES.find(s=>s.id===val)?.color || '#6B7280';
    if(field==='priority')return PRIOS.find(p=>p.id===val)?.color || '#6B7280';
    return '#6B7280';
  };
  const groupedRows = groupedRows_raw
    ? groupedRows_raw.map(([k,tasks])=>({key:k, label:getGroupLabel(groupBy,k), color:getGroupColor(groupBy,k), tasks}))
    : [{key:'__all', label:null, color:null, tasks:sorted}];
  const activeGroupLabel = GROUP_BY_OPTS.find(o=>o.field===groupBy)?.label || '';
  const DISCS     = ['ARCH','PM','ENVI','STRC','TRAF','ELEC','MECH','TNDR'];
  const DATE_RANGES= [{id:'overdue',label:'ЧівҖҳЧіВҗЧів„ўЧівҖ”ЧівҖўЧіВЁ'},{id:'this_week',label:'ЧівҖқЧіВ©ЧівҖҳЧівҖўЧіВў ЧівҖқЧіВ§ЧіВЁЧівҖўЧівҖҳ'},{id:'this_month',label:'ЧівҖқЧівҖ”ЧівҖўЧівҖңЧіВ© ЧівҖқЧіВ§ЧіВЁЧівҖўЧівҖҳ'},{id:'next_month',label:'ЧівҖ”ЧівҖўЧівҖңЧіВ© ЧівҖқЧівҖҳЧіВҗ'}];
  const SORT_FIELDS= [{field:'dueDate',label:'ЧіГ—ЧіВҗЧіВЁЧів„ўЧіВҡ Чів„ўЧіВўЧівҖң'},{field:'priority',label:'ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—'},{field:'statusId',label:'ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ'},{field:'_proj',label:'ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң'},{field:'discipline',label:'ЧіГ—ЧівҖ”ЧівҖўЧіВқ'}];

  const hasFilters = fProjects.length||fStatuses.length||fPriorities.length||fDiscips.length||fDateRange||fEventDays;
  const clearAll   = ()=>{setFProjects([]);setFStatuses([]);setFPriorities([]);setFDiscips([]);setFDateRange('');setFEventDays('');};

  /* active filter chips for display */
  const activeChips = [
    ...fProjects.map(v=>({key:'proj:'+v,  label:v,           onRemove:()=>toggleArr(fProjects,setFProjects,v)})),
    ...fStatuses.map(v=>({key:'st:'+v,    label:STATUSES.find(s=>s.id===v)?.label||v, onRemove:()=>toggleArr(fStatuses,setFStatuses,v)})),
    ...fPriorities.map(v=>({key:'pr:'+v,  label:PRIOS.find(p=>p.id===v)?.label||v,   onRemove:()=>toggleArr(fPriorities,setFPriorities,v)})),
    ...fDiscips.map(v=>({key:'d:'+v,      label:v,           onRemove:()=>toggleArr(fDiscips,setFDiscips,v)})),
    ...(fDateRange?[{key:'date',label:DATE_RANGES.find(r=>r.id===fDateRange)?.label||'',onRemove:()=>setFDateRange('')}]:[]),
    ...(fEventDays?[{key:'ev',label:`ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ Ч’вҖ°ВҘ${fEventDays}Чів„ў`,onRemove:()=>setFEventDays('')}]:[]),
  ];

  /* checkbox row helper */
  const ChkRow=({label,checked,color,onChange})=>(
    <label style={{display:'flex',alignItems:'center',gap:10,padding:'8px 0',cursor:'pointer',
      borderBottom:'1px solid var(--border)'}}>
      <input type="checkbox" checked={checked} onChange={onChange}
        style={{width:15,height:15,accentColor:color||'var(--accent)',cursor:'pointer',flexShrink:0}}/>
      {color&&<span style={{width:8,height:8,borderRadius:'50%',background:color,flexShrink:0}}/>}
      <span style={{fontSize:13,color:'var(--text)',fontWeight:500}}>{label}</span>
    </label>
  );

  /* filter panel section */
  const FSection=({title,children})=>(
    <div style={{marginBottom:16}}>
      <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',
        letterSpacing:.5,marginBottom:6}}>{title}</div>
      {children}
    </div>
  );

  return (
    <div style={{flex:1,display:'flex',flexDirection:'column',overflow:'hidden',background:'var(--bg)'}}
      onClick={()=>{setFilterOpen(false);setSortOpen(false);setShowGroupMenu(false);setShowViewsPanel(false);}}>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ toolbar Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div style={{background:'var(--surface)',borderBottom:'1px solid var(--border)',
        padding:'10px 20px',flexShrink:0,display:'flex',alignItems:'center',gap:10,flexWrap:'wrap'}}>
        <h2 style={{fontSize:15,fontWeight:700,color:'var(--text)',marginLeft:4}}>ЧівҖқЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ— ЧіВ©ЧіВңЧів„ў</h2>
        <span style={{fontSize:11,color:'var(--text-3)',background:'var(--bg)',
          border:'1px solid var(--border)',borderRadius:10,padding:'1px 8px'}}>
          {sorted.length} ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—
        </span>

        {/* Views button */}
        <div ref={viewsRef} style={{position:'relative'}} onClick={e=>e.stopPropagation()}>
          <button onClick={()=>{setShowViewsPanel(o=>!o);setFilterOpen(false);setSortOpen(false);setShowGroupMenu(false);}}
            className="btn-tb"
            style={{border:`1px solid ${activeViewId?'var(--accent)':'var(--border)'}`,
              background:activeViewId?'rgba(37,99,235,.07)':'var(--surface)',
              color:activeViewId?'var(--accent)':'var(--text-2)'}}>
            Ч’ЛңВ° ЧіВһЧівҖҳЧіЛңЧів„ўЧіВқ{myViews.length>0&&<span style={{marginRight:3,fontSize:10,background:'var(--accent)',color:'#fff',borderRadius:'50%',width:15,height:15,display:'inline-flex',alignItems:'center',justifyContent:'center'}}>{myViews.length}</span>}
          </button>
          {showViewsPanel&&(
            <div style={{position:'absolute',top:'calc(100% + 6px)',right:0,width:220,
              background:'var(--surface)',border:'1px solid var(--border)',borderRadius:10,
              boxShadow:'0 8px 24px rgba(0,0,0,.14)',zIndex:600,overflow:'hidden'}}>
              <div style={{padding:'8px 12px',fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5}}>ЧіВһЧівҖҳЧіЛңЧів„ўЧіВқ ЧіВ©ЧіВһЧівҖўЧіВЁЧів„ўЧіВқ</div>
              {/* Default */}
              <div onClick={()=>{loadView(null);setShowViewsPanel(false);}}
                style={{display:'flex',alignItems:'center',gap:8,padding:'8px 12px',cursor:'pointer',
                  background:!activeViewId?'rgba(37,99,235,.07)':'',fontSize:12,color:!activeViewId?'var(--accent)':'var(--text)'}}
                onMouseEnter={e=>e.currentTarget.style.background='var(--bg)'}
                onMouseLeave={e=>e.currentTarget.style.background=!activeViewId?'rgba(37,99,235,.07)':''}>
                {!activeViewId&&<span style={{color:'var(--accent)'}}>Ч’ВңвҖң</span>}
                <span>ЧівҖҳЧіВЁЧів„ўЧіВЁЧіГ— ЧіВһЧівҖ”ЧівҖңЧіВң</span>
              </div>
              {myViews.map(v=>(
                <div key={v.id} style={{display:'flex',alignItems:'center',gap:6,padding:'7px 12px',
                  background:activeViewId===v.id?'rgba(37,99,235,.07)':'',cursor:'pointer'}}
                  onMouseEnter={e=>e.currentTarget.style.background='var(--bg)'}
                  onMouseLeave={e=>e.currentTarget.style.background=activeViewId===v.id?'rgba(37,99,235,.07)':''}>
                  {renamingId===v.id
                    ? <input autoFocus value={renameDraft} onChange={e=>setRenameDraft(e.target.value)}
                        onKeyDown={e=>{if(e.key==='Enter'){renameView(v.id,renameDraft);setRenamingId(null);}if(e.key==='Escape')setRenamingId(null);}}
                        onBlur={()=>{renameView(v.id,renameDraft);setRenamingId(null);}}
                        style={{flex:1,border:'1px solid var(--accent)',borderRadius:4,padding:'2px 6px',fontSize:12,fontFamily:'inherit',outline:'none'}}/>
                    : <span style={{flex:1,fontSize:12,color:activeViewId===v.id?'var(--accent)':'var(--text)',fontWeight:activeViewId===v.id?600:400}}
                        onClick={()=>{loadView(v.id);setShowViewsPanel(false);}}>{v.name}</span>
                  }
                  <button title="ЧіВ©ЧіВ ЧівҖқ ЧіВ©ЧіВқ" onClick={e=>{e.stopPropagation();setRenamingId(v.id);setRenameDraft(v.name);}}
                    style={{background:'none',border:'none',cursor:'pointer',color:'var(--text-3)',fontSize:11,padding:'1px 3px'}}>Ч’ВңВҸ</button>
                  <button title="ЧіВһЧівҖ”ЧіВ§" onClick={e=>{e.stopPropagation();deleteView(v.id);}}
                    style={{background:'none',border:'none',cursor:'pointer',color:'var(--text-3)',fontSize:12,padding:'1px 3px'}}>ЦівҖ”</button>
                </div>
              ))}
              <div style={{borderTop:'1px solid var(--border)',padding:'6px 10px'}}>
                {savingView
                  ? <div style={{display:'flex',gap:6}}>
                      <input autoFocus value={viewNameDraft} onChange={e=>setViewNameDraft(e.target.value)}
                        onKeyDown={e=>{if(e.key==='Enter'&&viewNameDraft.trim())saveView(viewNameDraft.trim());if(e.key==='Escape')setSavingView(false);}}
                        placeholder="ЧіВ©ЧіВқ ЧівҖқЧіВһЧівҖҳЧіЛң..." style={{flex:1,border:'1px solid var(--border)',borderRadius:6,padding:'4px 8px',fontSize:12,fontFamily:'inherit',outline:'none',background:'var(--bg)',color:'var(--text)'}}/>
                      <button onClick={()=>{if(viewNameDraft.trim())saveView(viewNameDraft.trim());}}
                        style={{padding:'4px 10px',background:'var(--accent)',color:'#fff',border:'none',borderRadius:6,fontSize:12,cursor:'pointer',fontFamily:'inherit'}}>ЧіВ©ЧіВһЧівҖўЧіВЁ</button>
                    </div>
                  : <div onClick={()=>setSavingView(true)}
                      style={{display:'flex',alignItems:'center',gap:6,padding:'4px 2px',cursor:'pointer',fontSize:12,color:'var(--accent)',fontWeight:600}}
                      onMouseEnter={e=>e.currentTarget.style.opacity='.7'}
                      onMouseLeave={e=>e.currentTarget.style.opacity='1'}>
                      + ЧіВ©ЧіВһЧівҖўЧіВЁ ЧіВһЧівҖҳЧіЛң ЧіВ ЧівҖўЧівҖәЧівҖ”Чів„ў
                    </div>
                }
              </div>
            </div>
          )}
        </div>

        {/* Filter button */}
        <div style={{position:'relative'}} onClick={e=>e.stopPropagation()}>
          <button onClick={()=>{setFilterOpen(o=>!o);setSortOpen(false);}}
            style={{display:'flex',alignItems:'center',gap:6,padding:'5px 12px',borderRadius:6,
              border:`1px solid ${hasFilters?'var(--accent)':'var(--border)'}`,
              background:hasFilters?'rgba(37,99,235,.07)':'var(--surface)',
              color:hasFilters?'var(--accent)':'var(--text-2)',fontSize:12,fontWeight:600,
              cursor:'pointer',fontFamily:'inherit',transition:'all .12s'}}>
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"><path d="M2 4h12M4 8h8M6 12h4"/></svg>
            ЧіВЎЧів„ўЧіВ ЧівҖўЧіВҹ
            {hasFilters&&<span style={{background:'var(--accent)',color:'#fff',borderRadius:'50%',
              width:16,height:16,fontSize:10,fontWeight:700,display:'inline-flex',
              alignItems:'center',justifyContent:'center'}}>{activeChips.length}</span>}
          </button>

          {/* Filter panel */}
          {filterOpen&&(
            <div style={{position:'absolute',top:'calc(100% + 6px)',right:0,width:300,
              background:'var(--surface)',border:'1px solid var(--border)',borderRadius:10,
              boxShadow:'0 8px 24px rgba(0,0,0,.14)',zIndex:500,padding:'16px',
              maxHeight:'70vh',overflowY:'auto'}}>
              <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:14}}>
                <span style={{fontWeight:700,fontSize:13}}>ЧіВЎЧів„ўЧіВ ЧівҖўЧіВҹ ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
                <button onClick={clearAll}
                  style={{fontSize:11,color:'#EF4444',background:'none',border:'none',cursor:'pointer',fontFamily:'inherit'}}>
                  ЧіВ ЧіВ§ЧівҖқ ЧівҖқЧівҖәЧіВң
                </button>
              </div>

              <FSection title="ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң">
                {PROJS.map(p=>(
                  <ChkRow key={p.id} label={`${p.name} (${p.code})`} color={p.color}
                    checked={fProjects.includes(p.code)}
                    onChange={()=>toggleArr(fProjects,setFProjects,p.code)}/>
                ))}
              </FSection>

              <FSection title="ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ">
                {STATUSES.map(s=>(
                  <ChkRow key={s.id} label={s.label} color={s.color}
                    checked={fStatuses.includes(s.id)}
                    onChange={()=>toggleArr(fStatuses,setFStatuses,s.id)}/>
                ))}
              </FSection>

              <FSection title="ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—">
                {PRIOS.map(p=>(
                  <ChkRow key={p.id} label={p.label} color={p.color}
                    checked={fPriorities.includes(p.id)}
                    onChange={()=>toggleArr(fPriorities,setFPriorities,p.id)}/>
                ))}
              </FSection>

              <FSection title="ЧіГ—ЧівҖ”ЧівҖўЧіВқ">
                <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:2}}>
                  {DISCS.map(d=>(
                    <ChkRow key={d} label={d}
                      checked={fDiscips.includes(d)}
                      onChange={()=>toggleArr(fDiscips,setFDiscips,d)}/>
                  ))}
                </div>
              </FSection>

              <FSection title="ЧіГ—ЧіВҗЧіВЁЧів„ўЧіВҡ Чів„ўЧіВўЧівҖң">
                {DATE_RANGES.map(r=>(
                  <ChkRow key={r.id} label={r.label}
                    checked={fDateRange===r.id}
                    onChange={()=>setFDateRange(fDateRange===r.id?'':r.id)}/>
                ))}
              </FSection>

              <FSection title="ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ Ч’вӮ¬вҖқ ЧіВһЧів„ўЧіВ Чів„ўЧіВһЧівҖўЧіВқ Чів„ўЧіВһЧів„ўЧіВқ ЧівҖҳЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ">
                <div style={{display:'flex',alignItems:'center',gap:8,padding:'6px 0'}}>
                  <input type="number" min="0" placeholder="0"
                    value={fEventDays} onChange={e=>setFEventDays(e.target.value)}
                    style={{width:70,border:'1px solid var(--border)',borderRadius:6,
                      padding:'5px 8px',fontSize:12,fontFamily:'inherit',
                      background:'var(--bg)',color:'var(--text)',outline:'none'}}/>
                  <span style={{fontSize:12,color:'var(--text-2)'}}>Чів„ўЧіВһЧів„ўЧіВқ ЧівҖўЧіВһЧіВўЧіВңЧівҖқ</span>
                </div>
              </FSection>
            </div>
          )}
        </div>

        {/* Sort button */}
        <div style={{position:'relative'}} onClick={e=>e.stopPropagation()}>
          <button onClick={()=>{setSortOpen(o=>!o);setFilterOpen(false);}}
            style={{display:'flex',alignItems:'center',gap:6,padding:'5px 12px',borderRadius:6,
              border:`1px solid ${sorts.some(s=>s.field!=='dueDate'||s.dir!=='asc')?'var(--accent)':'var(--border)'}`,
              background:'var(--surface)',color:'var(--text-2)',fontSize:12,fontWeight:600,
              cursor:'pointer',fontFamily:'inherit'}}>
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M2 4h12M2 8h8M2 12h4"/><path d="M13 8v6M10 11l3 3 3-3"/></svg>
            ЧіВһЧів„ўЧівҖўЧіВҹ
          </button>

          {sortOpen&&(
            <div style={{position:'absolute',top:'calc(100% + 6px)',right:0,width:240,
              background:'var(--surface)',border:'1px solid var(--border)',borderRadius:10,
              boxShadow:'0 8px 24px rgba(0,0,0,.14)',zIndex:500,padding:'12px'}}>
              <div style={{fontSize:11,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',
                letterSpacing:.5,marginBottom:10}}>ЧіВһЧів„ўЧівҖўЧіВҹ ЧіВңЧівӮӘЧів„ў</div>
              {SORT_FIELDS.map(sf=>{
                const dir=sortDir(sf.field), rank=sortRank(sf.field);
                return (
                  <div key={sf.field} onClick={()=>toggleSort(sf.field)}
                    style={{display:'flex',alignItems:'center',gap:8,padding:'8px 10px',
                      borderRadius:6,cursor:'pointer',background:dir?'rgba(37,99,235,.07)':'none',
                      marginBottom:2,transition:'background .1s'}}
                    onMouseEnter={e=>e.currentTarget.style.background=dir?'rgba(37,99,235,.1)':'var(--bg)'}
                    onMouseLeave={e=>e.currentTarget.style.background=dir?'rgba(37,99,235,.07)':'none'}>
                    <div style={{width:18,height:18,borderRadius:4,border:`1.5px solid ${dir?'var(--accent)':'var(--border)'}`,
                      background:dir?'var(--accent)':'none',display:'flex',alignItems:'center',justifyContent:'center',flexShrink:0}}>
                      {dir&&<span style={{color:'#fff',fontSize:10,fontWeight:900}}>Ч’ВңвҖң</span>}
                    </div>
                    <span style={{flex:1,fontSize:13,color:dir?'var(--accent)':'var(--text)',fontWeight:dir?600:400}}>
                      {sf.label}
                    </span>
                    {dir&&<span style={{fontSize:12,color:'var(--accent)',fontWeight:700}}>
                      {dir==='asc'?'Ч’вҖ вҖҳ ЧіВўЧівҖўЧіВңЧівҖқ':'Ч’вҖ вҖң Чів„ўЧівҖўЧіВЁЧівҖң'}
                    </span>}
                    {rank&&sorts.length>1&&<span style={{fontSize:9,background:'var(--accent)',color:'#fff',
                      borderRadius:'50%',width:14,height:14,display:'inline-flex',alignItems:'center',
                      justifyContent:'center'}}>{rank}</span>}
                  </div>
                );
              })}
              {sorts.length>0&&<button onClick={()=>setSorts([{field:'dueDate',dir:'asc'}])}
                style={{width:'100%',marginTop:8,padding:'6px',fontSize:11,color:'var(--text-3)',
                  background:'none',border:'1px solid var(--border)',borderRadius:6,
                  cursor:'pointer',fontFamily:'inherit'}}>
                ЧіВҗЧівӮӘЧіВЎ ЧіВһЧів„ўЧівҖўЧіВҹ
              </button>}
            </div>
          )}
        </div>

        {/* Group-by button */}
        <div style={{position:'relative'}} onClick={e=>e.stopPropagation()}>
          <button onClick={()=>{setShowGroupMenu(o=>!o);setFilterOpen(false);setSortOpen(false);setShowViewsPanel(false);}}
            style={{display:'flex',alignItems:'center',gap:6,padding:'5px 12px',borderRadius:6,
              border:`1px solid ${groupBy?'var(--accent)':'var(--border)'}`,
              background:groupBy?'rgba(37,99,235,.07)':'var(--surface)',
              color:groupBy?'var(--accent)':'var(--text-2)',fontSize:12,fontWeight:600,
              cursor:'pointer',fontFamily:'inherit'}}>
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"><rect x="2" y="2" width="5" height="5" rx="1"/><rect x="9" y="2" width="5" height="5" rx="1"/><rect x="2" y="9" width="5" height="5" rx="1"/><rect x="9" y="9" width="5" height="5" rx="1"/></svg>
            ЧіВ§ЧівҖҳЧівҖўЧіВҰЧівҖўЧіГ—{groupBy&&<span style={{fontSize:10,opacity:.7}}> ЦІВ· {activeGroupLabel}</span>}
          </button>
          {showGroupMenu&&(
            <div style={{position:'absolute',top:'calc(100% + 6px)',right:0,width:180,
              background:'var(--surface)',border:'1px solid var(--border)',borderRadius:10,
              boxShadow:'0 8px 24px rgba(0,0,0,.14)',zIndex:500,padding:'6px'}}>
              <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:.5,padding:'4px 8px 8px'}}>ЧіВ§ЧівҖҳЧіВҘ ЧіВңЧівӮӘЧів„ў</div>
              {GROUP_BY_OPTS.map(o=>(
                <div key={o.field} onClick={()=>{setGroupBy(o.field);setShowGroupMenu(false);}}
                  style={{display:'flex',alignItems:'center',gap:8,padding:'8px 10px',borderRadius:6,
                    cursor:'pointer',background:groupBy===o.field?'rgba(37,99,235,.07)':'',marginBottom:1}}
                  onMouseEnter={e=>e.currentTarget.style.background='var(--bg)'}
                  onMouseLeave={e=>e.currentTarget.style.background=groupBy===o.field?'rgba(37,99,235,.07)':''}>
                  {groupBy===o.field&&<span style={{color:'var(--accent)',fontSize:11}}>Ч’ВңвҖң</span>}
                  <span style={{fontSize:13,color:groupBy===o.field?'var(--accent)':'var(--text)',fontWeight:groupBy===o.field?600:400}}>{o.label}</span>
                </div>
              ))}
            </div>
          )}
        </div>

        {/* active filter chips */}
        {activeChips.map(c=>(
          <span key={c.key} style={{display:'inline-flex',alignItems:'center',gap:4,padding:'3px 8px',
            borderRadius:12,background:'rgba(37,99,235,.09)',border:'1px solid rgba(37,99,235,.25)',
            fontSize:11,color:'var(--accent)',fontWeight:600}}>
            {c.label}
            <button onClick={c.onRemove}
              style={{background:'none',border:'none',cursor:'pointer',color:'var(--accent)',
                fontSize:13,lineHeight:1,padding:0,display:'flex',alignItems:'center'}}>ЦівҖ”</button>
          </span>
        ))}

        {hasFilters&&<button onClick={clearAll}
          style={{fontSize:11,color:'var(--text-3)',background:'none',border:'none',cursor:'pointer',fontFamily:'inherit'}}>
          ЧіВ ЧіВ§ЧівҖқ ЧівҖқЧівҖәЧіВң
        </button>}
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ table Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div style={{flex:1,overflow:'auto'}}>
        <table style={{width:'100%',borderCollapse:'collapse',fontSize:12}}>
          <thead>
            <tr style={{background:'var(--surface)',borderBottom:'2px solid var(--border)',position:'sticky',top:0,zIndex:10}}>
              {[{w:70,label:'ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң'},{w:'auto',label:'ЧіВ©ЧіВқ ЧівҖқЧіВһЧіВ©Чів„ўЧіВһЧівҖқ'},{w:90,label:'ЧіВ©ЧіВңЧівҖҳ'},{w:90,label:'ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ'},{w:80,label:'ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—'},{w:70,label:'ЧіГ—ЧівҖ”ЧівҖўЧіВқ'},{w:90,label:'Чів„ўЧіВўЧівҖң'},{w:60,label:'Чів„ўЧіВһЧів„ўЧіВқ'}].map((h,i)=>(
                <th key={i} style={{padding:'7px 12px',textAlign:'right',fontWeight:600,fontSize:11,
                  color:'var(--text-2)',whiteSpace:'nowrap',width:h.w}}>
                  {h.label}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {sorted.length===0 && (
              <tr><td colSpan={8} style={{padding:'40px',textAlign:'center',color:'var(--text-3)',fontSize:13}}>
                ЧіВҗЧів„ўЧіВҹ ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ— ЧівҖқЧіГ—ЧівҖўЧіВҗЧіВһЧівҖўЧіГ— ЧіВҗЧіГ— ЧівҖқЧівӮӘЧів„ўЧіВңЧіЛңЧіВЁЧів„ўЧіВқ
              </td></tr>
            )}
            {groupedRows.map(grp=>{
              const grpColor = grp.color;
              return (
                <React.Fragment key={grp.key}>
                  {/* group header row */}
                  {grp.label!==null&&(
                    <tr>
                      <td colSpan={8} style={{padding:'10px 14px 4px',background:'var(--bg)',borderBottom:'1px solid var(--border)'}}>
                        <div style={{display:'flex',alignItems:'center',gap:8}}>
                          {grpColor&&<span style={{width:10,height:10,borderRadius:'50%',background:grpColor,flexShrink:0}}/>}
                          <span style={{fontSize:12,fontWeight:700,color:'var(--text)'}}>{grp.label}</span>
                          <span style={{fontSize:11,color:'var(--text-3)',background:'var(--border)',borderRadius:8,padding:'1px 7px'}}>{grp.tasks.length}</span>
                        </div>
                      </td>
                    </tr>
                  )}
                  {grp.tasks.map(t=>{
                    const stCfg = {N:{label:'ЧіВңЧіВҗ ЧівҖқЧіГ—ЧівҖ”Чів„ўЧіВң',color:'#8B949E',bg:'rgba(139,148,158,.1)'},P:{label:'ЧівҖҳЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ',color:'#2563EB',bg:'rgba(37,99,235,.1)'},S:{label:'ЧіГ—ЧіВ§ЧівҖўЧіВў',color:'#EF4444',bg:'rgba(239,68,68,.1)'}}[t.statusId]||{label:t.statusId,color:'#999',bg:'#eee'};
                    const priCfg = {high:{label:'ЧівҖҷЧівҖҳЧівҖўЧівҖқЧівҖқ',color:'#EF4444',bg:'rgba(239,68,68,.1)'},medium:{label:'ЧівҖҳЧів„ўЧіВ ЧівҖўЧіВ Чів„ўЧіГ—',color:'#F59E0B',bg:'rgba(245,158,11,.1)'},low:{label:'ЧіВ ЧіВһЧівҖўЧівҖәЧівҖқ',color:'#3B82F6',bg:'rgba(59,130,246,.1)'}}[t.priority]||null;
                    const daysLeft = t.dueDate ? daysBetween(today,t.dueDate) : null;
                    const isLate   = daysLeft!==null && daysLeft<0;
                    const projColor = t._projColor||'#6B7280';
                    return (
                      <tr key={t.id} style={{borderBottom:'1px solid var(--border)',transition:'background .1s'}}
                        onMouseEnter={e=>e.currentTarget.style.background='var(--bg)'}
                        onMouseLeave={e=>e.currentTarget.style.background=''}>
                        <td style={{padding:'8px 12px'}}>
                          <span style={{display:'inline-block',padding:'2px 6px',borderRadius:4,fontSize:9,fontWeight:800,
                            fontFamily:'monospace',background:hexBg(projColor),color:projColor,border:`1px solid ${projColor}40`}}>
                            {t._proj}
                          </span>
                        </td>
                        <td style={{padding:'8px 12px',maxWidth:280}}>
                          <div style={{fontWeight:600,color:'var(--text)',fontSize:13,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{t.title}</div>
                          <div style={{fontSize:10,color:'var(--text-3)',marginTop:1}}>{t._sheet}</div>
                        </td>
                        <td style={{padding:'8px 12px'}}><span style={{fontSize:11,color:'var(--text-2)'}}>{t._sheet}</span></td>
                        <td style={{padding:'8px 12px'}}>
                          <span style={{padding:'2px 8px',borderRadius:10,fontSize:10,fontWeight:700,color:stCfg.color,background:stCfg.bg}}>{stCfg.label}</span>
                        </td>
                        <td style={{padding:'8px 12px'}}>
                          {priCfg&&<span style={{padding:'2px 8px',borderRadius:10,fontSize:10,fontWeight:600,color:priCfg.color,background:priCfg.bg}}>{priCfg.label}</span>}
                        </td>
                        <td style={{padding:'8px 12px'}}>
                          <span style={{fontSize:10,fontWeight:700,color:'var(--text-2)',fontFamily:'monospace'}}>{t.discipline||'Ч’вӮ¬вҖқ'}</span>
                        </td>
                        <td style={{padding:'8px 12px'}}>
                          <span style={{fontSize:11,fontWeight:600,color:isLate?'#EF4444':'var(--text-2)',fontFamily:'monospace'}}>
                            {t.dueDate?fmtDateFull(t.dueDate):'Ч’вӮ¬вҖқ'}
                          </span>
                        </td>
                        <td style={{padding:'8px 12px',textAlign:'center'}}>
                          {daysLeft!==null&&<span style={{fontSize:11,fontWeight:700,color:isLate?'#EF4444':daysLeft<=7?'#F59E0B':'var(--text-3)'}}>
                            {isLate?`-${Math.abs(daysLeft)}`:`${daysLeft}`}
                          </span>}
                        </td>
                      </tr>
                    );
                  })}
                </React.Fragment>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Coming Soon Placeholder
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function ComingSoonPage({iconName, title, desc}) {
  return (
    <div style={{flex:1,display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',
      gap:16,padding:40,background:'var(--bg)',color:'var(--text-2)'}}>
      <div style={{color:'var(--border-strong)',opacity:.5}}><Ic n={iconName} size={48}/></div>
      <div style={{fontSize:22,fontWeight:700,color:'var(--text)'}}>{title}</div>
      <div style={{fontSize:14,color:'var(--text-2)',maxWidth:360,textAlign:'center',lineHeight:1.6}}>{desc}</div>
      <div style={{marginTop:8,padding:'8px 20px',borderRadius:20,background:'var(--surface)',
        border:'1px solid var(--border)',fontSize:12,color:'var(--text-3)',fontWeight:600,
        display:'flex',alignItems:'center',gap:6}}>
        <Ic n="soon" size={13}/> ЧівҖҳЧіВ§ЧіВЁЧівҖўЧівҖҳ
      </div>
    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Sidebar
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
const MY_PROJECTS = [
  {id:'lod',      name:'ЧіВЎЧівӮӘЧіВЁЧів„ўЧів„ўЧіГ— ЧіВңЧівҖўЧівҖң',       color:'#2563EB', code:'LDLI', active:true },
  {id:'yanai',    name:'YANAI 20223',      color:'#7C3AED', code:'YN22', active:false},
  {id:'ramat',    name:'ЧіВЁЧіВһЧіГ— ЧівҖҷЧіВҹ CC',        color:'#059669', code:'RGCC', active:false},
  {id:'neptun',   name:'ЧіВ ЧівӮӘЧіЛңЧівҖўЧіВҹ',            color:'#F97316', code:'NPTN', active:false},
  {id:'feldman',  name:'ЧівӮӘЧіВңЧівҖңЧіВһЧіВҹ',            color:'#EC4899', code:'FLDM', active:false},
];

const PROJ_TRACKS = [
  {id:'overview',    label:'ЧіВһЧівҖҳЧіЛң ЧіВўЧіВң',              icon:'overview',    enabled:true},
  {id:'tasks',       label:'ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ',          icon:'tasks',       enabled:true},
  {id:'licensing',   label:'ЧіВһЧіВЎЧіВңЧівҖўЧіВң ЧіВЁЧів„ўЧіВ©ЧівҖўЧів„ў',          icon:'licensing',   enabled:true},
  {id:'planning',    label:'ЧіВһЧіВЎЧіВңЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВһЧівӮӘЧівҖўЧіВЁЧіЛң',    icon:'planning',    enabled:false},
  {id:'execution',   label:'ЧіВһЧіВЎЧіВңЧівҖўЧіВң ЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў',          icon:'execution',   enabled:false},
  {id:'meetings',    label:'Чів„ўЧіВ©Чів„ўЧівҖҳЧівҖўЧіГ—',               icon:'meetings',    enabled:true},
  {id:'supervision', label:'ЧівӮӘЧів„ўЧіВ§ЧівҖўЧівҖ”',                icon:'supervision', enabled:true},
];

function Sidebar({track, setTrack}) {
  const [sidebarOpen, setSidebarOpen] = React.useState(true);
  const [expandedProj, setExpandedProj] = React.useState('lod'); // lod open by default

  const NAV = [
    {id:'home',      label:'ЧівҖҳЧів„ўЧіГ—',           icon:'home'},
    {id:'mytasks',   label:'ЧівҖқЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ— ЧіВ©ЧіВңЧів„ў',   icon:'mytasks'},
    {id:'hours',     label:'ЧівҖңЧів„ўЧівҖўЧівҖўЧівҖ” ЧіВ©ЧіВўЧівҖўЧіГ—',    icon:'hours'},
    {id:'portfolio', label:'ЧівӮӘЧівҖўЧіВЁЧіЛңЧівӮӘЧівҖўЧіВңЧів„ўЧівҖў',     icon:'portfolio'},
  ];

  const ChevronIcon = ({dir}) => (
    <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round">
      {dir==='right' ? <path d="M4 2l4 4-4 4"/> : <path d="M8 2L4 6l4 4"/>}
    </svg>
  );
  const DownIcon = ({open}) => (
    <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round">
      {open ? <path d="M2 8l4-4 4 4"/> : <path d="M2 4l4 4 4-4"/>}
    </svg>
  );

  return (
    <>
      {!sidebarOpen && (
        <button className="sb-toggle-fixed" onClick={()=>setSidebarOpen(true)} title="ЧівӮӘЧіГ—ЧівҖ” ЧіГ—ЧівӮӘЧіВЁЧів„ўЧіЛң">
          <ChevronIcon dir="left"/>
        </button>
      )}

      <div className={`sidebar${sidebarOpen?'':' collapsed'}`}>
        {/* workspace */}
        <div className="sb-top">
          <div style={{display:'flex',alignItems:'center',gap:6,marginBottom:4}}>
            <div className="sb-workspace" style={{flex:1,marginBottom:0}}>
              <div className="sb-ws-icon"><Ic n="building" size={13}/></div>
              <span className="sb-ws-name">Knafo Klimor</span>
            </div>
            <button className="sb-toggle" onClick={()=>setSidebarOpen(false)} title="ЧіВЎЧівҖҷЧівҖўЧіВЁ ЧіГ—ЧівӮӘЧіВЁЧів„ўЧіЛң">
              <ChevronIcon dir="right"/>
            </button>
          </div>
          <button className="sb-create">
            <span className="sb-create-dot">+</span>
            ЧіВҰЧівҖўЧіВЁ ЧівҖ”ЧівҖңЧіВ©
          </button>
        </div>

        {/* nav */}
        <div className="sb-body">
          <div className="sb-section">
            {NAV.map(item=>{
              const trackMap={home:'overview',mytasks:'mytasks',portfolio:'portfolio'};
              const itemTrack = trackMap[item.id];
              const isActive = itemTrack && track===itemTrack;
              const isEnabled = !!itemTrack;
              return (
                <button key={item.id}
                  className={`sb-item${isActive?' active':isEnabled?'':' disabled'}`}
                  onClick={isEnabled?()=>setTrack(itemTrack):undefined}>
                  <span className="sb-item-icon"><Ic n={item.icon} size={15}/></span>
                  {item.label}
                </button>
              );
            })}
          </div>

          {/* projects */}
          <div className="sb-section">
            <div className="sb-section-label">ЧівҖқЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ ЧіВ©ЧіВңЧів„ў</div>
            {MY_PROJECTS.map(p=>{
              const isActive = p.id==='lod';
              const isExpanded = expandedProj===p.id;
              return (
                <div key={p.id}>
                  {/* project row */}
                  <div className="sb-proj-row">
                    <button className={`sb-proj-btn${isActive?' active':' disabled'}`}
                      onClick={isActive?()=>setExpandedProj(isExpanded?null:p.id):undefined}>
                      <span className="sb-proj-badge" style={{
                        background:hexBg(p.color), color:p.color, border:`1px solid ${p.color}40`}}>
                        {p.code}
                      </span>
                      {p.name}
                    </button>
                    <button className={`sb-proj-chevron${isActive?'':' disabled'}`}
                      onClick={isActive?()=>setExpandedProj(isExpanded?null:p.id):undefined}>
                      <DownIcon open={isExpanded}/>
                    </button>
                  </div>
                  {/* sub-items */}
                  {isExpanded && (
                    <div style={{marginBottom:2}}>
                      {PROJ_TRACKS.map(t=>(
                        <button key={t.id}
                          className={`sb-sub-item${!t.enabled?' disabled':track===t.id?' active':''}`}
                          onClick={t.enabled?()=>setTrack(t.id):undefined}>
                          <span className="sb-sub-dot" style={{
                            background: track===t.id ? 'var(--accent)' : t.enabled?'var(--border-strong)':'var(--border)'
                          }}/>
                          <span className="sb-item-icon" style={{width:13,height:13}}><Ic n={t.icon} size={13}/></span>
                          {t.label}
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>

        {/* footer */}
        <div className="sb-footer">
          <div className="sb-user">
            <div className="sb-avatar">YS</div>
            <span className="sb-user-name">Shay H.</span>
          </div>
        </div>
      </div>
    </>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   App Root
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function App() {
  const [data,setData]=useState(loadData);
  const [editName,setEditName]=useState(false);
  const [nameDraft,setNameDraft]=useState(data.projectName);
  const [editingSheetId,setEditingSheetId]=useState(null);
  const [sheetNameDraft,setSheetNameDraft]=useState('');

  const sheets = data.sheets||[];
  const [activeSheetId,setActiveSheetId]=useState(()=>sheets[0]?.id||'');
  const activeSheet = sheets.find(s=>s.id===activeSheetId)||sheets[0]||null;

  const save=useCallback(nd=>{
    const d={...nd,_ts:Date.now()};
    setData(d);localStorage.setItem(STORAGE_KEY,JSON.stringify(d));
  },[]);

  /* Save updates that originate from a list-sheet's toolbar/actions */
  const saveActiveSheet=useCallback(nd=>{
    const updatedSheets=(data.sheets||[]).map(s=>s.id===activeSheetId?{
      ...s,
      groups:nd.groups!==undefined?nd.groups:s.groups,
      tasks:nd.tasks!==undefined?nd.tasks:s.tasks,
      fields:nd.fields!==undefined?nd.fields:s.fields,
      hiddenCols:nd.hiddenCols!==undefined?nd.hiddenCols:s.hiddenCols,
      colOrder:nd.colOrder!==undefined?nd.colOrder:s.colOrder,
    }:s);
    save({...nd, sheets:updatedSheets});
  },[data,activeSheetId,save]);

  const commitName=()=>{if(nameDraft.trim())save({...data,projectName:nameDraft.trim()});setEditName(false);};

  const commitSheetName=()=>{
    if(sheetNameDraft.trim()){
      const updatedSheets=sheets.map(s=>s.id===editingSheetId?{...s,name:sheetNameDraft.trim()}:s);
      save({...data,sheets:updatedSheets});
    }
    setEditingSheetId(null);
  };

  const addSheet=()=>{
    const ns=makeEmptySheet('ЧіВ©ЧіВңЧівҖҳ ЧівҖ”ЧівҖңЧіВ©');
    const updatedSheets=[...sheets,ns];
    save({...data,sheets:updatedSheets});
    setActiveSheetId(ns.id);
  };

  /* top-level track: 'overview' | 'licensing' | future tracks */
  const [track, setTrack] = useState('licensing');

  /* When switching to tasks track Ч’вӮ¬вҖқ auto-select first list sheet (ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ) */
  const setTrackWithSheet = React.useCallback((newTrack) => {
    setTrack(newTrack);
    if(newTrack==='tasks') {
      const firstList = sheets.find(s=>s.type==='list');
      if(firstList) setActiveSheetId(firstList.id);
    } else if(newTrack==='licensing') {
      const dashboard = sheets.find(s=>s.type==='dashboard');
      if(dashboard) setActiveSheetId(dashboard.id);
    }
  }, [sheets]);

  /* Merge active sheet's list data into a "data-like" object for ListViewWithCtx */
  const sheetData = activeSheet?.type==='list' ? {
    ...data,
    groups:activeSheet.groups||[],
    tasks:activeSheet.tasks||[],
    fields:activeSheet.fields||[],
    hiddenCols:activeSheet.hiddenCols||{},
    colOrder:activeSheet.colOrder||[],
  } : data;

  const SheetTab = ({s}) => editingSheetId===s.id
    ? <input autoFocus value={sheetNameDraft}
        onChange={e=>setSheetNameDraft(e.target.value)}
        onBlur={commitSheetName}
        onKeyDown={e=>{if(e.key==='Enter')commitSheetName();if(e.key==='Escape')setEditingSheetId(null);}}
        style={{border:'1.5px solid var(--accent)',borderRadius:5,padding:'2px 8px',alignSelf:'center',
          fontSize:12,fontFamily:'inherit',outline:'none',background:'var(--surface)',
          color:'var(--text)',minWidth:60,maxWidth:130}}/>
    : <button className={`stab${s.id===activeSheetId?' active':''}`}
        onClick={()=>setActiveSheetId(s.id)}
        onDoubleClick={()=>{setSheetNameDraft(s.name);setEditingSheetId(s.id);}}>
        {s.type==='dashboard'?<><Ic n="overview"/> </>:''}{s.name}
      </button>;

  return(
    <div className="shell">
    <Sidebar track={track} setTrack={setTrackWithSheet}/>
    <div className="app">
      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Project Header Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div className="proj-header">
        <div className="proj-top">
          <div className="proj-icon"><Ic n="building" size={15}/></div>
          {editName
            ?<input className="proj-name-input" autoFocus value={nameDraft}
                onChange={e=>setNameDraft(e.target.value)}
                onBlur={commitName}
                onKeyDown={e=>{if(e.key==='Enter')commitName();if(e.key==='Escape')setEditName(false);}}/>
            :<span className="proj-name" onClick={()=>{setNameDraft(data.projectName);setEditName(true);}}>
                {data.projectName}
              </span>
          }
          <button className="icon-btn" title="ЧіВһЧівҖўЧіВўЧівҖңЧівӮӘЧів„ўЧіВқ"><Ic n="star"/></button>
          <div className="hdr-right">
            <div className="avatar-stack">
              {[['#2563EB','YS'],['#7C3AED','U'],['#059669','A']].map(([bg,l],i)=>(
                <div key={i} className="av" style={{background:bg}}>{l}</div>
              ))}
            </div>
            <button className="btn-share"><Ic n="share"/> ЧіВ©ЧіГ—ЧіВЈ</button>
          </div>
        </div>

        {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ track breadcrumb + sheet sub-tabs Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
        <div className="sheet-tabs" style={{borderTop:'1px solid var(--border)'}}>
          {/* current track label */}
          <span style={{fontSize:11,fontWeight:600,color:'var(--text-3)',paddingLeft:4,paddingRight:8,
            display:'flex',alignItems:'center',gap:5,flexShrink:0}}>
            <Ic n={PROJ_TRACKS.find(t=>t.id===track)?.icon||'overview'} size={12}/>
            {PROJ_TRACKS.find(t=>t.id===track)?.label||''}
          </span>
          {/* divider + sub-tabs for licensing Ч’вӮ¬вҖқ exclude ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ sheet */}
          {track==='licensing' && <span style={{color:'var(--border-strong)',marginLeft:4,marginRight:4}}>Ч’вӮ¬Г·</span>}
          {track==='licensing' && sheets.filter(s=>s.name!=='ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ').map(s=><SheetTab key={s.id} s={s}/>)}
          {track==='licensing' && <button className="stab-add" title="ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВ©ЧіВңЧівҖҳ" onClick={addSheet}>+</button>}
          {/* sub-tabs for tasks track Ч’вӮ¬вҖқ only ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ sheet */}
          {track==='tasks' && <span style={{color:'var(--border-strong)',marginLeft:4,marginRight:4}}>Ч’вӮ¬Г·</span>}
          {track==='tasks' && sheets.filter(s=>s.name==='ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ').map(s=><SheetTab key={s.id} s={s}/>)}
        </div>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Content Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div style={{display:'flex',flexDirection:'column',flex:1,overflow:'hidden'}}>
        {track==='overview' && <OverviewPage data={data} save={save}/>}
        {track==='tasks'    && activeSheet?.type==='list'      && <ListViewWithCtx data={sheetData} save={saveActiveSheet}/>}
        {track==='tasks'    && !activeSheet                    && <ComingSoonPage iconName="tasks" title="ЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ" desc="ЧівҖҳЧівҖ”ЧіВЁ ЧіВ©ЧіВңЧівҖҳ ЧіВһЧівҖқЧіГ—ЧівӮӘЧіВЁЧів„ўЧіЛң"/>}
        {track==='licensing' && activeSheet?.type==='dashboard' && <DashboardView data={data} save={save} onSwitchSheet={setActiveSheetId}/>}
        {track==='licensing' && activeSheet?.type==='list' && <ListViewWithCtx data={sheetData} save={saveActiveSheet}/>}
        {track==='meetings'    && <ComingSoonPage iconName="meetings"    title="Чів„ўЧіВ©Чів„ўЧівҖҳЧівҖўЧіГ—" desc="ЧіВЁЧів„ўЧівҖәЧівҖўЧівҖ“ ЧівҖўЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧіВЎЧів„ўЧівҖәЧівҖўЧіВһЧів„ў Чів„ўЧіВ©Чів„ўЧівҖҳЧівҖўЧіГ— Ч’вӮ¬вҖқ ЧівҖҳЧівӮӘЧів„ўЧіГ—ЧівҖўЧівҖ”"/>}
        {track==='supervision' && <ComingSoonPage iconName="supervision" title="ЧівӮӘЧів„ўЧіВ§ЧівҖўЧівҖ”"  desc="ЧіВЁЧів„ўЧівҖәЧівҖўЧівҖ“ ЧівҖўЧіВ Чів„ўЧівҖқЧівҖўЧіВң ЧівҖңЧівҖўЧівҖ”ЧівҖўЧіГ— ЧівӮӘЧів„ўЧіВ§ЧівҖўЧівҖ” ЧіВһЧівҖқЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў Ч’вӮ¬вҖқ ЧівҖҳЧівӮӘЧів„ўЧіГ—ЧівҖўЧівҖ”"/>}
        {track==='mytasks'     && <MyTasksView data={data} save={save}/>}
        {track==='portfolio'   && <PortfolioView/>}
      </div>
    </div>
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
</body>
</html>
