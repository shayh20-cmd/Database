/* Derive the current responsible discipline from a process task's latest event.
   Same-date tiebreaker: period events (active state) outrank their paired milestone. */
function getProcessResponsible(task) {
  if (!task.processEvents?.length) return null;
  return [...task.processEvents].sort((a,b) => {
    if(a.date !== b.date) return (b.date||'').localeCompare(a.date||'');
    return (EV_PERIOD.has(a.status)?0:1) - (EV_PERIOD.has(b.status)?0:1);
  })[0]?.assignee || null;
}

/* Get the most recent event status from a process task, mapped to task statusId.
   Returns the event status if found, otherwise returns the task's own statusId. */
function getMostRecentEventStatus(task) {
  if (task.taskType !== 'process' || !task.processEvents?.length) {
    return task.statusId;
  }

  const sorted = [...task.processEvents].sort((a,b) => {
    if(a.date !== b.date) return (b.date||'').localeCompare(a.date||'');
    return (EV_PERIOD.has(a.status)?0:1) - (EV_PERIOD.has(b.status)?0:1);
  });

  const latest = sorted[0];
  if (!latest?.status) return task.statusId;

  // Map event statuses to task statuses
  const statusMap = {
    'progress': 'I',   // ЧівҖҳЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ
    'sent': 'I',       // ЧівҖҳЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ (submitted)
    'response': 'I',   // ЧівҖҳЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ (in response phase)
    'comments': 'R',   // ЧівҖқЧіГ—Чів„ўЧів„ўЧівҖ”ЧіВЎЧівҖўЧіГ— (needs response)
    'approved': 'C',   // ЧівҖҳЧівҖўЧіВҰЧіВў (approved/done)
    'missing': 'N',    // ЧіВңЧіВҗ ЧівҖқЧіГ—ЧівҖ”Чів„ўЧіВң
  };

  return statusMap[latest.status] || task.statusId;
}
