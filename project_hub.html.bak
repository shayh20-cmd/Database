  {id:'LIFT', label:'LIFT', color:'#6B7280', bg:'rgba(107,114,128,.15)'},
  {id:'TNDR', label:'TNDR', color:'#EF4444', bg:'rgba(239,68,68,.15)'},
  {id:'AGRO', label:'AGRO', color:'#059669', bg:'rgba(5,150,105,.15)'},
];
const HE_MONTHS = ['Чів„ўЧіВ ЧівҖў','ЧівӮӘЧівҖҳЧіВЁ','ЧіВһЧіВЁЧіВҘ','ЧіВҗЧівӮӘЧіВЁ','ЧіВһЧіВҗЧів„ў','Чів„ўЧівҖўЧіВ ','Чів„ўЧівҖўЧіВң','ЧіВҗЧівҖўЧівҖҷ','ЧіВЎЧівӮӘЧіЛң','ЧіВҗЧівҖўЧіВ§','ЧіВ ЧівҖўЧівҖҳ','ЧівҖңЧіВҰЧіВһ'];

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Office staff list (loaded from Excel 06-2026) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
const OFFICE_STAFF = [
  {id:'st01',name:'ЧівҖңЧівҖўЧівҖң ЧіВ§ЧіВ ЧівӮӘЧівҖў',       role:'ЧівҖҳЧіВўЧіВңЧів„ўЧіВқ',                email:'david@kkarc.com',    phone:'054-2229515',office:'ЧіГ—ЧіВң ЧіВҗЧівҖҳЧів„ўЧівҖҳ'},
  {id:'st02',name:'ЧіГ—ЧівҖҷЧів„ўЧіГ— ЧіВ§ЧіВ ЧівӮӘЧівҖў ЧівҖәЧіВңЧів„ўЧіВһЧівҖўЧіВЁ',role:'ЧівҖҳЧіВўЧіВңЧів„ўЧіВқ',               email:'tagit@kkarc.com',    phone:'054-4714054',office:'ЧівҖ”Чів„ўЧівӮӘЧівҖқ'},
  {id:'st03',name:'ЧіВҗЧіВЁЧів„ўЧівҖқ ЧівҖ”Чів„ўЧівҖўЧіВҹ',       role:'ЧіВҗЧівҖңЧіВЁЧів„ўЧівҖәЧіВң ЧіВ©ЧівҖўЧіГ—ЧіВЈ',          email:'arie@kkarc.com',     phone:'050-8373041',office:'ЧівҖ”Чів„ўЧівӮӘЧівҖқ'},
