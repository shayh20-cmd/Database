/* Derives rgba bg string from 6-digit hex color at 15% opacity */
const hexBg = hex => {
  if(!hex||hex.length<7) return 'rgba(158,158,158,.15)';
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},.15)`;
};

/* Context Ч’вӮ¬вҖқ provides effective priority/discipline/status lists and edit trigger */
