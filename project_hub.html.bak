/* Responsible Cell
   - Process tasks: auto-derived from latest event assignee (read-only indicator)
   - Simple tasks: editable discipline dropdown stored in task.responsible           */
function ResponsibleCell({task, onChange}) {
  const {disciplines} = useContext(ListsCtx);
  const isProcess = task.taskType === 'process';
  const [open, setOpen] = useState(false);
  const ref = useRef(null);

  // For process tasks: derive from latest timeline event
  const processDiscId = isProcess ? getProcessResponsible(task) : null;
  const discId = isProcess ? processDiscId : (task.responsible || '');
  const disc = disciplines.find(d => d.id === discId);

  useEffect(()=>{
    if(!open)return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[open]);

  if (isProcess) {
    // Read-only for process tasks Ч’вӮ¬вҖқ value is auto-derived from timeline
    return (
      <td style={{padding:'0 10px',verticalAlign:'middle',textAlign:'right'}}>
        {disc
          ? <span title="ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў ЧіВ ЧівҖҷЧівҖ“ЧіВЁ ЧіВһЧівҖқЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ ЧівҖқЧіВҗЧівҖ”ЧіВЁЧівҖўЧіВҹ ЧівҖҳЧіЛңЧів„ўЧів„ўЧіВһЧіВңЧів„ўЧів„ўЧіВҹ"
              style={{display:'inline-flex',alignItems:'center',gap:4,padding:'2px 8px',borderRadius:5,
                      fontSize:11,fontWeight:700,background:disc.bg||'rgba(0,0,0,.06)',color:disc.color||'var(--text-2)',
                      border:`1px solid ${disc.color}30`,cursor:'default'}}>
              Ч’вҖ”ЛҶ {disc.label}
            </span>
          : <span style={{color:'var(--text-3)',fontSize:12}}>Ч’вӮ¬вҖқ</span>}
      </td>
    );
  }

  // Editable for simple tasks
  return (
    <td ref={ref} style={{position:'relative',cursor:'pointer',padding:'0 10px',verticalAlign:'middle',textAlign:'right'}}
        onClick={()=>setOpen(o=>!o)}>
      {disc
        ? <span className="pill" style={{color:'#fff',background:disc.color}}>{disc.label}</span>
        : <span style={{color:'var(--text-3)',fontSize:12}}>Ч’вӮ¬вҖқ</span>}
      {open&&(
        <div className="dp" onClick={e=>e.stopPropagation()}>
          <div className="dp-title">ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div>
          {disciplines.map(d=>(
            <div key={d.id} className={`dp-opt${d.id===discId?' sel':''}`}
              onClick={()=>{onChange(d.id);setOpen(false);}}>
              <span className="pill" style={{color:'#fff',background:d.color}}>{d.label}</span>
            </div>
          ))}
          {discId&&<><div className="dp-sep"/><div className="dp-opt" style={{color:'var(--text-3)'}} onClick={()=>{onChange('');setOpen(false);}}>ЧіВңЧіВңЧіВҗ ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div></>}
        </div>
      )}
    </td>
  );
}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ CalendarRangePicker Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
function CalendarRangePicker({initStart, initEnd, onCommit, onClose, minDate='', maxDate=''}) {
  const today = todayISO();
  const HE_MONTHS_LONG = ['Чів„ўЧіВ ЧівҖўЧіВҗЧіВЁ','ЧівӮӘЧівҖҳЧіВЁЧівҖўЧіВҗЧіВЁ','ЧіВһЧіВЁЧіВҘ','ЧіВҗЧівӮӘЧіВЁЧів„ўЧіВң','ЧіВһЧіВҗЧів„ў','Чів„ўЧівҖўЧіВ Чів„ў','Чів„ўЧівҖўЧіВңЧів„ў','ЧіВҗЧівҖўЧівҖҷЧівҖўЧіВЎЧіЛң','ЧіВЎЧівӮӘЧіЛңЧіВһЧівҖҳЧіВЁ','ЧіВҗЧівҖўЧіВ§ЧіЛңЧівҖўЧівҖҳЧіВЁ','ЧіВ ЧівҖўЧівҖҳЧіВһЧівҖҳЧіВЁ','ЧівҖңЧіВҰЧіВһЧівҖҳЧіВЁ'];
  const DAY_LABELS = ['ЧіВҗ','ЧівҖҳ','ЧівҖҷ','ЧівҖң','ЧівҖқ','ЧівҖў','ЧіВ©']; // SunЧ’вҖ вҖҷSat

  const initD = initStart ? new Date(initStart+'T12:00:00') : new Date();
  const [yr,  setYr]  = useState(initD.getFullYear());
  const [mo,  setMo]  = useState(initD.getMonth());
  const [selS, setSelS] = useState(initStart||null);
  const [selE, setSelE] = useState(initEnd||null);
  const [hover, setHover] = useState(null);
  const [phase, setPhase] = useState(initStart&&initEnd?'done':initStart?'pickEnd':'pickStart');

  const prevMo = () => mo===0 ? (setMo(11),setYr(y=>y-1)) : setMo(m=>m-1);
  const nextMo = () => mo===11? (setMo(0), setYr(y=>y+1)) : setMo(m=>m+1);

  const daysInMo  = new Date(yr, mo+1, 0).getDate();
  const firstDow  = new Date(yr, mo, 1).getDay(); // 0=Sun

  const toISO = d => `${yr}-${String(mo+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;

  const isDisabled = iso => (minDate && iso < minDate) || (maxDate && iso > maxDate);

  const handleDay = d => {
    const iso = toISO(d);
    if(isDisabled(iso)) return;
    if(phase==='pickStart'||phase==='done'){
      setSelS(iso); setSelE(null); setPhase('pickEnd');
    } else {
      if(iso <= selS){ setSelE(selS); setSelS(iso); }
      else             { setSelE(iso); }
      setPhase('done');
    }
  };

  const previewEnd = phase==='pickEnd' && hover ? hover : null;
  const dispEnd    = selE || previewEnd;
  const hasBoth    = selS && dispEnd && selS !== dispEnd;
  const lo = hasBoth ? (selS<=dispEnd?selS:dispEnd) : null;
  const hi = hasBoth ? (selS<=dispEnd?dispEnd:selS) : null;

  const empties = Array.from({length:firstDow},(_,i)=>({type:'e',k:'e'+i}));
  const dayCells= Array.from({length:daysInMo},(_,i)=>{
    const d=i+1, iso=toISO(d);
    const isEp  = iso===selS || iso===selE || (phase==='pickEnd'&&iso===hover&&selS);
    const inRng = lo&&hi && iso>lo && iso<hi;
    const rFirst= hasBoth && iso===lo;
    const rLast = hasBoth && iso===hi;
    return {type:'d',d,iso,isEp,inRng,rFirst,rLast,isToday:iso===today};
  });
  const cells=[...empties,...dayCells];

  return (
    <div className="dp cal-picker" dir="ltr" onClick={e=>e.stopPropagation()}>
      {/* Date chips */}
      <div className="cal-hdr-inputs">
        <div className={`cal-chip${phase==='pickStart'?' picking':''}`}
          onClick={()=>{setSelS(null);setSelE(null);setPhase('pickStart');}}>
          <span className={`cal-chip-val${selS?'':' empty'}`}>{selS?fmtDate(selS):'ЧівҖқЧіГ—ЧівҖ”ЧіВңЧівҖқ'}</span>
          {selS&&<button className="cal-chip-clr" onClick={e=>{e.stopPropagation();setSelS(null);setSelE(null);setPhase('pickStart');}}>ЦівҖ”</button>}
        </div>
        <span style={{color:'var(--text-3)',flexShrink:0,fontSize:12}}>Ч’вҖ вҖҷ</span>
        <div className={`cal-chip${phase==='pickEnd'?' picking':''}`}>
          <span className={`cal-chip-val${selE?'':' empty'}`}>{selE?fmtDate(selE):'ЧіВЎЧів„ўЧівҖўЧіВқ'}</span>
          {selE&&<button className="cal-chip-clr" onClick={e=>{e.stopPropagation();setSelE(null);setPhase(selS?'pickEnd':'pickStart');}}>ЦівҖ”</button>}
        </div>
      </div>

      {/* Month navigation */}
      <div className="cal-month-nav">
        <button className="cal-nav-btn" onClick={prevMo}>Ч’вӮ¬В№</button>
        <span className="cal-month-lbl">{HE_MONTHS_LONG[mo]} {yr}</span>
        <button className="cal-nav-btn" onClick={nextMo}>Ч’вӮ¬Г·</button>
      </div>

      {/* Day-of-week headers */}
      <div className="cal-grid">
        {DAY_LABELS.map(l=><div key={l} className="cal-day-hdr">{l}</div>)}
      </div>

      {/* Days grid */}
      <div className="cal-grid" style={{paddingBottom:4}}
        onMouseLeave={()=>phase==='pickEnd'&&setHover(null)}>
        {cells.map(c=>{
          if(c.type==='e') return <div key={c.k} className="cal-cell empty"/>;
          const {d,iso,isEp,inRng,rFirst,rLast,isToday} = c;
          const disabled = isDisabled(iso);
          const cellCls = ['cal-cell',
            isEp&&!disabled?'ep':'',
            inRng&&!disabled?'in-range':'',
            rFirst?'rng-first':'',
            rLast?'rng-last':'',
          ].filter(Boolean).join(' ');
          const numCls = ['cal-num',
            isEp&&!disabled?'ep':'',
            isToday&&!isEp?'today':'',
          ].filter(Boolean).join(' ');
          return (
            <div key={iso} className={cellCls}
              style={disabled?{opacity:.3,cursor:'not-allowed',pointerEvents:'none'}:{}}
              onMouseEnter={()=>!disabled&&phase==='pickEnd'&&setHover(iso)}
              onClick={()=>handleDay(d)}>
              <span className={numCls}>{d}</span>
            </div>
          );
        })}
      </div>

      {/* Footer */}
      <div className="cal-foot">
        <button className="cal-foot-btn" style={{color:'var(--text-3)'}}
          onClick={()=>{setSelS(null);setSelE(null);setPhase('pickStart');}}>
          ЧіВ Чів„ўЧіВ§ЧівҖўЧів„ў
        </button>
        <button className="cal-foot-btn" style={{color:'var(--blue)'}}
          onClick={()=>{onCommit(selS||null,selE||null);onClose();}}>
          ЧіВҗЧів„ўЧіВ©ЧівҖўЧіВЁ
        </button>
      </div>
    </div>
  );
}

/* Date Range Cell Ч’вӮ¬вҖқ graphical timeline bar */
function DateRangeCell({startDate, dueDate, onChange, isParent=false, minDate='', maxDate=''}) {
  const [open,setOpen]=useState(false);
  const ref=useRef(null);
  useEffect(()=>{
    if(!open)return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[open]);

  const today=todayISO();

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ progress calculation Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  let pct=0, barColor='var(--accent)', trackColor='rgba(37,99,235,.14)', textOnBar=false, daysLeft=null;
  const hasRange=startDate&&dueDate;
  if(hasRange){
    const s=new Date(startDate), e=new Date(dueDate), n=new Date(today);
    const total=Math.max(1,e-s);
    const elapsed=n-s;
    pct=Math.max(0,Math.min(100,Math.round(elapsed/total*100)));
    daysLeft=Math.round((e-n)/86400000);

    if(today>dueDate){
      /* Overdue Ч’вӮ¬вҖқ full red bar */
      barColor='#EF4444'; trackColor='rgba(239,68,68,.14)'; pct=100;
    } else {
      /* Normal Ч’вӮ¬вҖқ blue elapsed, halftone track is the remaining */
      barColor='var(--accent)'; trackColor='rgba(37,99,235,.14)';
    }
    textOnBar = pct >= 45;
  }

  return(
    <td ref={ref} style={{position:'relative',padding:'0 10px',cursor:'pointer',verticalAlign:'middle'}}
        onClick={()=>setOpen(o=>!o)}>

      {hasRange ? (
        isParent ? (
          <div title={`${pct}% ЧіВўЧівҖҳЧіВЁ${daysLeft!=null?` ЦІВ· ${Math.max(0,daysLeft)} Чів„ўЧіВһЧів„ўЧіВқ ЧіВ ЧівҖўЧіГ—ЧіВЁЧівҖў`:''}`}
            style={{position:'relative',height:22,borderRadius:11,background:trackColor,overflow:'hidden',minWidth:120,opacity:1}}>

            {/* Elapsed portion Ч’вӮ¬вҖқ solid fill */}
            {pct>0&&(
              <div style={{
                position:'absolute',top:0,left:0,bottom:0,
                width:`${pct}%`,background:barColor,
                borderRadius:11,opacity:.85,
              }}/>
            )}

            {/* "today" tick mark Ч’вӮ¬вҖқ white divider between elapsed and remaining */}
            {pct>0&&pct<100&&(
              <div style={{
                position:'absolute',top:2,bottom:2,
                left:`${pct}%`,
                width:2,background:'#fff',
                borderRadius:1,opacity:.95,
                transform:'translateX(-50%)',
                zIndex:2,
              }}/>
            )}

            {/* Date label Ч’вӮ¬вҖқ white when over the filled bar, colored otherwise */}
            <div style={{
              position:'absolute',inset:0,
              display:'flex',alignItems:'center',justifyContent:'center',
              fontSize:10,fontWeight:700,letterSpacing:.1,
              whiteSpace:'nowrap',pointerEvents:'none',
              color: textOnBar ? '#fff' : barColor,
              textShadow: textOnBar ? '0 1px 2px rgba(0,0,0,.25)' : 'none',
            }}>
              {fmtDate(dueDate)} Ч’вӮ¬вҖқ {fmtDate(startDate)}
            </div>
          </div>
        ) : (
          <div title={`${pct}% ЧіВўЧівҖҳЧіВЁ${daysLeft!=null?` ЦІВ· ${Math.max(0,daysLeft)} Чів„ўЧіВһЧів„ўЧіВқ ЧіВ ЧівҖўЧіГ—ЧіВЁЧівҖў`:''}`}
            style={{position:'relative',height:22,borderRadius:11,background:trackColor,overflow:'hidden',minWidth:120,filter:'saturate(60%) brightness(110%)'}}>
            {pct>0&&(
              <div style={{position:'absolute',top:0,left:0,bottom:0,width:`${pct}%`,background:barColor,borderRadius:11,opacity:.85}}/>
            )}
            {pct>0&&pct<100&&(
              <div style={{position:'absolute',top:2,bottom:2,left:`${pct}%`,width:2,background:'#fff',borderRadius:1,opacity:.95,transform:'translateX(-50%)',zIndex:2}}/>
            )}
            <div style={{position:'absolute',inset:0,display:'flex',alignItems:'center',justifyContent:'center',fontSize:10,fontWeight:700,letterSpacing:.1,whiteSpace:'nowrap',pointerEvents:'none',color:textOnBar?'#fff':barColor,textShadow:textOnBar?'0 1px 2px rgba(0,0,0,.25)':'none'}}>
              {fmtDate(dueDate)} Ч’вӮ¬вҖқ {fmtDate(startDate)}
            </div>
          </div>
        )
      ):(
        <span style={{color:'var(--text-3)',fontSize:12}}>Ч’вӮ¬вҖқ</span>
      )}

      {/* Calendar picker popup */}
      {open&&(
        <CalendarRangePicker
          initStart={startDate||null}
          initEnd={dueDate||null}
          minDate={minDate||''}
          maxDate={maxDate||''}
          onClose={()=>setOpen(false)}
          onCommit={(s,e)=>{
            const clamp=(v,mn,mx)=>mn&&v<mn?mn:mx&&v>mx?mx:v;
            const cs=clamp(s||'',minDate,maxDate);
            const ce=clamp(e||'',minDate,maxDate);
            onChange('startDate',cs);onChange('dueDate',ce);
          }}
        />
      )}
    </td>
  );
}

/* Days In Status Cell Ч’вӮ¬вҖқ shows how many days the latest status has been active (process tasks only) */
function DaysInStatusCell({task, threshold=null}) {
  const isProcess = task.taskType === 'process';
  const events = task.processEvents;

  if (!isProcess || !events?.length) {
    return (
      <td style={{padding:'0 10px',verticalAlign:'middle',textAlign:'center',
                  color:'var(--text-3)',fontSize:13}}>Ч’вӮ¬вҖқ</td>
    );
  }

  /* Find the latest event (same tiebreaker: period > milestone on same date) */
  const latest = [...events].sort((a,b) => {
    if (a.date !== b.date) return (b.date||'').localeCompare(a.date||'');
    return (EV_PERIOD.has(a.status)?0:1) - (EV_PERIOD.has(b.status)?0:1);
  })[0];

  if (!latest?.date) {
    return <td style={{padding:'0 10px',verticalAlign:'middle',textAlign:'center',color:'var(--text-3)',fontSize:13}}>Ч’вӮ¬вҖқ</td>;
  }

  const st      = EV_STATUSES[latest.status] || EV_STATUSES.missing;
  const days    = daysBetween(latest.date, todayISO());
  const delayed = threshold !== null && days > threshold;

  return (
    <td style={{padding:'0 10px',verticalAlign:'middle',textAlign:'center'}}>
      <span title={delayed
              ? `ЧіВўЧів„ўЧівҖәЧівҖўЧівҖҳ! ${days} Чів„ўЧіВһЧів„ўЧіВқ ЧівҖҳЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ "${st.label}" (ЧіВЎЧіВЈ: ${threshold})`
              : `${st.label} ЧіВһЧіВҗЧівҖ“ ${latest.date}`}
            style={{
              display:'inline-flex',alignItems:'center',justifyContent:'center',gap:4,
              padding:'3px 6px',borderRadius:20,whiteSpace:'nowrap',
              minWidth:52,fontSize:12,fontWeight:700,
              background: delayed ? 'rgba(239,68,68,.1)'  : st.bg,
              border:     delayed ? '2px solid #EF4444'   : `1.5px solid ${st.border}`,
              color:      delayed ? '#991B1B'              : st.color,
              boxShadow:  delayed ? '0 0 0 3px rgba(239,68,68,.18)' : 'none',
              animation:  delayed ? 'pulse-delay 2s infinite' : 'none',
            }}>
        {days}
        <span style={{fontWeight:400,fontSize:11,opacity:.8}}>Чів„ўЧіВі</span>
      </span>
    </td>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   StatusOwnerCell Ч’вӮ¬вҖқ merged responsible + event status + day count
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function StatusOwnerCell({task, onChangeResponsible, threshold=null}) {
  const {disciplines} = useContext(ListsCtx);
  const isProcess = task.taskType === 'process';
  const [open, setOpen] = useState(false);
  const ref = useRef(null);

  // Discipline: derived from latest event (process) or stored responsible (simple)
  const discId = isProcess ? getProcessResponsible(task) : (task.responsible || '');
  const disc   = disciplines.find(d => d.id === discId);

  // Latest event (process tasks only)
  const latest = isProcess && task.processEvents?.length
    ? [...task.processEvents].sort((a,b) => {
        if(a.date!==b.date) return (b.date||'').localeCompare(a.date||'');
        return (EV_PERIOD.has(a.status)?0:1)-(EV_PERIOD.has(b.status)?0:1);
      })[0]
    : null;

  const st      = latest ? (EV_STATUSES[latest.status] || EV_STATUSES.missing) : null;
  const days    = latest?.date ? daysBetween(latest.date, todayISO()) : null;
  const delayed = st && days !== null && threshold !== null && days > threshold;

  useEffect(()=>{
    if(!open)return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[open]);

  // Owner status is derived from process events Ч’вӮ¬вҖқ show nothing for non-process tasks
  if(!isProcess){
    return <td style={{padding:'0 10px',verticalAlign:'middle',background:'inherit'}}/>;
  }

  if(!disc && !st){
    return <td style={{padding:'0 10px',verticalAlign:'middle',textAlign:'center',color:'var(--text-3)',fontSize:13}}>Ч’вӮ¬вҖқ</td>;
  }

  // Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Unified chip Ч’вӮ¬вҖқ solid fill matching the discipline pill in 'ЧіГ—ЧівҖ”ЧівҖўЧіВқ' column Ч’вҖқвӮ¬Ч’вҖқвӮ¬
  const chipColor  = disc ? disc.color : st?.color || '#6B7280';
  const chipBorder = delayed
    ? '2px solid #EF4444'
    : 'none';
  const chipShadow = delayed ? '0 0 0 2px rgba(239,68,68,.28)' : 'none';
  const chipAnim   = delayed ? 'pulse-delay 2s infinite' : 'none';
  const title = [
    disc?.label,
    st ? `${st.label}${days!==null?` ЦІВ· ${days} Чів„ўЧіВһЧів„ўЧіВқ`:''}` : null,
  ].filter(Boolean).join(' Ч’вӮ¬вҖқ ');

  const inner = (
    <span
      title={title}
      style={{
        display:'flex',alignItems:'center',gap:0,
        background:'transparent',
        border: chipBorder,
        borderRadius: 6,
        boxShadow: chipShadow,
        animation: chipAnim,
        width:'100%',
        overflow:'hidden',
        fontSize:11,fontWeight:700,
        whiteSpace:'nowrap',
      }}>
      {/* Discipline label Ч’вӮ¬вҖқ solid fill, 50% */}
      {disc&&<span style={{
        flex:1,display:'flex',alignItems:'center',justifyContent:'center',
        padding:'2px 4px',fontWeight:700,letterSpacing:.2,
        background:chipColor, color:'#fff',
        minWidth:0,
      }}>
        {disc.label}
      </span>}
      {/* Divider */}
      {disc && st && <span style={{
        width:1, alignSelf:'stretch', flexShrink:0,
        background: delayed ? '#EF4444' : `rgba(0,0,0,.15)`,
      }}/>}
      {/* EV status Ч’вӮ¬вҖқ own status colors, 50% */}
      {st&&<span style={{
        flex:1,display:'inline-flex',alignItems:'center',justifyContent:'center',gap:2,
        padding:'2px 4px',
        background: delayed ? 'rgba(239,68,68,.12)' : st.bg,
        color:      delayed ? '#991B1B'             : st.color,
        minWidth:0,
      }}>
        <span style={{fontSize:11,lineHeight:1}}>{st.symbol}</span>
        {days!==null&&<><span style={{fontSize:11}}>{days}</span>
          <span style={{fontWeight:400,fontSize:9,opacity:.75}}>Чів„ўЧіВі</span></>}
      </span>}
    </span>
  );

  if(isProcess){
    return <td style={{padding:'0 6px',verticalAlign:'middle'}}>{inner}</td>;
  }

  // Simple task Ч’вӮ¬вҖқ responsible is editable
  return (
    <td ref={ref} style={{position:'relative',cursor:'pointer',padding:'0 6px',verticalAlign:'middle'}}
        onClick={()=>setOpen(o=>!o)}>
      {inner}
      {open&&(
        <div className="dp" onClick={e=>e.stopPropagation()}>
          <div className="dp-title">ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div>
          {disciplines.map(d=>(
            <div key={d.id} className={`dp-opt${d.id===discId?' sel':''}`}
              onClick={()=>{onChangeResponsible(d.id);setOpen(false);}}>
              <span className="pill" style={{background:d.color,color:'#fff'}}>{d.label}</span>
            </div>
          ))}
          {discId&&<><div className="dp-sep"/>
            <div className="dp-opt" style={{color:'var(--text-3)'}}
              onClick={()=>{onChangeResponsible('');setOpen(false);}}>ЧіВңЧіВңЧіВҗ ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div></>}
        </div>
      )}
    </td>
  );
}

/* Comment Cell */
function CommentCell({comment, onChange}) {
  const [editing,setEditing]=useState(false);
  const [draft,setDraft]=useState(comment||'');
  useEffect(()=>setDraft(comment||''),[comment]);
  const commit=()=>{onChange(draft);setEditing(false);};
  return(
    <td onClick={()=>setEditing(true)}>
      {editing
        ?<input className="cmt-input" autoFocus value={draft} onChange={e=>setDraft(e.target.value)}
            onBlur={commit} onKeyDown={e=>{if(e.key==='Enter'||e.key==='Escape')commit();}}/>
        :<span className="cmt">{comment||''}</span>
      }
    </td>
  );
}

/* Subtask discipline cell */
function SubtaskDisciplineCell({subtask, onUpdate}) {
  const {disciplines, onEditList} = useContext(ListsCtx);
  const [open, setOpen] = useState(false);
  const ref = useRef(null);
  useEffect(()=>{
    if(!open) return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[open]);
  const disc = disciplines.find(d=>d.id===(subtask.discipline||''));
  return (
    <td ref={ref} style={{position:'relative',cursor:'pointer',padding:'0 8px',background:'inherit'}}
        onClick={()=>setOpen(o=>!o)}>
      <div style={{display:'flex',width:'100%',justifyContent:'center'}}>
      {disc
        ? <span className="pill" style={{color:'#fff',background:disc.color,minWidth:53,justifyContent:'center'}}>{disc.label}</span>
        : <span style={{color:'var(--text-3)',fontSize:12,flex:1,textAlign:'center'}}>Ч’вӮ¬вҖқ</span>}
      </div>
      {open&&(
        <div className="dp" onClick={e=>e.stopPropagation()}>
          <div className="dp-title">ЧіГ—ЧівҖ”ЧівҖўЧіВқ</div>
          {disciplines.map(d=>(
            <div key={d.id} className={`dp-opt${d.id===(subtask.discipline||'')?' sel':''}`}
              onClick={()=>{onUpdate({...subtask,discipline:d.id});setOpen(false);}}>
              <span className="pill" style={{color:'#fff',background:d.color}}>{d.label}</span>
            </div>
          ))}
          {subtask.discipline&&<><div className="dp-sep"/>
            <div className="dp-opt" style={{color:'var(--text-3)'}}
              onClick={()=>{onUpdate({...subtask,discipline:''});setOpen(false);}}>ЧіВңЧіВңЧіВҗ ЧіГ—ЧівҖ”ЧівҖўЧіВқ</div></>}
          <div className="dp-sep"/>
          <div className="dp-opt" style={{color:'var(--text-2)',fontSize:11,gap:5}}
            onClick={()=>{setOpen(false);onEditList('discipline');}}>
            <span>Ч’ВңВҸЧҹВёВҸ</span>ЧіВўЧіВЁЧівҖўЧіВҡ ЧіВЁЧіВ©Чів„ўЧіВһЧівҖқ
          </div>
        </div>
      )}
    </td>
  );
}

/* Subtask owner cell Ч’вӮ¬вҖқ discipline chip + EV status badge, both editable */
function SubtaskOwnerCell({subtask, onUpdate, threshold=null}) {
  const {disciplines} = useContext(ListsCtx);
  const [panel, setPanel] = useState(null); // null | 'disc' | 'evst' | 'add'
  const [addDisc,   setAddDisc]   = useState('');
  const [addStatus, setAddStatus] = useState('progress');
  const ref = useRef(null);

  useEffect(()=>{
    if(!panel) return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setPanel(null);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[panel]);

  // Owner status is derived from process events Ч’вӮ¬вҖқ meaningless for non-process subtasks
  if (!subtask.isProcess) {
    return <td style={{padding:'0 8px',verticalAlign:'middle',background:'inherit'}}/>;
  }

  // Owner status = latest event in this process subtask's event sequence
  const events = subtask.events || [];
  const latestEv = events.length
    ? [...events].sort((a,b)=>{
        if(a.date!==b.date) return (b.date||'').localeCompare(a.date||'');
        return (EV_PERIOD.has(a.status)?0:1)-(EV_PERIOD.has(b.status)?0:1);
      })[0]
    : null;
  // Discipline chip: prefer latest event's assignee (who is currently responsible),
  // fall back to subtask.discipline if no events yet
  const discId = latestEv?.assignee || subtask.discipline || '';
  const disc   = disciplines.find(d=>d.id===discId);
  const evSt   = latestEv ? (EV_STATUSES[latestEv.status]||null) : null;
  const days   = latestEv?.date ? daysBetween(latestEv.date, todayISO()) : null;

  const delayed   = evSt && days !== null && threshold !== null && days > threshold;
  const chipColor = disc ? disc.color : '#6B7280';
  const hasChip   = disc || evSt;

  return (
    <td ref={ref} style={{position:'relative',padding:'0 8px',verticalAlign:'middle',background:'inherit'}}>
      <div style={{display:'flex',alignItems:'center',gap:5,flexWrap:'nowrap'}}>

        {/* Unified chip */}
        {hasChip
          ? <span
              title={[disc?.label, evSt ? `${evSt.label}${days!==null?` ЦІВ· ${days} Чів„ўЧіВһЧів„ўЧіВқ`:''}` : null, delayed?'Ч’ВҡВ  ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧівҖқ ЧівҖҳЧіВЎЧіВЈ Чів„ўЧіВһЧів„ўЧіВқ':null].filter(Boolean).join(' Ч’вӮ¬вҖқ ')}
              style={{
                display:'inline-flex',alignItems:'center',gap:0,
                background:'transparent',
                border:  delayed ? '2px solid #EF4444' : 'none',
                borderRadius:6,overflow:'hidden',
                boxShadow: delayed ? '0 0 0 2px rgba(239,68,68,.28)' : 'none',
                animation: delayed ? 'pulse-delay 2s infinite' : 'none',
                fontSize:11,fontWeight:700,
                flexShrink:0,whiteSpace:'nowrap',cursor:'pointer',
              }}>
              {/* Discipline part Ч’вӮ¬вҖқ solid fill, fixed width */}
              <span onClick={()=>setPanel(p=>p==='disc'?null:'disc')}
                style={{display:'inline-flex',alignItems:'center',justifyContent:'center',
                  width:48,padding:'2px 0',fontWeight:700,background:chipColor,color:'#fff'}}>
                {disc ? disc.label : <span style={{opacity:.5}}>Ч’вӮ¬вҖқ</span>}
              </span>
              {/* Divider */}
              {evSt&&<span style={{width:1,alignSelf:'stretch',background:delayed?'#EF4444':'rgba(0,0,0,.12)',flexShrink:0}}/>}
              {/* EV status part Ч’вӮ¬вҖқ own status colors, fixed width */}
              {evSt&&<span onClick={()=>setPanel(p=>p==='evst'?null:'evst')}
                style={{display:'inline-flex',alignItems:'center',justifyContent:'center',gap:2,
                  width:48,padding:'2px 0',
                  background:delayed?'rgba(239,68,68,.12)':evSt.bg,
                  color:delayed?'#991B1B':evSt.color}}>
                <span style={{fontSize:11,lineHeight:1}}>{evSt.symbol}</span>
                {days!==null&&<><span style={{fontSize:11}}>{days}</span>
                  <span style={{fontWeight:400,fontSize:9,opacity:.75}}>Чів„ўЧіВі</span></>}
              </span>}
              {/* + button when no EV status Ч’вӮ¬вҖқ same fixed width */}
              {!evSt&&<span onClick={()=>setPanel(p=>p==='evst'?null:'evst')}
                style={{display:'inline-flex',alignItems:'center',justifyContent:'center',
                  width:48,padding:'2px 0',background:chipColor,color:'rgba(255,255,255,.5)',fontSize:12,lineHeight:1}}>+</span>}
            </span>
          : <span onClick={()=>setPanel(p=>p==='disc'?null:'disc')}
              style={{width:22,height:22,borderRadius:'50%',border:'1.5px dashed var(--border-strong)',
                display:'flex',alignItems:'center',justifyContent:'center',
                fontSize:13,color:'var(--text-3)',cursor:'pointer',flexShrink:0}}>+</span>
        }

        {/* Last event title/note */}
        {(latestEv?.title||latestEv?.note)&&<span style={{fontSize:11,color:'var(--text-2)',overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap',maxWidth:120,flexShrink:1}}
          title={latestEv.title||latestEv.note}>{latestEv.title||latestEv.note}</span>}

        {/* Add-event button Ч’вӮ¬вҖқ visible on row hover */}
        <button className="add-ev-inline" title="ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ"
          onClick={e=>{
            e.stopPropagation();
            setAddDisc(discId||'');
            setAddStatus(latestEv?.status||'progress');
            setPanel(p=>p==='add'?null:'add');
          }}>+</button>
      </div>

      {/* Discipline picker Ч’вӮ¬вҖқ updates latest event's assignee, NOT subtask.discipline */}
      {panel==='disc'&&(
        <div className="dp" onClick={e=>e.stopPropagation()}>
          <div className="dp-title">ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў Ч’вӮ¬вҖқ ЧіГ—ЧівҖ”ЧівҖўЧіВқ</div>
          {disciplines.map(d=>(
            <div key={d.id} className={`dp-opt${d.id===discId?' sel':''}`}
              onClick={()=>{
                if(latestEv){
                  const evts=[...(subtask.events||[])];
                  const idx=evts.findIndex(e=>e.id===latestEv.id);
                  if(idx>=0) evts[idx]={...evts[idx],assignee:d.id};
                  onUpdate({...subtask,events:evts});
                } else {
                  onUpdate({...subtask,discipline:d.id});
                }
                setPanel(null);
              }}>
              <span className="pill" style={{background:d.color,color:'#fff'}}>{d.label}</span>
            </div>
          ))}
          {discId&&<><div className="dp-sep"/>
            <div className="dp-opt" style={{color:'var(--text-3)'}}
              onClick={()=>{
                if(latestEv){
                  const evts=[...(subtask.events||[])];
                  const idx=evts.findIndex(e=>e.id===latestEv.id);
                  if(idx>=0) evts[idx]={...evts[idx],assignee:''};
                  onUpdate({...subtask,events:evts});
                } else {
                  onUpdate({...subtask,discipline:''});
                }
                setPanel(null);
              }}>ЧіВңЧіВңЧіВҗ ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div></>}
        </div>
      )}

      {/* EV Status picker */}
      {panel==='evst'&&(
        <div className="dp" onClick={e=>e.stopPropagation()} style={{minWidth:180}}>
          <div className="dp-title">ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ</div>
          {Object.values(EV_STATUSES).filter(s=>s.id!=='missing').map(s=>(
            <div key={s.id} className={`dp-opt${subtask.ownerEvStatus===s.id?' sel':''}`}
              onClick={()=>{onUpdate({...subtask,ownerEvStatus:s.id,ownerEvDate:todayISO()});setPanel(null);}}>
              <span style={{
                display:'inline-flex',alignItems:'center',gap:4,padding:'2px 8px',borderRadius:12,
                fontSize:11,fontWeight:700,background:s.bg,border:`1px solid ${s.border}`,color:s.color,
              }}>
                {s.symbol} {s.label}
              </span>
            </div>
          ))}
          {subtask.ownerEvStatus&&<><div className="dp-sep"/>
            <div className="dp-opt" style={{color:'var(--text-3)'}}
              onClick={()=>{onUpdate({...subtask,ownerEvStatus:'',ownerEvDate:''});setPanel(null);}}>ЧіВңЧіВңЧіВҗ ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ</div></>}
        </div>
      )}

      {/* Add new event mini-panel */}
      {panel==='add'&&(
        <div className="dp" onClick={e=>e.stopPropagation()} style={{minWidth:220,padding:'10px 10px 8px'}}>
          <div className="dp-title" style={{marginBottom:8}}>ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ ЧівҖ”ЧівҖңЧіВ©</div>

          {/* Discipline row */}
          <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',marginBottom:4,letterSpacing:'0.04em'}}>ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div>
          <div style={{display:'flex',flexWrap:'wrap',gap:4,marginBottom:10}}>
            {disciplines.map(d=>(
              <span key={d.id} onClick={()=>setAddDisc(d.id)}
                style={{padding:'2px 8px',borderRadius:10,fontSize:10,fontWeight:700,cursor:'pointer',
                  background:d.id===addDisc?d.color:d.bg,
                  color:d.id===addDisc?'#fff':d.color,
                  border:`1px solid ${d.color}`,transition:'all .1s'}}>
                {d.label}
              </span>
            ))}
          </div>

          {/* Status row */}
          <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',marginBottom:4,letterSpacing:'0.04em'}}>ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ</div>
          <div style={{display:'flex',flexWrap:'wrap',gap:4,marginBottom:12}}>
            {Object.values(EV_STATUSES).filter(s=>s.id!=='missing').map(s=>(
              <span key={s.id} onClick={()=>setAddStatus(s.id)}
                style={{display:'inline-flex',alignItems:'center',gap:3,padding:'2px 7px',borderRadius:10,
                  fontSize:10,fontWeight:700,cursor:'pointer',
                  background:s.id===addStatus?s.border:s.bg,
                  color:s.id===addStatus?'#fff':s.color,
                  border:`1px solid ${s.border}`,transition:'all .1s'}}>
                {s.symbol} {s.label}
              </span>
            ))}
          </div>

          {/* Actions */}
          <div style={{display:'flex',gap:6,justifyContent:'flex-end'}}>
            <button onClick={()=>setPanel(null)}
              style={{padding:'4px 10px',fontSize:11,border:'1px solid var(--border-strong)',
                borderRadius:5,cursor:'pointer',background:'var(--surface)',fontFamily:'inherit',color:'var(--text-2)'}}>
              ЧівҖҳЧів„ўЧіЛңЧівҖўЧіВң
            </button>
            <button onClick={()=>{
                const newEv={id:uid(),title:'',status:addStatus,assignee:addDisc,date:todayISO(),note:''};
                const sorted=[...((subtask.events)||[])].sort((a,b)=>(b.date||'').localeCompare(a.date||''));
                onUpdate({...subtask,events:[newEv,...(subtask.events||[])]});
                setPanel(null);
              }}
              style={{padding:'4px 12px',fontSize:11,border:'none',
                borderRadius:5,cursor:'pointer',background:'var(--accent)',color:'#fff',fontFamily:'inherit',fontWeight:600}}>
              Ч’ВңвҖң ЧівҖқЧівҖўЧіВЎЧіВЈ
            </button>
          </div>
        </div>
      )}
    </td>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   SubtaskRow
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function SubtaskRow({subtask, onUpdate, onDelete, onOpenProcess, autoFocus=false, visibleColIds=[], threshold=null, parentStartDate='', parentDueDate='', nestedOpen=false, onToggleNested=null}) {
  const [editing,setEditing]=useState(autoFocus);
  const [title,setTitle]=useState(subtask.title);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Derive delayed flag Ч’вӮ¬вҖқ same logic as SubtaskOwnerCell Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const _evts = subtask.events||[];
  const _latestEv = _evts.length
    ? [..._evts].sort((a,b)=>(b.date||'').localeCompare(a.date||''))[0]
    : null;
  const _evDays = _latestEv?.date ? daysBetween(_latestEv.date, todayISO()) : null;
  const _isApproved = _latestEv?.status==='approved';
  const isDelayed = !_isApproved && _evDays!==null && threshold!==null && _evDays>threshold;
  const isDueDatePassed = subtask.dueDate && subtask.dueDate < todayISO() && subtask.statusId!=='C';
  const effectiveStatusId = (isDelayed || isDueDatePassed) ? 'S' : (subtask.statusId||'N');
  const inputRef=useRef(null);
  useEffect(()=>{if(autoFocus&&inputRef.current)inputRef.current.focus();},[]);
  const commit=()=>{
    if(title.trim()) onUpdate({...subtask,title:title.trim()});
    else onDelete();
    setEditing(false);
  };
  const isProc = !!subtask.isProcess;
  const evCount = (subtask.events||[]).length;
  return(
    <tr className="sub-row" style={{opacity:subtask.done?.5:1}}>
      <td className="sticky-td">
        <div className="sub-name-inner">
          <div onClick={()=>onUpdate({...subtask,done:!subtask.done})}
            title={isProc?'ЧіГ—ЧіГ—-ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ Ч’вӮ¬вҖқ ЧіВ§ЧіВңЧів„ўЧіВ§ Чів„ўЧіВһЧіВ Чів„ў ЧіВңЧівҖқЧівҖ”ЧівҖ“ЧіВЁЧівҖқ ЧіВңЧіВЁЧівҖҷЧів„ўЧіВң':'ЧіВңЧівҖ”ЧіВҘ ЧіВңЧіВЎЧів„ўЧіВһЧівҖўЧіВҹ ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ | ЧіВ§ЧіВңЧів„ўЧіВ§ Чів„ўЧіВһЧіВ Чів„ў Ч’вҖ вҖҷ ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ'}
            onContextMenu={e=>{e.preventDefault();onUpdate({...subtask,isProcess:!isProc,events:subtask.events||[]});}}
            style={{width:13,height:13,borderRadius:'50%',flexShrink:0,cursor:'pointer',
              border:`1.5px solid ${subtask.done?'#059669':'#8E8E8E'}`,
              background:subtask.done?'#059669':(isProc?'#8E8E8E':'transparent'),
              display:'flex',alignItems:'center',justifyContent:'center'}}>
            {subtask.done?'Ч’ВңвҖң':''}
          </div>
          {editing
            ?<input ref={inputRef} className="name-edit-input" style={{fontSize:12}} value={title}
                onChange={e=>setTitle(e.target.value)} onBlur={commit}
                onKeyDown={e=>{if(e.key==='Enter')commit();if(e.key==='Escape'){setTitle(subtask.title);setEditing(false);}}}/>
            :<span className="name-text" style={{fontSize:12,textDecoration:subtask.done?'line-through':'none',color:subtask.done?'var(--text-3)':'var(--text)',cursor:'text'}}
                  onClick={e=>{e.stopPropagation();setTitle(subtask.title||'');setEditing(true);}}>
                  {subtask.title||(isProc?<span style={{color:'var(--text-3)'}}>ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ ЧіВңЧіВңЧіВҗ ЧіВ©ЧіВқ</span>:<span style={{color:'var(--text-3)'}}>ЧіВңЧіВңЧіВҗ ЧіВ©ЧіВқ</span>)}
                </span>
          }
          {isProc&&(subtask.subtasks||[]).length>0&&onToggleNested&&(()=>{
            const nested=subtask.subtasks||[];
            const doneCnt=nested.filter(s=>s.done).length;
            return(
              <span className="sub-badge" onClick={e=>{e.stopPropagation();onToggleNested();}}
                title={nestedOpen?'ЧівҖқЧіВЎЧіГ—ЧіВЁ ЧіГ—ЧіГ—Чів„ў-ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—':'ЧівҖқЧіВҰЧівҖҷ ЧіГ—ЧіГ—Чів„ў-ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—'}
                style={{cursor:'pointer',display:'inline-flex',alignItems:'center',gap:3}}>
                <span style={{transition:'transform .15s',display:'inline-block',fontSize:8,
                  transform:nestedOpen?'rotate(0deg)':'rotate(-90deg)'}}>Ч’вҖ“Вҫ</span>
                {doneCnt}/{nested.length}
              </span>
            );
          })()}
          {isProc&&<span className="sub-badge" title="ЧіВЁЧіВҰЧіВЈ ЧіВўЧівҖңЧівҖәЧівҖўЧіВ Чів„ўЧіВқ" onClick={()=>onOpenProcess&&onOpenProcess()}
            style={{cursor:'pointer',color:'var(--accent)',background:'rgba(99,102,241,.10)'}}>Ч’ВҠВЎ {evCount}</span>}
          <button className="del-btn" onClick={onDelete}>Ч’ВңвҖў</button>
        </div>
      </td>
      {visibleColIds.filter(id=>id!=='__name').map(id=>{
        switch(id){
          case '__status':
            return <td key="__status" style={{padding:'0 8px',verticalAlign:'middle',textAlign:'center',background:'inherit'}}>
              <div style={{display:'flex',justifyContent:'center'}}><StatusCircle statusId={effectiveStatusId} onChange={v=>onUpdate({...subtask,statusId:v})}/></div></td>;
          case '__priority':
            return <PriorityCell key="__priority" priority={subtask.priority||''} onChange={v=>onUpdate({...subtask,priority:v})}/>;
          case '__discipline':
            return <SubtaskDisciplineCell key="__discipline" subtask={subtask} onUpdate={onUpdate}/>;
          case '__owner_status':
            return <SubtaskOwnerCell key="__owner_status" subtask={subtask} onUpdate={onUpdate} threshold={threshold}/>;
          case '__dates':
            return <DateRangeCell key="__dates" startDate={subtask.startDate||''} dueDate={subtask.dueDate||''}
              minDate={parentStartDate} maxDate={parentDueDate}
              onChange={(f,v)=>onUpdate({...subtask,[f]:v})}/>;
          default:
            return <td key={id} style={{background:'inherit'}}/>;
        }
      })}
      <td style={{background:'inherit'}}/>
    </tr>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   TaskRow
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Process Task Panel
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
/* Auto-follow: milestone statuses auto-create their follow-up period status */
const PANEL_W_KEY    = 'pm_panel_width';
const PANEL_W_DEFAULT = () => Math.min(780, Math.round(window.innerWidth * 0.78));
const EV_AUTO_FOLLOW = { sent: 'response', comments: 'progress' };
/* Statuses available to add manually (missing/response are auto-created) */
const EV_ADD_STATUSES = ['progress','sent','comments','approved'];

function getNextSuggestedStatus(lastStatus) {
  if (!lastStatus) return 'progress';
  const map = { missing:'progress', progress:'sent', sent:'response', response:'sent', comments:'progress', approved:'progress' };
  return map[lastStatus] || 'progress';
}

/* Single-timeline process panel:
   ONE chronological event chain (each event carries its own assignee = who holds the
   ball at that step). The "current responsible" is the latest event's assignee.
   Subtasks live per-event (inside the event they were born from) AND as general
   task-level items. The tracks model (TrackSection) is kept in code but hidden. */
/* Events-only side panel, scoped to ONE process node (a subtask). Opened by
   clicking a process subtask in the main list. Shows only the event sequence;
   subtasks themselves live in the main list, not here. */
function ProcessTaskPanel({parentTitle='', node, onUpdate, onClose, onAddToMain, threshold=null, parentStartDate='', parentDueDate=''}) {
  const {disciplines} = useContext(ListsCtx);
  const nodeSubs = node.subtasks || [];
  const events   = node.events   || [];
  const setEvents = newEvents => onUpdate({...node, events:newEvents});

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Panel width (resizable, persisted) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [panelW, setPanelW] = useState(() => {
    const s = localStorage.getItem(PANEL_W_KEY);
    return s ? parseInt(s,10) : PANEL_W_DEFAULT();
  });
  const startResize = e => {
    e.preventDefault();
    const onMove = ev => {
      const w = Math.max(320, Math.min(ev.clientX, window.innerWidth - 60));
      setPanelW(w);
    };
    const onUp = ev => {
      const w = Math.max(320, Math.min(ev.clientX, window.innerWidth - 60));
      setPanelW(w);
      localStorage.setItem(PANEL_W_KEY, String(w));
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup',   onUp);
    };
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup',   onUp);
  };

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Color mode toggle Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Add-event form state Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const latestByDate = [...events].sort((a,b)=>{
    if(a.date !== b.date) return (b.date||'').localeCompare(a.date||'');
    return (EV_PERIOD.has(a.status)?0:1) - (EV_PERIOD.has(b.status)?0:1);
  })[0];
  const [showForm,     setShowForm]     = useState(events.length === 0);
  const [formStatus,   setFormStatus]   = useState(()=>getNextSuggestedStatus(latestByDate?.status));
  const [formDate,     setFormDate]     = useState(todayISO());
  const [formAssignee, setFormAssignee] = useState(latestByDate?.assignee||'');
  const [formNote,     setFormNote]     = useState('');

  const submitEvent = () => {
    const newEv = {id:uid(), title:'', status:formStatus, assignee:formAssignee, date:formDate, note:formNote, subtasks:[]};
    let updated = [...events, newEv];
    const follow = EV_AUTO_FOLLOW[formStatus];
    if (follow) updated = [...updated, {id:uid(), title:'', status:follow, assignee:formAssignee, date:formDate, note:'', subtasks:[]}];
    setEvents(updated);
    setShowForm(false); setFormNote('');
    setFormStatus(getNextSuggestedStatus(follow || formStatus));
  };
  const updateEvent = ev => setEvents(events.map(x=>x.id===ev.id?ev:x));
  const deleteEvent = id => setEvents(events.filter(e=>e.id!==id));

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Which event card is expanded (only one at a time) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [expandedEvId, setExpandedEvId] = useState(null);
  const collapseAll = () => setExpandedEvId(null);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Event-spawned subtasks live on this node Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [newSubId, setNewSubId] = useState(null);
  const addSub    = (fromEventId=null) => { const id=uid(); onUpdate({...node,subtasks:[...nodeSubs,{id,title:'',done:false,fromEventId}]}); setNewSubId(id); };
  const updateSub = s  => onUpdate({...node,subtasks:nodeSubs.map(x=>x.id===s.id?s:x)});
  const deleteSub = id => onUpdate({...node,subtasks:nodeSubs.filter(s=>s.id!==id)});

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Calculations Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const chronoEvts = [...events].sort((a,b)=>(a.date||'').localeCompare(b.date||''));
  const firstEvt   = chronoEvts[0];
  const lastChronoEvt = chronoEvts[chronoEvts.length-1];
  const isFinished = lastChronoEvt?.status === 'approved';
  const totalDays  = firstEvt ? daysBetween(firstEvt.date, isFinished ? lastChronoEvt.date : todayISO()) : null;

  const latestEvt = latestByDate;
  const latestSt  = EV_STATUSES[latestEvt?.status] || EV_STATUSES.missing;
  const daysInStatus = latestEvt?.date ? daysBetween(latestEvt.date, todayISO()) : null;
  const delayed = !isFinished && threshold!=null && daysInStatus!=null && daysInStatus>threshold;
  const firstDisc  = disciplines.find(d=>d.id===firstEvt?.assignee);
  const latestDisc = disciplines.find(d=>d.id===latestEvt?.assignee);

  const _today = todayISO();
  const sortedEvts = [...events].sort((a,b)=>{
    const aFut=(a.date||'')>_today, bFut=(b.date||'')>_today;
    if(aFut!==bFut) return aFut?1:-1;
    if(a.date!==b.date) return (b.date||'').localeCompare(a.date||'');
    return (EV_PERIOD.has(a.status)?0:1)-(EV_PERIOD.has(b.status)?0:1);
  });
  const autoFollow = EV_AUTO_FOLLOW[formStatus];

  /* lookup any event by id on this node (provenance for event-spawned subtasks) */
  const allEvById = {};
  events.forEach(e=>allEvById[e.id]=e);

  return (
    <>
      <div className="tp-overlay" onClick={onClose}/>
      <div className="tp-panel" style={{width:panelW}} onClick={e=>e.stopPropagation()}>
        {/* Resize handle Ч’вӮ¬вҖқ right edge */}
        <div onMouseDown={startResize}
          style={{position:'absolute',top:0,right:0,bottom:0,width:6,cursor:'col-resize',zIndex:10,
            background:'transparent',transition:'background .15s'}}
          onMouseEnter={e=>e.currentTarget.style.background='rgba(99,102,241,.28)'}
          onMouseLeave={e=>e.currentTarget.style.background='transparent'}/>
        <div className="tp-hdr">
          <div className="tp-proc-icon">Ч’ВҠВЎ</div>
          <span className="tp-task-title">
            {parentTitle && <span style={{color:'var(--text-3)',fontWeight:600}}>{parentTitle}<span style={{margin:'0 6px'}}>Ч’вӮ¬В№</span></span>}
            {node.title||'ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ'}
          </span>
          <button className="tp-close" onClick={onClose}>ЦівҖ”</button>
        </div>

        <div className="tp-split">
          {/* Left: event timeline (events-only) */}
          <div className="tp-events" style={{flex:1}} onClick={collapseAll}>
            {events.length>0 && (
              <div style={{margin:'12px 20px 4px',padding:'10px 14px',background:delayed?'rgba(239,68,68,.07)':'var(--bg)',borderRadius:10,display:'flex',alignItems:'center',gap:10,flexWrap:'wrap',border:`1px solid ${delayed?'#EF4444':'var(--border)'}`}}>
                {/* Discipline chip */}
                {latestDisc&&(
                  <span style={{display:'inline-flex',alignItems:'center',justifyContent:'center',
                    padding:'3px 12px',borderRadius:20,fontSize:12,fontWeight:700,
                    background:latestDisc.color,color:'#fff',flexShrink:0}}>
                    {latestDisc.label}
                  </span>
                )}
                {/* Status pill */}
                <span className="ev-status-pill" style={{background:delayed?'rgba(239,68,68,.12)':latestSt.bg,color:delayed?'#991B1B':latestSt.color,border:`1px solid ${delayed?'#EF4444':latestSt.border}`,fontSize:13,padding:'4px 12px'}}>
                  <span style={{fontWeight:800}}>{latestSt.symbol}</span> {latestSt.label}
                </span>
                {daysInStatus!=null&&!EV_NO_DAYS.has(latestEvt?.status) && (
                  <span style={{fontSize:11,fontWeight:700,color:delayed?'#991B1B':'var(--text-3)',background:delayed?'rgba(239,68,68,.12)':'var(--border)',borderRadius:6,padding:'2px 8px'}}>
                    {isFinished?'Ч’ВңвҖң':'Ч’ВҸВұ'} {daysInStatus}Чів„ўЧіВі ЧівҖҳЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ
                  </span>
                )}
                {delayed && <span style={{fontSize:10,fontWeight:700,color:'#fff',background:'#EF4444',borderRadius:10,padding:'2px 9px'}}>ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧівҖқ</span>}
                {totalDays!==null && (
                  <span style={{display:'inline-flex',alignItems:'center',gap:4,
                    fontSize:12,fontWeight:700,color:'var(--text)',
                    background:'var(--border)',borderRadius:6,padding:'3px 10px'}}>
                    <span style={{fontSize:13}}>Ч’ВҸВі</span>
                    <span>{totalDays}Чів„ўЧіВі ЧіВЎЧівҖқЧіВҙЧівҖә</span>
                  </span>
                )}
              </div>
            )}

            <div className="tp-ev-hdr">
              <span className="tp-ev-title">ЧіВЁЧіВҰЧіВЈ ЧівҖқЧіВўЧівҖңЧівҖәЧівҖўЧіВ Чів„ўЧіВқ</span>
              {!showForm && <button className="tp-add-ev-btn" onClick={()=>setShowForm(true)}>+ ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ</button>}
            </div>

            {showForm && (
              <div style={{margin:'0 20px 14px',background:'var(--bg)',border:'1px solid var(--border)',borderRadius:12,padding:'14px 16px',flexShrink:0}}>
                {autoFollow && (
                  <div style={{display:'flex',alignItems:'center',gap:6,fontSize:11,color:'var(--text-2)',background:'var(--border)',borderRadius:6,padding:'5px 10px',marginBottom:10,flexWrap:'wrap'}}>
                    <span style={{fontWeight:600}}>{EV_STATUSES[formStatus].symbol} {EV_STATUSES[formStatus].label}</span>
                    <span style={{color:'var(--text-3)'}}>Ч’вҖ вҖҷ Чів„ўЧівҖўЧіВҰЧіВЁ ЧіВҗЧівҖўЧіЛңЧівҖўЧіВһЧіЛңЧів„ўЧіГ—:</span>
                    <span style={{fontWeight:700,color:'var(--text)'}}>{EV_STATUSES[autoFollow].symbol} {EV_STATUSES[autoFollow].label}</span>
                    <span style={{color:'var(--text-3)'}}>ЧівҖҳЧіВҗЧівҖўЧіГ—ЧівҖў ЧіГ—ЧіВҗЧіВЁЧів„ўЧіВҡ</span>
                  </div>
                )}
                <div style={{display:'grid',gridTemplateColumns:'1fr 1fr 1fr',gap:8,marginBottom:10}}>
                  <div>
                    <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:'0.05em',marginBottom:4}}>ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ</div>
                    <select style={{width:'100%',padding:'5px 7px',border:'1px solid var(--border-strong)',borderRadius:6,fontSize:12,fontFamily:'inherit',background:'var(--surface)',outline:'none',color:'var(--text)',cursor:'pointer'}}
                      value={formStatus} onChange={e=>setFormStatus(e.target.value)}>
                      {EV_ADD_STATUSES.map(s=><option key={s} value={s}>{EV_STATUSES[s].label}</option>)}
                    </select>
                  </div>
                  <div>
                    <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:'0.05em',marginBottom:4}}>ЧіГ—ЧіВҗЧіВЁЧів„ўЧіВҡ</div>
                    <input type="date" value={formDate}
                      min={parentStartDate||undefined} max={parentDueDate||undefined}
                      onChange={e=>{
                        let v=e.target.value;
                        if(parentStartDate&&v<parentStartDate)v=parentStartDate;
                        if(parentDueDate&&v>parentDueDate)v=parentDueDate;
                        setFormDate(v);
                      }}
                      style={{width:'100%',padding:'5px 7px',border:'1px solid var(--border-strong)',borderRadius:6,fontSize:12,fontFamily:'inherit',background:'var(--surface)',outline:'none',color:'var(--text)'}}/>
                  </div>
                  <div>
                    <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:'0.05em',marginBottom:4}}>ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div>
                    <select style={{width:'100%',padding:'5px 7px',border:'1px solid var(--border-strong)',borderRadius:6,fontSize:12,fontFamily:'inherit',background:'var(--surface)',outline:'none',color:'var(--text)',cursor:'pointer'}}
                      value={formAssignee} onChange={e=>setFormAssignee(e.target.value)}>
                      <option value="">Ч’вӮ¬вҖқ ЧіГ—ЧівҖ”ЧівҖўЧіВқ Ч’вӮ¬вҖқ</option>
                      {disciplines.map(d=><option key={d.id} value={d.id}>{d.label}</option>)}
                    </select>
                  </div>
                </div>
                <div style={{marginBottom:10}}>
                  <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',textTransform:'uppercase',letterSpacing:'0.05em',marginBottom:4}}>ЧівҖқЧіВўЧіВЁЧівҖқ</div>
                  <textarea value={formNote} onChange={e=>setFormNote(e.target.value)} placeholder="ЧівҖқЧіВўЧіВЁЧівҖқ ЧіВҗЧівҖўЧівӮӘЧіВҰЧів„ўЧівҖўЧіВ ЧіВңЧів„ўЧіГ—..."
                    style={{width:'100%',padding:'6px 10px',border:'1px solid var(--border-strong)',borderRadius:6,fontSize:12,fontFamily:'inherit',background:'var(--surface)',outline:'none',resize:'vertical',minHeight:52,color:'var(--text)',display:'block'}}/>
                </div>
                <div style={{display:'flex',gap:6,justifyContent:'flex-end'}}>
                  <button onClick={()=>setShowForm(false)} style={{padding:'5px 13px',fontSize:12,border:'1px solid var(--border-strong)',borderRadius:6,cursor:'pointer',background:'var(--surface)',fontFamily:'inherit',color:'var(--text-2)'}}>ЧівҖҳЧів„ўЧіЛңЧівҖўЧіВң</button>
                  <button onClick={submitEvent} style={{padding:'5px 14px',fontSize:12,border:'none',borderRadius:6,cursor:'pointer',background:'var(--accent)',color:'#fff',fontFamily:'inherit',fontWeight:600}}>Ч’ВңвҖң ЧіВ©ЧіВһЧівҖўЧіВЁ ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ</button>
                </div>
              </div>
            )}

            <div className="tp-ev-list">
              {sortedEvts.length===0 && !showForm && (
                <div style={{textAlign:'center',color:'var(--text-3)',fontSize:13,padding:'32px 0'}}>
                  ЧіВҗЧів„ўЧіВҹ ЧіВўЧівҖңЧівҖәЧівҖўЧіВ Чів„ўЧіВқ. ЧіВңЧівҖ”ЧіВҘ "+ ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ" ЧіВңЧівҖқЧіГ—ЧівҖ”Чів„ўЧіВң.
                </div>
              )}
              {sortedEvts.length>0 && (
                <div className="ev-timeline">
                  <div className="ev-timeline-line"/>
                  {sortedEvts.map((ev,idx)=>(
                    <EventItem key={ev.id} ev={ev} evIdx={idx} allEvts={sortedEvts}
                      eventSubtasks={nodeSubs.filter(s=>s.fromEventId===ev.id)}
                      onAddSub={()=>addSub(ev.id)} onUpdateSub={updateSub}
                      onDeleteSub={deleteSub} newSubId={newSubId}
                      onAddToMain={onAddToMain}
                      minDate={parentStartDate} maxDate={parentDueDate}
                      expandedEvId={expandedEvId} onSetExpanded={setExpandedEvId}
                      onUpdate={updateEvent} onDelete={()=>deleteEvent(ev.id)}/>
                  ))}
                </div>
              )}
              {firstEvt && (
                <div style={{display:'flex',alignItems:'center',gap:8,padding:'12px 0 4px',borderTop:'1px solid var(--border)',marginTop:10,fontSize:11,color:'var(--text-3)'}}>
                  <span>Ч’вҖ”ВҺ ЧівҖқЧіГ—ЧівҖ”Чів„ўЧіВң:</span>
                  <span style={{fontFamily:'monospace'}}>{fmtDate(firstEvt.date)}</span>
                  {firstDisc && <span className="ev-disc-chip" style={{background:firstDisc.bg,color:firstDisc.color}}>{firstDisc.label}</span>}
                  {totalDays!==null && <span style={{marginRight:'auto'}}>{totalDays} Чів„ўЧіВһЧів„ўЧіВқ</span>}
                </div>
              )}
            </div>
          </div>
        </div>
      </div>
    </>
  );
}

/* One consultant/discipline lane: its own event-chain + its own subtasks */
function TrackSection({track, threshold=null, open, onToggle, onChange, onDelete}) {
  const {disciplines} = useContext(ListsCtx);
  const events   = track.events   || [];
  const subtasks = track.subtasks || [];
  const disc = disciplines.find(d=>d.id===track.discipline);
  const chipColor = disc ? disc.color : '#6B7280';

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ current status (latest by date, period tiebreak) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const latest = [...events].sort((a,b)=>{
    if(a.date!==b.date) return (b.date||'').localeCompare(a.date||'');
    return (EV_PERIOD.has(a.status)?0:1)-(EV_PERIOD.has(b.status)?0:1);
  })[0];
  const st = EV_STATUSES[latest?.status] || EV_STATUSES.missing;
  const isFinished = latest?.status==='approved';
  const days = latest?.date ? daysBetween(latest.date, todayISO()) : null;
  const delayed = !isFinished && threshold!=null && days!=null && days>threshold;
  const doneCount = subtasks.filter(s=>s.done).length;

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ event helpers Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const updateEvent = ev => onChange({events: events.map(x=>x.id===ev.id?ev:x)});
  const deleteEvent = id => onChange({events: events.filter(e=>e.id!==id)});
  const [showForm,   setShowForm]   = useState(false);
  const [formStatus, setFormStatus] = useState(()=>getNextSuggestedStatus(latest?.status));
  const [formDate,   setFormDate]   = useState(todayISO());
  const [formNote,   setFormNote]   = useState('');
  const autoFollow = EV_AUTO_FOLLOW[formStatus];
  const submitEvent = () => {
    const newEv = {id:uid(), status:formStatus, date:formDate, note:formNote, assignee:track.discipline};
    let updated = [...events, newEv];
    const follow = EV_AUTO_FOLLOW[formStatus];
    if (follow) updated = [...updated, {id:uid(), status:follow, date:formDate, note:'', assignee:track.discipline}];
    onChange({events:updated});
    setShowForm(false); setFormNote(''); setFormStatus(getNextSuggestedStatus(follow||formStatus));
  };

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ subtask helpers Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const [newSubId, setNewSubId] = useState(null);
  const addSub = () => { const id=uid(); onChange({subtasks:[...subtasks,{id,title:'',done:false,fromEventId:null}]}); setNewSubId(id); };
  const updateSub = s => onChange({subtasks: subtasks.map(x=>x.id===s.id?s:x)});
  const deleteSub = id => onChange({subtasks: subtasks.filter(s=>s.id!==id)});

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ timeline order: newest-first, futures at bottom; inject assignee for EventItem chip Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const _today = todayISO();
  const sortedEvts = [...events].map(e=>({...e,assignee:track.discipline})).sort((a,b)=>{
    const aFut=(a.date||'')>_today, bFut=(b.date||'')>_today;
    if(aFut!==bFut) return aFut?1:-1;
    if(a.date!==b.date) return (b.date||'').localeCompare(a.date||'');
    return (EV_PERIOD.has(a.status)?0:1)-(EV_PERIOD.has(b.status)?0:1);
  });

  const inp = {padding:'5px 7px',border:'1px solid var(--border-strong)',borderRadius:6,fontSize:12,fontFamily:'inherit',background:'var(--surface)',outline:'none',color:'var(--text)'};

  return (
    <div style={{border:`1px solid ${delayed?'#EF4444':'var(--border)'}`,borderRadius:12,overflow:'hidden',
                 boxShadow:delayed?'0 0 0 2px rgba(239,68,68,.16)':'none'}}>
      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Track header Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div onClick={onToggle} style={{display:'flex',alignItems:'center',gap:9,padding:'9px 13px',cursor:'pointer',background:'var(--bg)'}}>
        <span style={{fontSize:10,color:'var(--text-3)',flexShrink:0}}>{open?'Ч’вҖ“Вј':'Ч’вҖ“В¶'}</span>
        <select value={track.discipline||''} onClick={e=>e.stopPropagation()} onChange={e=>onChange({discipline:e.target.value})}
          style={{background:chipColor,color:'#fff',border:'none',borderRadius:6,fontSize:12,fontWeight:700,padding:'3px 8px',cursor:'pointer',fontFamily:'inherit',flexShrink:0}}>
          <option value="" style={{color:'#000'}}>Ч’вӮ¬вҖқ ЧіГ—ЧівҖ”ЧівҖўЧіВқ Ч’вӮ¬вҖқ</option>
          {disciplines.map(d=><option key={d.id} value={d.id} style={{color:'#000'}}>{d.label}</option>)}
        </select>
        <span className="ev-status-pill" style={{
          background:delayed?'rgba(239,68,68,.12)':st.bg, color:delayed?'#991B1B':st.color,
          border:`1px solid ${delayed?'#EF4444':st.border}`, fontSize:12, padding:'3px 10px', flexShrink:0}}>
          <span style={{fontWeight:800}}>{st.symbol}</span> {st.label}
        </span>
        {days!=null && (
          <span style={{fontSize:11,fontWeight:700,color:delayed?'#991B1B':'var(--text-3)',flexShrink:0}}>
            {isFinished?'Ч’ВңвҖң':'Ч’ВҸВұ'} {days}Чів„ўЧіВі
          </span>
        )}
        {delayed && <span style={{fontSize:10,fontWeight:700,color:'#fff',background:'#EF4444',borderRadius:10,padding:'1px 8px',flexShrink:0}}>ЧівҖ”ЧіВЁЧів„ўЧівҖҷЧівҖқ</span>}
        <span style={{marginRight:'auto',display:'flex',alignItems:'center',gap:9}}>
          {subtasks.length>0 && <span style={{fontSize:11,color:'var(--text-3)'}}>Ч’ЛңвҖҳ {doneCount}/{subtasks.length}</span>}
          <button className="ev-del" style={{opacity:1}} title="ЧіВһЧівҖ”ЧіВ§ ЧіВһЧіВЎЧіВңЧівҖўЧіВң" onClick={e=>{e.stopPropagation();onDelete();}}>ЦівҖ”</button>
        </span>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Track body Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      {open && (
        <div style={{display:'flex',borderTop:'1px solid var(--border)'}}>
          {/* Events */}
          <div style={{flex:1,minWidth:0,padding:'12px 14px',borderLeft:'1px solid var(--border)'}}>
            <div style={{display:'flex',alignItems:'center',marginBottom:10}}>
              <span style={{fontSize:12,fontWeight:700,color:'var(--text-2)'}}>ЧіВўЧівҖңЧівҖәЧівҖўЧіВ Чів„ўЧіВқ</span>
              {!showForm && <button className="tp-add-ev-btn" style={{marginRight:'auto'}} onClick={()=>setShowForm(true)}>+ ЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ</button>}
            </div>

            {showForm && (
              <div style={{background:'var(--surface)',border:'1px solid var(--border)',borderRadius:10,padding:'12px',marginBottom:12}}>
                {autoFollow && (
                  <div style={{display:'flex',alignItems:'center',gap:5,fontSize:10,color:'var(--text-2)',background:'var(--border)',borderRadius:6,padding:'4px 8px',marginBottom:8,flexWrap:'wrap'}}>
                    <span style={{fontWeight:600}}>{EV_STATUSES[formStatus].symbol} {EV_STATUSES[formStatus].label}</span>
                    <span style={{color:'var(--text-3)'}}>Ч’вҖ вҖҷ Чів„ўЧівҖўЧіВҰЧіВЁ:</span>
                    <span style={{fontWeight:700,color:'var(--text)'}}>{EV_STATUSES[autoFollow].symbol} {EV_STATUSES[autoFollow].label}</span>
                  </div>
                )}
                <div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:8,marginBottom:8}}>
                  <select style={{...inp,cursor:'pointer'}} value={formStatus} onChange={e=>setFormStatus(e.target.value)}>
                    {EV_ADD_STATUSES.map(s=><option key={s} value={s}>{EV_STATUSES[s].label}</option>)}
                  </select>
                  <input type="date" style={inp} value={formDate} onChange={e=>setFormDate(e.target.value)}/>
                </div>
                <input style={{...inp,width:'100%',marginBottom:8,display:'block',boxSizing:'border-box'}} placeholder="ЧівҖқЧіВўЧіВЁЧівҖқ..."
                  value={formNote} onChange={e=>setFormNote(e.target.value)} onKeyDown={e=>{if(e.key==='Enter')submitEvent();}}/>
                <div style={{display:'flex',gap:6,justifyContent:'flex-end'}}>
                  <button onClick={()=>setShowForm(false)} style={{padding:'5px 12px',fontSize:12,border:'1px solid var(--border-strong)',borderRadius:6,cursor:'pointer',background:'var(--surface)',fontFamily:'inherit',color:'var(--text-2)'}}>ЧівҖҳЧів„ўЧіЛңЧівҖўЧіВң</button>
                  <button onClick={submitEvent} style={{padding:'5px 13px',fontSize:12,border:'none',borderRadius:6,cursor:'pointer',background:'var(--accent)',color:'#fff',fontFamily:'inherit',fontWeight:600}}>Ч’ВңвҖң ЧіВ©ЧіВһЧівҖўЧіВЁ</button>
                </div>
              </div>
            )}

            {sortedEvts.length===0 && !showForm && (
              <div style={{textAlign:'center',color:'var(--text-3)',fontSize:12,padding:'16px 0'}}>ЧіВҗЧів„ўЧіВҹ ЧіВўЧівҖңЧівҖәЧівҖўЧіВ Чів„ўЧіВқ ЧівҖҳЧіВһЧіВЎЧіВңЧівҖўЧіВң ЧівҖ“ЧівҖқ.</div>
            )}
            {sortedEvts.length>0 && (
              <div className="ev-timeline">
                <div className="ev-timeline-line"/>
                {sortedEvts.map((ev,idx)=>(
                  <EventItem key={ev.id} ev={ev} evIdx={idx} allEvts={sortedEvts}
                    onUpdate={updateEvent} onDelete={()=>deleteEvent(ev.id)}/>
                ))}
              </div>
            )}
          </div>

          {/* Subtasks */}
          <div style={{width:240,flexShrink:0,padding:'12px 14px'}}>
            <div style={{fontSize:12,fontWeight:700,color:'var(--text-2)',marginBottom:8}}>ЧіГ—ЧіГ—Чів„ў-ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ— ЦІВ· {subtasks.length}</div>
            {subtasks.map(s=>(
              <SubPanelRow key={s.id} sub={s} autoFocus={s.id===newSubId} onUpdate={updateSub} onDelete={()=>deleteSub(s.id)}/>
            ))}
            <button className="tp-add-sub" onClick={addSub}>
              <span style={{fontSize:15,color:'var(--accent)',lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіГ—ЧіГ—-ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ
            </button>
          </div>
        </div>
      )}
    </div>
  );
}

function SubPanelRow({sub, onUpdate, onDelete, autoFocus, fromEvent, selected=false, onSelect, onMakeProcess, eventCount=0, onAddToMain}) {
  const {disciplines} = useContext(ListsCtx);
  const [title,setTitle]=useState(sub.title);
  const ref=useRef(null);
  useEffect(()=>{if(autoFocus&&ref.current)ref.current.focus();},[]);
  const commit=()=>{ if(title.trim()) onUpdate({...sub,title:title.trim()}); else onDelete(); };
  const disc = sub.discipline ? disciplines.find(d=>d.id===sub.discipline) : null;
  const hasMeta = disc || sub.startDate || sub.dueDate;
  return(
    <div className={`tp-sub-row${selected?' selected':''}`} onClick={onSelect?(e=>{if(!e.target.closest('input,button'))onSelect();}):undefined}
      style={{alignItems:hasMeta?'flex-start':'center',...(onSelect?{cursor:'pointer',...(selected?{background:'var(--accent-soft, rgba(99,102,241,.10))',borderRadius:7}:{})}:{})}}>
      <button className={`tp-sub-cb${sub.done?' done':''}`} style={{marginTop:hasMeta?3:0}}
        onClick={()=>onUpdate({...sub,done:!sub.done})}>
        {sub.done&&'Ч’ВңвҖң'}
      </button>
      <div style={{flex:1,minWidth:0,display:'flex',flexDirection:'column',gap:3}}>
        <input ref={ref} className={`tp-sub-text${sub.done?' done-text':''}`} style={{width:'100%'}}
          value={title} placeholder="ЧіГ—ЧіГ—-ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ..."
          onChange={e=>setTitle(e.target.value)}
          onBlur={commit}
          onKeyDown={e=>{if(e.key==='Enter')commit();if(e.key==='Escape')commit();}}/>
        {hasMeta && (
          <div style={{display:'flex',alignItems:'center',gap:6,flexWrap:'wrap',paddingRight:2}}>
            {disc && <span style={{fontSize:9,fontWeight:700,color:disc.color,background:disc.bg,borderRadius:5,padding:'1px 6px',whiteSpace:'nowrap'}}>{disc.label}</span>}
            {(sub.startDate||sub.dueDate) && (
              <span style={{fontSize:10,color:'var(--text-3)',fontFamily:'monospace',whiteSpace:'nowrap'}}>
                {sub.startDate?fmtDate(sub.startDate):'Ч’вӮ¬вҖқ'} Ч’вӮ¬В№ {sub.dueDate?fmtDate(sub.dueDate):'Ч’вӮ¬вҖқ'}
              </span>
            )}
          </div>
        )}
      </div>
      {sub.isProcess && eventCount>0 && (
        <span title="ЧіВЁЧіВҰЧіВЈ ЧіВўЧівҖңЧівҖәЧівҖўЧіВ Чів„ўЧіВқ" style={{flexShrink:0,fontSize:9,fontWeight:700,color:'var(--accent)',background:'rgba(99,102,241,.10)',borderRadius:5,padding:'1px 5px',whiteSpace:'nowrap'}}>
          Ч’ВҠВЎ {eventCount}
        </span>
      )}
      {fromEvent && (
        <span title={`ЧіВһЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ: ${EV_STATUSES[fromEvent.status]?.label||''}`}
          style={{flexShrink:0,fontSize:9,fontWeight:700,color:'var(--text-3)',background:'var(--border)',borderRadius:5,padding:'1px 5px',whiteSpace:'nowrap'}}>
          Ч’ВҠВЎ {EV_STATUSES[fromEvent.status]?.symbol||''}
        </span>
      )}
      {sub.isProcess
        ? (onSelect && <button className="tp-sub-del" onClick={onSelect} title="ЧівҖқЧіВҰЧівҖҷ ЧіВЁЧіВҰЧіВЈ ЧіВўЧівҖңЧівҖәЧівҖўЧіВ Чів„ўЧіВқ" style={{color:'var(--accent)'}}>Ч’вӮ¬В№</button>)
        : (onMakeProcess && <button className="tp-sub-del" onClick={onMakeProcess} title="ЧівҖқЧівӮӘЧівҖўЧіВҡ ЧіВңЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ" style={{color:'var(--text-3)',fontSize:13}}>Ч’ВҠВЎ</button>)}
      {onAddToMain && (
        <button onClick={e=>{e.stopPropagation();onAddToMain();}}
          title="ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВңЧіВЁЧіВ©Чів„ўЧіВһЧівҖқ ЧівҖқЧіВЁЧіВҗЧіВ©Чів„ўЧіГ—"
          style={{flexShrink:0,fontSize:10,fontWeight:700,padding:'2px 6px',borderRadius:6,border:'1px solid var(--accent)',
            background:'transparent',color:'var(--accent)',cursor:'pointer',whiteSpace:'nowrap',lineHeight:1.4}}>
          + ЧіВЁЧіВ©Чів„ўЧіВһЧівҖқ
        </button>
      )}
      <button className="tp-sub-del" onClick={onDelete}>ЦівҖ”</button>
    </div>
  );
}

function EventItem({ev, evIdx, allEvts, onUpdate, onDelete, colorByAssignee=false, eventSubtasks=[], onAddSub, onUpdateSub, onDeleteSub, newSubId, onAddToMain, expandedEvId, onSetExpanded, minDate='', maxDate=''}) {
  const {disciplines} = useContext(ListsCtx);
  // Support both controlled (expandedEvId) and uncontrolled (local) expanded state
  const [localExpanded, setLocalExpanded] = useState(false);
  const expanded    = onSetExpanded ? expandedEvId === ev.id : localExpanded;
  const setExpanded = (val) => {
    if(onSetExpanded) onSetExpanded(val ? ev.id : null);
    else setLocalExpanded(val);
  };
  const [activeField, setActiveField] = useState(null); // 'disc' | 'status' | 'date' | null
  const toggleField = (f,e) => { e.stopPropagation(); setActiveField(v=>v===f?null:f); };

  // Support both old (statusId) and new (status) field names
  const statusKey = ev.status || (ev.statusId==='C'?'approved':ev.statusId==='N'?'missing':ev.statusId==='I'?'progress':'missing');
  const st = EV_STATUSES[statusKey] || EV_STATUSES.missing;
  const isPeriod    = EV_PERIOD.has(statusKey);
  const isMilestone = EV_MILESTONE.has(statusKey);

  // Day count: allEvts sorted newest-first; newerEvt = event above this one
  const newerEvt = allEvts[evIdx - 1];
  const periodEnd  = newerEvt?.date || todayISO();
  const periodDays = isPeriod ? daysBetween(ev.date, periodEnd) : 0;
  const isActive   = isPeriod && evIdx === 0;

  const disc = disciplines.find(d => d.id === ev.assignee);

  // Card identity = discipline; status is a secondary badge
  const cardColor  = disc ? disc.color : '#9CA3AF';
  const cardBg     = disc ? disc.bg    : 'var(--bg)';

  const [statusPickOpen, setStatusPickOpen] = useState(false);
  const statusPickRef = useRef(null);
  useEffect(()=>{
    if(!statusPickOpen) return;
    const h=e=>{if(statusPickRef.current&&!statusPickRef.current.contains(e.target))setStatusPickOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[statusPickOpen]);

  const cycleStatus = (e) => {
    e.stopPropagation();
    setStatusPickOpen(v=>!v);
  };
  const pickStatus = (key,e) => {
    e.stopPropagation();
    onUpdate({...ev, status:key, statusId:undefined});
    setStatusPickOpen(false);
  };

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Compact row Ч’вӮ¬вҖқ discipline-first design Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const compactRow = (marker, clickHandler) => (
    <div className="ev-compact-row"
      style={{
        borderRight:`3px solid ${cardColor}`,
        borderLeft:'1px solid rgba(0,0,0,.07)',
        borderTop:'1px solid rgba(0,0,0,.07)',
        borderBottom:'1px solid rgba(0,0,0,.07)',
        background: cardBg,
        cursor: clickHandler?'pointer':'default',
      }}
      onClick={clickHandler}>
      <div style={{display:'flex',alignItems:'center',gap:7}}>
        {/* Discipline chip Ч’вӮ¬вҖқ primary identity, fixed width so all rows align */}
        {disc
          ? <span style={{display:'inline-flex',alignItems:'center',justifyContent:'center',
              width:52,padding:'2px 0',borderRadius:12,fontSize:11,fontWeight:700,
              background:cardColor,color:'#fff',flexShrink:0,letterSpacing:.2}}>
              {disc.label}
            </span>
          : <span style={{display:'inline-flex',alignItems:'center',justifyContent:'center',
              width:52,padding:'2px 0',borderRadius:12,fontSize:11,fontWeight:700,
              background:'#9CA3AF',color:'#fff',flexShrink:0}}>Ч’вӮ¬вҖқ</span>
        }
        {/* Status badge Ч’вӮ¬вҖқ secondary, fixed width, click opens picker */}
        <div ref={statusPickRef} style={{position:'relative',flexShrink:0}}>
          <span onClick={cycleStatus} title="ЧіВңЧівҖ”ЧіВҘ ЧіВңЧіВ©Чів„ўЧіВ ЧівҖўЧів„ў ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ"
            style={{display:'inline-flex',alignItems:'center',justifyContent:'center',gap:4,
              width:83,padding:'2px 6px',borderRadius:12,flexShrink:0,cursor:'pointer',userSelect:'none',
              background:st.bg, border:`1px solid ${st.border}`, color:st.color,
              fontSize:11,fontWeight:700,
            }}>
            <span style={{fontSize:12,lineHeight:1}}>{st.symbol}</span>
            <span>{st.label}</span>
          </span>
          {statusPickOpen&&(
            <div className="dp" onClick={e=>e.stopPropagation()}
              style={{minWidth:130,padding:'4px',top:'calc(100% + 4px)',right:0,left:'auto'}}>
              {Object.values(EV_STATUSES).filter(s=>s.id!==statusKey).map(s=>(
                <div key={s.id} className="dp-opt" onClick={e=>pickStatus(s.id,e)}
                  style={{gap:6,padding:'5px 8px',borderRadius:6}}>
                  <span style={{display:'inline-flex',alignItems:'center',gap:4,
                    padding:'1px 8px',borderRadius:10,fontSize:11,fontWeight:700,
                    background:s.bg,border:`1px solid ${s.border}`,color:s.color}}>
                    <span style={{fontSize:11}}>{s.symbol}</span>
                    {s.label}
                  </span>
                </div>
              ))}
            </div>
          )}
        </div>
        {(ev.title||ev.note)&&(
          <span style={{fontSize:11,fontWeight:500,color:'var(--text)',
            overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>
            {ev.title||ev.note}
          </span>
        )}
      </div>
      <div style={{display:'flex',alignItems:'center',gap:7,flexShrink:0}}>
        {eventSubtasks.length>0&&(
          <span title="ЧіГ—ЧіГ—Чів„ў-ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ— ЧіВңЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ" style={{fontSize:10,fontWeight:700,color:cardColor,
            background:'rgba(255,255,255,.6)',borderRadius:8,padding:'1px 6px',flexShrink:0}}>
            Ч’ЛңвҖҳ {eventSubtasks.filter(s=>s.done).length}/{eventSubtasks.length}
          </span>
        )}
        <span style={{display:'inline-flex',alignItems:'center',gap:2,
          flexShrink:0,width:46,justifyContent:'flex-end',
          visibility:(isPeriod&&!EV_NO_DAYS.has(statusKey))?'visible':'hidden'}}>
          <span style={{display:'inline-flex',alignItems:'center',gap:2,
            padding:'1px 6px',borderRadius:10,
            background:'#E5E7EB',color:'#4B5563',
            fontSize:10,fontWeight:600}}>
            Ч’ВҸВұ {periodDays}
          </span>
        </span>
        <span style={{fontSize:11,color:'var(--text-2)',flexShrink:0,fontFamily:'monospace',width:74,textAlign:'left',display:'inline-block'}}>{fmtDateFull(ev.date)}</span>
        <button className="ev-del" onClick={e=>{e.stopPropagation();onDelete();}}>ЦівҖ”</button>
        <span style={{fontSize:10,color:cardColor,opacity:.45,flexShrink:0,width:10,textAlign:'center',visibility:isPeriod?'visible':'hidden'}}>Ч’вӮ¬Г·</span>
      </div>
    </div>
  );

  const diamond = (
    <div style={{
      position:'absolute', right:-20, top:'50%', transform:'translateY(-50%) rotate(45deg)',
      width:10, height:10,
      background:cardColor, borderRadius:2,
      border:'2px solid var(--surface)',
      boxShadow:`0 0 0 1.5px ${cardColor}`,
    }}/>
  );

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Shared edit-card contents (used by both milestone & period when expanded) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const editCard = (
    <>
      {/* Header: chips are clickable pickers; right side = date + collapse + delete */}
      <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',gap:8}}>
        <div style={{display:'flex',alignItems:'center',gap:6,flexWrap:'wrap'}}>
          {/* Discipline chip Ч’вҖ вҖҷ picker */}
          <span onClick={e=>toggleField('disc',e)} title="ЧіВ©ЧіВ ЧівҖқ ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў" style={{
            padding:'2px 9px',borderRadius:12,fontSize:11,fontWeight:700,cursor:'pointer',flexShrink:0,
            background:disc?cardColor:'#9CA3AF',color:'#fff',
            outline:activeField==='disc'?`2px solid ${disc?cardColor:'#9CA3AF'}`:'none',outlineOffset:1,
          }}>{disc?disc.label:'Ч’вӮ¬вҖқ ЧіГ—ЧівҖ”ЧівҖўЧіВқ'}</span>
          {/* Status pill Ч’вҖ вҖҷ picker */}
          <span className="ev-status-pill" onClick={e=>toggleField('status',e)} title="ЧіВ©ЧіВ ЧівҖқ ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ"
            style={{background:st.bg,color:st.color,border:`1px solid ${st.border}`,cursor:'pointer',
              outline:activeField==='status'?`2px solid ${st.border}`:'none',outlineOffset:1}}>
            <span style={{fontWeight:700}}>{st.symbol}</span>{st.label}
          </span>
        </div>
        <div style={{display:'flex',alignItems:'center',gap:4}}>
          {/* Date Ч’вӮ¬вҖқ click to open date picker */}
          {activeField==='date'
            ?<input type="date" autoFocus value={ev.date||''} onClick={e=>e.stopPropagation()}
                min={minDate||undefined} max={maxDate||undefined}
                onChange={e=>{
                  let v=e.target.value;
                  if(minDate&&v<minDate)v=minDate;
                  if(maxDate&&v>maxDate)v=maxDate;
                  onUpdate({...ev,date:v});setActiveField(null);
                }}
                onBlur={()=>setActiveField(null)}
                style={{fontSize:11,fontFamily:'monospace',border:'1px solid var(--border)',borderRadius:4,
                  background:'var(--bg)',padding:'1px 4px',width:120}}/>
            :<span onClick={e=>toggleField('date',e)} title="ЧіВ©ЧіВ ЧівҖқ ЧіГ—ЧіВҗЧіВЁЧів„ўЧіВҡ"
                style={{fontSize:11,color:'var(--text-3)',fontFamily:'monospace',cursor:'pointer',
                  textDecoration:'underline dotted',textUnderlineOffset:2}}>
                {fmtDate(ev.date)}
              </span>
          }
          <button title="ЧівҖәЧівҖўЧівҖўЧіВҘ" onClick={e=>{e.stopPropagation();setExpanded(false);setActiveField(null);}}
            style={{background:'none',border:'none',cursor:'pointer',fontSize:14,color:'var(--text-3)',padding:'0 3px',lineHeight:1}}>Ч’вӮ¬В№</button>
          <button className="ev-del" style={{opacity:1}} onClick={e=>{e.stopPropagation();onDelete();}}>ЦівҖ”</button>
        </div>
      </div>
      {/* Inline pickers */}
      {activeField==='disc'&&(
        <div onClick={e=>e.stopPropagation()}
          style={{display:'flex',flexWrap:'wrap',gap:5,padding:'6px 0 2px'}}>
          {disciplines.map(d=>(
            <span key={d.id} onClick={()=>{onUpdate({...ev,assignee:d.id});setActiveField(null);}}
              style={{padding:'2px 10px',borderRadius:10,fontSize:11,fontWeight:700,cursor:'pointer',
                background:d.id===ev.assignee?d.color:d.bg,
                color:d.id===ev.assignee?'#fff':d.color,
                border:`1px solid ${d.color}`,transition:'all .1s'}}>
              {d.label}
            </span>
          ))}
          {ev.assignee&&<span onClick={()=>{onUpdate({...ev,assignee:''});setActiveField(null);}}
            style={{padding:'2px 10px',borderRadius:10,fontSize:11,cursor:'pointer',
              color:'var(--text-3)',border:'1px solid var(--border)'}}>ЧіВңЧіВңЧіВҗ</span>}
        </div>
      )}
      {activeField==='status'&&(
        <div onClick={e=>e.stopPropagation()}
          style={{display:'flex',flexWrap:'wrap',gap:5,padding:'6px 0 2px'}}>
          {Object.values(EV_STATUSES).filter(s=>s.id!=='missing').map(s=>(
            <span key={s.id} onClick={()=>{onUpdate({...ev,status:s.id});setActiveField(null);}}
              style={{display:'inline-flex',alignItems:'center',gap:3,padding:'2px 8px',borderRadius:10,
                fontSize:11,fontWeight:700,cursor:'pointer',
                background:s.id===statusKey?s.border:s.bg,
                color:s.id===statusKey?'#fff':s.color,
                border:`1px solid ${s.border}`,transition:'all .1s'}}>
              {s.symbol} {s.label}
            </span>
          ))}
        </div>
      )}

      {/* Title input */}
      <input className="tl-ev-title" style={{marginTop:6}}
        value={ev.title||''} placeholder="ЧівҖқЧіВўЧіВЁЧівҖқ / ЧівҖәЧівҖўЧіГ—ЧіВЁЧіГ—..."
        onChange={e=>onUpdate({...ev,title:e.target.value})}/>

      {/* Day count Ч’вӮ¬вҖқ period events only */}
      {isPeriod && (
        <div className="ev-duration">
          <span className="ev-dur-label">{isActive?'Ч’ВҸВұ ЧівҖҳЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ':'Ч’ВҸВұ ЧіВһЧіВ©ЧіВҡ:'}</span>
          <span className="ev-dur-val">{periodDays} Чів„ўЧіВһЧів„ўЧіВқ</span>
        </div>
      )}

      {/* Note input only (disc + date now inline in header) */}
      <div className="ev-meta-row">
        <input className="ev-meta-input" placeholder="ЧівҖқЧіВўЧіВЁЧівҖқ / ЧівӮӘЧів„ўЧіВЁЧівҖўЧіЛң..." value={ev.note||''}
          onChange={e=>onUpdate({...ev,note:e.target.value})} style={{flex:1,minWidth:60}}/>
      </div>

      {/* Per-event subtasks Ч’вӮ¬вҖқ concrete work spawned by this event */}
      <EventSubtasks subs={eventSubtasks} onAdd={onAddSub} onUpdate={onUpdateSub} onDelete={onDeleteSub} newSubId={newSubId} onAddToMain={onAddToMain}/>
    </>
  );

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ ЧіВһЧів„ўЧів„ўЧіВңЧіВЎЧіЛңЧівҖўЧіВҹ: compact row with diamond marker (expandable to edit card) Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  if (isMilestone) {
    if (!expanded) {
      return (
        <div className="ev-milestone" onClick={e=>e.stopPropagation()}>
          {diamond}
          {compactRow(null, () => setExpanded(true))}
        </div>
      );
    }
    return (
      <div className="ev-milestone" onClick={e=>e.stopPropagation()}>
        {diamond}
        <div className="ev-card" style={{borderRightColor:cardColor}}>
          {editCard}
        </div>
      </div>
    );
  }

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ ЧівӮӘЧіВЁЧіВ§ ЧівҖ“ЧіВһЧіВҹ ЧіВһЧівҖәЧівҖўЧівҖўЧіВҘ: compact row with dot Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  if (!expanded) {
    return (
      <div className="ev-event">
        <div className="ev-dot" style={{background:cardColor}} onClick={e=>{e.stopPropagation();cycleStatus(e);}} title="ЧіВңЧівҖ”ЧіВҘ ЧіВңЧіВ©Чів„ўЧіВ ЧівҖўЧів„ў ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ"/>
        {compactRow(null, e=>{e&&e.stopPropagation&&e.stopPropagation();setExpanded(true);})}
      </div>
    );
  }

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ ЧівӮӘЧіВЁЧіВ§ ЧівҖ“ЧіВһЧіВҹ ЧіВһЧівҖўЧіВЁЧівҖ”ЧівҖҳ: ЧівҖәЧіВЁЧіЛңЧів„ўЧіВЎ ЧіВўЧіВЁЧів„ўЧівҖәЧівҖқ Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  return (
    <div className="ev-event" onClick={e=>e.stopPropagation()}>
      <div className="ev-dot" style={{background:cardColor}} onClick={e=>{e.stopPropagation();cycleStatus(e);}} title="ЧіВңЧівҖ”ЧіВҘ ЧіВңЧіВ©Чів„ўЧіВ ЧівҖўЧів„ў ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ"/>
      <div className="ev-card" style={{borderRightColor:cardColor}}>
        {editCard}
      </div>
    </div>
  );
}

/* Subtasks that belong to a single event (e.g. "ЧівӮӘЧіВ Чів„ўЧів„ўЧівҖқ ЧіВңЧіВһЧіВўЧівҖҳЧівҖңЧівҖўЧіГ—" Ч’вҖ вҖҷ list of labs) */
function EventSubtasks({subs=[], onAdd, onUpdate, onDelete, newSubId, onAddToMain}) {
  return (
    <div style={{marginTop:8,paddingTop:8,borderTop:'1px dashed var(--border)'}}>
      <div style={{fontSize:10,fontWeight:700,color:'var(--text-3)',marginBottom:3,letterSpacing:'.04em'}}>
        ЧіГ—ЧіГ—Чів„ў-ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ— ЧіВңЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ{subs.length>0 && ` ЦІВ· ${subs.filter(s=>s.done).length}/${subs.length}`}
      </div>
      {subs.map(s=>(
        <SubPanelRow key={s.id} sub={s} autoFocus={s.id===newSubId} onUpdate={onUpdate} onDelete={()=>onDelete(s.id)}
          onAddToMain={onAddToMain?()=>onAddToMain(s):undefined}/>
      ))}
      <button className="tp-add-sub" style={{fontSize:11,padding:'2px 0'}} onClick={onAdd}>
        <span style={{fontSize:14,color:'var(--accent)',lineHeight:1}}>+</span> ЧіГ—ЧіГ—-ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ ЧіВңЧіВўЧівҖңЧівҖәЧівҖўЧіВҹ
      </button>
    </div>
  );
}

function CustomFieldCell({field, value, onChange}) {
  const [editing, setEditing] = useState(false);
  const [draft,   setDraft]   = useState(value||'');
  useEffect(()=>setDraft(value||''),[value]);
  const commit = () => { onChange(draft); setEditing(false); };

  if(field.type==='date') return(
    <td style={{padding:'0 10px',verticalAlign:'middle'}}>
      <input type="date" value={draft} onChange={e=>{setDraft(e.target.value);onChange(e.target.value);}}
        style={{border:'1px solid var(--border)',borderRadius:5,padding:'2px 6px',fontSize:11,fontFamily:'inherit',outline:'none',color:'var(--text)',background:'transparent'}}/>
    </td>
  );
  if(field.type==='number') return(
    <td style={{padding:'0 10px',verticalAlign:'middle'}}>
      {editing
        ?<input autoFocus type="number" value={draft} onChange={e=>setDraft(e.target.value)}
            onBlur={commit} onKeyDown={e=>{if(e.key==='Enter')commit();}}
            style={{width:80,border:'1px solid var(--blue)',borderRadius:5,padding:'2px 6px',fontSize:12,fontFamily:'inherit',outline:'none'}}/>
        :<span style={{fontSize:12,color:draft?'var(--text)':'var(--text-3)',cursor:'text'}} onClick={()=>{setDraft(value||'');setEditing(true);}}>
            {draft||'Ч’вӮ¬вҖқ'}
          </span>
      }
    </td>
  );
  // text / people / single-select / multi-select / timeline Ч’вӮ¬вҖқ all as editable text for now
  return(
    <td style={{padding:'0 10px',verticalAlign:'middle',cursor:'text'}} onClick={()=>{setDraft(value||'');setEditing(true);}}>
      {editing
        ?<input autoFocus value={draft} onChange={e=>setDraft(e.target.value)}
            onBlur={commit} onKeyDown={e=>{if(e.key==='Enter')commit();if(e.key==='Escape')setEditing(false);}}
            style={{width:'100%',border:'1px solid var(--blue)',borderRadius:5,padding:'2px 6px',fontSize:12,fontFamily:'inherit',outline:'none'}}/>
        :<span style={{fontSize:12,color:draft?'var(--text)':'var(--text-3)'}}>{draft||'Ч’вӮ¬вҖқ'}</span>
      }
    </td>
  );
}

/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ AssigneeCell Ч’вӮ¬вҖқ person picker from project team Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
function AssigneeCell({task, onUpdate}) {
  const {team} = useContext(ListsCtx);
  const [open, setOpen] = useState(false);
  const ref = useRef(null);

  useEffect(()=>{
    if(!open) return;
    const h=e=>{if(ref.current&&!ref.current.contains(e.target))setOpen(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[open]);

  const assigneeId = task.assigneeId || '';
  const assignee = team.find(m=>m.staffId===assigneeId) || null;
  const color = assigneeId ? staffColor(assigneeId) : '#D1D5DB';
  const initials = assignee ? staffInitials(assignee.name) : '+';

  return (
    <td ref={ref} style={{position:'relative',padding:'0 6px',verticalAlign:'middle',textAlign:'center'}}>
      <div style={{display:'flex',justifyContent:'center'}}>
        <div className="assignee-av" style={{background: assigneeId ? color : 'none',
          border: assigneeId ? 'none' : '1.5px dashed var(--border-strong)',
          color: assigneeId ? '#fff' : 'var(--text-3)'}}
          title={assignee ? `${assignee.name}${assignee.projectRole?' Ч’вӮ¬вҖқ '+assignee.projectRole:''}` : 'ЧіВ©Чів„ўЧів„ўЧіВҡ ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў'}
          onClick={e=>{e.stopPropagation();setOpen(o=>!o);}}>
          {initials}
        </div>
      </div>
      {open&&(
        <div className="assignee-dp" onClick={e=>e.stopPropagation()}>
          <div style={{padding:'6px 10px',fontSize:10,fontWeight:700,color:'var(--text-3)',borderBottom:'1px solid var(--border)',textTransform:'uppercase',letterSpacing:.5}}>ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў</div>
          {team.map(m=>(
            <div key={m.staffId} className="ov-staff-item"
              style={{background: m.staffId===assigneeId?'rgba(37,99,235,.07)':''}}
              onClick={()=>{onUpdate({...task,assigneeId:m.staffId});setOpen(false);}}>
              <div className="ov-staff-av" style={{background:staffColor(m.staffId)}}>{staffInitials(m.name)}</div>
              <div>
                <div className="ov-staff-name">{m.name}</div>
                {m.projectRole&&<div className="ov-staff-role">{m.projectRole}</div>}
              </div>
              {m.staffId===assigneeId&&<span style={{marginRight:'auto',color:'var(--accent)',fontSize:12}}>Ч’ВңвҖң</span>}
            </div>
          ))}
          {team.length===0&&<div style={{padding:'12px',fontSize:12,color:'var(--text-3)',textAlign:'center'}}>ЧіВҗЧів„ўЧіВҹ ЧіВўЧівҖўЧівҖҳЧівҖңЧів„ўЧіВқ ЧівҖҳЧіВҰЧівҖўЧівҖўЧіГ— ЧівҖқЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң</div>}
          {assigneeId&&<>
            <div style={{height:1,background:'var(--border)',margin:'2px 0'}}/>
            <div className="ov-staff-item" style={{color:'var(--text-3)'}}
              onClick={()=>{onUpdate({...task,assigneeId:''});setOpen(false);}}>
              <span style={{fontSize:12}}>Ч’ВңвҖў</span><span style={{fontSize:12}}>ЧівҖқЧіВЎЧіВЁ ЧіВ©Чів„ўЧівҖўЧіВҡ</span>
            </div>
          </>}
        </div>
      )}
    </td>
  );
}

function TaskRow({task, onUpdate, onDelete, autoFocus=false, fields=[], visibleColIds=[], daysThreshold=null, sortState=null, onTaskDragStart, onTaskDragEnd, taskDragSrc, taskDragTarget, onTaskDragOver, onTaskDrop}) {
  const [editTitle,setEditTitle]=useState(autoFocus);
  const [title,setTitle]=useState(task.title);
  const [panelSubId,setPanelSubId]=useState(null);
  const isProcess = task.taskType==='process';
  const [expanded,setExpanded]=useState(false);
  const [subsFirst,setSubsFirst]=useState(false); // processes before simples
  const [newSubId,setNewSubId]=useState(null);
  const inputRef=useRef(null);
  useEffect(()=>{if(autoFocus&&inputRef.current)inputRef.current.focus();},[]);
  useEffect(()=>{if(editTitle&&inputRef.current)inputRef.current.focus();},[editTitle]);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Auto-stuck: if any process subtask has a delayed event Ч’вҖ вҖҷ set statusId='S' on it and on task Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  useEffect(()=>{
    if(daysThreshold===null) return;
    const today=todayISO();
    const daysBetweenLocal=(a,b)=>Math.round((new Date(b)-new Date(a))/86400000);
    let taskNeedsStuck=false;
    let updatedSubs=null;
    const subs=task.subtasks||[];
    subs.forEach((sub,i)=>{
      const evts=sub.events||[];
      if(!evts.length) return;
      const sorted=[...evts].sort((a,b)=>(b.date||'').localeCompare(a.date||''));
      const latest=sorted[0];
      if(!latest?.status||latest.status==='approved') return; // finished Ч’вӮ¬вҖқ no stuck
      const isPeriod=EV_PERIOD.has(latest.status);
      if(!isPeriod) return; // only period statuses can be "stuck"
      const days=daysBetweenLocal(latest.date,today);
      if(days>daysThreshold && sub.statusId!=='S'){
        if(!updatedSubs) updatedSubs=[...subs];
        updatedSubs[i]={...sub,statusId:'S'};
        taskNeedsStuck=true;
      }
    });
    if(taskNeedsStuck){
      const patch={...(updatedSubs?{subtasks:updatedSubs}:{})};
      if(task.statusId!=='S') patch.statusId='S';
      if(Object.keys(patch).length) onUpdate({...task,...patch});
    }
  },[daysThreshold, JSON.stringify((task.subtasks||[]).map(s=>({id:s.id,statusId:s.statusId,events:s.events})))]);

  const {priorities} = useContext(ListsCtx);

  /* Sort subtask array by active sortState Ч’вӮ¬вҖқ mirrors top-level sort logic */
  const sortSubtasks = arr => {
    if(!sortState?.length) return arr;
    const order=Object.fromEntries([...priorities.map((p,i)=>[p.id,i]),['',priorities.length]]);
    return [...arr].sort((a,b)=>{
      for(const {column,dir} of sortState){
        const va=column==='priority'?order[a.priority??'']:a[column]??'';
        const vb=column==='priority'?order[b.priority??'']:b[column]??'';
        const cmp=va<vb?-1:va>vb?1:0;
        if(cmp!==0) return dir==='asc'?cmp:-cmp;
      }
      return 0;
    });
  };

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Derive task-level stuck: any process subtask with a delayed event Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const _today = todayISO();
  const _taskDelayed = (task.subtasks||[]).some(sub=>{
    if(sub.statusId==='C') return false;
    if(sub.dueDate && sub.dueDate < _today) return true;
    if(daysThreshold===null) return false;
    const evts=sub.events||[];
    if(!evts.length) return false;
    const latest=[...evts].sort((a,b)=>(b.date||'').localeCompare(a.date||''))[0];
    if(latest?.status==='approved') return false;
    return daysBetween(latest.date,_today)>daysThreshold;
  });
  const taskEffectiveStatusId = _taskDelayed ? 'S' : task.statusId;

  const commitTitle=()=>{
    if(title.trim()) onUpdate({...task,title:title.trim()});
    else onDelete();
    setEditTitle(false);
  };
  const subtasks=task.subtasks||[];
  const doneCount=subtasks.filter(s=>s.done).length;
  const addSubtask=()=>{
    const id=uid();
    onUpdate({...task,subtasks:[...subtasks,{id,title:'',done:false,statusId:'N',priority:'',discipline:''}]});
    setNewSubId(id);setExpanded(true);
  };
  const updateSubtask=s=>onUpdate({...task,subtasks:subtasks.map(x=>x.id===s.id?s:x)});
  const addSubToMain=sub=>{
    /* Add sub into the process subtask's own subtasks (not top-level) */
    const procSub=subtasks.find(s=>s.id===panelSubId);
    if(!procSub) return;
    const nested=procSub.subtasks||[];
    if(nested.find(x=>x.id===sub.id)) return; // already there
    const updated={...procSub,subtasks:[...nested,sub]};
    updateSubtask(updated);
  };
  const deleteSubtask=id=>onUpdate({...task,subtasks:subtasks.filter(s=>s.id!==id)});

  return(
    <>
    <tr className={`t-row${task.done?' task-done':''}${expanded?' t-expanded':''}${taskDragSrc===task.id?' t-drag-src':''}${taskDragTarget===task.id?' t-drag-over':''}`}
      draggable
      onDragStart={e=>{e.stopPropagation();e.dataTransfer.effectAllowed='move';onTaskDragStart?.(task.id);}}
      onDragEnd={e=>{e.stopPropagation();onTaskDragEnd?.();}}
      onDragOver={e=>{e.preventDefault();e.stopPropagation();onTaskDragOver?.(task.id);}}
      onDrop={e=>{e.preventDefault();e.stopPropagation();onTaskDrop?.(task.id);}}>
      <td className="sticky-td">
        <div className="name-inner">
          <span className="task-drag-handle" title="ЧівҖҷЧіВЁЧівҖўЧіВЁ">Ч’В Вҝ</span>
          <button className={`expand-btn${subtasks.length>0?' has-sub':''}`}
            title="ЧіГ—ЧіГ—-ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—" onClick={e=>{e.stopPropagation();setExpanded(o=>!o);}}>
            {expanded?'Ч’вҖ“Вј':'Ч’вҖ“В¶'}
          </button>
          {/* Done/type toggle */}
          {isProcess
            ?<button className={`proc-btn${task.done?' is-done':''}`}
                title="ЧіВһЧіВ©Чів„ўЧіВһЧіГ— ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ Ч’вӮ¬вҖқ ЧіВңЧівҖ”ЧіВҘ ЧіВңЧіВЎЧів„ўЧіВһЧівҖўЧіВҹ ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ"
                onContextMenu={e=>{e.preventDefault();onUpdate({...task,taskType:'simple'});}}
                onClick={e=>{e.stopPropagation();onUpdate({...task,done:!task.done});}}>
                {task.done&&'Ч’ВңвҖң'}
              </button>
            :<button className={`done-btn${task.done?' is-done':''}`}
                title="ЧіВңЧівҖ”ЧіВҘ ЧіВңЧіВЎЧів„ўЧіВһЧівҖўЧіВҹ ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ | ЧіВңЧівҖ”ЧіВҘ Чів„ўЧіВһЧіВ Чів„ў Ч’вҖ вҖҷ ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ"
                onContextMenu={e=>{e.preventDefault();onUpdate({...task,taskType:'process',processEvents:task.processEvents||[]});}}
                onClick={e=>{e.stopPropagation();onUpdate({...task,done:!task.done});}}>
                {task.done&&'Ч’ВңвҖң'}
              </button>
          }
          {editTitle
            ?<input ref={inputRef} className="name-edit-input" value={title}
                onChange={e=>setTitle(e.target.value)} onBlur={commitTitle}
                onKeyDown={e=>{if(e.key==='Enter')commitTitle();if(e.key==='Escape'){setTitle(task.title);setEditTitle(false);}}}/>
            :<span className="name-text"
                style={{textDecoration:task.done?'line-through':'none',color:task.done?'var(--text-3)':'var(--text)',cursor:'text'}}
                onClick={e=>{e.stopPropagation();setTitle(task.title);setEditTitle(true);}}>
                {task.title||<span style={{color:'var(--text-3)'}}>ЧіВңЧіВңЧіВҗ ЧіВ©ЧіВқ</span>}
              </span>
          }
          {subtasks.length>0&&!expanded&&(
            <span className="sub-badge" onClick={e=>{e.stopPropagation();setExpanded(true);}}>
              {doneCount}/{subtasks.length}
            </span>
          )}
          <button className="del-btn" onClick={onDelete}>Ч’ВңвҖў</button>
        </div>
      </td>
      {visibleColIds.filter(id=>id!=='__name').map(id=>{
        switch(id){
          case '__status':
            const displayStatusId = isProcess ? getMostRecentEventStatus(task) : taskEffectiveStatusId;
            return <td key="__status" style={{padding:'0 8px',verticalAlign:'middle',textAlign:'center'}}>
              <div style={{display:'flex',justifyContent:'center'}}><StatusCircle statusId={displayStatusId} onChange={v=>onUpdate({...task,statusId:v})}/></div></td>;
          case '__priority':
            return <PriorityCell key="__priority" priority={task.priority} onChange={v=>onUpdate({...task,priority:v})}/>;
          case '__discipline':
            return <DisciplineCell key="__discipline" discipline={task.discipline} onChange={v=>onUpdate({...task,discipline:v})}/>;
          case '__owner_status':
            return <StatusOwnerCell key="__owner_status" task={task} onChangeResponsible={v=>onUpdate({...task,responsible:v})} threshold={daysThreshold}/>;
          case '__assignee':
            return <AssigneeCell key="__assignee" task={task} onUpdate={onUpdate}/>;
          case '__dates':
            return <DateRangeCell key="__dates" startDate={task.startDate} dueDate={task.dueDate} isParent={true} onChange={(f,v)=>onUpdate({...task,[f]:v})}/>;
          case '__comment':
            return <CommentCell key="__comment" comment={task.comment} onChange={v=>onUpdate({...task,comment:v})}/>;
          default:{
            const f=fields.find(f=>f.id===id);
            if(!f) return null;
            return <CustomFieldCell key={id} field={f}
              value={(task.fieldValues||{})[id]}
              onChange={v=>onUpdate({...task,fieldValues:{...(task.fieldValues||{}),[id]:v}})}/>;
          }
        }
      })}
      <td/>
    </tr>
    {expanded&&(()=>{
      const simples  = subtasks.filter(s=>!s.isProcess);
      const procs    = subtasks.filter(s=>!!s.isProcess);
      const colSpan  = visibleColIds.length + 1;
      const showHeaders = simples.length > 0 && procs.length > 0;
      const SectionHdr = ({label, icon, isFirst}) => (
        <tr style={{cursor: showHeaders ? 'grab' : 'default'}} onClick={showHeaders ? ()=>setSubsFirst(v=>!v) : undefined}>
          <td colSpan={colSpan} className="sticky-td"
            style={{padding:'4px 16px 2px',borderBottom:'1px solid var(--border)',background:'var(--bg)',userSelect:'none'}}>
            <span style={{fontSize:10,fontWeight:700,color:'#888',letterSpacing:.5,textTransform:'uppercase',display:'inline-flex',alignItems:'center',gap:5}}>
              {icon} {label}
              {showHeaders && <span style={{fontSize:9,opacity:.5,marginRight:4}}>Ч’вҖЎвҖҰ</span>}
            </span>
          </td>
        </tr>
      );
      const NestedRows = ({sub}) => {
        const [open, setOpen] = React.useState(false);
        const nestedSubs = sub.isProcess ? (sub.subtasks||[]) : [];
        return (
          <React.Fragment>
            <SubtaskRow subtask={sub}
              visibleColIds={visibleColIds}
              threshold={daysThreshold}
              autoFocus={sub.id===newSubId}
              parentStartDate={task.startDate||''}
              parentDueDate={task.dueDate||''}
              nestedOpen={open}
              onToggleNested={nestedSubs.length>0?()=>setOpen(o=>!o):null}
              onOpenProcess={()=>setPanelSubId(sub.id)}
              onUpdate={s=>{setNewSubId(null);updateSubtask(s);}}
              onDelete={()=>{setNewSubId(null);deleteSubtask(sub.id);}}/>
            {open && nestedSubs.map(ns=>(
              <tr key={ns.id} className="sub-row" style={{background:'var(--bg)'}}>
                <td className="sticky-td" style={{paddingRight:36,paddingLeft:8,verticalAlign:'middle',background:'inherit'}}>
                  <div style={{display:'flex',alignItems:'center',gap:6}}>
                    <span style={{color:'var(--border-strong)',fontSize:12,flexShrink:0}}>Ч’вҖқвҖқ</span>
                    <input type="checkbox" checked={!!ns.done}
                      onChange={()=>updateSubtask({...sub,subtasks:nestedSubs.map(x=>x.id===ns.id?{...x,done:!x.done}:x)})}
                      style={{flexShrink:0,cursor:'pointer'}}/>
                    <span style={{fontSize:11,color:ns.done?'var(--text-3)':'var(--text)',textDecoration:ns.done?'line-through':'none'}}>
                      {ns.title||<span style={{color:'var(--text-3)'}}>ЧіВңЧіВңЧіВҗ ЧіВ©ЧіВқ</span>}
                    </span>
                  </div>
                </td>
                {visibleColIds.filter(id=>id!=='__name').map(id=>(
                  <td key={id} style={{background:'inherit'}}/>
                ))}
                <td style={{background:'inherit'}}/>
              </tr>
            ))}
          </React.Fragment>
        );
      };
      const makeRow = sub => <NestedRows key={sub.id} sub={sub}/>;
      const firstGroup  = sortSubtasks(subsFirst ? simples : procs);
      const firstIcon   = subsFirst ? 'Ч’вҖ”вҖ№' : 'Ч’ВҠВЎ';
      const firstLabel  = subsFirst ? 'ЧіГ—ЧіГ—Чів„ў ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—' : 'ЧіГ—ЧівҖқЧіВңЧів„ўЧівҖәЧів„ўЧіВқ';
      const secondGroup = sortSubtasks(subsFirst ? procs : simples);
      const secondIcon  = subsFirst ? 'Ч’ВҠВЎ' : 'Ч’вҖ”вҖ№';
      const secondLabel = subsFirst ? 'ЧіГ—ЧівҖқЧіВңЧів„ўЧівҖәЧів„ўЧіВқ' : 'ЧіГ—ЧіГ—Чів„ў ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—';
      return <>
        {showHeaders && <SectionHdr icon={firstIcon}  label={firstLabel}/>}
        {firstGroup.map(makeRow)}
        {showHeaders && <SectionHdr icon={secondIcon} label={secondLabel}/>}
        {secondGroup.map(makeRow)}
      </>;
    })()}
    {expanded&&(
      <tr className="sub-row">
        <td className="sticky-td">
          <div className="sub-name-inner">
            <button onClick={addSubtask}
              style={{background:'none',border:'none',cursor:'pointer',fontSize:12,color:'var(--text-3)',fontFamily:'inherit',display:'flex',alignItems:'center',gap:5,padding:0}}>
              <span style={{fontSize:15,color:'var(--accent)',lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіГ—ЧіГ—-ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ
            </button>
          </div>
        </td>
        {visibleColIds.filter(id=>id!=='__name').map(id=>(
          <td key={id} style={{background:'inherit'}}/>
        ))}
        <td style={{background:'inherit'}}/>
      </tr>
    )}
    {/* Per-subtask events panel */}
    {panelSubId&&(()=>{
      const node=subtasks.find(s=>s.id===panelSubId);
      if(!node) return null;
      return <ProcessTaskPanel key={panelSubId} parentTitle={task.title} node={node}
        threshold={daysThreshold}
        parentStartDate={task.startDate||''}
        parentDueDate={task.dueDate||''}
        onUpdate={updated=>updateSubtask(updated)}
        onAddToMain={sub=>addSubToMain(sub)}
        onClose={()=>setPanelSubId(null)}/>;
    })()}
    </>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Edit Field Modal
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function EditFieldModal({field, isBuiltin, onSave, onDelete, onClose}) {
  const {priorities, disciplines} = useContext(ListsCtx);
  const [title,          setTitle]          = useState(field.title || field.label || '');
  const [type,           setType]           = useState(field.type  || 'single-select');
  const [delayThreshold, setDelayThreshold] = useState(field.delayThreshold ?? '');
  const [options,        setOptions]        = useState(() => {
    if(field.options) return field.options;
    // Seed built-in options from effective lists
    if(field.id==='__priority')   return priorities.map(p=>({id:p.id,label:p.label,color:p.color}));
    if(field.id==='__discipline') return disciplines.map(d=>({id:d.id,label:d.label,color:d.color}));
    if(field.id==='__status')     return STATUSES.map(s=>({id:s.id,label:s.label,color:s.color}));
    return [];
  });
  const [showTypeMenu,  setShowTypeMenu]  = useState(false);
  const [colorPickFor,  setColorPickFor]  = useState(null);
  const typeMenuRef = useRef(null);

  useEffect(()=>{
    if(!showTypeMenu && colorPickFor===null) return;
    const h = e => {
      if(typeMenuRef.current && !typeMenuRef.current.contains(e.target)) setShowTypeMenu(false);
      if(colorPickFor!==null && !e.target.closest('.color-picker-pop') && !e.target.closest('.opt-color-btn')) setColorPickFor(null);
    };
    document.addEventListener('mousedown', h);
    return () => document.removeEventListener('mousedown', h);
  }, [showTypeMenu, colorPickFor]);

  const needsOptions = ['single-select','multi-select'].includes(type) ||
    ['__status','__priority','__discipline'].includes(field.id);

  const addOption = () => setOptions(prev => [
    ...prev,
    {id:uid(), label:'', color: OPTION_COLORS[prev.length % OPTION_COLORS.length]}
  ]);

  const updateOpt = (id, key, val) =>
    setOptions(prev => prev.map(o => o.id===id ? {...o,[key]:val} : o));

  const deleteOpt = id => setOptions(prev => prev.filter(o => o.id!==id));

  const moveOpt = (id, dir) => setOptions(prev => {
    const idx = prev.findIndex(o => o.id===id);
    const next = idx + dir;
    if(next < 0 || next >= prev.length) return prev;
    const arr = [...prev];
    [arr[idx], arr[next]] = [arr[next], arr[idx]];
    return arr;
  });

  const handleSave = () => {
    if(!title.trim()) return;
    const thresh = delayThreshold==='' ? null : parseInt(delayThreshold,10);
    onSave({
      ...field,
      title: title.trim(),
      type,
      options: needsOptions ? options.filter(o=>o.label.trim()) : [],
      ...(field.id==='__owner_status' ? {delayThreshold: isNaN(thresh) ? null : thresh} : {}),
    });
  };

  const selectedFT = FIELD_TYPES.find(f=>f.id===type);

  return(
    <div className="af-overlay" onClick={onClose}>
      <div className="ef-box" onClick={e=>e.stopPropagation()}>

        {/* Header */}
        <div className="ef-hdr">
          <div>
            <div className="ef-title">{isBuiltin ? `ЧіВўЧіВЁЧівҖўЧіВҡ ЧіВ©ЧівҖңЧівҖқ: ${field.label}` : 'ЧіВўЧіВЁЧівҖўЧіВҡ ЧіВ©ЧівҖңЧівҖқ'}</div>
          </div>
          <button className="af-close" onClick={onClose}>ЦівҖ”</button>
        </div>

        <div className="ef-body">
          {/* Title + Type */}
          <div className="ef-row">
            <div style={{flex:1}}>
              <div className="af-label">ЧіВ©ЧіВқ ЧівҖқЧіВ©ЧівҖңЧівҖқ *</div>
              <input className="af-input" value={title}
                onChange={e=>setTitle(e.target.value)}
                disabled={isBuiltin}
                style={{background:isBuiltin?'var(--bg)':undefined, color:isBuiltin?'var(--text-2)':undefined}}
                onKeyDown={e=>{if(e.key==='Enter')handleSave();}}
              />
            </div>
            <div style={{width:168}}>
              <div className="af-label">ЧіВЎЧівҖўЧівҖҷ ЧіВ©ЧівҖңЧівҖқ</div>
              <div className="af-type-wrap" ref={typeMenuRef}>
                <button className="af-type-btn"
                  onClick={()=>{ if(!isBuiltin) setShowTypeMenu(o=>!o); }}
                  style={{cursor:isBuiltin?'default':undefined}}>
                  <span className="af-type-icon">{selectedFT?.icon||'Ч’вҖ”вҖ№'}</span>
                  <span className="af-type-label">{FIELD_TYPE_LABEL[type]||type}</span>
                  {!isBuiltin&&<span style={{color:'var(--text-3)',fontSize:10}}>Ч’вҖ“Вҫ</span>}
                </button>
                {showTypeMenu&&(
                  <div className="af-type-menu">
                    {FIELD_TYPES.map(ft=>(
                      <div key={ft.id} className={`af-type-opt${ft.id===type?' sel':''}`}
                        onClick={()=>{setType(ft.id);setShowTypeMenu(false);}}>
                        <span className="af-type-icon">{ft.icon}</span>
                        {ft.label}
                        {ft.id===type&&<span style={{marginRight:'auto',color:'var(--blue)'}}>Ч’ВңвҖң</span>}
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          </div>

          {/* Delay threshold Ч’вӮ¬вҖқ only for __owner_status (ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ ЧіВҗЧівҖ”ЧіВЁЧіВҗЧів„ў) field */}
          {field.id==='__owner_status'&&(
            <div>
              <div className="af-label">ЧіВЎЧіВЈ ЧіВўЧів„ўЧівҖәЧівҖўЧівҖҳ (Чів„ўЧіВһЧів„ўЧіВқ)</div>
              <div style={{display:'flex',alignItems:'center',gap:10}}>
                <input
                  type="number" min="1" max="365"
                  className="af-input"
                  style={{width:90,textAlign:'center'}}
                  placeholder="Ч’вӮ¬вҖқ"
                  value={delayThreshold}
                  onChange={e=>setDelayThreshold(e.target.value)}
                  onKeyDown={e=>{if(e.key==='Enter')handleSave();}}
                />
                <span style={{fontSize:12,color:'var(--text-2)'}}>
                  {delayThreshold ? `ЧіВҗЧіВқ ЧіВўЧівҖҳЧіВЁЧівҖў Чів„ўЧівҖўЧіГ—ЧіВЁ ЧіВһ-${delayThreshold} Чів„ўЧіВһЧів„ўЧіВқ Ч’вӮ¬вҖқ Чів„ўЧіВЎЧівҖўЧіВһЧіВҹ ЧівҖҳЧіВҗЧівҖңЧівҖўЧіВқ` : 'ЧівҖқЧіВ©ЧіВҗЧіВЁ ЧіВЁЧів„ўЧіВ§ ЧіВңЧівҖқЧіВ©ЧівҖҳЧіГ—ЧіГ— ЧіВЎЧів„ўЧіВһЧівҖўЧіВҹ ЧіВўЧів„ўЧівҖәЧівҖўЧівҖҳ'}
                </span>
              </div>
              {delayThreshold&&(
                <div style={{marginTop:6,display:'flex',alignItems:'center',gap:7,fontSize:12,color:'var(--text-2)'}}>
                  <span>ЧіГ—ЧіВҰЧівҖўЧівҖҷЧівҖқ ЧіВһЧіВ§ЧівҖңЧів„ўЧіВһЧівҖқ:</span>
                  <span style={{
                    display:'inline-flex',alignItems:'center',gap:4,
                    padding:'3px 9px',borderRadius:20,
                    background:'rgba(239,68,68,.1)', border:'2px solid #EF4444',
                    color:'#991B1B', fontSize:12, fontWeight:700,
                  }}>
                    {delayThreshold}+ <span style={{fontWeight:400,fontSize:11,opacity:.8}}>Чів„ўЧіВі</span>
                  </span>
                </div>
              )}
            </div>
          )}

          {/* Options editor */}
          {needsOptions&&(
            <div>
              <div className="af-label" style={{marginBottom:8}}>ЧіВҗЧівӮӘЧіВ©ЧіВЁЧівҖўЧів„ўЧівҖўЧіГ— *</div>
              <div style={{display:'flex',flexDirection:'column'}}>
                {options.map((opt,idx)=>(
                  <div key={opt.id} className="opt-row">
                    {/* Up / Down arrows */}
                    <div className="opt-move">
                      <button className="opt-move-btn" disabled={idx===0}
                        onClick={()=>moveOpt(opt.id,-1)} title="ЧівҖқЧівҖ“ЧівҖ“ ЧіВңЧіВһЧіВўЧіВңЧівҖқ">Ч’вҖ“ВІ</button>
                      <button className="opt-move-btn" disabled={idx===options.length-1}
                        onClick={()=>moveOpt(opt.id,1)} title="ЧівҖқЧівҖ“ЧівҖ“ ЧіВңЧіВһЧіЛңЧівҖқ">Ч’вҖ“Вј</button>
                    </div>
                    {/* Color swatch + picker */}
                    <div style={{position:'relative',flexShrink:0}}>
                      <button className="opt-color-btn"
                        style={{background:opt.color||'#ccc',borderRadius:5}}
                        onClick={()=>setColorPickFor(colorPickFor===opt.id?null:opt.id)}
                      />
                      {colorPickFor===opt.id&&(
                        <div className="color-picker-pop">
                          {OPTION_COLORS.map(c=>(
                            <button key={c} className={`color-swatch${c===opt.color?' selected':''}`}
                              style={{background:c}}
                              onClick={()=>{updateOpt(opt.id,'color',c);setColorPickFor(null);}}
                            />
                          ))}
                        </div>
                      )}
                    </div>
                    {/* Label */}
                    <input className="opt-input" value={opt.label}
                      placeholder="ЧіВ©ЧіВқ ЧівҖқЧіВҗЧівӮӘЧіВ©ЧіВЁЧівҖўЧіГ—..."
                      onChange={e=>updateOpt(opt.id,'label',e.target.value)}
                    />
                    {/* Delete */}
                    <button className="opt-del" onClick={()=>deleteOpt(opt.id)}>ЦівҖ”</button>
                  </div>
                ))}
                <button className="opt-add-btn" onClick={addOption}>
                  <span style={{fontSize:15,color:'var(--accent)',lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВҗЧівӮӘЧіВ©ЧіВЁЧівҖўЧіГ—
                </button>
              </div>
            </div>
          )}
        </div>

        {/* Footer */}
        <div className="ef-footer">
          {!isBuiltin&&onDelete&&(
            <button className="ef-delete" onClick={()=>{onDelete(field.id);onClose();}}>ЧіВһЧівҖ”ЧіВ§ ЧіВ©ЧівҖңЧівҖқ</button>
          )}
          <div style={{marginRight:'auto',display:'flex',gap:8}}>
            <button className="af-cancel" onClick={onClose}>ЧівҖҳЧів„ўЧіЛңЧівҖўЧіВң</button>
            <button className="af-save" disabled={!title.trim()} onClick={handleSave}>ЧіВ©ЧіВһЧівҖўЧіВЁ ЧіВ©Чів„ўЧіВ ЧівҖўЧів„ўЧів„ўЧіВқ</button>
          </div>
        </div>
      </div>
    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Add Field Modal
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function AddFieldModal({onSave, onClose, fieldToEdit}) {
  const [title,  setTitle]  = useState(fieldToEdit?.title  || '');
  const [type,   setType]   = useState(fieldToEdit?.type   || 'single-select');
  const [showTypeMenu, setShowTypeMenu] = useState(false);
  const menuRef = useRef(null);
  useEffect(()=>{
    if(!showTypeMenu)return;
    const h=e=>{if(menuRef.current&&!menuRef.current.contains(e.target))setShowTypeMenu(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showTypeMenu]);

  const selectedType = FIELD_TYPES.find(f=>f.id===type) || FIELD_TYPES[0];

  const handleSave = () => {
    if(!title.trim()) return;
    onSave({...(fieldToEdit||{}), title:title.trim(), type});
  };

  return(
    <div className="af-overlay" onClick={onClose}>
      <div className="af-box" onClick={e=>e.stopPropagation()}>
        <div className="af-hdr">
          <span className="af-title">{fieldToEdit?'ЧіВўЧіВЁЧівҖўЧіВҡ ЧіВ©ЧівҖңЧівҖқ':'ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВ©ЧівҖңЧівҖқ'}</span>
          <button className="af-close" onClick={onClose}>ЦівҖ”</button>
        </div>
        {!fieldToEdit&&(
          <div className="af-tabs">
            <button className="af-tab active">ЧіВҰЧівҖўЧіВЁ ЧівҖ”ЧівҖңЧіВ©</button>
            <button className="af-tab">ЧівҖҳЧівҖ”ЧіВЁ ЧіВһЧівҖқЧіВЎЧівӮӘЧіВЁЧів„ўЧів„ўЧівҖқ</button>
          </div>
        )}
        <div className="af-body">
          <div>
            <div className="af-label">ЧіВ©ЧіВқ ЧівҖқЧіВ©ЧівҖңЧівҖқ *</div>
            <input className="af-input" autoFocus placeholder="ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—, ЧіВ©ЧіВңЧівҖҳ, ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ..."
              value={title} onChange={e=>setTitle(e.target.value)}
              onKeyDown={e=>{if(e.key==='Enter')handleSave();if(e.key==='Escape')onClose();}}/>
          </div>
          <div>
            <div className="af-label">ЧіВЎЧівҖўЧівҖҷ ЧіВ©ЧівҖңЧівҖқ</div>
            <div className="af-type-wrap" ref={menuRef}>
              <button className="af-type-btn" onClick={()=>setShowTypeMenu(o=>!o)}>
                <span className="af-type-icon">{selectedType.icon}</span>
                <span className="af-type-label">{selectedType.label}</span>
                <span style={{color:'var(--text-3)',fontSize:10}}>Ч’вҖ“Вҫ</span>
              </button>
              {showTypeMenu&&(
                <div className="af-type-menu">
                  {FIELD_TYPES.map(ft=>(
                    <div key={ft.id} className={`af-type-opt${ft.id===type?' sel':''}`}
                      onClick={()=>{setType(ft.id);setShowTypeMenu(false);}}>
                      <span className="af-type-icon">{ft.icon}</span>
                      {ft.label}
                      {ft.id===type&&<span style={{marginRight:'auto',color:'var(--blue)'}}>Ч’ВңвҖң</span>}
                    </div>
                  ))}
                </div>
              )}
            </div>
          </div>
        </div>
        <div className="af-footer">
          <button className="af-save" disabled={!title.trim()} onClick={handleSave}>
            {fieldToEdit?'ЧіВ©ЧіВһЧівҖўЧіВЁ':'ЧіВҰЧівҖўЧіВЁ ЧіВ©ЧівҖңЧівҖқ'}
          </button>
          <button className="af-cancel" onClick={onClose}>ЧівҖҳЧів„ўЧіЛңЧівҖўЧіВң</button>
        </div>
      </div>
    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Edit List Modal  (Priority / Discipline)
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function EditListModal({title, items, onSave, onClose, previewType='pill'}) {
  const [list, setList] = useState(items.map(i=>({...i})));
  const [colorOpen, setColorOpen] = useState(null);
  const [pickerPos, setPickerPos] = useState(null);

  useEffect(()=>{
    if(colorOpen===null) return;
    const h=e=>{
      if(!e.target.closest('.color-picker-pop')&&!e.target.closest('.elm-color-btn'))
        { setColorOpen(null); setPickerPos(null); }
    };
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[colorOpen]);

  const openColor=(i,e)=>{
    if(colorOpen===i){setColorOpen(null);setPickerPos(null);return;}
    const r=e.currentTarget.getBoundingClientRect();
    setPickerPos({top:r.bottom+6,left:r.left});
    setColorOpen(i);
  };

  const move = (i, dir) => {
    const a=[...list], j=i+dir;
    if(j<0||j>=a.length) return;
    [a[i],a[j]]=[a[j],a[i]]; setList(a);
  };
  const upd = (i, patch) => setList(list.map((x,k)=>k===i?{...x,...patch}:x));
  const setColor = (i, color) => { upd(i,{color, bg:hexBg(color)}); setColorOpen(null); setPickerPos(null); };
  const del = i => setList(list.filter((_,k)=>k!==i));
  const add = () => {
    const c=OPTION_COLORS[list.length % OPTION_COLORS.length];
    setList([...list,{id:uid(), label:'', color:c, bg:hexBg(c)}]);
  };

  return (
    <>
    <div className="af-overlay" onClick={onClose}>
      <div className="ef-box" style={{width:460}} onClick={e=>e.stopPropagation()}>
        <div className="ef-hdr">
          <span className="ef-title">{title}</span>
          <button className="af-close" onClick={onClose}>Ч’ВңвҖў</button>
        </div>
        <div className="ef-body" style={{gap:4}}>
          <p style={{fontSize:11,color:'var(--text-3)',marginBottom:6,lineHeight:1.5}}>
            ЧіВ Чів„ўЧіГ—ЧіВҹ ЧіВңЧіВ©ЧіВ ЧівҖўЧіГ— ЧіВҰЧівҖҳЧіВў, ЧіВ©ЧіВқ ЧівҖўЧіВЎЧівҖңЧіВЁ ЧівҖқЧіВўЧіВЁЧівҖәЧів„ўЧіВқ.<br/>
            ЧіВһЧівҖ“ЧівҖқЧівҖқ (ID) ЧіВҗЧів„ўЧіВ ЧівҖў ЧіВ Чів„ўЧіГ—ЧіВҹ ЧіВңЧіВ©Чів„ўЧіВ ЧівҖўЧів„ў Ч’вӮ¬вҖқ ЧівҖқЧівҖўЧіВҗ ЧіВһЧіВ§ЧіВ©ЧіВЁ ЧіВңЧіВ ЧіГ—ЧівҖўЧіВ Чів„ў ЧівҖқЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—.
          </p>
          {list.map((item, i)=>(
            <div key={item.id||i} className="opt-row" style={{alignItems:'center',gap:8,padding:'6px 8px'}}>
              {/* Color picker */}
              <div style={{flexShrink:0}}>
                <button className="elm-color-btn"
                  style={{width:24,height:24,borderRadius:6,border:'2px solid rgba(0,0,0,.1)',
                          background:item.color,cursor:'pointer',display:'block',padding:0}}
                  onClick={e=>openColor(i,e)}/>
              </div>
              {/* Label input */}
              <input className="opt-input" value={item.label}
                style={{flex:1,fontSize:13}}
                onChange={e=>upd(i,{label:e.target.value})}
                placeholder="ЧіВ©ЧіВқ ЧівҖқЧіВўЧіВЁЧіВҡ..."/>
              {/* Preview */}
              {previewType==='status'
                ? <div style={{width:22,height:22,borderRadius:'50%',background:item.color,flexShrink:0,
                      display:'flex',alignItems:'center',justifyContent:'center',
                      fontSize:9,fontWeight:800,color:'#fff',fontFamily:'Heebo,system-ui,sans-serif'}}>
                    {(item.label||'?')[0]}
                  </div>
                : <span className="pill" style={{color:'#fff',background:item.color,fontSize:11,flexShrink:0}}>
                    {item.label||'?'}
                  </span>
              }
              {/* ID badge */}
              <span style={{fontSize:9,color:'var(--text-3)',background:'var(--bg)',border:'1px solid var(--border)',
                            borderRadius:4,padding:'1px 5px',whiteSpace:'nowrap',fontFamily:'monospace',flexShrink:0}}>
                {item.id}
              </span>
              {/* Reorder */}
              <div className="opt-move" style={{opacity:1}}>
                <button className="opt-move-btn" onClick={()=>move(i,-1)} disabled={i===0}>Ч’вҖ“ВІ</button>
                <button className="opt-move-btn" onClick={()=>move(i,1)} disabled={i===list.length-1}>Ч’вҖ“Вј</button>
              </div>
              {/* Delete */}
              <button className="opt-del" style={{opacity:.6}} onClick={()=>del(i)}>Ч’ВңвҖў</button>
            </div>
          ))}
          <button className="opt-add-btn" onClick={add}>ЧҹВјвҖ№ ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВўЧіВЁЧіВҡ</button>
        </div>
        <div className="ef-footer">
          <button className="af-save" onClick={()=>onSave(list)}>ЧіВ©ЧіВһЧівҖўЧіВЁ ЧіВ©Чів„ўЧіВ ЧівҖўЧів„ўЧів„ўЧіВқ</button>
          <button className="af-cancel" onClick={onClose}>ЧівҖҳЧів„ўЧіЛңЧівҖўЧіВң</button>
        </div>
      </div>
    </div>
    {colorOpen!==null&&pickerPos&&ReactDOM.createPortal(
      <div className="color-picker-pop"
        style={{position:'fixed',top:pickerPos.top,left:pickerPos.left,right:'auto',zIndex:9999}}>
        {OPTION_COLORS.map(c=>(
          <button key={c} className={`color-swatch${c===list[colorOpen]?.color?' selected':''}`}
            style={{background:c}} onClick={()=>setColor(colorOpen,c)}/>
        ))}
      </div>,
      document.body
    )}
    </>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Settings Panel
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function SettingsPanel({data, save, onClose}) {
  const [view, setView]             = useState('menu');  // 'menu' | 'fields'
  const [showAddField, setShowAddField] = useState(false);
  const [editField, setEditField]   = useState(null);   // {field, isBuiltin}

  const fields     = data.fields    || [];
  const hiddenCols = data.hiddenCols || {};

  const addField = f => {
    save({...data, fields:[...fields,{...f,id:uid()}]});
    setShowAddField(false);
  };
  const updateField = f => {
    save({...data, fields:fields.map(x=>x.id===f.id?f:x)});
    setEditField(null);
  };
  const deleteField = id => save({...data, fields:fields.filter(f=>f.id!==id)});
  const toggleCol   = id => save({...data, hiddenCols:{...hiddenCols,[id]:!hiddenCols[id]}});

  const BUILTIN_TYPE_LABEL = {status:'ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ',priority:'ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—',tag:'ЧіГ—ЧівҖҷЧів„ўЧіГ—',timeline:'ЧіЛңЧів„ўЧів„ўЧіВһЧіВңЧів„ўЧів„ўЧіВҹ',text:'ЧіЛңЧіВ§ЧіВЎЧіЛң',days:'Чів„ўЧіВһЧів„ўЧіВқ',gantt:'ЧівҖҷЧіВ ЧіЛң'};

  return(
    <>
      {/* Backdrop Ч’вӮ¬вҖқ click outside closes */}
      <div style={{position:'fixed',inset:0,zIndex:899}} onClick={onClose}/>

      <div className="sp-panel">
        {/* Header */}
        <div className="sp-hdr">
          {view==='fields'&&(
            <button className="sp-hdr-btn" onClick={()=>setView('menu')} title="ЧівҖ”ЧівҖ“ЧіВЁЧівҖқ">Ч’вҖ Вҗ</button>
          )}
          <span className="sp-hdr-title">{view==='fields'?'ЧіВ©ЧівҖңЧівҖўЧіГ—':'ЧівҖқЧіГ—ЧіВҗЧіВһЧівҖқ ЧіВҗЧів„ўЧіВ©Чів„ўЧіГ—'}</span>
          <button className="sp-hdr-btn" onClick={onClose} title="ЧіВЎЧівҖҷЧівҖўЧіВЁ">Ч’вҖ вҖҷ|</button>
        </div>

        {view==='menu'&&(
          <>
            {/* Project section */}
            <div className="sp-proj">
              <div className="sp-proj-row">
                <span className="sp-proj-name">ЧівҖқЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң</span>
                <button className="sp-btn-sm">+ ЧівҖқЧівҖўЧіВЎЧіВЈ Ч’вҖ“Вҫ</button>
              </div>
              <div className="sp-proj-sub">ЧіВҰЧівӮӘЧівҖқ ЧівҖўЧіВўЧіВЁЧівҖўЧіВҡ ЧіГ—ЧівҖәЧівҖўЧіВ ЧівҖўЧіГ— ЧіВ©ЧіВң ЧівҖқЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң</div>
            </div>

            {/* Nav items */}
            <div className="sp-sec-lbl">ЧіГ—ЧівҖәЧівҖўЧіВ ЧівҖўЧіГ— ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ ЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ</div>
            <div className="sp-nav">
              <button className="sp-nav-item" onClick={()=>setView('fields')}>
                <div className="sp-nav-icon">Ч’ВҠв„ў</div>
                ЧіВ©ЧівҖңЧівҖўЧіГ—
                <span className="sp-nav-badge">{BUILTIN_FIELDS.length + fields.length}</span>
                <span style={{marginRight:'auto',color:'var(--text-3)',fontSize:11}}>Ч’вӮ¬Г·</span>
              </button>
              <button className="sp-nav-item" style={{opacity:.45,cursor:'default'}} disabled>
                <div className="sp-nav-icon">Ч’ВҠВЎ</div>
                ЧіЛңЧівӮӘЧіВЎЧів„ўЧіВқ
                <span style={{marginRight:'auto',color:'var(--text-3)',fontSize:11}}>Ч’вӮ¬Г·</span>
              </button>
              <button className="sp-nav-item" style={{opacity:.45,cursor:'default'}} disabled>
                <div className="sp-nav-icon">Ч’ВҡВЎ</div>
                ЧівҖәЧіВңЧіВңЧів„ўЧіВқ
                <span style={{marginRight:'auto',color:'var(--text-3)',fontSize:11}}>Ч’вӮ¬Г·</span>
              </button>
            </div>
          </>
        )}

        {view==='fields'&&(
          <div className="sp-content">
            {/* Built-in fields */}
            <div className="sp-sec-lbl">ЧіВ©ЧівҖңЧівҖўЧіГ— ЧіВһЧівҖўЧівҖҳЧіВ Чів„ўЧіВқ</div>
            {BUILTIN_FIELDS.map(f=>(
              <div key={f.id} className="sp-field-row" style={{cursor:'pointer'}}
                onClick={()=>setEditField({field:{...f,...(data.builtinConfig?.[f.id]||{})}, isBuiltin:true})}>
                <div className="sp-ficon">{f.icon}</div>
                <span className="sp-fname">{f.label}</span>
                <span className="sp-ftype">{BUILTIN_TYPE_LABEL[f.type]||f.type}</span>
                <div className="sp-faction" onClick={e=>e.stopPropagation()}>
                  {!f.locked&&(
                    <button className={`sp-toggle${!hiddenCols[f.id]?' on':''}`}
                      title={hiddenCols[f.id]?'ЧівҖқЧіВҰЧівҖҷ':'ЧівҖқЧіВЎЧіГ—ЧіВЁ'}
                      onClick={()=>toggleCol(f.id)}/>
                  )}
                  {f.locked&&<div style={{width:28}}/>}
                </div>
              </div>
            ))}

            {/* Custom fields */}
            {fields.length>0&&(
              <>
                <div className="sp-sep"/>
                <div className="sp-sec-lbl">ЧіВ©ЧівҖңЧівҖўЧіГ— ЧіВһЧівҖўЧіГ—ЧіВҗЧіВһЧів„ўЧіВқ ЧіВҗЧів„ўЧіВ©Чів„ўЧіГ—</div>
                {fields.map(f=>(
                  <div key={f.id} className="sp-field-row" style={{cursor:'pointer'}}
                    onClick={()=>setEditField({field:f, isBuiltin:false})}>
                    <div className="sp-ficon">
                      {FIELD_TYPES.find(t=>t.id===f.type)?.icon||'Ч’вҖ”вҖ№'}
                    </div>
                    <span className="sp-fname">{f.title}</span>
                    <span className="sp-ftype">{FIELD_TYPE_LABEL[f.type]||f.type}</span>
                    <div className="sp-faction" onClick={e=>e.stopPropagation()}>
                      <button className={`sp-toggle${!hiddenCols[f.id]?' on':''}`}
                        title={hiddenCols[f.id]?'ЧівҖқЧіВҰЧівҖҷ':'ЧівҖқЧіВЎЧіГ—ЧіВЁ'}
                        onClick={()=>toggleCol(f.id)}/>
                      <button className="sp-fbtn" title="ЧіВһЧівҖ”ЧіВ§" onClick={()=>deleteField(f.id)}
                        style={{color:'#EF4444'}}>Ч’ВңвҖў</button>
                    </div>
                  </div>
                ))}
              </>
            )}

            {/* Add field button */}
            <button className="sp-add-btn" onClick={()=>setShowAddField(true)}>
              <span style={{fontSize:15,lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВ©ЧівҖңЧівҖқ
            </button>
          </div>
        )}
      </div>

      {/* Add field modal */}
      {showAddField&&(
        <AddFieldModal
          onSave={addField}
          onClose={()=>setShowAddField(false)}
        />
      )}

      {/* Edit field modal */}
      {editField&&(
        <EditFieldModal
          field={editField.field}
          isBuiltin={editField.isBuiltin}
          onSave={editField.isBuiltin
            ? (updated=>{ save({...data, builtinConfig:{...(data.builtinConfig||{}),[updated.id]:updated}}); setEditField(null); })
            : updateField}
          onDelete={!editField.isBuiltin ? deleteField : null}
          onClose={()=>setEditField(null)}
        />
      )}
    </>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Toolbar with Filter / Sort
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function Toolbar({onAddTask, onAddGroup, filterState, setFilterState, sortState, setSortState, groupByState, setGroupByState, onSettings, settingsOpen, views, activeViewId, activeViewName, isViewDirty, onSaveView, onLoadView, onDeleteView, onRenameView, onUpdateView}) {
  const {priorities, disciplines} = useContext(ListsCtx);
  const [showFilter,setShowFilter]=useState(false);
  const [showSort,setShowSort]=useState(false);
  const [showGroup,setShowGroup]=useState(false);
  const [showViews,setShowViews]=useState(false);
  const [savingName,setSavingName]=useState(false);
  const [viewNameDraft,setViewNameDraft]=useState('');
  const [renamingId,setRenamingId]=useState(null);
  const [renameDraft,setRenameDraft]=useState('');
  const [filterStep,setFilterStep]=useState(null); // null | 'priority'|'discipline'|'status'
  const [sortCol,setSortCol]=useState(null);
  const [groupAddStep,setGroupAddStep]=useState(false);
  const [showAddMenu,setShowAddMenu]=useState(false);
  const filterRef=useRef(null);
  const sortRef=useRef(null);
  const groupRef=useRef(null);
  const viewsRef=useRef(null);
  const addMenuRef=useRef(null);

  useEffect(()=>{
    if(!showAddMenu)return;
    const h=e=>{if(addMenuRef.current&&!addMenuRef.current.contains(e.target)){setShowAddMenu(false);}};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showAddMenu]);

  useEffect(()=>{
    if(!showFilter)return;
    const h=e=>{if(filterRef.current&&!filterRef.current.contains(e.target)){setShowFilter(false);setFilterStep(null);}};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showFilter]);
  useEffect(()=>{
    if(!showSort)return;
    const h=e=>{if(sortRef.current&&!sortRef.current.contains(e.target)){setShowSort(false);setSortCol(null);}};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showSort]);
  useEffect(()=>{
    if(!showGroup)return;
    const h=e=>{if(groupRef.current&&!groupRef.current.contains(e.target)){setShowGroup(false);setGroupAddStep(false);}};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showGroup]);
  useEffect(()=>{
    if(!showViews)return;
    const h=e=>{if(viewsRef.current&&!viewsRef.current.contains(e.target)){setShowViews(false);setSavingName(false);setViewNameDraft('');setRenamingId(null);}};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showViews]);

  const applyFilter=(col,val)=>{setFilterState({column:col,value:val});setShowFilter(false);setFilterStep(null);};

  const sortList    = sortState||[];
  const filterCount = filterState?1:0;
  const sortCount   = sortList.length;
  const groupList   = groupByState||[{field:'section'}];
  const isDefaultGroup = groupList.length===1 && groupList[0].field==='section';
  const groupCount  = isDefaultGroup ? 0 : groupList.length;

  const addSortField  = col => { setSortState([...sortList,{column:col,dir:'desc'}]); setSortCol(null); };
  const removeSortField = col => { const a=sortList.filter(s=>s.column!==col); setSortState(a.length?a:null); };
  const toggleSortDir = col => setSortState(sortList.map(s=>s.column===col?{...s,dir:s.dir==='asc'?'desc':'asc'}:s));
  const moveSortField = (i,d) => {
    const a=[...sortList]; const j=i+d;
    if(j<0||j>=a.length) return;
    [a[i],a[j]]=[a[j],a[i]]; setSortState(a);
  };

  return(
    <div className="toolbar">
      {/* Add task */}
      <div ref={addMenuRef} style={{position:'relative'}}>
        <div className="btn-add-wrap">
          <button className="btn-add-main" onClick={()=>onAddTask('simple')}>+ ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ</button>
          <button className="btn-add-arr" onClick={()=>setShowAddMenu(o=>!o)}>Ч’вҖ“Вҫ</button>
        </div>
        {showAddMenu&&(
          <div className="dp" style={{right:0,left:'auto',minWidth:170,top:'calc(100% + 6px)'}}>
            <div className="dp-title">ЧіВЎЧівҖўЧівҖҷ ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ</div>
            <div className="dp-opt" onClick={()=>{onAddTask('simple');setShowAddMenu(false);}}>
              <span style={{width:14,height:14,borderRadius:'50%',border:'2px solid var(--text-3)',display:'inline-block',flexShrink:0}}/>
              ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ
            </div>
            <div className="dp-opt" onClick={()=>{onAddTask('process');setShowAddMenu(false);}}>
              <span style={{width:14,height:14,borderRadius:2,border:'2px solid var(--text-3)',display:'inline-block',flexShrink:0}}/>
              ЧіГ—ЧівҖқЧіВңЧів„ўЧіВҡ
            </div>
            <div className="dp-sep"/>
            <div className="dp-title">ЧіВһЧівҖҳЧіВ ЧівҖқ</div>
            <div className="dp-opt" onClick={()=>{onAddGroup();setShowAddMenu(false);}}>
              <span style={{width:14,height:3,background:'var(--text-3)',borderRadius:1,display:'inline-block',flexShrink:0,marginBottom:1}}/>
              ЧіВһЧіВ§ЧіЛңЧіВў
            </div>
          </div>
        )}
      </div>

      <div className="tb-right">
        {/* Views */}
        <div ref={viewsRef} style={{position:'relative'}}>
          <button className={`btn-tb${activeViewId?' on':''}`}
            onClick={()=>{setShowViews(o=>!o);setShowFilter(false);setShowSort(false);setShowGroup(false);}}>
            Ч’ЛңВ° {activeViewId ? activeViewName : 'ЧіВһЧівҖҳЧіЛңЧів„ўЧіВқ'}
            {!activeViewId && views?.length>0 && <span className="tb-badge">{views.length}</span>}
          </button>
          {/* Update-view button Ч’вӮ¬вҖқ shown when active view has unsaved changes */}
          {activeViewId && isViewDirty && (
            <button onClick={onUpdateView}
              style={{display:'flex',alignItems:'center',gap:5,padding:'4px 10px',borderRadius:7,
                border:'1px solid var(--accent)',fontSize:11,fontWeight:700,cursor:'pointer',
                fontFamily:'inherit',background:'rgba(37,99,235,.08)',color:'var(--accent)',
                whiteSpace:'nowrap',marginRight:4}}>
              Ч’вҖ вҖҳ ЧіВўЧівҖңЧівҖәЧіВҹ ЧіВһЧівҖҳЧіЛң
            </button>
          )}
          {showViews&&(
            <div className="dp" style={{right:0,left:'auto',minWidth:230,padding:0}} onClick={e=>e.stopPropagation()}>
              <div className="dp-title" style={{padding:'8px 12px 6px'}}>ЧіВһЧівҖҳЧіЛңЧів„ўЧіВқ ЧіВ©ЧіВһЧівҖўЧіВЁЧів„ўЧіВқ</div>
              {/* Default view */}
              <div className={`dp-opt${!activeViewId?' sel':''}`}
                onClick={()=>{onLoadView(null);setShowViews(false);}}>
                <span style={{width:14,textAlign:'center',color:!activeViewId?'var(--accent)':'var(--text-3)',fontWeight:700,fontSize:12}}>{!activeViewId?'Ч’ВңвҖң':''}</span>
                ЧівҖҳЧіВЁЧів„ўЧіВЁЧіГ— ЧіВһЧівҖ”ЧівҖңЧіВң
              </div>
              {/* Saved views */}
              {(views||[]).map(v=>(
                <div key={v.id} style={{display:'flex',alignItems:'center',gap:4,padding:'3px 8px 3px 12px',borderRadius:7,cursor:'pointer'}}
                  onMouseEnter={e=>e.currentTarget.style.background='var(--bg)'}
                  onMouseLeave={e=>e.currentTarget.style.background=''}>
                  {renamingId===v.id
                    ?<input autoFocus value={renameDraft}
                        onChange={e=>setRenameDraft(e.target.value)}
                        onBlur={()=>{if(renameDraft.trim())onRenameView(v.id,renameDraft.trim());setRenamingId(null);}}
                        onKeyDown={e=>{if(e.key==='Enter'){if(renameDraft.trim())onRenameView(v.id,renameDraft.trim());setRenamingId(null);}if(e.key==='Escape')setRenamingId(null);}}
                        onClick={e=>e.stopPropagation()}
                        style={{flex:1,border:'1px solid var(--accent)',borderRadius:5,padding:'2px 6px',fontSize:12,fontFamily:'inherit',outline:'none'}}/>
                    :<div style={{flex:1,display:'flex',alignItems:'center',gap:6}}
                        onClick={()=>{onLoadView(v.id);setShowViews(false);}}>
                        <span style={{width:14,textAlign:'center',color:'var(--accent)',fontWeight:700,fontSize:12}}>{activeViewId===v.id?'Ч’ВңвҖң':''}</span>
                        <span style={{fontSize:13,fontWeight:activeViewId===v.id?600:400}}>{v.name}</span>
                      </div>
                  }
                  {renamingId!==v.id&&(
                    <div style={{display:'flex',gap:2,flexShrink:0}}>
                      <button title="ЧіВ©ЧіВ ЧівҖқ ЧіВ©ЧіВқ" onClick={e=>{e.stopPropagation();setRenameDraft(v.name);setRenamingId(v.id);}}
                        style={{background:'none',border:'none',cursor:'pointer',color:'var(--text-3)',fontSize:11,padding:'2px 4px',borderRadius:4}}
                        onMouseEnter={e=>e.currentTarget.style.color='var(--text)'}
                        onMouseLeave={e=>e.currentTarget.style.color='var(--text-3)'}>Ч’ВңВҸ</button>
                      <button title="ЧіВһЧівҖ”ЧіВ§" onClick={e=>{e.stopPropagation();onDeleteView(v.id);}}
                        style={{background:'none',border:'none',cursor:'pointer',color:'var(--text-3)',fontSize:12,padding:'2px 4px',borderRadius:4}}
                        onMouseEnter={e=>e.currentTarget.style.color='#EF4444'}
                        onMouseLeave={e=>e.currentTarget.style.color='var(--text-3)'}>ЦівҖ”</button>
                    </div>
                  )}
                </div>
              ))}
              <div className="dp-sep"/>
              {/* Save current view */}
              {!savingName
                ?<div className="dp-opt" onClick={()=>{setSavingName(true);setViewNameDraft('');}}>
                    <span style={{color:'var(--blue)',fontWeight:700,fontSize:14,lineHeight:1}}>+</span> ЧіВ©ЧіВһЧівҖўЧіВЁ ЧіВһЧівҖҳЧіЛң ЧіВ ЧівҖўЧівҖәЧівҖ”Чів„ў
                  </div>
                :<div style={{padding:'6px 12px 10px',display:'flex',gap:6,alignItems:'center'}}>
                    <input autoFocus value={viewNameDraft}
                      onChange={e=>setViewNameDraft(e.target.value)}
                      onKeyDown={e=>{
                        if(e.key==='Enter'&&viewNameDraft.trim()){onSaveView(viewNameDraft.trim());setSavingName(false);setViewNameDraft('');setShowViews(false);}
                        if(e.key==='Escape'){setSavingName(false);setViewNameDraft('');}
                      }}
                      placeholder="ЧіВ©ЧіВқ ЧівҖқЧіВһЧівҖҳЧіЛң..."
                      style={{flex:1,border:'1px solid var(--accent)',borderRadius:5,padding:'4px 8px',fontSize:12,fontFamily:'inherit',outline:'none'}}/>
                    <button
                      onClick={()=>{if(viewNameDraft.trim()){onSaveView(viewNameDraft.trim());setSavingName(false);setViewNameDraft('');setShowViews(false);}}}
                      style={{background:'var(--accent)',color:'#fff',border:'none',borderRadius:5,padding:'4px 10px',fontSize:12,cursor:'pointer',fontFamily:'inherit',fontWeight:600,whiteSpace:'nowrap'}}>
                      ЧіВ©ЧіВһЧівҖўЧіВЁ
                    </button>
                  </div>
              }
            </div>
          )}
        </div>

        {/* Filter */}
        <div ref={filterRef} style={{position:'relative'}}>
          <button className={`btn-tb${filterCount>0?' on':''}`} onClick={()=>{setShowFilter(o=>!o);setShowSort(false);setShowGroup(false);setShowViews(false);}}>
            Ч’ВҠВј ЧіВЎЧів„ўЧіВ ЧівҖўЧіВҹ {filterCount>0&&<span className="tb-badge">{filterCount}</span>}
          </button>
          {showFilter&&(
            <div className="dp" style={{right:0,left:'auto',minWidth:220}} onClick={e=>e.stopPropagation()}>
              {!filterStep&&(
                <>
                  <div className="dp-title">ЧіВЎЧіВ ЧіВҹ ЧіВңЧівӮӘЧів„ў</div>
                  {[['priority','ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—'],['discipline','ЧіГ—ЧівҖ”ЧівҖўЧіВқ'],['status','ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ']].map(([col,lbl])=>(
                    <div key={col} className="dp-opt" onClick={()=>setFilterStep(col)}>
                      {lbl} <span style={{marginRight:'auto',color:'var(--text-3)',fontSize:11}}>Ч’вӮ¬Г·</span>
                    </div>
                  ))}
                </>
              )}
              {filterStep==='priority'&&(
                <>
                  <div className="dp-opt" style={{color:'var(--text-3)',fontSize:11,cursor:'pointer'}} onClick={()=>setFilterStep(null)}>Ч’вӮ¬В№ ЧівҖ”ЧівҖ“ЧіВЁЧівҖқ</div>
                  <div className="dp-title">ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧіГ—</div>
                  {priorities.map(p=>(
                    <div key={p.id} className="dp-opt" onClick={()=>applyFilter('priority',p.id)}>
                      <span className="pill" style={{color:p.color,background:p.bg}}>{p.label}</span>
                    </div>
                  ))}
                </>
              )}
              {filterStep==='discipline'&&(
                <>
                  <div className="dp-opt" style={{color:'var(--text-3)',fontSize:11,cursor:'pointer'}} onClick={()=>setFilterStep(null)}>Ч’вӮ¬В№ ЧівҖ”ЧівҖ“ЧіВЁЧівҖқ</div>
                  <div className="dp-title">ЧіГ—ЧівҖ”ЧівҖўЧіВқ</div>
                  {disciplines.map(d=>(
                    <div key={d.id} className="dp-opt" onClick={()=>applyFilter('discipline',d.id)}>
                      <span className="pill" style={{color:d.color,background:d.bg}}>{d.label}</span>
                    </div>
                  ))}
                </>
              )}
              {filterStep==='status'&&(
                <>
                  <div className="dp-opt" style={{color:'var(--text-3)',fontSize:11,cursor:'pointer'}} onClick={()=>setFilterStep(null)}>Ч’вӮ¬В№ ЧівҖ”ЧівҖ“ЧіВЁЧівҖқ</div>
                  <div className="dp-title">ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ</div>
                  {STATUSES.map(s=>(
                    <div key={s.id} className="dp-opt" onClick={()=>applyFilter('status',s.id)}>
                      <div className={`sc${s.id==='C'?' sc-done':''}`}
                        style={{color:s.id==='C'?'#fff':s.color,backgroundColor:s.id==='C'?s.color:'transparent',borderColor:s.color,width:14,height:14,fontSize:6,flexShrink:0}}>
                        {s.letter}
                      </div>
                      {s.label}
                    </div>
                  ))}
                </>
              )}
            </div>
          )}
        </div>

        {/* Group */}
        <div ref={groupRef} style={{position:'relative'}}>
          <button className={`btn-tb${groupCount>0?' on':''}`} onClick={()=>{setShowGroup(o=>!o);setShowFilter(false);setShowSort(false);setShowViews(false);}}>
            Ч’ВҠВһ ЧіВ§ЧівҖҳЧівҖўЧіВҰЧівҖўЧіГ— {groupCount>0&&<span className="tb-badge">{groupCount}</span>}
          </button>
          {showGroup&&(
            <div className="dp" style={{right:0,left:'auto',minWidth:260,padding:0}} onClick={e=>e.stopPropagation()}>
              {!groupAddStep?(
                <>
                  <div className="dp-title" style={{padding:'8px 12px 6px'}}>ЧіВ§ЧівҖҳЧівҖўЧіВҰЧівҖқ ЧіВңЧівӮӘЧів„ў</div>
                  {groupList.length===0&&(
                    <div style={{padding:'6px 14px 8px',color:'var(--text-3)',fontSize:12}}>ЧіВҗЧів„ўЧіВҹ ЧіВ§ЧівҖҳЧівҖўЧіВҰЧівҖқ ЧівӮӘЧіВўЧів„ўЧіВңЧівҖқ</div>
                  )}
                  {groupList.map((g,i)=>{
                    const lbl=GROUP_FIELDS.find(f=>f.field===g.field)?.label||g.field;
                    return(
                      <div key={g.field} className="sort-crit-row">
                        <span className="sort-crit-num">{i+1}</span>
                        <span className="sort-crit-label">{lbl}</span>
                        <button className="sort-crit-move" disabled={i===0} onClick={()=>{const a=[...groupList];[a[i-1],a[i]]=[a[i],a[i-1]];setGroupByState(a);}}>Ч’вҖ вҖҳ</button>
                        <button className="sort-crit-move" disabled={i===groupList.length-1} onClick={()=>{const a=[...groupList];[a[i],a[i+1]]=[a[i+1],a[i]];setGroupByState(a);}}>Ч’вҖ вҖң</button>
                        <button className="sort-crit-del" onClick={()=>{const a=groupList.filter((_,j)=>j!==i);setGroupByState(a.length?a:[{field:'section'}]);}}>Ч’ВңвҖў</button>
                      </div>
                    );
                  })}
                  <div style={{padding:'6px 0 4px',borderTop:groupList.length?'1px solid var(--border)':'none'}}>
                    {groupList.length<GROUP_FIELDS.length&&(
                      <div className="dp-opt" onClick={()=>setGroupAddStep(true)}>
                        <span style={{color:'var(--blue)',fontWeight:700,fontSize:14,lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВЁЧіВһЧіГ— ЧіВ§ЧівҖҳЧівҖўЧіВҰЧівҖқ
                      </div>
                    )}
                    {!isDefaultGroup&&(
                      <div className="dp-opt" style={{color:'#EF4444'}} onClick={()=>{setGroupByState([{field:'section'}]);setShowGroup(false);}}>
                        Ч’ВңвҖў ЧіВҗЧівӮӘЧіВЎ ЧіВ§ЧівҖҳЧівҖўЧіВҰЧівҖқ
                      </div>
                    )}
                  </div>
                </>
              ):(
                <>
                  <div className="dp-opt" style={{color:'var(--text-3)',fontSize:11,cursor:'pointer',padding:'8px 12px'}} onClick={()=>setGroupAddStep(false)}>Ч’вӮ¬В№ ЧівҖ”ЧівҖ“ЧіВЁЧівҖқ</div>
                  <div className="dp-title" style={{padding:'0 12px 6px'}}>ЧівҖҳЧівҖ”ЧіВЁ ЧіВ©ЧівҖңЧівҖқ</div>
                  {GROUP_FIELDS.filter(f=>!groupList.find(g=>g.field===f.field)).map(f=>(
                    <div key={f.field} className="dp-opt" onClick={()=>{setGroupByState([...groupList,{field:f.field}]);setGroupAddStep(false);}}>
                      {f.label}
                    </div>
                  ))}
                </>
              )}
            </div>
          )}
        </div>

        {/* Sort */}
        <div ref={sortRef} style={{position:'relative'}}>
          <button className={`btn-tb${sortCount>0?' on':''}`} onClick={()=>{setShowSort(o=>!o);setShowFilter(false);setShowGroup(false);setShowViews(false);}}>
            Ч’вҖЎвҖҰ ЧіВһЧів„ўЧівҖўЧіВҹ {sortCount>0&&<span className="tb-badge">{sortCount}</span>}
          </button>
          {showSort&&(
            <div className="dp" style={{right:0,left:'auto',minWidth:260,padding:0}} onClick={e=>e.stopPropagation()}>
              {!sortCol?(
                <>
                  <div className="dp-title" style={{padding:'8px 12px 6px'}}>ЧіВһЧів„ўЧів„ўЧіВҹ ЧіВңЧівӮӘЧів„ў</div>
                  {/* existing criteria */}
                  {sortList.length===0&&(
                    <div style={{padding:'6px 14px 8px',color:'var(--text-3)',fontSize:12}}>ЧіВҗЧів„ўЧіВҹ ЧіВһЧів„ўЧівҖўЧіВҹ ЧівӮӘЧіВўЧів„ўЧіВң</div>
                  )}
                  {sortList.map((s,i)=>{
                    const lbl=SORT_FIELDS.find(f=>f.column===s.column)?.label||s.column;
                    return(
                      <div key={s.column} className="sort-crit-row">
                        <span className="sort-crit-num">{i+1}</span>
                        <span className="sort-crit-label">{lbl}</span>
                        <button className="sort-crit-move" disabled={i===0} onClick={()=>moveSortField(i,-1)}>Ч’вҖ вҖҳ</button>
                        <button className="sort-crit-move" disabled={i===sortList.length-1} onClick={()=>moveSortField(i,1)}>Ч’вҖ вҖң</button>
                        <button className="sort-crit-btn" onClick={()=>toggleSortDir(s.column)}>
                          {s.dir==='asc'?'Ч’вҖ вҖҳ ЧіВўЧівҖўЧіВңЧівҖқ':'Ч’вҖ вҖң Чів„ўЧівҖўЧіВЁЧівҖң'}
                        </button>
                        <button className="sort-crit-del" onClick={()=>removeSortField(s.column)}>Ч’ВңвҖў</button>
                      </div>
                    );
                  })}
                  <div style={{padding:'6px 0 4px',borderTop: sortList.length?'1px solid var(--border)':'none'}}>
                    {sortList.length<SORT_FIELDS.length&&(
                      <div className="dp-opt" onClick={()=>setSortCol('__pick')}>
                        <span style={{color:'var(--blue)',fontWeight:700,fontSize:14,lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВ©ЧівҖңЧівҖқ ЧіВһЧів„ўЧівҖўЧіВҹ
                      </div>
                    )}
                    {sortList.length>0&&(
                      <div className="dp-opt" style={{color:'#EF4444'}} onClick={()=>{setSortState(null);setShowSort(false);}}>
                        Ч’ВңвҖў ЧіВ ЧіВ§ЧівҖқ ЧіВһЧів„ўЧівҖўЧіВҹ
                      </div>
                    )}
                  </div>
                </>
              ):(
                <>
                  <div className="dp-opt" style={{color:'var(--text-3)',fontSize:11,cursor:'pointer',padding:'8px 12px'}} onClick={()=>setSortCol(null)}>Ч’вӮ¬В№ ЧівҖ”ЧівҖ“ЧіВЁЧівҖқ</div>
                  <div className="dp-title" style={{padding:'0 12px 6px'}}>ЧівҖҳЧівҖ”ЧіВЁ ЧіВ©ЧівҖңЧівҖқ</div>
                  {SORT_FIELDS.filter(f=>!sortList.find(s=>s.column===f.column)).map(f=>(
                    <div key={f.column} className="dp-opt" onClick={()=>addSortField(f.column)}>
                      {f.label}
                    </div>
                  ))}
                </>
              )}
            </div>
          )}
        </div>

        {/* Settings */}
        <button className={`btn-tb${settingsOpen?' on':''}`} onClick={onSettings}>Ч’Вҡв„ў ЧівҖқЧівҖҷЧівҖңЧіВЁЧівҖўЧіГ—</button>
      </div>
    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   SVG Icon system Ч’вӮ¬вҖқ minimalist line icons
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
const ICONS = {
  overview:    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><rect x="9" y="9" width="6" height="6" rx="1"/></svg>,
  licensing:   <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M4 1h6l4 4v10H2V1h2"/><path d="M10 1v4h4"/><path d="M5 8h6M5 11h4"/></svg>,
  planning:    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><rect x="1" y="1" width="14" height="14" rx="1"/><path d="M1 5h14M5 5v10M9 5v10"/></svg>,
  execution:   <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M2 13V7l6-6 6 6v6a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1z"/><path d="M6 14V9h4v5"/></svg>,
  meetings:    <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><rect x="3" y="2" width="10" height="12" rx="1"/><path d="M6 2V1M10 2V1"/><path d="M5 6h6M5 9h4"/></svg>,
  supervision: <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="8" cy="8" r="3"/><path d="M1 8s2.5-5 7-5 7 5 7 5-2.5 5-7 5-7-5-7-5z"/></svg>,
  goals:       <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="8" cy="8" r="7"/><circle cx="8" cy="8" r="3"/><line x1="8" y1="1" x2="8" y2="4"/></svg>,
  milestones:  <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M8 2 L14 8 L8 14 L2 8 Z"/></svg>,
  consultants: <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="6" cy="5" r="3"/><path d="M1 14s1-4 5-4 5 4 5 4"/><path d="M11 7c1.1 0 2 .9 2 2s-.9 2-2 2"/><path d="M13 4c1.1 0 2 .9 2 2s-.9 2-2 2"/></svg>,
  star:        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M8 1l2 5h5l-4 3 1.5 5L8 11l-4.5 3L5 9 1 6h5z"/></svg>,
  share:       <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="3" r="2"/><circle cx="4" cy="8" r="2"/><circle cx="12" cy="13" r="2"/><path d="M6 7l4-3M6 9l4 3"/></svg>,
  building:    <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><rect x="2" y="3" width="12" height="11" rx="1"/><path d="M2 7h12M6 3V2M10 3V2M5 10h2M9 10h2"/></svg>,
  soon:        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>,
  tasks:       <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M3 4h10M3 8h10M3 12h6"/><path d="M11 10l2 2 3-3"/></svg>,
  home:        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M2 7L8 2l6 5v7a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1z"/><path d="M6 14V9h4v5"/></svg>,
  mytasks:     <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="8" cy="8" r="7"/><path d="M5.5 8l2 2 3-3"/></svg>,
  hours:       <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="8" cy="8" r="7"/><path d="M8 4v4l3 2"/></svg>,
  portfolio:   <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><rect x="1" y="5" width="14" height="9" rx="1"/><path d="M5 5V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1"/><path d="M1 9h14"/></svg>,
  projects:    <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><rect x="1" y="1" width="6" height="6" rx="1"/><rect x="9" y="1" width="6" height="6" rx="1"/><rect x="1" y="9" width="6" height="6" rx="1"/><path d="M9 12h6M12 9v6"/></svg>,
  chevron:     <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><path d="M4 2l4 4-4 4"/></svg>,
  menu:        <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round"><path d="M2 4h12M2 8h12M2 12h12"/></svg>,
};
function Ic({n, size=14}) {
  const el = ICONS[n];
  if (!el) return null;
  return React.cloneElement(el, {width:size, height:size});
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Home / Landing Page
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function HomeView({data}) {
  const today = new Date();
  const todayStr = today.toISOString().split('T')[0];
  const hour = today.getHours();
  const greeting = hour < 12 ? 'ЧівҖҳЧівҖўЧіВ§ЧіВЁ ЧіЛңЧівҖўЧівҖҳ' : hour < 17 ? 'ЧіВҰЧівҖқЧіВЁЧів„ўЧів„ўЧіВқ ЧіЛңЧівҖўЧівҖҳЧів„ўЧіВқ' : 'ЧіВўЧіВЁЧівҖҳ ЧіЛңЧівҖўЧівҖҳ';
  const userName = 'ЧіВ©Чів„ў';
  const fullName = 'ЧіВ©Чів„ў ЧівҖқЧіВЁЧіВ©ЧіВ§ЧівҖўЧівҖҳЧів„ўЧіВҘ';

  const DAY_NAMES = ['ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВҹ','ЧіВ©ЧіВ Чів„ў','ЧіВ©ЧіВңЧів„ўЧіВ©Чів„ў','ЧіВЁЧівҖҳЧів„ўЧіВўЧів„ў','ЧівҖ”ЧіВһЧів„ўЧіВ©Чів„ў','ЧіВ©Чів„ўЧіВ©Чів„ў','ЧіВ©ЧівҖҳЧіГ—'];
  const MONTH_NAMES = ['Чів„ўЧіВ ЧівҖўЧіВҗЧіВЁ','ЧівӮӘЧівҖҳЧіВЁЧівҖўЧіВҗЧіВЁ','ЧіВһЧіВЁЧіВҘ','ЧіВҗЧівӮӘЧіВЁЧів„ўЧіВң','ЧіВһЧіВҗЧів„ў','Чів„ўЧівҖўЧіВ Чів„ў','Чів„ўЧівҖўЧіВңЧів„ў','ЧіВҗЧівҖўЧівҖҷЧівҖўЧіВЎЧіЛң','ЧіВЎЧівӮӘЧіЛңЧіВһЧівҖҳЧіВЁ','ЧіВҗЧівҖўЧіВ§ЧіЛңЧівҖўЧівҖҳЧіВЁ','ЧіВ ЧівҖўЧівҖҳЧіВһЧівҖҳЧіВЁ','ЧівҖңЧіВҰЧіВһЧівҖҳЧіВЁ'];
  const dateLabel = `Чів„ўЧівҖўЧіВқ ${DAY_NAMES[today.getDay()]}, ${today.getDate()} ${MONTH_NAMES[today.getMonth()]} ${today.getFullYear()}`;

  const [showAll, setShowAll] = useState(false);

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Data helpers Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const myProjects = PORTFOLIO_DATA.filter(p => p.team?.includes(fullName) || p.pm === fullName);
  const displayProjects = showAll ? PORTFOLIO_DATA : (myProjects.length ? myProjects : PORTFOLIO_DATA.slice(0,6));
  const activePhase = p => p.phases.find(ph => ph.status === 'active');
  const phaseProgress = p => {
    const done = p.phases.filter(ph => ph.status === 'done').length;
    const hasActive = p.phases.some(ph => ph.status === 'active') ? 0.5 : 0;
    return Math.round(((done + hasActive) / p.phases.length) * 100);
  };
  const daysUntil = d => { if(!d) return null; return Math.round((new Date(d) - today) / 86400000); };
  const fmtDate   = d => d ? d.split('-').reverse().join('.') : '';
  const addDaysStr = n => { const x = new Date(today); x.setDate(x.getDate()+n); return x.toISOString().split('T')[0]; };

  const allBlockers = PORTFOLIO_DATA.flatMap(p =>
    (p.blockers||[]).filter(Boolean).map(b => ({text:b, project:p}))
  );

  const future60 = addDaysStr(60);
  const upcomingMs = [];
  PORTFOLIO_DATA.forEach(p => {
    (MILESTONES_BY_PROJECT[p.id]||[]).forEach(m => {
      if(m.date >= todayStr && m.date <= future60) upcomingMs.push({...m, project:p});
    });
  });
  upcomingMs.sort((a,b) => a.date.localeCompare(b.date));

  /* tasks from current project */
  const tasks = data.tasks || [];
  const urgentTasks = tasks.filter(t => t.priority==='high' && t.statusId!=='C').slice(0,6);

  /* KPIs */
  const activeCount = PORTFOLIO_DATA.filter(p => p.phases.some(ph=>ph.status==='active')).length;

  /* Phase bar colors */
  const phaseColor = (phId, status) => {
    const map = {'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВ Чів„ў':'#6366F1','ЧівҖқЧів„ўЧіГ—ЧіВЁ':'#F59E0B','ЧіВһЧівҖәЧіВЁЧівҖ“':'#8B5CF6','ЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў':'#EF4444'};
    if(status==='done') return '#10B981';
    if(status==='active') return map[phId]||'#3B82F6';
    return '#E5E7EB';
  };
  const priColor = p => p==='high'?'#EF4444':p==='medium'?'#F59E0B':'#9CA3AF';

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Styles Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const card = {background:'var(--surface)',border:'1px solid var(--border)',borderRadius:12};
  const cardHdr = {padding:'13px 18px',borderBottom:'1px solid var(--border)',display:'flex',alignItems:'center',gap:8};
  const cardHdrTitle = {fontSize:14,fontWeight:700,color:'var(--text)'};
  const pill = (bg,clr) => ({fontSize:10,fontWeight:700,background:bg,color:clr,borderRadius:20,padding:'2px 8px',flexShrink:0});

  return (
    <div style={{flex:1,overflow:'auto',background:'var(--bg)',padding:'28px 32px 56px',direction:'rtl',fontFamily:'Heebo,system-ui,sans-serif'}}>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Greeting header Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div style={{marginBottom:28,display:'flex',alignItems:'flex-start',justifyContent:'space-between',flexWrap:'wrap',gap:16}}>
        <div>
          <div style={{fontSize:22,fontWeight:700,color:'var(--text)',marginBottom:3}}>{greeting}, {userName} Ч ВҹвҖҳвҖ№</div>
          <div style={{fontSize:13,color:'var(--text-2)'}}>{dateLabel}</div>
        </div>
        <div style={{display:'flex',gap:10}}>
          {[
            {label:'ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ ЧівӮӘЧіВўЧів„ўЧіВңЧів„ўЧіВқ', val:activeCount,   color:'#2563EB', bg:'rgba(37,99,235,.08)'},
            {label:'ЧіГ—ЧіВ§Чів„ўЧіВўЧівҖўЧіГ— ЧівӮӘЧіГ—ЧівҖўЧівҖ”ЧівҖўЧіГ—',  val:allBlockers.length, color:'#EF4444', bg:'rgba(239,68,68,.08)'},
            {label:'ЧіВҗЧівҖҳЧіВ Чів„ў ЧівҖңЧіВЁЧіВҡ ЧіВ§ЧіВЁЧівҖўЧівҖҳЧівҖўЧіГ—',val:upcomingMs.length,  color:'#8B5CF6', bg:'rgba(139,92,246,.08)'},
          ].map(({label,val,color,bg}) => (
            <div key={label} style={{...card,padding:'11px 20px',textAlign:'center',minWidth:96}}>
              <div style={{fontSize:26,fontWeight:800,color,lineHeight:1.1}}>{val}</div>
              <div style={{fontSize:11,color:'var(--text-2)',marginTop:3,whiteSpace:'nowrap'}}>{label}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Two-column layout Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div style={{display:'grid',gridTemplateColumns:'1fr 310px',gap:20,alignItems:'start'}}>

        {/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ LEFT COLUMN Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */}
        <div style={{display:'flex',flexDirection:'column',gap:20}}>

          {/* Projects + Phase Gantt */}
          <div style={card}>
            <div style={{...cardHdr,justifyContent:'space-between'}}>
              <div style={{display:'flex',alignItems:'center',gap:8}}>
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="#6366F1" strokeWidth="1.8" strokeLinecap="round"><rect x="1" y="1" width="6" height="6" rx="1.5"/><rect x="9" y="1" width="6" height="6" rx="1.5"/><rect x="1" y="9" width="6" height="6" rx="1.5"/><rect x="9" y="9" width="6" height="6" rx="1.5"/></svg>
                <span style={cardHdrTitle}>ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ Ч’вӮ¬вҖқ ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ ЧіВ©ЧіВңЧівҖҳЧів„ўЧіВқ</span>
              </div>
              <button onClick={()=>setShowAll(v=>!v)}
                style={{fontSize:12,color:'var(--accent)',background:'none',border:'none',cursor:'pointer',fontFamily:'inherit',fontWeight:600}}>
                {showAll ? 'ЧівҖқЧіВҰЧівҖҷ ЧіВ©ЧіВңЧів„ў ЧівҖҳЧіВңЧівҖҳЧівҖң' : `ЧівҖәЧіВң ЧівҖқЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ (${PORTFOLIO_DATA.length})`}
              </button>
            </div>

            {/* Legend row */}
            <div style={{display:'flex',gap:16,padding:'6px 18px',borderBottom:'1px solid var(--border)',alignItems:'center'}}>
              {[{c:'#10B981',l:'ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ'},{c:'#6366F1',l:'ЧівӮӘЧіВўЧів„ўЧіВң (ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ/ЧівҖқЧів„ўЧіГ—ЧіВЁ)'},{c:'#E5E7EB',l:'ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ'}].map(({c,l})=>(
                <div key={l} style={{display:'flex',alignItems:'center',gap:4,fontSize:10,color:'var(--text-3)'}}>
                  <span style={{width:8,height:8,borderRadius:2,background:c,flexShrink:0}}/>
                  {l}
                </div>
              ))}
            </div>

            {displayProjects.map((p, idx) => {
              const ap = activePhase(p);
              const prog = phaseProgress(p);
              return (
                <div key={p.id}
                  style={{padding:'11px 18px',borderBottom:idx<displayProjects.length-1?'1px solid var(--border)':'none',transition:'background .1s',cursor:'default'}}
                  onMouseEnter={e=>e.currentTarget.style.background='var(--bg)'}
                  onMouseLeave={e=>e.currentTarget.style.background=''}>

                  <div style={{display:'flex',alignItems:'center',gap:8,marginBottom:7}}>
                    <span style={{fontSize:9,fontWeight:800,fontFamily:'monospace',letterSpacing:.5,background:'rgba(99,102,241,.1)',color:'#6366F1',padding:'2px 6px',borderRadius:4,flexShrink:0}}>{p.code}</span>
                    <span style={{fontSize:13,fontWeight:600,color:'var(--text)',flex:1,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{p.name}</span>
                    <span style={{width:7,height:7,borderRadius:'50%',background:priColor(p.priority),flexShrink:0}} title={p.priority}/>
                    {ap && <span style={{fontSize:11,color:'var(--text-2)',flexShrink:0,fontWeight:500}}>{ap.id}</span>}
                    {(p.blockers||[]).length>0 && <span style={pill('rgba(239,68,68,.08)','#EF4444')}>Ч’ВҡВ  ЧіГ—ЧіВ§ЧівҖўЧіВў</span>}
                  </div>

                  {/* 4-phase bar */}
                  <div style={{display:'grid',gridTemplateColumns:'repeat(4,1fr)',gap:3,marginBottom:5}}>
                    {p.phases.map(ph => (
                      <div key={ph.id} title={`${ph.id}: ${ph.status==='done'?'ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ':ph.status==='active'?'ЧівӮӘЧіВўЧів„ўЧіВң':'ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ'}`}
                        style={{height:7,borderRadius:3,background:phaseColor(ph.id,ph.status),opacity:ph.status==='pending'?.22:1,position:'relative'}}>
                        {ph.status==='active' && (
                          <div style={{position:'absolute',right:0,top:0,bottom:0,width:'40%',background:'rgba(255,255,255,.35)',borderRadius:'0 3px 3px 0'}}/>
                        )}
                      </div>
                    ))}
                  </div>

                  <div style={{display:'flex',justifyContent:'space-between',alignItems:'center'}}>
                    <span style={{fontSize:11,color:'var(--text-3)'}}>{p.type} ЦІВ· {p.pm}</span>
                    <span style={{fontSize:11,color:'var(--text-3)'}}>{prog}%</span>
                  </div>

                  {ap?.blocker && (
                    <div style={{marginTop:6,fontSize:11,color:'#92400E',background:'#FFFBEB',border:'1px solid #FDE68A',borderRadius:6,padding:'4px 10px',display:'flex',gap:5,alignItems:'flex-start'}}>
                      <span style={{flexShrink:0}}>Ч’ВҡВ </span>
                      <span>{ap.blocker}</span>
                    </div>
                  )}
                </div>
              );
            })}
          </div>

          {/* Urgent tasks */}
          {urgentTasks.length > 0 && (
            <div style={card}>
              <div style={cardHdr}>
                <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="#EF4444" strokeWidth="1.8" strokeLinecap="round"><circle cx="8" cy="8" r="7"/><path d="M8 5v3.5"/><circle cx="8" cy="12" r=".6" fill="#EF4444"/></svg>
                <span style={cardHdrTitle}>ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ— ЧівҖңЧівҖ”ЧівҖўЧівӮӘЧівҖўЧіГ— Ч’вӮ¬вҖқ ЧіВЎЧівӮӘЧіВЁЧів„ўЧів„ўЧіГ— ЧіВңЧівҖўЧівҖң</span>
                <span style={{...pill('rgba(239,68,68,.08)','#EF4444'),marginRight:'auto'}}>{urgentTasks.length}</span>
              </div>
              {urgentTasks.map((t, idx) => {
                const du = daysUntil(t.dueDate);
                return (
                  <div key={t.id} style={{display:'flex',alignItems:'center',gap:10,padding:'9px 18px',borderBottom:idx<urgentTasks.length-1?'1px solid var(--border)':'none'}}>
                    <div style={{width:6,height:6,borderRadius:'50%',background:'#EF4444',flexShrink:0}}/>
                    <span style={{flex:1,fontSize:13,color:'var(--text)',overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{t.title}</span>
                    {t.responsible && <span style={{fontSize:11,color:'var(--text-3)',flexShrink:0}}>{t.responsible}</span>}
                    {du !== null && (
                      <span style={{fontSize:11,fontWeight:600,flexShrink:0,color:du<0?'#EF4444':du<=7?'#F59E0B':'var(--text-3)'}}>
                        {du<0?`${Math.abs(du)}Чів„ўЧіВі ЧіВҗЧів„ўЧівҖ”ЧівҖўЧіВЁ`:du===0?'ЧівҖқЧів„ўЧівҖўЧіВқ':`${du}Чів„ўЧіВі`}
                      </span>
                    )}
                  </div>
                );
              })}
            </div>
          )}

          {/* Hours utilization */}
          <div style={card}>
            <div style={cardHdr}>
              <svg width="15" height="15" viewBox="0 0 16 16" fill="none" stroke="#059669" strokeWidth="1.8" strokeLinecap="round"><circle cx="8" cy="8" r="6"/><path d="M8 4v4l2.5 2"/></svg>
              <span style={cardHdrTitle}>ЧіВ Чів„ўЧіВҰЧівҖўЧіВң ЧіВ©ЧіВўЧівҖўЧіГ— Ч’вӮ¬вҖқ ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛңЧів„ўЧіВқ ЧівӮӘЧіВўЧів„ўЧіВңЧів„ўЧіВқ</span>
            </div>
            <div style={{padding:'8px 0'}}>
              {PORTFOLIO_DATA.filter(p=>p.phases.some(ph=>ph.status==='active')).slice(0,6).map((p,idx,arr)=>{
                const totalB = Object.values(p.hours).reduce((s,h)=>s+h.budget,0);
                const totalA = Object.values(p.hours).reduce((s,h)=>s+h.actual,0);
                const pct = totalB>0 ? Math.min(120,Math.round(totalA/totalB*100)) : 0;
                const bar = pct>100?'#EF4444':pct>85?'#F59E0B':'#059669';
                return (
                  <div key={p.id} style={{padding:'8px 18px',borderBottom:idx<arr.length-1?'1px solid var(--border)':'none'}}>
                    <div style={{display:'flex',justifyContent:'space-between',marginBottom:5,alignItems:'center'}}>
                      <div style={{display:'flex',gap:6,alignItems:'center'}}>
                        <span style={{fontSize:9,fontWeight:800,fontFamily:'monospace',color:'#6366F1',background:'rgba(99,102,241,.1)',padding:'1px 5px',borderRadius:3}}>{p.code}</span>
                        <span style={{fontSize:12,color:'var(--text)',overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap',maxWidth:160}}>{p.name.split('Ч’вӮ¬вҖқ')[0].trim()}</span>
                      </div>
                      <span style={{fontSize:12,fontWeight:700,color:bar,flexShrink:0}}>{totalA}/{totalB} ЧіВ©ЧіВі ({pct}%)</span>
                    </div>
                    <div style={{height:5,background:'var(--bg)',borderRadius:4,overflow:'hidden'}}>
                      <div style={{height:'100%',width:`${Math.min(100,pct)}%`,background:bar,borderRadius:4,transition:'width .4s ease'}}/>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>
        </div>

        {/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ RIGHT COLUMN Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */}
        <div style={{display:'flex',flexDirection:'column',gap:16}}>

          {/* Blockers */}
          <div style={card}>
            <div style={cardHdr}>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#EF4444" strokeWidth="1.8" strokeLinecap="round"><circle cx="8" cy="8" r="7"/><path d="M5 5l6 6M11 5l-6 6"/></svg>
              <span style={{...cardHdrTitle,fontSize:13}}>ЧіГ—ЧіВ§Чів„ўЧіВўЧівҖўЧіГ— ЧівӮӘЧіГ—ЧівҖўЧівҖ”ЧівҖўЧіГ—</span>
              {allBlockers.length>0 && <span style={{...pill('rgba(239,68,68,.1)','#EF4444'),marginRight:'auto'}}>{allBlockers.length}</span>}
            </div>
            <div style={{maxHeight:260,overflowY:'auto'}}>
              {allBlockers.length===0
                ? <div style={{padding:'20px 16px',textAlign:'center',fontSize:12,color:'var(--text-3)'}}>ЧіВҗЧів„ўЧіВҹ ЧіГ—ЧіВ§Чів„ўЧіВўЧівҖўЧіГ— Ч ВҹВҺвҖ°</div>
                : allBlockers.map((b,idx)=>(
                  <div key={idx} style={{padding:'9px 14px',borderBottom:idx<allBlockers.length-1?'1px solid var(--border)':'none'}}>
                    <div style={{display:'flex',alignItems:'flex-start',gap:6}}>
                      <span style={{fontSize:9,fontWeight:800,fontFamily:'monospace',background:'rgba(239,68,68,.08)',color:'#EF4444',padding:'2px 5px',borderRadius:4,flexShrink:0,marginTop:1}}>{b.project.code}</span>
                      <span style={{fontSize:12,color:'var(--text-2)',lineHeight:1.5}}>{b.text}</span>
                    </div>
                  </div>
                ))
              }
            </div>
          </div>

          {/* Upcoming milestones */}
          <div style={card}>
            <div style={cardHdr}>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#8B5CF6" strokeWidth="1.8" strokeLinecap="round" strokeLinejoin="round"><polygon points="8,2 10,7 15,7 11,10.5 12.5,15.5 8,12.5 3.5,15.5 5,10.5 1,7 6,7"/></svg>
              <span style={{...cardHdrTitle,fontSize:13}}>ЧіВҗЧівҖҳЧіВ Чів„ў ЧівҖңЧіВЁЧіВҡ Ч’вӮ¬вҖқ 60 Чів„ўЧіВһЧів„ўЧіВқ</span>
              {upcomingMs.length>0 && <span style={{...pill('rgba(139,92,246,.1)','#8B5CF6'),marginRight:'auto'}}>{upcomingMs.length}</span>}
            </div>
            <div style={{maxHeight:320,overflowY:'auto'}}>
              {upcomingMs.length===0
                ? <div style={{padding:'20px 16px',textAlign:'center',fontSize:12,color:'var(--text-3)'}}>ЧіВҗЧів„ўЧіВҹ ЧіВҗЧівҖҳЧіВ Чів„ў ЧівҖңЧіВЁЧіВҡ ЧівҖҳЧіЛңЧівҖўЧівҖўЧівҖ” ЧівҖқЧіВ§ЧіВЁЧівҖўЧівҖҳ</div>
                : upcomingMs.slice(0,12).map((m,idx,arr)=>{
                  const du = daysUntil(m.date);
                  const msDate = new Date(m.date);
                  return (
                    <div key={m.id} style={{display:'flex',alignItems:'center',gap:9,padding:'9px 14px',borderBottom:idx<arr.length-1?'1px solid var(--border)':'none'}}>
                      <div style={{flexShrink:0,textAlign:'center',minWidth:38,background:'rgba(139,92,246,.07)',border:'1px solid rgba(139,92,246,.18)',borderRadius:8,padding:'3px 6px'}}>
                        <div style={{fontSize:15,fontWeight:700,color:'#8B5CF6',lineHeight:1.1}}>{msDate.getDate()}</div>
                        <div style={{fontSize:9,color:'#A78BFA'}}>{HE_MONTHS[msDate.getMonth()]}</div>
                      </div>
                      <div style={{flex:1,minWidth:0}}>
                        <div style={{fontSize:12,fontWeight:600,color:'var(--text)',overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{m.title}</div>
                        <div style={{fontSize:10,color:'var(--text-3)',marginTop:1}}>{m.project.code} ЦІВ· {m.project.name.split('Ч’вӮ¬вҖқ')[0].trim()}</div>
                      </div>
                      <span style={{fontSize:10,fontWeight:700,flexShrink:0,color:du<=7?'#EF4444':du<=21?'#F59E0B':'var(--text-3)'}}>
                        {du===0?'ЧівҖқЧів„ўЧівҖўЧіВқ':du===1?'ЧіВһЧівҖ”ЧіВЁ':`${du}Чів„ўЧіВі`}
                      </span>
                    </div>
                  );
                })
              }
            </div>
          </div>

          {/* Quick actions */}
          <div style={card}>
            <div style={cardHdr}>
              <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="#2563EB" strokeWidth="1.8" strokeLinecap="round"><path d="M8 1v14M1 8h14"/></svg>
              <span style={{...cardHdrTitle,fontSize:13}}>ЧівӮӘЧіВўЧівҖўЧіВңЧівҖўЧіГ— ЧіВһЧівҖқЧів„ўЧіВЁЧівҖўЧіГ—</span>
            </div>
            <div style={{padding:'10px 12px',display:'flex',flexDirection:'column',gap:6}}>
              {[
                {icon:'Ч ВҹвҖңвҖ№',label:'ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ ЧівҖ”ЧівҖңЧіВ©ЧівҖқ',    color:'#2563EB'},
                {icon:'Ч ВҹвҖңвҖҰ',label:'ЧіГ—ЧівҖ“ЧіВһЧіВҹ Чів„ўЧіВ©Чів„ўЧівҖҳЧівҖқ',          color:'#8B5CF6'},
                {icon:'Ч ВҹвҖңвӮӘ',label:'ЧіВ©ЧіВңЧівҖ” ЧівҖңЧівҖўЧівҖ” ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ',       color:'#059669'},
                {icon:'Ч ВҹвҖқвҖ”',label:'ЧіВ©ЧіГ—ЧіВЈ ЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң',           color:'#F59E0B'},
              ].map(({icon,label,color})=>(
                <button key={label} style={{display:'flex',alignItems:'center',gap:9,padding:'8px 10px',border:'1px solid var(--border)',borderRadius:8,background:'var(--surface)',cursor:'pointer',fontFamily:'inherit',fontSize:12,color:'var(--text)',textAlign:'right',transition:'all .12s',fontWeight:500}}
                  onMouseEnter={e=>{e.currentTarget.style.background='var(--bg)';e.currentTarget.style.borderColor='var(--border-strong)';}}
                  onMouseLeave={e=>{e.currentTarget.style.background='var(--surface)';e.currentTarget.style.borderColor='var(--border)';}}>
                  <span style={{fontSize:14}}>{icon}</span>
                  <span style={{flex:1}}>{label}</span>
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round"><path d="M8 2L4 6l4 4"/></svg>
                </button>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Overview Page
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function OverviewPage({data, save}) {
  const tasks        = data.tasks           || [];
  const pi           = data.projectInfo     || {};
  const team         = data.team            || [];
  const consultants  = data.consultants     || [];
  const extContacts  = data.externalContacts|| [];
  const goals        = data.goals           || [];
  const milestones   = data.milestones      || [];

  const [editDesc,  setEditDesc]  = useState(false);
  const [descVal,   setDescVal]   = useState('');
  const [conTableH, setConTableH] = useState(null);
  const conTableRef = useRef(null);

  const startConResize = e => {
    e.preventDefault();
    const startY = e.clientY;
    const startH = conTableRef.current?.getBoundingClientRect().height || 400;
    const onMove = ev => {
      const newH = Math.max(120, startH + (ev.clientY - startY));
      setConTableH(newH);
    };
    const onUp = () => {
      document.removeEventListener('mousemove', onMove);
      document.removeEventListener('mouseup', onUp);
    };
    document.addEventListener('mousemove', onMove);
    document.addEventListener('mouseup', onUp);
  };

  const sp = patch => save({...data,...patch});

  /* Stats */
  const total   = tasks.length;
  const done    = tasks.filter(t=>t.statusId==='C').length;
  const inProg  = tasks.filter(t=>t.statusId==='I').length;
  const waiting = tasks.filter(t=>t.statusId==='R'||t.statusId==='S').length;

  /* Goals */
  const toggleGoal    = id   => sp({goals: goals.map(g=>g.id===id?{...g,done:!g.done}:g)});
  const deleteGoal    = id   => sp({goals: goals.filter(g=>g.id!==id)});
  const addGoal       = ()   => sp({goals: [...goals,{id:uid(),text:'',done:false}]});
  const updateGoalTxt = (id,t)=>sp({goals: goals.map(g=>g.id===id?{...g,text:t}:g)});

  /* Milestones */
  const toggleMs    = id   => sp({milestones: milestones.map(m=>m.id===id?{...m,done:!m.done}:m)});
  const deleteMs    = id   => sp({milestones: milestones.filter(m=>m.id!==id)});
  const addMs       = ()   => sp({milestones: [...milestones,{id:uid(),text:'',date:'',done:false}]});
  const updateMsTxt = (id,t)=>sp({milestones: milestones.map(m=>m.id===id?{...m,text:t}:m)});
  const updateMsDt  = (id,d)=>sp({milestones: milestones.map(m=>m.id===id?{...m,date:d}:m)});

  /* Team editing */
  const [showStaffPicker, setShowStaffPicker] = useState(false);
  const [staffSearch, setStaffSearch] = useState('');
  const staffPickerRef = useRef(null);
  useEffect(()=>{
    if(!showStaffPicker) return;
    const h=e=>{if(staffPickerRef.current&&!staffPickerRef.current.contains(e.target))setShowStaffPicker(false);};
    document.addEventListener('mousedown',h);
    return()=>document.removeEventListener('mousedown',h);
  },[showStaffPicker]);

  const staff = data.staff || OFFICE_STAFF;
  const teamStaffIds = new Set(team.map(m=>m.staffId));
  const availableStaff = staff.filter(s=>!teamStaffIds.has(s.id)&&
    (s.name.includes(staffSearch)||s.role.includes(staffSearch)||staffSearch===''));

  const addToTeam = s => {
    const member = {id:uid(), staffId:s.id, name:s.name, role:s.role, email:s.email, phone:s.phone, projectRole:''};
    sp({team:[...team, member]});
    setStaffSearch('');
  };
  const removeFromTeam = memberId => sp({team: team.filter(m=>m.id!==memberId)});
  const updateProjectRole = (memberId, role) => sp({team: team.map(m=>m.id===memberId?{...m,projectRole:role}:m)});

  /* Helpers */
  const TCOLORS=['#2563EB','#EF4444','#059669','#D97706','#7C3AED','#14B8A6','#F97316'];
  const tColor  = name => TCOLORS[name.charCodeAt(0)%TCOLORS.length];
  const initials= name => name.split(' ').map(w=>w[0]).join('').slice(0,2);
  const effDiscs = data.disciplines || DISCIPLINES;
  const discObj  = code => effDiscs.find(d=>d.id===code);

  return (
    <div className="ov-page">

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ 1. Project card Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div className="ov-proj-card">
        <div className="ov-proj-desc-wrap">
          <div className="ov-proj-label">ЧіГ—Чів„ўЧіВҗЧівҖўЧіВЁ ЧівҖқЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң</div>
          {editDesc
            ? <textarea className="ov-proj-desc-input" rows={4} value={descVal}
                onChange={e=>setDescVal(e.target.value)}
                onBlur={()=>{sp({projectInfo:{...pi,description:descVal}});setEditDesc(false);}}
                autoFocus/>
            : <div className="ov-proj-desc-text"
                onClick={()=>{setDescVal(pi.description||'');setEditDesc(true);}}>
                {pi.description||<span style={{color:'var(--text-3)'}}>ЧіВңЧівҖ”ЧіВҘ ЧіВңЧівҖқЧівҖўЧіВЎЧівӮӘЧіГ— ЧіГ—Чів„ўЧіВҗЧівҖўЧіВЁ...</span>}
              </div>
          }
        </div>
        <div className="ov-proj-meta-wrap">
          {[
            {label:'ЧіВңЧіВ§ЧівҖўЧівҖ”',  val:pi.client||'Ч’вӮ¬вҖқ'},
            {label:'ЧіВһЧів„ўЧіВ§ЧівҖўЧіВқ', val:pi.location||'Ч’вӮ¬вҖқ'},
            {label:'ЧіВ©ЧіВңЧівҖҳ',   val:pi.phase||'Ч’вӮ¬вҖқ'},
            {label:'ЧіВ©ЧіЛңЧівҖ”',   val:pi.area||'Ч’вӮ¬вҖқ'},
          ].map(({label,val})=>(
            <div key={label} className="ov-meta-item">
              <div className="ov-meta-label">{label}</div>
              <div className="ov-meta-val">{val}</div>
            </div>
          ))}
        </div>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ 2. Stats row Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div className="ov-stats-row">
        {[
          {num:total,      label:'ЧіВЎЧівҖқ"ЧівҖә ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—',    color:'var(--text)'},
          {num:inProg,     label:'ЧівҖҳЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ',          color:'#2563EB'},
          {num:waiting,    label:'ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ / ЧівҖҳЧіВЎЧіВ§Чів„ўЧіВЁЧівҖқ',  color:'#D97706'},
          {num:done,       label:'ЧівҖқЧівҖўЧіВ©ЧіВңЧіВһЧівҖў',          color:'#059669'},
          {num:total-done, label:'ЧівӮӘЧіГ—ЧівҖўЧівҖ”ЧівҖўЧіГ—',          color:'#6B7280'},
        ].map((c,i)=>(
          <div key={i} className="ov-stat-card">
            <div className="ov-stat-num" style={{color:c.color}}>{c.num}</div>
            <div className="ov-stat-label">{c.label}</div>
          </div>
        ))}
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ 3. Three-column: Team | Goals | Milestones Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div className="ov-3grid">

        {/* Team */}
        <div className="ov-section" style={{position:'relative'}}>
          <div className="ov-sec-hdr"><span className="ov-sec-icon"><Ic n="consultants"/></span>ЧіВҰЧівҖўЧівҖўЧіГ— ЧівҖқЧіВһЧіВ©ЧіВЁЧівҖң</div>
          <div className="ov-sec-body">
            {team.map(m=>(
              <div key={m.id} className="ov-team-row">
                <div className="ov-team-av" style={{background:staffColor(m.staffId||m.id)}}>{staffInitials(m.name)}</div>
                <div className="ov-team-info">
                  <div className="ov-team-name">{m.name}</div>
                  <input className="ov-team-role" value={m.projectRole||''} placeholder={m.role||'ЧіГ—ЧівӮӘЧіВ§Чів„ўЧівҖң ЧівҖҳЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң...'}
                    style={{border:'none',outline:'none',background:'transparent',font:'inherit',fontSize:10,color:'var(--text-3)',width:'100%',cursor:'text'}}
                    onChange={e=>updateProjectRole(m.id,e.target.value)}/>
                </div>
                <div className="ov-team-links">
                  {m.email&&<a href={`mailto:${m.email}`}>{m.email}</a>}
                  {m.phone&&<a href={`tel:${m.phone}`}>{m.phone}</a>}
                </div>
                <button className="ov-team-remove" title="ЧівҖқЧіВЎЧіВЁ ЧіВһЧівҖқЧіВҰЧівҖўЧівҖўЧіГ—" onClick={()=>removeFromTeam(m.id)}>Ч’ВңвҖў</button>
              </div>
            ))}
            {/* Add staff button */}
            <div ref={staffPickerRef} style={{position:'relative'}}>
              <button className="ov-team-add-btn" onClick={()=>setShowStaffPicker(o=>!o)}>
                <span style={{fontSize:14,lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВўЧівҖўЧівҖҳЧівҖң
              </button>
              {showStaffPicker&&(
                <div className="ov-staff-picker">
                  <input className="ov-staff-search" autoFocus placeholder="ЧівҖ”Чів„ўЧівӮӘЧівҖўЧіВ© ЧіВўЧівҖўЧівҖҳЧівҖң..."
                    value={staffSearch} onChange={e=>setStaffSearch(e.target.value)}/>
                  <div className="ov-staff-list">
                    {availableStaff.length===0
                      ? <div style={{padding:'10px 12px',fontSize:12,color:'var(--text-3)'}}>ЧівҖәЧіВң ЧівҖқЧіВўЧівҖўЧівҖҳЧівҖңЧів„ўЧіВқ ЧівҖәЧівҖҳЧіВЁ ЧівҖҳЧіВҰЧівҖўЧівҖўЧіГ—</div>
                      : availableStaff.map(s=>(
                        <div key={s.id} className="ov-staff-item" onClick={()=>{addToTeam(s);setShowStaffPicker(false);}}>
                          <div className="ov-staff-av" style={{background:staffColor(s.id)}}>{staffInitials(s.name)}</div>
                          <div>
                            <div className="ov-staff-name">{s.name}</div>
                            {s.role&&<div className="ov-staff-role">{s.role}</div>}
                          </div>
                        </div>
                      ))
                    }
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>

        {/* Goals */}
        <div className="ov-section">
          <div className="ov-sec-hdr"><span className="ov-sec-icon"><Ic n="goals"/></span>Чів„ўЧіВўЧівҖңЧів„ўЧіВқ</div>
          <div className="ov-sec-body">
            {goals.map(g=>(
              <div key={g.id} className="ov-checklist-item">
                <button className={`ov-check-cb${g.done?' done':''}`}
                  onClick={()=>toggleGoal(g.id)}>{g.done?'Ч’ВңвҖң':''}</button>
                <input className={`ov-check-text${g.done?' done-text':''}`}
                  style={{border:'none',outline:'none',background:'transparent',
                          font:'inherit',fontSize:12,width:'100%',cursor:'text',color:'inherit'}}
                  value={g.text}
                  onChange={e=>updateGoalTxt(g.id,e.target.value)}
                  placeholder="Чів„ўЧіВўЧівҖң ЧівҖ”ЧівҖңЧіВ©..."/>
                <button className="ov-del-item" onClick={()=>deleteGoal(g.id)}>Ч’ВңвҖў</button>
              </div>
            ))}
          </div>
          <button className="ov-add-item-btn" onClick={addGoal}>ЧҹВјвҖ№ ЧівҖқЧівҖўЧіВЎЧіВЈ Чів„ўЧіВўЧівҖң</button>
        </div>

        {/* Milestones */}
        <div className="ov-section">
          <div className="ov-sec-hdr"><span className="ov-sec-icon"><Ic n="milestones"/></span>ЧіВҗЧівҖҳЧіВ Чів„ў ЧівҖңЧіВЁЧіВҡ</div>
          <div className="ov-sec-body">
            {milestones.map(m=>(
              <div key={m.id} className="ov-checklist-item" style={{flexDirection:'column',gap:3,cursor:'default'}}>
                <div style={{display:'flex',alignItems:'center',gap:8,width:'100%'}}>
                  <button className={`ov-check-cb${m.done?' done':''}`}
                    onClick={()=>toggleMs(m.id)}>{m.done?'Ч’ВңвҖң':''}</button>
                  <input className={`ov-check-text${m.done?' done-text':''}`}
                    style={{border:'none',outline:'none',background:'transparent',
                            font:'inherit',fontSize:12,flex:1,cursor:'text',color:'inherit'}}
                    value={m.text}
                    onChange={e=>updateMsTxt(m.id,e.target.value)}
                    placeholder="ЧіВҗЧівҖҳЧіВҹ ЧівҖңЧіВЁЧіВҡ..."/>
                  <button className="ov-del-item" onClick={()=>deleteMs(m.id)}>Ч’ВңвҖў</button>
                </div>
                {m.date&&<div style={{fontSize:10,color:'var(--text-3)',paddingRight:22}}>
                  {fmtDate(m.date)}
                  {m.done&&<span style={{color:'#059669',marginRight:6}}>Ч’ВңвҖң ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ</span>}
                  {!m.done&&daysBetween(todayISO(),m.date)>=0&&
                    <span style={{color:daysBetween(todayISO(),m.date)<14?'#EF4444':'var(--text-3)',marginRight:6}}>
                      {daysBetween(todayISO(),m.date)} Чів„ўЧіВһЧів„ўЧіВқ
                    </span>}
                </div>}
              </div>
            ))}
          </div>
          <button className="ov-add-item-btn" onClick={addMs}>ЧҹВјвҖ№ ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВҗЧівҖҳЧіВҹ ЧівҖңЧіВЁЧіВҡ</button>
        </div>

      </div>{/* /ov-3grid */}

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ 4. Consultants table Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      <div className="ov-consultants" style={{position:'relative'}}>
        <div className="ov-sec-hdr" style={{padding:'11px 16px'}}>
          <span className="ov-sec-icon"><Ic n="consultants"/></span>Чів„ўЧівҖўЧіВўЧіВҰЧів„ўЧіВқ ЧівҖўЧіВһЧіГ—ЧівҖәЧіВ ЧіВ Чів„ўЧіВқ
          <span style={{marginRight:'auto',fontSize:11,fontWeight:400,color:'var(--text-3)'}}>
            {consultants.length} ЧіВһЧіВ©ЧіВЁЧівҖңЧів„ўЧіВқ
          </span>
        </div>
        <div ref={conTableRef} style={{overflowY:'auto', height: conTableH ? conTableH+'px' : 'auto'}}>
          <table className="ov-con-table">
            <thead>
              <tr>
                <th style={{width:170}}>ЧіГ—ЧівҖ”ЧівҖўЧіВқ</th>
                <th style={{width:190}}>ЧіВһЧіВ©ЧіВЁЧівҖң</th>
                <th>ЧіВҗЧіВ ЧіВ©Чів„ў ЧіВ§ЧіВ©ЧіВЁ</th>
                <th style={{width:130}}>ЧіЛңЧіВңЧівӮӘЧівҖўЧіВҹ / ЧіВ Чів„ўЧів„ўЧівҖң</th>
                <th style={{width:200}}>ЧіВһЧів„ўЧів„ўЧіВң</th>
              </tr>
            </thead>
            <tbody>
              {consultants.map(c=>{
                const d=discObj(c.discCode);
                return (
                  <tr key={c.id}>
                    <td>
                      {d&&<span className="ov-con-disc-chip" style={{background:d.bg,color:d.color}}>{d.id}</span>}
                      {c.discipline}
                    </td>
                    <td style={{fontWeight:600}}>{c.firm}</td>
                    <td>
                      {c.contacts.map((ct,i)=>(
                        <div key={i} className="ov-con-contact-line"
                          style={i>0?{fontSize:11,color:'var(--text-2)',marginTop:4}:{}}>
                          {ct.name||'Ч’вӮ¬вҖқ'}
                        </div>
                      ))}
                    </td>
                    <td>
                      {c.contacts.map((ct,i)=>(
                        <div key={i} className="ov-con-sub" style={i>0?{marginTop:4}:{}}>
                          <a href={`tel:${ct.mobile||ct.phone}`}>{ct.mobile||ct.phone||'Ч’вӮ¬вҖқ'}</a>
                        </div>
                      ))}
                    </td>
                    <td>
                      {c.contacts.map((ct,i)=>(
                        <div key={i} className="ov-con-sub" style={i>0?{marginTop:4}:{}}>
                          {ct.email?<a href={`mailto:${ct.email}`}>{ct.email}</a>:'Ч’вӮ¬вҖқ'}
                        </div>
                      ))}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        {/* Resize handle */}
        <div
          onMouseDown={startConResize}
          style={{
            position:'absolute',bottom:0,left:0,right:0,height:8,
            cursor:'ns-resize',display:'flex',alignItems:'center',justifyContent:'center',
            borderTop:'1px solid var(--border)',background:'var(--bg)',userSelect:'none',
          }}
          title="ЧівҖҷЧіВЁЧівҖўЧіВЁ ЧіВңЧівҖқЧіГ—ЧіВҗЧіВһЧіГ— ЧівҖҷЧівҖўЧівҖҳЧівҖқ">
          <div style={{width:32,height:3,borderRadius:2,background:'var(--border-strong)'}}/>
        </div>
      </div>

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ 5. External contacts Ч’вӮ¬вҖқ table format per category Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      {(()=>{
        const EXT_CATS=[
          {id:'muni',       label:'ЧіВўЧів„ўЧіВЁЧів„ўЧів„ўЧівҖқ',              icon:<Ic n="building"/>},
          {id:'ref',        label:'ЧіВЁЧівӮӘЧіВЁЧіВ ЧіЛңЧів„ўЧіВқ ЧівҖ”Чів„ўЧіВҰЧівҖўЧіВ Чів„ўЧів„ўЧіВқ',    icon:<Ic n="consultants"/>},
          {id:'contractor', label:'ЧіВ§ЧівҖҳЧіВңЧіВҹ',                icon:<Ic n="execution"/>},
          {id:'supplier',   label:'ЧіВЎЧівӮӘЧіВ§Чів„ўЧіВқ',               icon:<Ic n="licensing"/>},
        ];
        return EXT_CATS.map(cat=>{
          const items=extContacts.filter(c=>(c.category||'muni')===cat.id);
          if(!items.length) return null;
          return (
            <div key={cat.id} className="ov-consultants" style={{marginTop:16}}>
              <div className="ov-sec-hdr" style={{padding:'11px 16px'}}>
                <span className="ov-sec-icon">{cat.icon}</span>{cat.label}
                <span style={{marginRight:'auto',fontSize:11,fontWeight:400,color:'var(--text-3)'}}>
                  {items.length} ЧіВҗЧіВ ЧіВ©Чів„ў ЧіВ§ЧіВ©ЧіВЁ
                </span>
              </div>
              <table className="ov-con-table">
                <thead>
                  <tr>
                    <th style={{width:190}}>ЧіВ©ЧіВқ</th>
                    <th style={{width:220}}>ЧіВҗЧіВЁЧівҖҷЧівҖўЧіВҹ</th>
                    <th style={{width:180}}>ЧіГ—ЧівӮӘЧіВ§Чів„ўЧівҖң</th>
                    <th style={{width:130}}>ЧіЛңЧіВңЧівӮӘЧівҖўЧіВҹ / ЧіВ Чів„ўЧів„ўЧівҖң</th>
                    <th>ЧіВһЧів„ўЧів„ўЧіВң</th>
                  </tr>
                </thead>
                <tbody>
                  {items.map(c=>(
                    <tr key={c.id}>
                      <td style={{fontWeight:600}}>{c.name}</td>
                      <td>{c.org}</td>
                      <td style={{color:'var(--text-2)'}}>{c.role||'Ч’вӮ¬вҖқ'}</td>
                      <td>
                        {(c.mobile||c.phone)
                          ? <div className="ov-con-sub">
                              <a href={`tel:${c.mobile||c.phone}`}>{c.mobile||c.phone}</a>
                              {c.mobile&&c.phone&&<div style={{marginTop:3}}><a href={`tel:${c.phone}`} style={{fontSize:11}}>{c.phone}</a></div>}
                            </div>
                          : 'Ч’вӮ¬вҖқ'}
                      </td>
                      <td>
                        {c.email
                          ? <div className="ov-con-sub"><a href={`mailto:${c.email}`}>{c.email}</a></div>
                          : 'Ч’вӮ¬вҖқ'}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          );
        });
      })()}

    </div>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   List View
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function ListView({data, save}) {
  const {groups,tasks}=data;
  const [filterState,setFilterState]=useState(null);
  const [sortState,setSortState]=useState(null);
  const [groupByState,setGroupByState]=useState([{field:'section'}]);
  const [newTaskId,setNewTaskId]=useState(null);
  const [showSettings,setShowSettings]=useState(false);
  const [dragOver,setDragOver]=useState(null);
  const [openDone,setOpenDone]=useState(()=>new Set());   /* empty = all collapsed by default */
  const [editingGroupId,setEditingGroupId]=useState(null);
  const [groupNameDraft,setGroupNameDraft]=useState('');
  const [selectedGroup,setSelectedGroup]=useState(null);  /* selected section id */
  const [dragSrc,setDragSrc]=useState(null);              /* dragging group id */
  const [dragTarget,setDragTarget]=useState(null);        /* drag-over group id */
  const [secMenu,setSecMenu]=useState(null);  /* {id, x, y} Ч’вӮ¬вҖқ floating section menu */
  const [taskDragSrc,setTaskDragSrc]=useState(null);
  const [taskDragTarget,setTaskDragTarget]=useState(null);
  const colGroupRef=useRef({});

  /* Effective lists Ч’вӮ¬вҖқ provided by ListViewWithCtx context wrapper */
  const {priorities, disciplines} = useContext(ListsCtx);

  const fields     = data.fields     || [];
  const hiddenCols = data.hiddenCols || {};

  /* Merge stored col order with defaults so new built-in cols always appear */
  const storedOrder = data.colOrder || [];
  const colOrder = [
    ...storedOrder.filter(id=>COL_ORDER_DEFAULT.includes(id)),
    ...COL_ORDER_DEFAULT.filter(id=>!storedOrder.includes(id)),
  ];
  const colWidths = data.colWidths || {};

  const savePartial=patch=>save({...data,...patch});
  const updateTask=t=>savePartial({tasks:tasks.map(x=>x.id===t.id?t:x)});
  const deleteTask=id=>savePartial({tasks:tasks.filter(t=>t.id!==id)});

  const handleTaskDragStart=id=>{setTaskDragSrc(id);setTaskDragTarget(null);};
  const handleTaskDragEnd=()=>{setTaskDragSrc(null);setTaskDragTarget(null);};
  const handleTaskDragOver=id=>{if(id!==taskDragSrc)setTaskDragTarget(id);};
  const handleTaskDropOnTask=targetId=>{
    if(!taskDragSrc||taskDragSrc===targetId){setTaskDragSrc(null);setTaskDragTarget(null);return;}
    const src=tasks.find(t=>t.id===taskDragSrc);
    const tgt=tasks.find(t=>t.id===targetId);
    if(!src||!tgt){setTaskDragSrc(null);setTaskDragTarget(null);return;}
    const without=tasks.filter(t=>t.id!==taskDragSrc);
    const tgtIdx=without.findIndex(t=>t.id===targetId);
    const moved={...src,groupId:tgt.groupId};
    without.splice(tgtIdx,0,moved);
    savePartial({tasks:without});
    setTaskDragSrc(null);setTaskDragTarget(null);
  };
  const handleTaskDropOnGroup=groupId=>{
    if(!taskDragSrc){return;}
    savePartial({tasks:tasks.map(t=>t.id===taskDragSrc?{...t,groupId}:t)});
    setTaskDragSrc(null);setTaskDragTarget(null);
  };

  /* Column width helper */
  const getColW=id=>colWidths[id]??COL_DEFS[id]?.defaultW??120;

  /* Drag-reorder */
  const handleColReorder=(fromId,toId)=>{
    if(!fromId||fromId===toId||COL_DEFS[fromId]?.locked||toId==='__name') return;
    const arr=[...colOrder];
    const fi=arr.indexOf(fromId),ti=arr.indexOf(toId);
    if(fi<0||ti<0) return;
    arr.splice(fi,1); arr.splice(ti,0,fromId);
    savePartial({colOrder:arr});
  };

  /* Resize Ч’вӮ¬вҖқ direct DOM update during drag, persist on mouseup */
  const startResize=(e,colId)=>{
    e.preventDefault(); e.stopPropagation();
    const startX=e.clientX, startW=getColW(colId), minW=COL_DEFS[colId]?.minW??40;
    const onMove=ev=>{
      const newW=Math.max(minW, startW+(startX-ev.clientX));
      if(colGroupRef.current[colId]) colGroupRef.current[colId].style.width=newW+'px';
    };
    const onUp=ev=>{
      const newW=Math.max(minW, startW+(startX-ev.clientX));
      savePartial({colWidths:{...colWidths,[colId]:newW}});
      document.removeEventListener('mousemove',onMove);
      document.removeEventListener('mouseup',onUp);
    };
    document.addEventListener('mousemove',onMove);
    document.addEventListener('mouseup',onUp);
  };
  const addTask=(type='simple', targetGroupId=null)=>{
    const gId=targetGroupId||groups[0]?.id;
    if(!gId)return;
    const id=uid();
    const isProcess=type==='process';
    savePartial({tasks:[...tasks,{id,groupId:gId,title:'',statusId:'N',priority:'',discipline:'',startDate:'',dueDate:'',comment:'',done:false,subtasks:[],fieldValues:{},taskType:isProcess?'process':'simple',processEvents:isProcess?[]:undefined}]});
    setNewTaskId(id);
  };
  const addGroup=(afterGroupId=null)=>{
    const ng={id:uid(),name:'ЧіВһЧіВ§ЧіЛңЧіВў ЧівҖ”ЧівҖңЧіВ©'};
    let newGroups;
    if(afterGroupId){
      const idx=groups.findIndex(x=>x.id===afterGroupId);
      newGroups=[...groups.slice(0,idx+1),ng,...groups.slice(idx+1)];
    } else {
      newGroups=[...groups,ng];
    }
    savePartial({groups:newGroups});
    setGroupNameDraft('ЧіВһЧіВ§ЧіЛңЧіВў ЧівҖ”ЧівҖңЧіВ©');
    setEditingGroupId(ng.id);
  };

  /* filter */
  let display=[...tasks];
  if(filterState){
    display=display.filter(t=>{
      if(filterState.column==='priority')  return t.priority===filterState.value;
      if(filterState.column==='discipline')return t.discipline===filterState.value;
      if(filterState.column==='status')    return t.statusId===filterState.value;
      return true;
    });
  }
  /* sort */
  if(sortState?.length){
    const order=Object.fromEntries([...priorities.map((p,i)=>[p.id,i]),['',priorities.length]]);
    display.sort((a,b)=>{
      for(const {column,dir} of sortState){
        const va=column==='priority'?order[a.priority??'']:a[column]??'';
        const vb=column==='priority'?order[b.priority??'']:b[column]??'';
        const cmp=va<vb?-1:va>vb?1:0;
        if(cmp!==0) return dir==='asc'?cmp:-cmp;
      }
      return 0;
    });
  }
  /* completed tasks always sink to the bottom within each group */
  display.sort((a,b)=>(a.statusId==='C'?1:0)-(b.statusId==='C'?1:0));

  const clearAll=()=>{setFilterState(null);setSortState(null);setGroupByState([{field:'section'}]);};

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Views Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const views = data.views || [];
  const viewStorageKey = `pm_activeView_${data.id}`;
  const [activeViewId, setActiveViewId] = useState(() => localStorage.getItem(viewStorageKey) || null);

  /* Restore view state on mount when activeViewId was persisted */
  const didRestoreView = useRef(false);
  useEffect(() => {
    if(didRestoreView.current || !activeViewId) return;
    didRestoreView.current = true;
    const v = (data.views||[]).find(x => x.id === activeViewId);
    if(v) {
      setFilterState(v.filterState || null);
      setSortState(v.sortState || null);
      setGroupByState(v.groupByState || [{field:'section'}]);
      if(v.hiddenCols || v.colOrder) savePartial({hiddenCols:v.hiddenCols||{}, colOrder:v.colOrder||[]});
    } else {
      setActiveViewId(null);
      localStorage.removeItem(viewStorageKey);
    }
  }, []);

  const saveView = name => {
    const nv = {id:uid(), name,
      filterState, sortState,
      groupByState,
      hiddenCols: data.hiddenCols||{},
      colOrder: data.colOrder||[],
    };
    savePartial({views:[...views, nv]});
    setActiveViewId(nv.id);
    localStorage.setItem(viewStorageKey, nv.id);
  };
  const loadView = viewId => {
    setActiveViewId(viewId);
    localStorage.setItem(viewStorageKey, viewId || '');
    if(!viewId) return;
    const v = views.find(x => x.id === viewId);
    if(!v) return;
    setFilterState(v.filterState||null);
    setSortState(v.sortState||null);
    setGroupByState(v.groupByState||[{field:'section'}]);
    savePartial({hiddenCols:v.hiddenCols||{}, colOrder:v.colOrder||[]});
  };
  const deleteView = viewId => {
    savePartial({views:views.filter(v=>v.id!==viewId)});
    if(activeViewId===viewId) {
      setActiveViewId(null);
      localStorage.removeItem(viewStorageKey);
    }
  };
  const renameView = (viewId, newName) => {
    savePartial({views:views.map(v=>v.id===viewId?{...v,name:newName}:v)});
  };
  const updateView = () => {
    if(!activeViewId) return;
    savePartial({views: views.map(v => v.id===activeViewId ? {
      ...v, filterState, sortState, groupByState,
      hiddenCols: data.hiddenCols||{}, colOrder: data.colOrder||[]
    } : v)});
  };

  /* Dirty detection Ч’вӮ¬вҖқ current state vs saved view */
  const activeView = views.find(v => v.id === activeViewId);
  const isViewDirty = !!(activeViewId && activeView && (() => {
    if(JSON.stringify(activeView.filterState||null) !== JSON.stringify(filterState)) return true;
    if(JSON.stringify(activeView.sortState||null)   !== JSON.stringify(sortState))   return true;
    if(JSON.stringify(activeView.groupByState||[])  !== JSON.stringify(groupByState))return true;
    if(JSON.stringify(activeView.hiddenCols||{})    !== JSON.stringify(data.hiddenCols||{})) return true;
    if(JSON.stringify(activeView.colOrder||[])      !== JSON.stringify(data.colOrder||[]))   return true;
    return false;
  })());

  /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Virtual group computation Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
  const isDefaultGrouping = groupByState.length===1 && groupByState[0].field==='section';
  const buildVirtualGroups=()=>{
    const primaryField=groupByState[0].field;
    const getLabel=(field,value)=>{
      if(!value) return 'ЧіВңЧіВңЧіВҗ '+(GROUP_FIELDS.find(f=>f.field===field)?.label||'');
      if(field==='discipline'){const d=disciplines.find(x=>x.id===value);return d?d.label:value;}
      if(field==='priority')  {const p=priorities.find(x=>x.id===value); return p?p.label:value;}
      if(field==='statusId')  {const s=STATUSES.find(x=>x.id===value);   return s?s.label:value;}
      return value;
    };
    const getPill=(field,value)=>{
      if(!value) return null;
      if(field==='discipline'){const d=disciplines.find(x=>x.id===value);return d?{color:d.color,bg:d.bg}:null;}
      if(field==='priority')  {const p=priorities.find(x=>x.id===value); return p?{color:p.color,bg:p.bg}:null;}
      if(field==='statusId')  {const s=STATUSES.find(x=>x.id===value);   return s?{color:s.color,bg:'rgba(0,0,0,.06)'}:null;}
      return null;
    };
    const priOrder=Object.fromEntries(priorities.map((p,i)=>[p.id,i]));
    const primaryValues=[...new Set(display.map(t=>t[primaryField]??''))];
    if(primaryField==='priority') primaryValues.sort((a,b)=>(priOrder[a]??99)-(priOrder[b]??99));
    return primaryValues.map(val=>{
      const gTasks=display.filter(t=>(t[primaryField]??'')===val);
      let subGroups=null;
      if(groupByState.length>=2){
        const secField=groupByState[1].field;
        const secVals=[...new Set(gTasks.map(t=>t[secField]??''))];
        if(secField==='priority') secVals.sort((a,b)=>(priOrder[a]??99)-(priOrder[b]??99));
        subGroups=secVals.map(sval=>({
          id:`vg_${val}_${sval}`,
          label:getLabel(secField,sval),
          pill:getPill(secField,sval),
          field:secField,value:sval,
          tasks:gTasks.filter(t=>(t[secField]??'')===sval),
        }));
      }
      return{id:`vg_${primaryField}_${val}`,label:getLabel(primaryField,val),pill:getPill(primaryField,val),
        field:primaryField,value:val,tasks:gTasks,subGroups};
    });
  };
  const virtualGroups=isDefaultGrouping?null:buildVirtualGroups();

  /* Ordered visible columns Ч’вӮ¬вҖқ built-ins first (in colOrder), then custom fields */
  const builtinVis=colOrder.filter(id=>!hiddenCols[id]);
  const customVis=fields.filter(f=>!hiddenCols[f.id]).map(f=>f.id);
  const visibleColIds=[...builtinVis,...customVis];
  const visibleCols=visibleColIds.map(id=>{
    if(COL_DEFS[id]) return {id,...COL_DEFS[id]};
    const f=fields.find(f=>f.id===id);
    return {id, label:f?.title||id, align:'right', defaultW:120, minW:60, locked:false};
  });

  return(
    <>
      <Toolbar onAddTask={addTask} onAddGroup={addGroup} filterState={filterState} setFilterState={setFilterState} sortState={sortState} setSortState={setSortState}
        groupByState={groupByState} setGroupByState={setGroupByState}
        views={views} activeViewId={activeViewId} activeViewName={activeView?.name}
        isViewDirty={isViewDirty} onUpdateView={updateView}
        onSaveView={saveView} onLoadView={loadView} onDeleteView={deleteView} onRenameView={renameView}
        onSettings={()=>setShowSettings(o=>!o)} settingsOpen={showSettings}/>

      {/* Active chips */}
      {(filterState||sortState?.length||!isDefaultGrouping)&&(
        <div className="active-bar">
          {filterState&&(
            <div className="f-chip">
              {filterState.column}: {filterState.value}
              <button onClick={()=>setFilterState(null)}>ЦівҖ”</button>
            </div>
          )}
          {sortState?.length>0&&(
            <div className="s-chip">
              ЧіВһЧів„ўЧівҖўЧіВҹ:&nbsp;
              {sortState.map((s,i)=>{
                const lbl=SORT_FIELDS.find(f=>f.column===s.column)?.label||s.column;
                return <span key={s.column}>{i>0?' Ч’вӮ¬Г· ':''}{lbl} {s.dir==='asc'?'Ч’вҖ вҖҳ':'Ч’вҖ вҖң'}</span>;
              })}
              <button onClick={()=>setSortState(null)}>ЦівҖ”</button>
            </div>
          )}
          {!isDefaultGrouping&&(
            <div className="s-chip">
              ЧіВ§ЧівҖҳЧівҖўЧіВҰЧівҖқ:&nbsp;
              {groupByState.map((g,i)=>{
                const lbl=GROUP_FIELDS.find(f=>f.field===g.field)?.label||g.field;
                return <span key={g.field}>{i>0?' Ч’вӮ¬Г· ':''}{lbl}</span>;
              })}
              <button onClick={()=>setGroupByState([{field:'section'}])}>ЦівҖ”</button>
            </div>
          )}
          <button className="clear-all" onClick={clearAll}>ЧіВ ЧіВ§ЧівҖқ ЧівҖқЧівҖәЧіВң</button>
        </div>
      )}

      {/* Table */}
      <div className="list-wrap" onClick={()=>{setSelectedGroup(null);setSecMenu(null);}}>
        <table className="list-table">
          {/* colgroup drives column widths; updated via ref during resize */}
          <colgroup>
            {visibleCols.map(col=>(
              <col key={col.id}
                ref={el=>{if(el)colGroupRef.current[col.id]=el;}}
                style={{width:getColW(col.id)+'px'}}/>
            ))}
            <col style={{width:'42px'}}/>
          </colgroup>
          <thead>
            <tr>
              {visibleCols.map(col=>{
                const sortField  = SORTABLE_COL_FIELD[col.id] ?? (col.id.startsWith('__')?null:col.id);
                const sortList2  = sortState||[];
                const sortEntry  = sortField ? sortList2.find(s=>s.column===sortField) : null;
                const isSorted   = !!sortEntry;
                const sortDir    = sortEntry?.dir ?? null;
                const sortNum    = isSorted && sortList2.length>1 ? sortList2.indexOf(sortEntry)+1 : null;
                const handleColClick = e => {
                  if(e.target.closest('.col-rh')) return;
                  if(!sortField) return;
                  if(!sortEntry){
                    // add as last criterion, default desc
                    setSortState([...sortList2,{column:sortField,dir:'desc'}]);
                  } else if(sortEntry.dir==='desc'){
                    setSortState(sortList2.map(s=>s.column===sortField?{...s,dir:'asc'}:s));
                  } else {
                    // was asc Ч’вҖ вҖҷ remove
                    const a=sortList2.filter(s=>s.column!==sortField);
                    setSortState(a.length?a:null);
                  }
                };
                return (
                <th key={col.id}
                  className={[col.id==='__name'?'c-name':'', sortField?'sortable':''].join(' ').trim()}
                  style={{
                    textAlign: col.align,
                    position: col.id==='__name' ? 'sticky' : 'relative',
                    right: col.id==='__name' ? 0 : undefined,
                    userSelect: 'none',
                    cursor: col.locked ? 'default' : (sortField ? 'pointer' : 'grab'),
                    background: isSorted ? 'rgba(37,99,235,.06)' : dragOver===col.id ? 'rgba(37,99,235,.07)' : undefined,
                    outline: dragOver===col.id ? '2px solid var(--accent)' : undefined,
                    outlineOffset: '-2px',
                  }}
                  draggable={!col.locked}
                  onClick={handleColClick}
                  onDragStart={e=>{e.dataTransfer.setData('text/plain',col.id); e.dataTransfer.effectAllowed='move';}}
                  onDragOver={e=>{e.preventDefault(); if(!col.locked) setDragOver(col.id);}}
                  onDragLeave={()=>setDragOver(null)}
                  onDrop={e=>{
                    e.preventDefault(); setDragOver(null);
                    handleColReorder(e.dataTransfer.getData('text/plain'),col.id);
                  }}>
                  <span style={{display:'inline-flex',alignItems:'center',gap:4}}>
                    {col.label}
                    {sortField&&(
                      <span className="sort-arrow" style={{
                        display:'inline-flex',alignItems:'center',gap:1,
                        fontSize:8, lineHeight:1, opacity: isSorted?1:0,
                        color:'var(--blue)', transition:'opacity .15s',
                      }}>
                        {sortDir==='asc'?'Ч’вҖ“ВІ':'Ч’вҖ“Вј'}
                        {sortNum&&<span style={{fontSize:7,fontWeight:700}}>{sortNum}</span>}
                      </span>
                    )}
                  </span>
                  {/* Resize handle Ч’вӮ¬вҖқ always visible on hover; col-rh class handles cursor */}
                  <div className="col-rh"
                    onMouseDown={e=>startResize(e,col.id)}
                    draggable={false}
                    onClick={e=>e.stopPropagation()}/>
                </th>
                );
              })}
              <th className="c-addcol">
                <button onClick={()=>{setShowSettings(true);}}
                  style={{width:20,height:20,borderRadius:'50%',border:'1px dashed var(--border-strong)',background:'transparent',cursor:'pointer',fontSize:14,display:'flex',alignItems:'center',justifyContent:'center',margin:'0 auto',color:'var(--text-3)'}}>+</button>
              </th>
            </tr>
          </thead>
          <tbody>
            {virtualGroups&&virtualGroups.map(vg=>{
              const colSpan2=visibleColIds.length+1;
              const taskRowPropsV={fields,visibleColIds,daysThreshold:data.builtinConfig?.__owner_status?.delayThreshold??null,sortState,
                taskDragSrc,taskDragTarget,onTaskDragStart:handleTaskDragStart,onTaskDragEnd:handleTaskDragEnd,onTaskDragOver:handleTaskDragOver,onTaskDrop:handleTaskDropOnTask};
              const addTaskForVg=()=>{
                const gId=groups[0]?.id; if(!gId)return;
                const id=uid(); const fieldPatch={[vg.field]:vg.value};
                savePartial({tasks:[...tasks,{id,groupId:gId,title:'',statusId:'N',priority:'',discipline:'',startDate:'',dueDate:'',comment:'',done:false,subtasks:[],fieldValues:{},taskType:'simple',...fieldPatch}]});
                setNewTaskId(id);
              };
              const renderVgTaskRows=(taskList,doneKey)=>{
                const active=taskList.filter(t=>t.statusId!=='C');
                const done=taskList.filter(t=>t.statusId==='C');
                const doneOpen2=openDone.has(doneKey);
                const toggleDone2=()=>setOpenDone(prev=>{const n=new Set(prev);n.has(doneKey)?n.delete(doneKey):n.add(doneKey);return n;});
                return(<>
                  {active.map(task=>(<TaskRow key={task.id} task={task} {...taskRowPropsV} autoFocus={task.id===newTaskId} onUpdate={t=>{setNewTaskId(null);updateTask(t);}} onDelete={()=>{setNewTaskId(null);deleteTask(task.id);}}/>))}
                  {done.length>0&&(<>
                    <tr className="done-sec-row" onClick={toggleDone2}>
                      <td colSpan={colSpan2}><div style={{display:'flex',alignItems:'center',gap:7}}>
                        <span className={`done-chevron${doneOpen2?' open':''}`}>Ч’вҖ“В¶</span>
                        <span style={{fontSize:12,fontWeight:600,color:'#888'}}>ЧівҖқЧівҖўЧіВ©ЧіВңЧіВһЧівҖў</span>
                        <span style={{fontSize:11,fontWeight:400,color:'#888'}}>{done.length} ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
                      </div></td>
                    </tr>
                    {doneOpen2&&done.map(task=>(<TaskRow key={task.id} task={task} {...taskRowPropsV} autoFocus={task.id===newTaskId} onUpdate={t=>{setNewTaskId(null);updateTask(t);}} onDelete={()=>{setNewTaskId(null);deleteTask(task.id);}}/>))}
                  </>)}
                </>);
              };
              return(<React.Fragment key={vg.id}>
                <tr className="sec-row">
                  <td colSpan={colSpan2}>
                    <div style={{display:'flex',alignItems:'center',gap:8}}>
                      <div style={{width:10,height:10,borderRadius:'50%',background:'var(--blue)',flexShrink:0}}/>
                      <span style={{fontWeight:700,fontSize:13}}>
                        {vg.pill
                          ?<span className="pill" style={{color:vg.pill.color,background:vg.pill.bg}}>{vg.label}</span>
                          :vg.label}
                      </span>
                      <span style={{fontSize:11,color:'var(--text-3)',fontWeight:400}}>{vg.tasks.length} ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
                    </div>
                  </td>
                </tr>
                {vg.subGroups
                  ?vg.subGroups.map(sg=>(<React.Fragment key={sg.id}>
                      <tr className="sub-sec-row">
                        <td colSpan={colSpan2}>
                          <div style={{display:'flex',alignItems:'center',gap:7}}>
                            <div style={{width:7,height:7,borderRadius:'50%',background:'var(--border-strong)',flexShrink:0}}/>
                            <span style={{fontWeight:600,fontSize:12}}>
                              {sg.pill
                                ?<span className="pill" style={{color:sg.pill.color,background:sg.pill.bg}}>{sg.label}</span>
                                :sg.label}
                            </span>
                            <span style={{fontSize:11,color:'var(--text-3)',fontWeight:400}}>{sg.tasks.length} ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
                          </div>
                        </td>
                      </tr>
                      {renderVgTaskRows(sg.tasks,sg.id)}
                    </React.Fragment>))
                  :renderVgTaskRows(vg.tasks,vg.id)}
                <tr className="add-task-row"><td colSpan={colSpan2}>
                  <button className="add-task-btn" onClick={addTaskForVg}>
                    <span style={{fontSize:16,lineHeight:1,color:'var(--accent)'}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ
                  </button>
                </td></tr>
              </React.Fragment>);
            })}
            {!virtualGroups&&groups.map(g=>{
              const gTasks=display.filter(t=>t.groupId===g.id);
              const activeTasks=gTasks.filter(t=>t.statusId!=='C');
              const doneTasks=gTasks.filter(t=>t.statusId==='C');
              const doneOpen=openDone.has(g.id);
              const toggleDone=()=>setOpenDone(prev=>{
                const next=new Set(prev);
                if(next.has(g.id)) next.delete(g.id); else next.add(g.id);
                return next;
              });
              const colSpan=visibleColIds.length+1;
              const taskRowProps={fields,visibleColIds,daysThreshold:data.builtinConfig?.__owner_status?.delayThreshold??null,sortState,
                taskDragSrc,taskDragTarget,onTaskDragStart:handleTaskDragStart,onTaskDragEnd:handleTaskDragEnd,onTaskDragOver:handleTaskDragOver,onTaskDrop:handleTaskDropOnTask};

              const isDragSrc  = dragSrc===g.id;
              const isDragOver = dragTarget===g.id;

              /* reorder helper */
              const reorderGroups = (srcId, tgtId) => {
                if(srcId===tgtId) return;
                const arr=[...groups];
                const si=arr.findIndex(x=>x.id===srcId);
                const ti=arr.findIndex(x=>x.id===tgtId);
                const [item]=arr.splice(si,1);
                arr.splice(ti,0,item);
                save({...data,groups:arr});
              };

              return(
                <React.Fragment key={g.id}>
                  <tr className="sec-row"
                    draggable
                    onDragStart={e=>{e.dataTransfer.effectAllowed='move';setDragSrc(g.id);}}
                    onDragEnd={()=>{setDragSrc(null);setDragTarget(null);}}
                    onDragOver={dragSrc===g.id?undefined:e=>{e.preventDefault();setDragTarget(g.id);}}
                    onDrop={e=>{e.preventDefault();
                      if(taskDragSrc){handleTaskDropOnGroup(g.id);}
                      else if(dragSrc){reorderGroups(dragSrc,g.id);}
                      setDragTarget(null);}}
                    style={{outline:isDragOver?'2px dashed var(--accent)':'none',opacity:isDragSrc?.5:1}}>
                    <td colSpan={colSpan}>
                      <div style={{display:'flex',alignItems:'center',gap:8}}>
                        <span className="sec-drag-handle" title="ЧівҖҷЧіВЁЧівҖўЧіВЁ ЧіВңЧіВ©Чів„ўЧіВ ЧівҖўЧів„ў ЧіВЎЧівҖңЧіВЁ">Ч’В Вҝ</span>
                        <div style={{width:10,height:10,borderRadius:'50%',background:'var(--blue)',flexShrink:0}}/>
                        {editingGroupId===g.id
                          ?<input autoFocus value={groupNameDraft}
                              onChange={e=>setGroupNameDraft(e.target.value)}
                              onBlur={()=>{
                                if(groupNameDraft.trim()) save({...data,groups:groups.map(x=>x.id===g.id?{...x,name:groupNameDraft.trim()}:x)});
                                setEditingGroupId(null);
                              }}
                              onKeyDown={e=>{if(e.key==='Enter'){e.target.blur();}if(e.key==='Escape'){setEditingGroupId(null);}}}
                              onClick={e=>e.stopPropagation()}
                              style={{fontWeight:700,fontSize:13,border:'none',borderBottom:'1.5px solid var(--accent)',
                                outline:'none',background:'transparent',fontFamily:'inherit',padding:'0 2px',minWidth:80}}/>
                          :<span
                              onClick={e=>{e.stopPropagation();setGroupNameDraft(g.name);setEditingGroupId(g.id);}}
                              style={{fontWeight:700,fontSize:13,color:'var(--text)',cursor:'text',padding:'0 2px'}}>
                              {g.name}
                            </span>
                        }
                        <span style={{fontSize:11,color:'var(--text-3)',fontWeight:400}}>{gTasks.length} ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
                        <button className="sec-actions-btn"
                          onClick={e=>{
                            e.stopPropagation();
                            const r=e.currentTarget.getBoundingClientRect();
                            setSecMenu(secMenu?.id===g.id?null:{id:g.id,left:Math.max(4,r.left),y:r.bottom+4,gRef:g});
                          }}
                          style={{marginRight:'auto',background:'none',border:'none',cursor:'pointer',
                            color:'var(--text-3)',padding:'2px 5px',borderRadius:4,display:'flex',
                            alignItems:'center',flexShrink:0,transition:'color .12s'}}
                          onMouseEnter={e=>e.currentTarget.style.color='var(--text)'}
                          onMouseLeave={e=>e.currentTarget.style.color='var(--text-3)'}
                          title="ЧіВҗЧівӮӘЧіВ©ЧіВЁЧівҖўЧів„ўЧівҖўЧіГ—">
                          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.8" strokeLinecap="round"><circle cx="8" cy="3" r="1.2" fill="currentColor" stroke="none"/><circle cx="8" cy="8" r="1.2" fill="currentColor" stroke="none"/><circle cx="8" cy="13" r="1.2" fill="currentColor" stroke="none"/></svg>
                        </button>
                      </div>
                    </td>
                  </tr>
                  {activeTasks.map(task=>(
                    <TaskRow key={task.id} task={task} {...taskRowProps}
                      autoFocus={task.id===newTaskId}
                      onUpdate={t=>{setNewTaskId(null);updateTask(t);}}
                      onDelete={()=>{setNewTaskId(null);deleteTask(task.id);}}/>
                  ))}
                  <tr className="add-task-row">
                    <td colSpan={colSpan}>
                      <button className="add-task-btn" onClick={addTask}>
                        <span style={{fontSize:16,lineHeight:1,color:'var(--accent)'}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВһЧіВ©Чів„ўЧіВһЧівҖқ
                      </button>
                    </td>
                  </tr>
                  {doneTasks.length>0&&(
                    <>
                      <tr className="done-sec-row" onClick={toggleDone}>
                        <td colSpan={colSpan}>
                          <div style={{display:'flex',alignItems:'center',gap:7}}>
                            <span className={`done-chevron${doneOpen?' open':''}`}>Ч’вҖ“В¶</span>
                            <span style={{fontSize:12,fontWeight:600,color:'#888'}}>ЧівҖқЧівҖўЧіВ©ЧіВңЧіВһЧівҖў</span>
                            <span style={{fontSize:11,fontWeight:400,color:'#888'}}>{doneTasks.length} ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
                          </div>
                        </td>
                      </tr>
                      {doneOpen&&doneTasks.map(task=>(
                        <TaskRow key={task.id} task={task} {...taskRowProps}
                          autoFocus={task.id===newTaskId}
                          onUpdate={t=>{setNewTaskId(null);updateTask(t);}}
                          onDelete={()=>{setNewTaskId(null);deleteTask(task.id);}}/>
                      ))}
                    </>
                  )}
                </React.Fragment>
              );
            })}
          </tbody>
        </table>
        {filterState && display.length===0 && (
          <div style={{display:'flex',flexDirection:'column',alignItems:'center',justifyContent:'center',padding:'48px 24px',gap:12,color:'var(--text-3)'}}>
            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.5" strokeLinecap="round" strokeLinejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/><path d="M8 11h6"/></svg>
            <span style={{fontSize:14,fontWeight:600,color:'var(--text-2)'}}>ЧіВңЧіВҗ ЧіВ ЧіВһЧіВҰЧіВҗЧівҖў ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
            <span style={{fontSize:12}}>ЧівҖқЧіВЎЧів„ўЧіВ ЧівҖўЧіВҹ ЧівҖқЧіВ ЧівҖўЧівҖәЧівҖ”Чів„ў ЧіВҗЧів„ўЧіВ ЧівҖў ЧіВһЧівҖ”ЧівҖ“Чів„ўЧіВЁ ЧіГ—ЧівҖўЧіВҰЧіВҗЧівҖўЧіГ—</span>
            <button onClick={()=>setFilterState(null)} style={{marginTop:4,fontSize:12,fontWeight:600,color:'var(--accent)',background:'none',border:'1px solid var(--accent)',borderRadius:6,padding:'5px 16px',cursor:'pointer',fontFamily:'inherit'}}>ЧіВ ЧіВ§ЧівҖқ ЧіВЎЧів„ўЧіВ ЧівҖўЧіВҹ</button>
          </div>
        )}
      </div>

      {/* Settings panel */}
      {showSettings&&(
        <SettingsPanel data={data} save={save} onClose={()=>setShowSettings(false)}/>
      )}

      {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Floating section menu Ч’вӮ¬вҖқ portal to body Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
      {secMenu && ReactDOM.createPortal((()=>{
        const g = secMenu.gRef;
        const ITEMS = [
          {icon:'Ч’ВңВҸ', label:'ЧіВ©ЧіВ ЧівҖқ ЧіВ©ЧіВқ',    action:()=>{setGroupNameDraft(g.name);setEditingGroupId(g.id);setSecMenu(null);}},
          {icon:'+', label:'ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВһЧіВ§ЧіЛңЧіВў', action:()=>{addGroup(g.id);setSecMenu(null);}},
          null,
          {icon:'ЦівҖ”', label:'ЧіВһЧівҖ”ЧіВ§ ЧіВһЧіВ§ЧіЛңЧіВў', danger:true, action:()=>{
            if(!window.confirm(`ЧіВңЧіВһЧівҖ”ЧівҖўЧіВ§ ЧіВҗЧіГ— ЧівҖқЧіВһЧіВ§ЧіЛңЧіВў "${g.name}"?`)) return;
            save({...data,groups:groups.filter(x=>x.id!==g.id),tasks:(data.tasks||[]).filter(t=>t.groupId!==g.id)});
            setSecMenu(null);}},
        ];
        return (
          <>
            {/* backdrop */}
            <div style={{position:'fixed',inset:0,zIndex:9998}} onClick={()=>setSecMenu(null)}/>
            <div dir="rtl" style={{position:'fixed',top:secMenu.y,left:secMenu.left,minWidth:180,
              background:'var(--surface)',border:'1px solid var(--border)',borderRadius:8,
              boxShadow:'0 6px 20px rgba(0,0,0,.14)',zIndex:9999,padding:'4px',
              fontFamily:'Heebo,system-ui,sans-serif'}}>
              {ITEMS.map((item,idx)=>!item
                ? <div key={idx} style={{height:1,background:'var(--border)',margin:'3px 0'}}/>
                : <button key={idx} onClick={item.action}
                    style={{display:'flex',alignItems:'center',gap:9,width:'100%',padding:'8px 12px',
                      border:'none',background:'none',cursor:'pointer',fontSize:13,fontFamily:'inherit',
                      textAlign:'right',borderRadius:5,color:item.danger?'#EF4444':'var(--text)'}}
                    onMouseEnter={e=>e.currentTarget.style.background=item.danger?'rgba(239,68,68,.07)':'var(--bg)'}
                    onMouseLeave={e=>e.currentTarget.style.background='none'}>
                    <span style={{color:item.danger?'#EF4444':'var(--text-3)',fontWeight:700,width:14,textAlign:'center'}}>{item.icon}</span>
                    {item.label}
                  </button>
              )}
            </div>
          </>
        );
      })(), document.body)}

    </>
  );
}
/* ListView wrapper Ч’вӮ¬вҖқ provides lists context */
function ListViewWithCtx({data, save}) {
  const priorities  = data.priorities  || PRIORITIES;
  const disciplines = data.disciplines || DISCIPLINES;
  const statuses    = data.statuses    || STATUSES;
  const [editList, setEditList] = useState(null);
  const savePartial = patch => save({...data,...patch});

  const listTitle = t => t==='priority'?'ЧіВўЧіВЁЧів„ўЧівҖәЧіГ— ЧіВўЧівҖңЧів„ўЧівӮӘЧівҖўЧів„ўЧівҖўЧіГ—':t==='status'?'ЧіВўЧіВЁЧів„ўЧівҖәЧіГ— ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎЧів„ўЧіВқ':'ЧіВўЧіВЁЧів„ўЧівҖәЧіГ— ЧіГ—ЧівҖ”ЧівҖўЧіВһЧів„ўЧіВқ';
  const listItems = t => t==='priority'?priorities:t==='status'?statuses:disciplines;

  return (
    <ListsCtx.Provider value={{
      priorities,
      disciplines,
      statuses,
      team: data.team || [],
      onEditList: type => setEditList(type),
    }}>
      <ListView data={data} save={save}/>
      {editList&&(
        <EditListModal
          title={listTitle(editList)}
          items={listItems(editList)}
          previewType={editList==='status'?'status':'pill'}
          onSave={items=>{
            if(editList==='priority') savePartial({priorities:items});
            else if(editList==='status') savePartial({statuses:items});
            else savePartial({disciplines:items});
            setEditList(null);
          }}
          onClose={()=>setEditList(null)}
        />
      )}
    </ListsCtx.Provider>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Dashboard View
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
function Confetti({onDone}) {
  const canvasRef = useRef(null);
  useEffect(()=>{
    const canvas = canvasRef.current;
    if(!canvas) return;
    const ctx = canvas.getContext('2d');
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const COLORS = ['#FFD700','#059669','#3B82F6','#8B5CF6','#EF4444','#F59E0B','#EC4899','#10B981','#06B6D4'];
    const particles = Array.from({length:180},()=>({
      x: Math.random()*canvas.width,
      y: Math.random()*-canvas.height*0.6 - 10,
      w: Math.random()*10+4,
      h: Math.random()*5+2,
      color: COLORS[Math.floor(Math.random()*COLORS.length)],
      speed: Math.random()*4+2,
      drift: (Math.random()-0.5)*3,
      angle: Math.random()*Math.PI*2,
      spin: (Math.random()-0.5)*.18,
    }));
    const start = Date.now();
    const DURATION = 5000;
    let raf;
    const draw=()=>{
      const elapsed = Date.now()-start;
      if(elapsed>DURATION){ ctx.clearRect(0,0,canvas.width,canvas.height); onDone&&onDone(); return; }
      ctx.clearRect(0,0,canvas.width,canvas.height);
      const opacity = elapsed>3500 ? 1-(elapsed-3500)/1500 : 1;
      particles.forEach(p=>{
        p.y+=p.speed; p.x+=p.drift; p.angle+=p.spin;
        if(p.y>canvas.height+20){ p.y=-20; p.x=Math.random()*canvas.width; }
        ctx.save();
        ctx.globalAlpha=opacity;
        ctx.translate(p.x,p.y);
        ctx.rotate(p.angle);
        ctx.fillStyle=p.color;
        ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
        ctx.restore();
      });
      raf=requestAnimationFrame(draw);
    };
    raf=requestAnimationFrame(draw);
    return()=>cancelAnimationFrame(raf);
  },[]);
  return ReactDOM.createPortal(
    <canvas ref={canvasRef} style={{position:'fixed',top:0,left:0,
      width:'100%',height:'100%',zIndex:9999,pointerEvents:'none'}}/>,
    document.body
  );
}

function DashboardView({data, save, onSwitchSheet}) {
  const [confetti, setConfetti] = useState(false);
  const sheets = (data.sheets||[]).filter(s=>s.type==='list');
  const today = todayISO();

  /* Per-sheet date range from tasks */
  const sheetMeta = sheets.map(sheet=>{
    const tasks = sheet.tasks||[];
    const done  = tasks.filter(t=>t.statusId==='C'||t.done).length;
    const stuck = tasks.filter(t=>t.statusId==='S').length;
    const pct   = tasks.length ? Math.round(done/tasks.length*100) : 0;
    const starts = tasks.map(t=>t.startDate).filter(Boolean).sort();
    const ends   = tasks.map(t=>t.dueDate).filter(Boolean).sort();
    const startD = starts[0]||null;
    const endD   = ends[ends.length-1]||null;
    const days   = startD&&endD ? daysBetween(startD, endD) : null;
    return {sheet, tasks, done, stuck, pct, startD, endD, days};
  });

  /* Gantt: global time range */
  const allStarts = sheetMeta.map(m=>m.startD).filter(Boolean).sort();
  const allEnds   = sheetMeta.map(m=>m.endD).filter(Boolean).sort();
  const ganttMin  = allStarts[0]||today;
  const ganttMax  = [allEnds[allEnds.length-1],today].filter(Boolean).sort().reverse()[0]||today;
  const ganttSpan = Math.max(1, daysBetween(ganttMin, ganttMax));

  const fmtD = iso => iso ? fmtDateFull(iso) : 'Ч’вӮ¬вҖқ';
  const GANTT_COLORS = ['#3B82F6','#8B5CF6','#10B981','#F59E0B','#EF4444','#06B6D4'];

  return (
    <>
    {confetti&&<Confetti onDone={()=>setConfetti(false)}/>}
    <div style={{padding:'28px 24px',overflow:'auto',flex:1,background:'var(--bg)'}}>
      <div style={{maxWidth:960,margin:'0 auto',display:'flex',flexDirection:'column',gap:28}}>

        {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Cards Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
        <div>
          <h2 style={{fontSize:15,fontWeight:700,marginBottom:14,color:'var(--text)'}}>ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ ЧіВ©ЧіВңЧівҖҳЧів„ў ЧівҖқЧівӮӘЧіВЁЧівҖўЧів„ўЧіВ§ЧіЛң</h2>
          <div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(210px,1fr))',gap:12}}>
            {sheetMeta.map(({sheet,tasks,done,stuck,pct,startD,endD,days},i)=>{
              const open = tasks.length - done;
              const color = pct===100?'#059669':stuck?'#EF4444':GANTT_COLORS[i%GANTT_COLORS.length];
              return (
              <div key={sheet.id} onClick={()=>onSwitchSheet(sheet.id)}
                style={{cursor:'pointer',padding:'14px 16px',borderRadius:12,
                  background:'var(--surface)',border:`1px solid ${stuck?'rgba(239,68,68,.3)':'var(--border)'}`,
                  boxShadow:'0 1px 4px rgba(0,0,0,.06)',transition:'box-shadow .15s'}}
                onMouseEnter={e=>e.currentTarget.style.boxShadow='0 4px 16px rgba(0,0,0,.1)'}
                onMouseLeave={e=>e.currentTarget.style.boxShadow='0 1px 4px rgba(0,0,0,.06)'}>
                <div style={{fontWeight:700,fontSize:14,marginBottom:8,color:'var(--text)'}}>{sheet.name}</div>
                <div style={{height:5,borderRadius:3,background:'var(--border)',marginBottom:8}}>
                  <div style={{height:5,borderRadius:3,background:color,width:pct+'%',transition:'width .4s'}}/>
                </div>
                <div style={{display:'flex',justifyContent:'space-between',alignItems:'center',marginBottom:startD?6:0}}>
                  <div style={{display:'flex',flexDirection:'column',gap:2}}>
                    {tasks.length===0
                      ? <span style={{fontSize:11,color:'var(--text-3)'}}>ЧіЛңЧіВЁЧіВқ ЧіВ ЧівҖўЧіВЎЧівӮӘЧівҖў ЧіВһЧіВ©Чів„ўЧіВһЧівҖўЧіГ—</span>
                      : <>
                          <span style={{fontSize:11,color:open>0?'var(--text)':'#059669',fontWeight:600}}>
                            {open>0?`${open} ЧівӮӘЧіГ—ЧівҖўЧівҖ”ЧівҖўЧіГ—`:'Ч’ВңвҖң ЧівҖқЧівҖәЧіВң ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ'}
                          </span>
                          <span style={{fontSize:10,color:'var(--text-3)'}}>
                            {done}/{tasks.length} ЧівҖқЧівҖўЧіВ©ЧіВңЧіВһЧівҖў
                          </span>
                        </>
                    }
                  </div>
                  <div style={{display:'flex',gap:4,alignItems:'center'}}>
                    {stuck>0&&<span style={{fontSize:10,fontWeight:700,color:'#fff',background:'#EF4444',borderRadius:10,padding:'1px 7px'}}>Ч’ВҡВ  {stuck}</span>}
                  </div>
                </div>
                {startD&&(
                  <div style={{fontSize:10,color:'var(--text-3)',borderTop:'1px solid var(--border)',paddingTop:6,marginTop:4,display:'flex',justifyContent:'space-between'}}>
                    <span>{fmtD(startD)} Ч’вҖ вҖҷ {fmtD(endD)}</span>
                    {days!==null&&<span style={{fontWeight:600,color:'var(--text-2)'}}>{days} Чів„ўЧіВі</span>}
                  </div>
                )}
              </div>
            );})}
          </div>
        </div>

        {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Goals + Milestones row Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
        {(()=>{
          /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ shared status config Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
          const STATUS_CFG = {
            not_started: {label:'ЧіВңЧіВҗ ЧівҖқЧіГ—ЧівҖ”Чів„ўЧіВң', color:'var(--text-3)',   bg:'var(--bg)',           border:'var(--border)'},
            in_progress: {label:'ЧівҖҳЧіВўЧівҖҳЧівҖўЧівҖңЧівҖқ',   color:'var(--accent)',   bg:'rgba(37,99,235,.08)', border:'rgba(37,99,235,.25)'},
            stuck:       {label:'ЧіГ—ЧіВ§ЧівҖўЧіВў',     color:'#EF4444',         bg:'rgba(239,68,68,.08)', border:'rgba(239,68,68,.3)'},
            done:        {label:'Ч’ВңвҖң ЧівҖҳЧівҖўЧіВҰЧіВў',   color:'#059669',         bg:'rgba(5,150,105,.1)',  border:'rgba(5,150,105,.3)'},
          };
          const resolveStatus = (item) => item.status || (item.done ? 'done' : 'not_started');

          /* days X / Y: X = elapsed from effectiveStart to today, Y = total span */
          const daysXofY = (startDate, endDate) => {
            const sd = startDate || ganttMin; /* fallback to project start */
            if (!sd || !endDate) return null;
            const total   = Math.max(1, daysBetween(sd, endDate));
            const elapsed = Math.max(0, Math.min(total, daysBetween(sd, today)));
            return {elapsed, total};
          };

          /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Status dropdown Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
          const StatusDropdown = ({value, onChange}) => {
            const [open, setOpen] = React.useState(false);
            const cfg = STATUS_CFG[value] || STATUS_CFG.not_started;
            return (
              <div style={{position:'relative',width:82,flexShrink:0}}>
                <div onClick={e=>{e.stopPropagation();setOpen(o=>!o);}}
                  style={{textAlign:'center',fontSize:11,fontWeight:700,cursor:'pointer',
                    color:cfg.color,background:cfg.bg,border:`1px solid ${cfg.border}`,
                    borderRadius:10,padding:'3px 0',userSelect:'none',transition:'all .15s'}}>
                  {cfg.label} Ч’вҖ“Вҫ
                </div>
                {open && (
                  <div onClick={e=>e.stopPropagation()}
                    style={{position:'absolute',top:'calc(100% + 4px)',left:0,right:0,
                      background:'var(--surface)',border:'1px solid var(--border)',borderRadius:8,
                      boxShadow:'0 4px 16px rgba(0,0,0,.12)',zIndex:999,overflow:'hidden'}}>
                    {Object.entries(STATUS_CFG).map(([k,c])=>(
                      <div key={k} onClick={()=>{onChange(k);setOpen(false);}}
                        style={{padding:'7px 12px',fontSize:12,fontWeight:600,cursor:'pointer',
                          color:c.color,background:value===k?c.bg:'transparent',
                          transition:'background .1s'}}
                        onMouseEnter={e=>e.currentTarget.style.background=c.bg}
                        onMouseLeave={e=>e.currentTarget.style.background=value===k?c.bg:'transparent'}>
                        {c.label}
                      </div>
                    ))}
                  </div>
                )}
              </div>
            );
          };

          /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ column header Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
          const ColHdr = ({children, w, align}) => (
            <div style={{width:w,flexShrink:0,fontSize:10,fontWeight:700,color:'var(--text-3)',
              textTransform:'uppercase',letterSpacing:.4,textAlign:align||'right',paddingBottom:6,
              borderBottom:'1px solid var(--border)'}}>
              {children}
            </div>
          );

          /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Goals panel Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
          const GoalsPanel = () => {
            const goals = data.licensingGoals||[];
            const doneGoals = goals.filter(g=>resolveStatus(g)==='done').length;
            const pct = goals.length ? Math.round(doneGoals/goals.length*100) : 0;

            const saveGoals = upd => save({...data, licensingGoals: upd});
            const addGoal = () => saveGoals([...goals,
              {id:uid(), title:'', targetDate:'', startDate:today, status:'not_started', done:false}]);
            const delGoal = id => saveGoals(goals.filter(g=>g.id!==id));
            const updGoal = (id,patch) => saveGoals(goals.map(g=>g.id===id?{...g,...patch}:g));
            const setGoalStatus = (id, ns) => {
              const willDone = ns==='done';
              updGoal(id,{status:ns, done:ns==='done'});
              if(willDone) setConfetti(true);
            };

            return (
              <div style={{background:'var(--surface)',borderRadius:12,border:'1px solid var(--border)',
                padding:'18px 20px',flex:'1 1 0%',minWidth:0}}>
                {/* header */}
                <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:10}}>
                  <h2 style={{fontSize:15,fontWeight:700,color:'var(--text)'}}>Чів„ўЧіВўЧівҖңЧів„ўЧіВқ</h2>
                  <span style={{fontSize:12,color:'var(--text-2)',fontWeight:600}}>{doneGoals}/{goals.length} ЧівҖқЧівҖўЧіВ©ЧівҖҷЧівҖў</span>
                </div>
                {/* progress bar */}
                <div style={{height:4,borderRadius:2,background:'var(--border)',marginBottom:14}}>
                  <div style={{height:4,borderRadius:2,background:pct===100?'#059669':'var(--accent)',
                    width:pct+'%',transition:'width .5s'}}/>
                </div>
                {/* column headers */}
                <div style={{display:'flex',alignItems:'flex-end',gap:8,paddingBottom:2}}>
                  <ColHdr w="auto">ЧіГ—Чів„ўЧіВҗЧівҖўЧіВЁ</ColHdr>
                  <div style={{flex:1}}/>
                  <ColHdr w={80} align="center">ЧіГ—ЧіВҗЧіВЁЧів„ўЧіВҡ Чів„ўЧіВўЧівҖң</ColHdr>
                  <ColHdr w={62} align="center">Чів„ўЧіВһЧів„ўЧіВқ</ColHdr>
                  <ColHdr w={82} align="center">ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ</ColHdr>
                  <div style={{width:20}}/>
                </div>
                {/* rows */}
                {goals.map((g,i)=>{
                  const st = resolveStatus(g);
                  const cfg = STATUS_CFG[st];
                  const xy = daysXofY(g.startDate, g.targetDate);
                  const isLate = st!=='done' && g.targetDate && g.targetDate < today;
                  return (
                    <div key={g.id} style={{display:'flex',alignItems:'center',gap:8,
                      padding:'7px 0',borderBottom:i<goals.length-1?'1px solid var(--border)':'none'}}>
                      {/* title */}
                      <input value={g.title||''} placeholder="ЧіВ©ЧіВқ Чів„ўЧіВўЧівҖңЧ’вӮ¬ВҰ"
                        onChange={e=>updGoal(g.id,{title:e.target.value})}
                        style={{flex:1,border:'none',outline:'none',fontSize:13,fontWeight:600,
                          background:'transparent',color:st==='done'?'var(--text-2)':'var(--text)',
                          textDecoration:st==='done'?'line-through':'none',fontFamily:'inherit',
                          minWidth:0}}/>
                      {/* target date */}
                      <input type="date" value={g.targetDate||''}
                        onChange={e=>updGoal(g.id,{targetDate:e.target.value})}
                        style={{width:80,border:'none',outline:'none',fontSize:11,background:'transparent',
                          color:isLate?'#EF4444':'var(--text-2)',fontFamily:'monospace',textAlign:'center',
                          cursor:'pointer',fontFamily:'inherit'}}/>
                      {/* days X/Y */}
                      <div style={{width:62,textAlign:'center',fontSize:11,fontWeight:600,
                        color:isLate?'#EF4444':'var(--text-3)',fontFamily:'monospace'}}>
                        {xy ? `${xy.elapsed}/${xy.total}` : g.targetDate ? `${daysBetween(today,g.targetDate)}Чів„ў` : 'Ч’вӮ¬вҖқ'}
                      </div>
                      {/* status dropdown */}
                      <StatusDropdown value={st} onChange={ns=>setGoalStatus(g.id,ns)}/>
                      {/* delete */}
                      <button onClick={()=>delGoal(g.id)}
                        style={{width:20,height:20,border:'none',background:'none',cursor:'pointer',
                          color:'var(--text-3)',fontSize:14,lineHeight:1,borderRadius:4,padding:0,
                          display:'flex',alignItems:'center',justifyContent:'center'}}
                        title="ЧіВһЧівҖ”ЧіВ§">ЦівҖ”</button>
                    </div>
                  );
                })}
                {/* add button */}
                <button onClick={addGoal}
                  style={{marginTop:10,width:'100%',border:'1px dashed var(--border)',background:'none',
                    borderRadius:8,padding:'6px 0',fontSize:12,color:'var(--text-3)',cursor:'pointer',
                    fontFamily:'inherit',display:'flex',alignItems:'center',justifyContent:'center',gap:5,
                    transition:'all .15s'}}
                  onMouseEnter={e=>{e.currentTarget.style.borderColor='var(--accent)';e.currentTarget.style.color='var(--accent)';}}
                  onMouseLeave={e=>{e.currentTarget.style.borderColor='var(--border)';e.currentTarget.style.color='var(--text-3)';}}>
                  <span style={{fontSize:16,lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ Чів„ўЧіВўЧівҖң
                </button>
              </div>
            );
          };

          /* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Milestones panel Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */
          const MsPanel = () => {
            const milestones = data.licensingMilestones||[];
            const saveMss = upd => save({...data, licensingMilestones: upd});
            const addMs  = () => saveMss([...milestones,
              {id:uid(), title:'', date:'', startDate:today, status:'not_started', done:false}]);
            const delMs  = id => saveMss(milestones.filter(m=>m.id!==id));
            const updMs  = (id,patch) => saveMss(milestones.map(m=>m.id===id?{...m,...patch}:m));
            const setMsStatus = (id, ns) => {
              const willDone = ns==='done';
              updMs(id,{status:ns, done:ns==='done'});
              if(willDone) setConfetti(true);
            };

            return (
              <div style={{background:'var(--surface)',borderRadius:12,border:'1px solid var(--border)',
                padding:'18px 20px',flex:'1 1 0%',minWidth:0}}>
                {/* header */}
                <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:10}}>
                  <h2 style={{fontSize:15,fontWeight:700,color:'var(--text)'}}>ЧіВҗЧівҖҳЧіВ Чів„ў ЧівҖңЧіВЁЧіВҡ</h2>
                  <span style={{fontSize:12,color:'var(--text-2)',fontWeight:600}}>
                    {milestones.filter(m=>resolveStatus(m)==='done').length}/{milestones.length} ЧівҖқЧівҖўЧіВ©ЧіВңЧіВһЧівҖў
                  </span>
                </div>
                {/* column headers */}
                <div style={{display:'flex',alignItems:'flex-end',gap:8,paddingBottom:2}}>
                  <ColHdr w="auto">ЧіГ—Чів„ўЧіВҗЧівҖўЧіВЁ</ColHdr>
                  <div style={{flex:1}}/>
                  <ColHdr w={80} align="center">ЧіГ—ЧіВҗЧіВЁЧів„ўЧіВҡ</ColHdr>
                  <ColHdr w={62} align="center">Чів„ўЧіВһЧів„ўЧіВқ</ColHdr>
                  <ColHdr w={82} align="center">ЧіВЎЧіЛңЧіЛңЧівҖўЧіВЎ</ColHdr>
                  <div style={{width:20}}/>
                </div>
                {/* rows */}
                {milestones.map((m,i)=>{
                  const st = resolveStatus(m);
                  const cfg = STATUS_CFG[st];
                  const xy = daysXofY(m.startDate, m.date);
                  const isLate = st!=='done' && m.date && m.date < today;
                  return (
                    <div key={m.id} style={{display:'flex',alignItems:'center',gap:8,
                      padding:'7px 0',borderBottom:i<milestones.length-1?'1px solid var(--border)':'none'}}>
                      {/* diamond icon */}
                      <div style={{width:12,height:12,flexShrink:0,
                        background:st==='done'?'#059669':'transparent',
                        border:`2px solid ${st==='done'?'#059669':'#8B5CF6'}`,
                        borderRadius:2,transform:'rotate(45deg)'}}/>
                      {/* title */}
                      <input value={m.title||''} placeholder="ЧіВ©ЧіВқ ЧіВҗЧівҖҳЧіВҹ ЧівҖңЧіВЁЧіВҡЧ’вӮ¬ВҰ"
                        onChange={e=>updMs(m.id,{title:e.target.value})}
                        style={{flex:1,border:'none',outline:'none',fontSize:13,fontWeight:600,
                          background:'transparent',color:st==='done'?'var(--text-2)':'var(--text)',
                          textDecoration:st==='done'?'line-through':'none',fontFamily:'inherit',
                          minWidth:0}}/>
                      {/* date */}
                      <input type="date" value={m.date||''}
                        onChange={e=>updMs(m.id,{date:e.target.value})}
                        style={{width:80,border:'none',outline:'none',fontSize:11,background:'transparent',
                          color:isLate?'#EF4444':'var(--text-2)',fontFamily:'monospace',textAlign:'center',
                          cursor:'pointer',fontFamily:'inherit'}}/>
                      {/* days X/Y */}
                      <div style={{width:62,textAlign:'center',fontSize:11,fontWeight:600,
                        color:isLate?'#EF4444':'var(--text-3)',fontFamily:'monospace'}}>
                        {xy ? `${xy.elapsed}/${xy.total}` : m.date ? `${daysBetween(today,m.date)}Чів„ў` : 'Ч’вӮ¬вҖқ'}
                      </div>
                      {/* status dropdown */}
                      <StatusDropdown value={st} onChange={ns=>setMsStatus(m.id,ns)}/>
                      {/* delete */}
                      <button onClick={()=>delMs(m.id)}
                        style={{width:20,height:20,border:'none',background:'none',cursor:'pointer',
                          color:'var(--text-3)',fontSize:14,lineHeight:1,borderRadius:4,padding:0,
                          display:'flex',alignItems:'center',justifyContent:'center'}}
                        title="ЧіВһЧівҖ”ЧіВ§">ЦівҖ”</button>
                    </div>
                  );
                })}
                {/* add button */}
                <button onClick={addMs}
                  style={{marginTop:10,width:'100%',border:'1px dashed var(--border)',background:'none',
                    borderRadius:8,padding:'6px 0',fontSize:12,color:'var(--text-3)',cursor:'pointer',
                    fontFamily:'inherit',display:'flex',alignItems:'center',justifyContent:'center',gap:5,
                    transition:'all .15s'}}
                  onMouseEnter={e=>{e.currentTarget.style.borderColor='var(--accent)';e.currentTarget.style.color='var(--accent)';}}
                  onMouseLeave={e=>{e.currentTarget.style.borderColor='var(--border)';e.currentTarget.style.color='var(--text-3)';}}>
                  <span style={{fontSize:16,lineHeight:1}}>+</span> ЧівҖқЧівҖўЧіВЎЧіВЈ ЧіВҗЧівҖҳЧіВҹ ЧівҖңЧіВЁЧіВҡ
                </button>
              </div>
            );
          };

          return (
            <div style={{display:'flex',gap:14,alignItems:'stretch'}}>
              <GoalsPanel/>
              <MsPanel/>
            </div>
          );
        })()}

        {/* Ч’вҖқвӮ¬Ч’вҖқвӮ¬ Gantt with monthly columns Ч’вҖқвӮ¬Ч’вҖқвӮ¬ */}
        {(()=>{
          const [scrollOffset, setScrollOffset] = React.useState(0); // months offset
          const LABEL_W = 140;
          const COL_W   = 72; // px per month
          const VISIBLE  = 12; // months visible

          /* Build month list: start from ganttMin month Ч’ЛҶвҖҷ scroll, show VISIBLE months */
          const baseYM = new Date(ganttMin);
          baseYM.setDate(1);
          baseYM.setMonth(baseYM.getMonth() + scrollOffset);

          const months = Array.from({length:VISIBLE},(_,i)=>{
            const d = new Date(baseYM);
            d.setMonth(d.getMonth()+i);
            return d;
          });
          const viewStart = months[0].toISOString().slice(0,10);
          const viewEnd   = new Date(months[VISIBLE-1].getFullYear(), months[VISIBLE-1].getMonth()+1, 0)
                              .toISOString().slice(0,10);
          const viewSpan  = Math.max(1, daysBetween(viewStart, viewEnd));

          const HE_MONTHS_SHORT=['Чів„ўЧіВ ЧівҖў','ЧівӮӘЧівҖҳЧіВЁ','ЧіВһЧіВЁЧіВҘ','ЧіВҗЧівӮӘЧіВЁ','ЧіВһЧіВҗЧів„ў','Чів„ўЧівҖўЧіВ ','Чів„ўЧівҖўЧіВң','ЧіВҗЧівҖўЧівҖҷ','ЧіВЎЧівӮӘЧіЛң','ЧіВҗЧівҖўЧіВ§','ЧіВ ЧівҖўЧівҖҳ','ЧівҖңЧіВҰЧіВһ'];

          const toX = iso => Math.max(0, Math.min(1, daysBetween(viewStart,iso)/viewSpan)) * VISIBLE * COL_W;

          const todayX = daysBetween(viewStart,today)/viewSpan * VISIBLE * COL_W;
          const totalW = VISIBLE * COL_W;

          return (
            <div style={{background:'var(--surface)',borderRadius:12,border:'1px solid var(--border)',padding:'18px 20px'}}>
              <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginBottom:14}}>
                <h2 style={{fontSize:15,fontWeight:700,color:'var(--text)'}}>ЧіВҰЧів„ўЧіВЁ ЧівҖ“ЧіВһЧіВҹ Ч’вӮ¬вҖқ ЧівҖҷЧіВҗЧіВ ЧіЛң</h2>
                <div style={{display:'flex',alignItems:'center',gap:6}}>
                  <button onClick={()=>setScrollOffset(o=>o-6)}
                    style={{padding:'3px 10px',fontSize:12,border:'1px solid var(--border-strong)',
                      borderRadius:6,cursor:'pointer',background:'var(--surface)',fontFamily:'inherit'}}>Ч’вӮ¬В№ 6 ЧівҖ”ЧівҖўЧівҖңЧіВ©Чів„ўЧіВқ</button>
                  <button onClick={()=>setScrollOffset(0)}
                    style={{padding:'3px 10px',fontSize:12,border:'1px solid var(--accent)',
                      borderRadius:6,cursor:'pointer',background:'rgba(37,99,235,.06)',color:'var(--accent)',fontFamily:'inherit'}}>ЧівҖқЧів„ўЧівҖўЧіВқ</button>
                  <button onClick={()=>setScrollOffset(o=>o+6)}
                    style={{padding:'3px 10px',fontSize:12,border:'1px solid var(--border-strong)',
                      borderRadius:6,cursor:'pointer',background:'var(--surface)',fontFamily:'inherit'}}>6 ЧівҖ”ЧівҖўЧівҖңЧіВ©Чів„ўЧіВқ Ч’вӮ¬Г·</button>
                </div>
              </div>

              <div style={{display:'flex',direction:'ltr'}}>
                {/* Labels column */}
                <div style={{width:LABEL_W,flexShrink:0,direction:'rtl'}}/>
                {/* Month header */}
                <div style={{flex:1,overflowX:'hidden'}}>
                  <div style={{display:'flex',width:totalW}}>
                    {months.map((m,i)=>(
                      <div key={i} style={{width:COL_W,flexShrink:0,textAlign:'center',
                        fontSize:10,fontWeight:600,color:m.getFullYear()===new Date(today).getFullYear()&&m.getMonth()===new Date(today).getMonth()?'var(--accent)':'var(--text-3)',
                        borderLeft:'1px solid var(--border)',paddingBottom:6}}>
                        {HE_MONTHS_SHORT[m.getMonth()]} {m.getFullYear()!==new Date().getFullYear()?m.getFullYear():''}
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              <div style={{display:'flex',flexDirection:'column',gap:8,direction:'ltr',position:'relative'}}>
                {/* milestone markers */}
                {(data.licensingMilestones||[]).map(m=>{
                  const mx = daysBetween(viewStart,m.date)/viewSpan * VISIBLE * COL_W;
                  if(mx<0||mx>totalW) return null;
                  const mColor = m.done?'#059669':'#8B5CF6';
                  return (
                    <div key={m.id} style={{position:'absolute',top:-2,bottom:-2,
                      left:LABEL_W+mx-1,width:1,background:mColor,
                      zIndex:9,pointerEvents:'none',opacity:.7}}>
                      <div style={{position:'absolute',top:-4,left:'50%',transform:'translateX(-50%)',
                        width:10,height:10,background:mColor,borderRadius:2,rotate:'45deg',
                        boxShadow:'0 0 0 2px #fff'}}/>
                      <div style={{position:'absolute',bottom:-18,left:'50%',transform:'translateX(-50%)',
                        whiteSpace:'nowrap',fontSize:9,fontWeight:700,color:mColor,
                        background:'#fff',padding:'0 3px',borderRadius:3}}>
                        {m.title}
                      </div>
                    </div>
                  );
                })}
                {/* single today line spanning all rows */}
                {todayX>=0&&todayX<=totalW&&(
                  <div style={{position:'absolute',top:0,bottom:0,
                    left:LABEL_W+todayX-1,width:2,background:'#EF4444',zIndex:10,pointerEvents:'none'}}>
                    <div style={{position:'absolute',top:-6,left:'50%',
                      transform:'translateX(-50%)',
                      width:8,height:8,borderRadius:'50%',background:'#EF4444',
                      boxShadow:'0 0 0 2px #fff'}}/>
                  </div>
                )}
                {sheetMeta.filter(m=>m.startD).map(({sheet,pct,startD,endD,days},i)=>{
                  const x1 = toX(startD);
                  const x2 = toX(endD||today);
                  const barW = Math.max(4, x2-x1);
                  const color = pct===100?'#059669':GANTT_COLORS[i%GANTT_COLORS.length];
                  return (
                    <div key={sheet.id} style={{display:'flex',alignItems:'center'}}>
                      <span style={{width:LABEL_W,flexShrink:0,fontSize:12,fontWeight:600,
                        color:'var(--text)',textAlign:'right',paddingRight:12,direction:'rtl'}}>{sheet.name}</span>
                      <div style={{flex:1,position:'relative',height:24}}>
                        <div style={{width:totalW,height:'100%',position:'relative'}}>
                          {/* month grid lines */}
                          {months.map((m,j)=>(
                            <div key={j} style={{position:'absolute',top:0,bottom:0,left:j*COL_W,
                              width:1,background:'var(--border)',opacity:.6}}/>
                          ))}
                          {/* bar */}
                          {x1<totalW&&x2>0&&(
                            <div onClick={()=>onSwitchSheet(sheet.id)}
                              title={`${sheet.name}: ${fmtD(startD)} Ч’вҖ вҖҷ ${fmtD(endD||today)} | ${days??'?'} Чів„ўЧіВһЧів„ўЧіВқ`}
                              style={{position:'absolute',top:4,height:16,borderRadius:5,cursor:'pointer',
                                left:x1,width:barW,background:color,
                                opacity:.88,transition:'opacity .12s',zIndex:2,
                                display:'flex',alignItems:'center',justifyContent:'center',overflow:'hidden'}}
                              onMouseEnter={e=>e.currentTarget.style.opacity=1}
                              onMouseLeave={e=>e.currentTarget.style.opacity=.88}>
                              {barW>40&&<span style={{fontSize:9,color:'#fff',fontWeight:700,whiteSpace:'nowrap'}}>
                                {days!=null?days+' Чів„ўЧіВі':''}
                              </span>}
                            </div>
                          )}
                        </div>
                      </div>
                    </div>
                  );
                })}
              </div>

              <div style={{display:'flex',alignItems:'center',justifyContent:'space-between',marginTop:14,direction:'rtl'}}>
                <div style={{display:'flex',alignItems:'center',gap:5,fontSize:10,color:'var(--text-3)'}}>
                  <div style={{width:14,height:2,background:'#EF4444',borderRadius:1}}/>
                  <span>ЧівҖқЧів„ўЧівҖўЧіВқ Ч’вӮ¬вҖқ {fmtDateFull(today)}</span>
                </div>
                {(()=>{
                  const totalStart = allStarts[0];
                  const totalEnd   = allEnds[allEnds.length-1];
                  const totalDaysAll = totalStart&&totalEnd ? daysBetween(totalStart,totalEnd) : null;
                  return totalDaysAll!=null&&(
                    <div style={{display:'inline-flex',alignItems:'center',gap:6,
                      padding:'5px 14px',borderRadius:10,
                      background:'var(--bg)',border:'1px solid var(--border-strong)'}}>
                      <span style={{fontSize:14}}>Ч’ВҸВі</span>
                      <span style={{fontSize:12,fontWeight:700,color:'var(--text)'}}>
                        {totalDaysAll} Чів„ўЧіВһЧів„ўЧіВқ
                      </span>
                      <span style={{fontSize:10,color:'var(--text-3)'}}>
                        ЧіВЎЧівҖқЧіВҙЧівҖә ЧіВһЧіВЎЧіВңЧівҖўЧіВң ЧіВЁЧів„ўЧіВ©ЧівҖўЧів„ў
                      </span>
                    </div>
                  );
                })()}
              </div>
            </div>
          );
        })()}

      </div>
    </div>
    </>
  );
}

/* Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ
   Portfolio View
Ч’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗЧ’вҖўВҗ */
/* phases: array of {id, label, status:'done'|'active'|'pending', startDate?, endDate?, note?, blocker?} */
const PORTFOLIO_PHASES = ['ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВ Чів„ў','ЧівҖқЧів„ўЧіГ—ЧіВЁ','ЧіВһЧівҖәЧіВЁЧівҖ“','ЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў'];

const PORTFOLIO_DATA = [
  {
    id:'p1', code:'SLOD', name:'ЧіВЎЧівӮӘЧіВЁЧів„ўЧів„ўЧіГ— ЧіВңЧівҖўЧівҖң', type:'ЧіВһЧівҖўЧіВЎЧівҖң ЧіВҰЧів„ўЧівҖҳЧівҖўЧіВЁЧів„ў', area:3200,
    pm:'Чів„ўЧівҖўЧіВ ЧіГ—ЧіВҹ ЧіВһЧіВҗЧів„ўЧіВЁЧів„ў', team:['ЧіВ©Чів„ў ЧівҖқЧіВЁЧіВ©ЧіВ§ЧівҖўЧівҖҳЧів„ўЧіВҘ','ЧіВ ЧіЛңЧіВў ЧіВ©ЧівҖўЧівҖўЧіВЁЧіВҘ','ЧіВҗЧіВЎЧіВЈ ЧівҖәЧівҖқЧіВ Чів„ўЧіВқ'],
    budget:'Ч’вҖҡГ—4.2M', priority:'high', lastUpdate:'2026-06-12',
    phases:[
      {id:'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВ Чів„ў', status:'done',    startDate:'2024-01-15', endDate:'2025-12-31', note:'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВ©ЧіВңЧівҖң ЧівҖўЧівҖ”ЧівҖ“Чів„ўЧіГ—ЧівҖўЧіГ— ЧівҖқЧівҖўЧіВ©ЧіВңЧіВқ'},
      {id:'ЧівҖқЧів„ўЧіГ—ЧіВЁ',         status:'active',  startDate:'2026-01-15', endDate:'2026-09-01', note:'ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ ЧіВңЧіВҗЧів„ўЧіВ©ЧівҖўЧіВЁ ЧіВўЧів„ўЧіВЁЧів„ўЧів„ўЧіГ— ЧіВңЧівҖўЧівҖң', blocker:'ЧіВҗЧів„ўЧіВ©ЧівҖўЧіВЁ ЧіВўЧів„ўЧіВЁЧів„ўЧів„ўЧіГ— ЧіВңЧівҖўЧівҖң Ч’вӮ¬вҖқ 3 ЧіВ©ЧівҖҳЧівҖўЧіВўЧівҖўЧіГ— ЧіВңЧіВңЧіВҗ ЧіВһЧіВўЧіВ ЧівҖқ'},
      {id:'ЧіВһЧівҖәЧіВЁЧівҖ“',         status:'pending', plannedMonths:3},
      {id:'ЧівҖҳЧів„ўЧіВҰЧівҖўЧіВў',        status:'pending', plannedMonths:20},
    ],
    hours:{
      ARCH:{budget:900, actual:680},
      ENVI:{budget:160, actual:175},
      STRC:{budget:280, actual:120},
      TRAF:{budget:90,  actual:88},
      LAND:{budget:110, actual:45},
      PM:  {budget:200, actual:155},
    },
    blockers:['ЧіВҗЧів„ўЧіВ©ЧівҖўЧіВЁ ЧіВўЧів„ўЧіВЁЧів„ўЧів„ўЧіГ— ЧіВңЧівҖўЧівҖң Ч’вӮ¬вҖқ 3 ЧіВ©ЧівҖҳЧівҖўЧіВўЧівҖўЧіГ— ЧіВңЧіВңЧіВҗ ЧіВһЧіВўЧіВ ЧівҖқ','ЧіГ—Чів„ўЧіВ§ЧівҖўЧіВҹ ЧіГ—ЧівҖәЧіВ Чів„ўЧіГ— ЧіГ—ЧіВ ЧівҖўЧіВўЧівҖқ Ч’вӮ¬вҖқ ЧіВһЧіВһЧіГ—Чів„ўЧіВҹ ЧіВңЧіВһЧівҖқЧіВ ЧівҖңЧіВЎ'],
  },
  {
    id:'p2', code:'NEPT', name:'ЧіВһЧівҖҷЧівҖўЧіВЁЧів„ўЧіВқ ЧіВ ЧівӮӘЧіЛңЧівҖўЧіВҹ', type:'ЧіВһЧівҖҷЧівҖўЧіВЁЧів„ўЧіВқ', area:8400,
    pm:'ЧівҖңЧівҖўЧівҖң ЧіВ§ЧіВ ЧівӮӘЧівҖў', team:['ЧівҖ”ЧіВ ЧіВҹ ЧіВЁЧівҖўЧівҖңЧів„ўЧіВҡ','ЧіВһЧів„ўЧіВ§ЧівҖқ ЧіВһЧіВЁЧіВ§ЧівҖўЧіВЎЧівҖўЧіВҹ'],
    budget:'Ч’вҖҡГ—12M', priority:'medium', lastUpdate:'2026-06-10',
    phases:[
      {id:'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВЁЧіВҗЧіВ©ЧівҖўЧіВ Чів„ў', status:'active',  startDate:'2025-09-01', endDate:'2026-12-31', note:'ЧіГ—ЧівҖәЧіВ ЧівҖўЧіВҹ ЧіВ©ЧіВңЧівҖҳЧів„ў ЧівҖҳЧіВі Ч’вӮ¬вҖқ ЧівӮӘЧіВЁЧівҖўЧівҖҷЧіВЁЧіВһЧівҖқ ЧівҖўЧіВһЧіВҗЧіВЎЧівҖқ', blocker:'ЧівҖ”ЧівҖўЧівҖўЧіГ— ЧівҖңЧіВўЧіГ— ЧіВЎЧівҖҳЧів„ўЧівҖҳЧіГ—Чів„ўЧіГ— Ч’вӮ¬вҖқ ЧіВңЧіВҗ ЧівҖқЧівҖўЧівҖ“ЧіВһЧіВ ЧівҖқ'},
